Usage: get_reinforce_pg_mode [-help] [-auto_ir_fix_effort]
                             [-critical_path_slack] [-irdrop_hierarchical_block]
                             [-irdrop_hierarchical_top_rail_analysis_directory]
                             [-respect_defined_nets] [-respect_routes]
                             [-respect_stdcell_geometry] [-timing_aware_effort]
                             [-quiet] [-nonDefault]

-help                                   # Prints out the command usage
-auto_ir_fix_effort                     # Specifies the IR fixing effort level
                                        # during stripe generation.
                                        # (enums={low medium high}, default=low)
-critical_path_slack                    # Specifies a slack threshold, in
                                        # nanoseconds, for critical nets during
                                        # timing-driven reinforce_pg.
                                        # (float, default=0)
-irdrop_hierarchical_block              # Specifies hierarchical blocks to fix
                                        # irdrop. (string, default="")
-irdrop_hierarchical_top_rail_analysis_directory
                                        # Specifies the directory of rail
                                        # analysis information of full chip for
                                        # hierarchical blocks to fix irdrop.
                                        # (string, default="")
-respect_defined_nets                   # Specifies reinforce_pg to respect
                                        # user defined nets in file.
                                        # (string, default="")
-respect_routes                         # Specifies whether to honor
                                        # pre-existing routes check during
                                        # stripe generation
                                        # (enums={none fixed fixed_and_clock all}, default=fixed_and_clock)
-respect_stdcell_geometry               # Specifies the cell type to be
                                        # respected in via generation.
                                        # (enums={none sequential all}, default=all)
-timing_aware_effort                    # Specifies the timing effort level
                                        # during timing-driven reinforce_pg.
                                        # (enums={none low medium high}, default=none)
-quiet                                  # Displays the current settings in Tcl list format only
-nonDefault                             # Displays the current settings which are not default settings