Usage: checkPinAssignment [-help] [-outFile <fileName>]
                          [-reportSameNetPinAsOverlap]
                          [-reportUncoloredViolation] [<topCellName> | -ptn <partitionName list> ] [-ptn <partitionName list> | {-pin_file <fileName> [-exclude_ptn <string>]} | -exclude_pin_file <fileName>] [ -report_violating_pin ] [-ignore {bus_guide net_group pin_abutment pin_depth pin_group pin_guide pin_layer pin_min_area pin_on_fence pin_on_track pin_spacing pin_spacing_constraint pin_spacing_routeBlk pin_width clones logical_pin pin_color unplaced} ] [ [-preCheck [-skipCheck {overlap layer spacingConstraint fixedIoPins multiTermNet masterClone netGroup connection relativeOrientRelation gridTrackAlignment symmetryOffset masterCloneSize alignZone}] [-excludeNetFile <fileName>] ] | { [-ptn <partitionName list>] [-pin {pinName list}] [-pin_file <fileName>] [-exclude_pin_file <fileName>] [-ignore {bus_guide net_group pin_abutment pin_depth pin_group pin_guide pin_layer pin_min_area pin_on_fence pin_on_track pin_spacing pin_spacing_constraint pin_spacing_routeBlk pin_width clones logical_pin pin_color unplaced}] [-report_violating_pin ] [-exclude_ptn <string>] } ]

-help                                      # Prints out the command usage
<topCellName>                              # Specifies top cell name
                                           # (string, optional)
-excludeNetFile <fileName>                 # Exclude checkinh on following nets
                                           # (string, optional)
-exclude_pin_file <fileName>               # Specify pin-list to be excluded
                                           # for partition in a file
                                           # (string, optional)
-exclude_ptn <string>                      # Specifies the list of exluded
                                           # partition for pin-file
                                           # (string, optional)
-ignore {bus_guide net_group pin_abutment pin_depth pin_group pin_guide pin_layer pin_min_area pin_on_fence pin_on_track pin_spacing pin_spacing_constraint pin_spacing_routeBlk pin_width clones logical_pin pin_color unplaced}
                                           # Check and report one category from
                                           # the list of type of checks.
                                           # (enum_list, optional)
-outFile <fileName>                        # Print the output in the specified
                                           # file (default file is
                                           # <design_name>.checkPin.rpt)
                                           # (string, optional)
-pin {pinName list}                        # Specifies list of pins
                                           # (string, optional)
-pin_file <fileName>                       # Specify pin-list for partition in
                                           # a file (string, optional)
-preCheck                                  #   (bool, optional)
-ptn <partitionName list>                  # Specifies name of the partition
                                           # (string, optional)
-reportSameNetPinAsOverlap                 # Report the pins (connected to same
                                           # net) placed at same location and
                                           # same layer as overlap violation
                                           # (bool, optional)
-reportUncoloredViolation                  # Check and report uncolored pin as
                                           # violation (bool, optional)
-report_violating_pin                      # Reports all the pins with
                                           # violation. (bool, optional)
-skipCheck {overlap layer spacingConstraint fixedIoPins multiTermNet masterClone netGroup connection relativeOrientRelation gridTrackAlignment symmetryOffset masterCloneSize alignZone}
                                           # Skip checking the category from
                                           # the list of type of checks.
                                           # (enum_list, optional)