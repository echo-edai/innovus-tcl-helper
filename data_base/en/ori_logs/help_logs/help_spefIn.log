Usage: spefIn [-help] <fileNameList> [-extended] [-idx] [-scaleNets <string>]
              [-scaleRC] [-via_variation_file <string>] [-starN  | -noStarN ] [{-rc_corner <string> [-spef_field <string>]} ]

-help                             # Prints out the command usage
<fileNameList>                    # SPEF file or list of SPEF files
                                  # (string, required)
-extended                         # Enables reading of *llx, $L and $W
                                  # statements in the SPEF file (bool, optional)
-idx                              # Enable the IDX flow (bool, optional)
-noStarN                          # Disables reading of *N statements in the
                                  # SPEF file (bool, optional)
-rc_corner <string>               # RC Corner, or list of RC Corners, to be
                                  # used for annotation in multi-corner
                                  # analysis mode (string, optional)
-scaleNets <string>               # Apply scaling on the specified nets
                                  # (string, optional)
-scaleRC                          # Scales the RCs using PostRoute
                                  # Scale-factors during SPEF-reading
                                  # (bool, optional)
-spef_field <string>              # Integer list of rc value indices
                                  # (string, required)
-starN                            # Enables reading of *N statements in the
                                  # SPEF file (bool, optional)
-via_variation_file <string>      # VIA Variation File (string, optional)