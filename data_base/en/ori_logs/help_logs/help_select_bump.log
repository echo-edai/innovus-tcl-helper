Usage: select_bump [-help] [-alternate {row column}]
                   [-area {{x1 y1 x2 y2} ...}] [-assigned]
                   [-bump_cell {cell_list}] [-bumps {bump_list}] [-floating]
                   [-max_distance_to_side <distance>] [-nets {net_list}]
                   [-side {top bottom left right}] [-start_lower_left]
                   [-type {signal power ground}]

-help                                # Prints out the command usage
-alternate {row column}              # Specifies the alternate bump pattern
                                     # (string, optional)
-area {{x1 y1 x2 y2} ...}            # Specifies areas in which bumps are
                                     # selected (box_list, optional)
-assigned                            # Only selects assigned bumps
                                     # (bool, optional)
-bump_cell {cell_list}               # Specifies names of bump cells and bumps
                                     # with these bump cells will be selected
                                     # (string, optional)
-bumps {bump_list}                   # Specified names of bumps to be selected
                                     # (string, optional)
-floating                            # Only selects unassigned or floating
                                     # bumps (bool, optional)
-max_distance_to_side <distance>     # Specifies the maximum distance away from
                                     # the side
                                     # (float, optional, min=0, max=1e+20)
-nets {net_list}                     # Specifies names of nets and the related
                                     # bump will be selected (string, optional)
-side {top bottom left right}        # Specifies the side in which bump are
                                     # selected (enum, optional)
-start_lower_left                    # Specifies the start point of alternate
                                     # selection (bool, optional)
-type {signal power ground}          # Specifies the type of bumps to be
                                     # selected (enum, optional)