Usage: verifyPowerVia [-help] [-append] [-area {x1 y1 x2 y2}]
                      [-checkWirePinOverlap] [-edgeToEdge] [-error <integer>]
                      [-exclude_region_file <string>] [-fill]
                      [-hookup_pitch <integer>]
                      [-ignore_objects {drc_fill io_wire}]
                      [-ignore_partial_overlap <string>] [-layerRange <string>]
                      [-layer_rail <string>] [-layer_stripe <string>]
                      [-pitch <integer>] [-report <string>]
                      [-search_range {x y}] [-shielding] [-stackedVia]
                      [-stripe_rule <float>] [-viaUtil <float>]
                      [-what_if_report <string>] [-widthRange <string>] [ -net <string> | -selected ] [-nonOrthogonalCheck [-distance {x y}]]

-help                                  # Prints out the command usage
-append                                # specifies that all previous
                                       # verifyPowerVia settings will be kept
                                       # (bool, optional)
-area {x1 y1 x2 y2}                    # specifies the area to check
                                       # (box, optional)
-checkWirePinOverlap                   # specifies the overlap of wire and pin
                                       # to be checked (bool, optional)
-distance {x y}                        # specifies distances (x, y)
                                       # (center-to-center) for non-orthogonal
                                       # check (point, optional)
-edgeToEdge                            # specifies to check non-orthogonal
                                       # distance by edge-to-edge (bool, optional)
-error <integer>                       # Specifies the maximum number of errors
                                       # to report (int, optional)
-exclude_region_file <string>          # Specifies the file to ignore missing
                                       # VIA check within these regions in
                                       # cell. (string, optional)
-fill                                  # Specifies that metal fill should also
                                       # be checked (bool, optional)
-hookup_pitch <integer>                # specifies the hookup pitch
                                       # (int, optional)
-ignore_objects {drc_fill io_wire}     # specifies the wire type to no check
                                       # (enum_list, optional)
-ignore_partial_overlap <string>       # Specifies that partially overlap
                                       # metals need to be check for missing
                                       # vias. (string, optional)
-layerRange <string>                   # Specifies the top and bottom metal
                                       # layers to consider (string, optional)
-layer_rail <string>                   # specifies the power rail layer for
                                       # checking (string, optional)
-layer_stripe <string>                 # specifies the stripe layer list for
                                       # checking (string, optional)
-net <string>                          # The name of power nets that will be
                                       # checked (string, optional)
-nonOrthogonalCheck                    # specifies non othogonal checks for
                                       # wire and wire intersection
                                       # (bool, optional)
-pitch <integer>                       # specifies the pitch (int, optional)
-report <string>                       # Specifies the report file for
                                       # verifyPowerVia violations data
                                       # (string, optional)
-search_range {x y}                    # specifies a rectangle area with XY, a
                                       # valid connection should be in the
                                       # specified area (point, optional)
-selected                              # Specifies whether to check between
                                       # selected objects (bool, optional)
-shielding                             # specifies to check shielding wire
                                       # (bool, optional)
-stackedVia                            # specifies to check missing vias
                                       # between all non-adjacent layers as
                                       # well as adjacent layers (bool, optional)
-stripe_rule <float>                   # specifies the distance for power via
                                       # center-to-center spacing checking
                                       # (float, optional)
-viaUtil <float>                       # specifies the ratio of cutArea/metal
                                       # intersection area. If the actual ratio
                                       # is less than specified ratio, mark it
                                       # as violation. (float, optional)
-what_if_report <string>               # Specifies the what_if report file for
                                       # verifyPowerVia violations data. power
                                       # rail analysis command could read in
                                       # the report file and do power rail
                                       # analysis. (string, optional)
-widthRange <string>                   # specifies metal width to consider
                                       # (string, optional)