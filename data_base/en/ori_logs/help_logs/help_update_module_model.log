Usage: update_module_model [-help] [-cpu <integer>] [-distribute_job]
                           [-eco_report] [-log_dir <string>]
                           [-return_tag <string>]
                           [-return_type {lef flexIlm ilm pnr}] [-tag <string>] { [-cell <string>] [-distribute_run ] [ -interactive | -plugin_tcl <string> | -gen_eco_only ]}

-help                                  # Prints out the command usage
-cell <string>                         # <cellName> (string, optional)
-cpu <integer>                         # <number of cpus> (int, optional)
-distribute_job                        # <setup update_module_model job for
                                       # distributed run> (bool, optional)
-distribute_run                        # <run update_module_model in
                                       # distribute> (bool, optional)
-eco_report                            # <report module model change>
                                       # (bool, optional)
-gen_eco_only                          # <generate eco file only>
                                       # (bool, optional)
-interactive                           # <interactive mode> (bool, optional)
-log_dir <string>                      # log file directory (string, optional)
-plugin_tcl <string>                   # <tcl_commands> (string, optional)
-return_tag <string>                   # <tag of module model returned>
                                       # (string, optional)
-return_type {lef flexIlm ilm pnr}     # <type of module model returned>
                                       # (enum, optional)
-tag <string>                          # <module tag> (string, optional)