Usage: analyze_paths_by_drv [-help] {[-generate_cap_file <string> | -load_cap_file <string>] [-generate_tran_file <string> | -load_tran_file <string>] [-generate_fanout_file <string> | -load_fanout_file <string>]} [-master <string>]

-help                                  # Prints out the command usage
-generate_cap_file <string>            # Generates a file containing a list of
                                       # paths containing max capacitance
                                       # violations. (string, optional)
-generate_fanout_file <string>         # Generates a file containing a list of
                                       # paths containing max fanout
                                       # violations. (string, optional)
-generate_tran_file <string>           # Generates a file containing a list of
                                       # paths containing max transition
                                       # violations. (string, optional)
-load_cap_file <string>                # Reads a file containing a list of
                                       # paths containing max capacitance
                                       # violations. (string, optional)
-load_fanout_file <string>             # Reads a file containing a list of
                                       # paths containing max fanout
                                       # violations. (string, optional)
-load_tran_file <string>               # Reads a file containing a list of
                                       # paths containing max transition
                                       # violations. (string, optional)
-master <string>                       # Specifies that the analysis should be
                                       # performed only for the specified
                                       # master category. (string, optional)