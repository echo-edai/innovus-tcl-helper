Usage: report_analysis_coverage [-help] [<pin_port_list>]
                                [-check_type <check_type_list>]
                                [-exclude_untested <reason_list>]
                                [-include_dyn_checks]
                                [-include_parallel_check_arcs]
                                [-include_when_cond] [-max_paths <integer>]
                                [-nworst <integer>]
                                [-retime {aocv ssta path_slew_propagation aocv_path_slew_propagation}]
                                [-sort {pin refpin checktype slack reason}]
                                [-tcl_list] [-unsorted]
                                [-verbose <check_status_list>]
                                [-view <view_name>] [> <filename[.gz]>]
                                [>> <filename[.gz]>]

-help                             # Prints out the command usage
<pin_port_list>                   # Limits the report to timing checks on
                                  # specified pins or ports (string, optional)
-check_type <check_type_list>     # Limits the report to the type of check(s)
                                  # in the check_type_list. Valid types are:
                                  # setup, hold, pulse_width, recovery,
                                  # removal, etc (string, optional)
-exclude_untested <reason_list>   # Excludes the unconstrained endpoints due to
                                  # a specific reason. Valid reasons are:
                                  # false_path, const, user_disable,
                                  # power_mode_shutoff etc (string, optional)
-include_dyn_checks               # Reports the non-structural endpoints
                                  # constrained due to set_data_check,
                                  # set_max_delay, set_min_delay, etc
                                  # (bool, optional)
-include_parallel_check_arcs      # Reports all parallel check arcs which have
                                  # been merged (bool, optional)
-include_when_cond                # Reports the when cond of check arcs
                                  # (bool, optional)
-max_paths <integer>              # Enumerates the specified number of worst
                                  # paths in the design, regardless of the
                                  # endpoint (supported with -retime)
                                  # (int, optional)
-nworst <integer>                 # Enumerates the specified number of paths
                                  # for each endpoint (supported with -retime)
                                  # (int, optional)
-retime {aocv ssta path_slew_propagation aocv_path_slew_propagation}
                                  # Reanalyzes the specified set of paths using
                                  # the specified method (enum, optional)
-sort {pin refpin checktype slack reason}
                                  # Sorts the checks by the specified method
                                  # under -verbose mode (enum, optional)
-tcl_list                         # Produces the report in Tcl list format
                                  # instead of a tabular format (bool, optional)
-unsorted                         # Reports unsorted slacks with untested end
                                  # points in end of report (bool, optional)
-verbose <check_status_list>      # Limits the detailed information to only the
                                  # checks with the status specified. Valid
                                  # status types are: met, violated, and
                                  # untested (string, optional)
-view <view_name>                 # Generates a timing check report for the
                                  # specified analysis view only. By default
                                  # all active views are reported
                                  # (string, optional)
> <filename[.gz]>                 # Redirects output to specified file
                                  # (redirect_operator, optional)
>> <filename[.gz]>                # Redirects output to specified file
                                  # (redirect_operator, optional)