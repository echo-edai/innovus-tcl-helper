Usage: createPinGroup [-help] [-cell <string>]
                      [-excludePin {allLayer sameLayer allLayerInGuidedArea}]
                      [-keep_out_spacing <integer>] [-spacing <integer>]
                      [-width <float>] [ {[-optimizeOrder ]} | -spreadPin | -compact_area ] [ {<pinGroupName> [-pin {pinNameList}]} ]

-help                                     # Prints out the command usage
<pinGroupName>                            # Specifies the name of the pin
                                          # group. (string, required)
-cell <string>                            # Specifies the name of the
                                          # module.The module name is not
                                          # required if the command is run on a
                                          # top-level module. (string, optional)
-compact_area                             # Specifies that pins in the group
                                          # are assigned tightly together.
                                          # (bool, optional)
-excludePin {allLayer sameLayer allLayerInGuidedArea}
                                          # Specifies that pins in the group
                                          # exclude foreign pins on all layers
                                          # or same layer. (enum, optional)
-keep_out_spacing <integer>               # Specifies minimum spacing between
                                          # the pins placed oustide of this
                                          # group, in number of tracks or
                                          # pitch.
                                          # (int, optional, min=0, max=65535)
-optimizeOrder                            # Specifies that pins in the group
                                          # are reordered to optimize wire
                                          # length. (bool, optional)
-pin {pinNameList}                        # Specifies the pin(s) that should be
                                          # added to the pin group.
                                          # (string, optional)
-spacing <integer>                        # Specifies the minimum spacing
                                          # between the pins of the pin group,
                                          # in number of tracks or pitch.
                                          # (int, optional)
-spreadPin                                # Specifies that pins in the group
                                          # are distributed evenly.
                                          # (bool, optional)
-width <float>                            # Specifies minimum width in microns.
                                          # (float, optional)