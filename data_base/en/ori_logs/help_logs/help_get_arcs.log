Usage: get_arcs [-help] [-filter <expr>] [-quiet] { [ [-from <from_list>] [-to <to_list>] ] | -of_objects <object_list> }

-help                         # Prints out the command usage
-filter <expr>                # Filters a collection based on the specified
                              # expression. For any arcs that match the
                              # pattern, the software evaluates the expression
                              # based on the attribute of the arc
                              # (string, optional)
-from <from_list>             # Adds all timing arcs that fan in directly to
                              # the specified pins or ports to the collection
                              # (string, optional)
-of_objects <object_list>     # Adds all timing arcs that are associated with
                              # the specified cells or nets to the collection
                              # (string, optional)
-quiet                        # Suppresses all error and warning messages
                              # generated when the get_arcs command is run
                              # (bool, optional)
-to <to_list>                 # Adds all timing arcs that fan out directly from
                              # the specified list of pins or ports to the
                              # collection (string, optional)