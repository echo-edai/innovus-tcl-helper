Usage: placePIO [-help] [-assignBump] [-cellList <{cellNamePattern}>]
                [-extraConfig <fileName>] [-instList <{instNamePattern}>]
                [-ioFile <fileName>] [-maxIOHeight] [-noRandomPlacement]
                [-optIOs] [-overflowMap] [-powerDomain <powerDomainName>]
                [-rdlConstraintFile <fileName>]

-help                             # Prints out the command usage
-assignBump                       # allows signal bumps to be reassigned to
                                  # improve routing (bool, optional)
-cellList <{cellNamePattern}>     # specifies the Area IO cells to be placed
                                  # (string, optional)
-extraConfig <fileName>           # specifies extra configuration file
                                  # (string, optional)
-instList <{instNamePattern}>     # specifies the Area IO instances to be
                                  # placed (string, optional)
-ioFile <fileName>                # specifies the io file name
                                  # (string, optional)
-maxIOHeight                      # specifies the maximum height for the I/O
                                  # row (bool, optional)
-noRandomPlacement                # will not do random initial IO placement
                                  # (bool, optional)
-optIOs                           # optimizes the initial placement to improve
                                  # routing (bool, optional)
-overflowMap                      # display the congestion map (bool, optional)
-powerDomain <powerDomainName>    # places IOs in the row of specified power
                                  # domain (string, optional)
-rdlConstraintFile <fileName>     # specifies rdl constraint file
                                  # (string, optional)