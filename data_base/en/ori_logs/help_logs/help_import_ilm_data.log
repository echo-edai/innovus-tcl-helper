Usage: import_ilm_data [-help] [-incr] -model_type {timing cts si} [-overwrite]
                       [-xtwf <string>] {-dir <string> | -cell_view <string> } [-verilog <string> [-cell_prefix <string> -uniquify_netlist ]] [-sdc <string> -timing_view <string>] [-spef <string> -rc_corner <string>]  -cell <string> [-optStage <string>]

-help                           # Prints out the command usage
-cell <string>                  # Specifies the block name (string, required)
-cell_prefix <string>           # Specifies the cell prefix (string, optional)
-cell_view <string>             # Specifies the library name, cell name, and
                                # view name in the OpenAccess database format
                                # (string, optional)
-dir <string>                   # Stores the ILM data in the specified
                                # directory: the absolute directory path or the
                                # path relative to the current directory
                                # (string, optional)
-incr                           # Let you add files in addition to the existing
                                # files to the directory (bool, optional)
-model_type {timing cts si}     # Decide the type of ILM model (enum, required)
-optStage <string>              # opt. stage (string, optional)
-overwrite                      # Overwrites existing files in the directory
                                # (bool, optional)
-rc_corner <string>             # Specifies the RC corner name for MMMC
                                # analysis. The -rc_corner parameter identifies
                                # the specified corner to be used with -spef
                                # (string, optional)
-sdc <string>                   # Specifies an existing .sdc file that you want
                                # to include in the directory. The -sdc
                                # parameter identifies the sdc file to be used
                                # with the specified view (string, optional)
-spef <string>                  # Specifies an existing .spef file that you
                                # want to include in the directory. The -spef
                                # parameter identifies the spef file to be used
                                # with the specified corner (string, optional)
-timing_view <string>           # Specifies the view name for the ILM module.
                                # The -timing_view parameter identifies the
                                # specified view to be used with -sdc
                                # (string, optional)
-uniquify_netlist               # Uniquifies the input Verilog netlist. This
                                # ensures that there are no errors when ILMs
                                # are being loaded (bool, optional)
-verilog <string>               # Specifies the verilog file you want to
                                # include in the ILM data directory
                                # (string, optional)
-xtwf <string>                  # Specifies the .xtwf file that you want to
                                # include in the directory (string, optional)