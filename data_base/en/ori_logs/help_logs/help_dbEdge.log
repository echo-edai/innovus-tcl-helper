Usage: dbEdge [-help] [-index <integer>] {<shapeList> [-direction <direction>] [-d ] [-clockwise  | -counterclockwise ]}

-help                                # Prints out the command usage
<shapeList>                          # shapeList: a polygon {{x y} {x y} ...},
                                     # rect {xl yl xu yu} or list of polygons
                                     # and/or rects {{{x1 y1} {x2 y2} ...} {xl
                                     # yl xu yu} ...} (string, required)
-clockwise                           # The returned list of edges is sorted by
                                     # clockwise. (bool, optional)
-counterclockwise                    # The returned list of edges is sorted by
                                     # counterclockwise. (bool, optional)
-d                                   # User specified values and return values
                                     # are in database units: default is
                                     # microns (bool, optional)
-direction {N S E W NE NW SE SW}     # The kinds of edges that are needed. This
                                     # can be N, S, E, W, NE, NW, SE, SW. It
                                     # can be a list For eg.: dbEdge -direction
                                     # {N S NW NE} {10 20 30 40}.
                                     # (enum_list, optional)
-index <integer>                     # Specify the index number of the edge to
                                     # be returned. The index number starts
                                     # with 0 from the first edge specified in
                                     # the shapelist, and increases in the
                                     # direction along with the shapelist. You
                                     # can specify a number between 0 and
                                     # "the_number_of_edge - 1". (int, optional)