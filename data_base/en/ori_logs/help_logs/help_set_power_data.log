Usage: set_power_data [-help] -reset | {-format {current ascii area ascii_current} [-instance <string>] [-strip_hier_instance <string>] [-offset <string>] [-power <float>] [-scale <float>] [-repeat <float>] [-repeat_window <string>] [-bias_voltage <float>] [-die_instance_name <string>] [<filename> | -power_output_directory <string>]}

-help                             # Prints out the command usage
<filename>                        # <power filename> (string, optional)
-bias_voltage <float>             # <bias voltage value>
                                  # (float, optional, min=0, max=10)
-die_instance_name <string>       # <die instance name> (string, optional)
-format {current ascii area ascii_current}
                                  # <format: current | ascii | area |
                                  # ascii_current> (enum, required)
-instance <string>                # <instance name> (string, optional)
-offset <string>                  # <cycle offset> (string, optional)
-power <float>                    # <power value> (float, optional)
-power_output_directory <string>  # <power file directory> (string, optional)
-repeat <float>                   # <repeat number>
                                  # (float, optional, default unit=n, current unit = n)
-repeat_window <string>           # <repeat window {start end} (ns)>
                                  # (string, optional)
-reset                            # reset all power data (bool, optional)
-scale <float>                    # <scale number> (float, optional)
-strip_hier_instance <string>     # <instance name> (string, optional)