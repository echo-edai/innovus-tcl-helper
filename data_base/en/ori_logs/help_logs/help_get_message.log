Usage: get_message [-help] -id <msgID> {-severity  | -limit  | -suppress  | -count  | -short  | -long  | -on_error  | -stop_script_limit  | -detail }

-help                  # Prints out the command usage
-count                 # Return the number of times this message has been
                       # issued this session. (bool, optional)
-detail                # Returns the message of specified id. (bool, optional)
-id <msgID>            # A single message ID, in the form "ENCFOO-123".
                       # (string, required)
-limit                 # Return the limit for the specified message as an
                       # integer. -1 is unlimited. 0 is suppressed.
                       # (bool, optional)
-long                  # Return the long message description, as used for the
                       # Description section in "man <msgID>" (bool, optional)
-on_error              # Return the error action for the specified message.
                       # (bool, optional)
-severity              # Return the severity of the specified message as a
                       # string. One of "error warn info default" (bool, optional)
-short                 # Return the short message description. Equivalent to
                       # "help <msgID>" (bool, optional)
-stop_script_limit     # Returns the message limit allowed for every public
                       # command. -1 is unlimited. (bool, optional)
-suppress              # Return 1 if the message is suppressed, 0 otherwise.
                       # (bool, optional)