Usage: signoffTimeDesign [-help] [-noExpandedViews] [-outDir <string>]
                         [-prefix <string>] [-reportFullClockPath] [-noEcoDb]
                         [-reportOnly]

-help                      # Prints out the command usage
-noExpandedViews           # Do not print expanded timing per view
                           # (bool, optional)
-outDir <string>           # Reports would be saved in this directory
                           # (string, optional)
-prefix <string>           # Prefix for timing report file names
                           # (string, optional)
-reportFullClockPath       # Enable full clock path in detailed report
                           # (bool, optional)
-noEcoDb                   # Do not generate ECO Timing DB (bool, optional)
-reportOnly                # No parasitic extraction (bool, optional)