Usage: wireload [-help] [-cellLimit <integer>] [-custom] [-logarithmic]
                [-netCoverRatio <float>] [-noSmooth] [-outfile <string>]
                [-peakCap] [-percent <float>] [-scale <float>] [-view <string>] [-cell <string> | {[-inst <string>] [-instanceBased ]}] [[-name <string>] {-cell <string> | -inst <string>}]

-help                    # Prints out the command usage
-cell <string>           # the cell name for generating a wireload model
                         # (string, optional)
-cellLimit <integer>     # the module size limit of cells or instances for
                         # generating a wireload model (int, optional)
-custom                  # generates the Synopsys custom wireload model format
                         # (bool, optional)
-inst <string>           # the name of the hierarchical instance in a path for
                         # which to generate a wireload model (string, optional)
-instanceBased           # generates wireload models for each instance in the
                         # design (bool, optional)
-logarithmic             # uses logarithmic average of the fanout value to
                         # calculate the wireload model (bool, optional)
-name <string>           # renames the cell name or instance name
                         # (string, optional)
-netCoverRatio <float>   # the percentage of nets to be considered for
                         # generating wireload model (float, optional)
-noSmooth                # suppresses the smoothing of the wireload models
                         # (bool, optional)
-outfile <string>        # the filenames for the generated wireload models
                         # (string, optional)
-peakCap                 # uses peak fanout value to calculate the wireload
                         # model (bool, optional)
-percent <float>         # the sample rate of the number of nets for
                         # calculation of wireload models (float, optional)
-scale <float>           # the scaling value used to multiply the results
                         # (float, optional)
-view <string>           # generates the wireload models for the specified
                         # analysis view (string, optional)