Usage: getPinDensityMapMode [-help] [-displayStep] [-gridInMicron] [-gridInRow]
                            [-threshold] [-quiet] [-nonDefault]

-help                                # Prints out the command usage
-displayStep                         # range step for displaying the pin
                                     # density map (float, default=0.05)
-gridInMicron                        # specify the value (in micron) of side of
                                     # square grid for pin density
                                     # calculations.
                                     # (float, default=50, min=0, max=1000)
-gridInRow                           # specify the value (in row-height) of
                                     # side of square grid for pin density
                                     # calculations.
                                     # (int, default=10, min=1, max=100)
-threshold                           # threshold value over which the densities
                                     # must be reported. (float, default=0.5)
-quiet                               # Displays the current settings in Tcl list format only
-nonDefault                          # Displays the current settings which are not default settings