Usage: reportCongestArea [-help] [-cutoffArea <number>] [-cutoffRatio <ratio>]
                         [-cutoffValue <number>] [-mode <mode name>]
                         [-num <number>] [-outfile <file name>] [-step <number>]

-help                    # Prints out the command usage
-cutoffArea <number>     # cutoff area (int, optional)
-cutoffRatio <ratio>     # cutoff ratio (float, optional, min=0, max=1)
-cutoffValue <number>    # cutoff # (int, optional)
-mode <mode name>        # average or max (string, optional)
-num <number>            # # of areas or all (string, optional)
-outfile <file name>     # output file name (string, optional)
-step <number>           # # of steps (int, optional)