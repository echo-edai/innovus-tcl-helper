Usage: query_power_data [-help] [<in_file <file1[file2] ...>>]
                        [-average_current] [-clock_average] [-dump_pwl]
                        [-frame <string>] [-instance_list <string>]
                        [-instance_list_file <string>] [-list]
                        [-output <string>] [-output_tap_name <string>]
                        [-peak_current] [-peak_time] [-pin] [-stdout]
                        [-time_steps] [-total_current]

-help                            # Prints out the command usage
<in_file <file1[file2] ...>>     # read the pti files (string, optional)
-average_current                 # write average current of all instances
                                 # (bool, optional)
-clock_average                   # write clock based current report
                                 # (bool, optional)
-dump_pwl                        # write tap current in pwl format
                                 # (bool, optional)
-frame <string>                  # specify numerical intervals [t1 t2 t3] for
                                 # clock_average report (ns) (string, optional)
-instance_list <string>          # specify list of instances (string, optional)
-instance_list_file <string>     # specify file with list of instances
                                 # (string, optional)
-list                            # write list of instances (bool, optional)
-output <string>                 # specify output report prefix
                                 # (string, optional)
-output_tap_name <string>        # specify output tap name for total current
                                 # report (string, optional)
-peak_current                    # write peak current of all instances
                                 # (bool, optional)
-peak_time                       # write peak current time of all instances
                                 # (bool, optional)
-pin                             # report instance pin (bool, optional)
-stdout                          # print on stdout (bool, optional)
-time_steps                      # write total current (bool, optional)
-total_current                   # write total current of all taps
                                 # (bool, optional)