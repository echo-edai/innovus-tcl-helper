help timing_hierarchical_context_continue_on_top_block_clock_misma tch

	# By default or when timing_hierarchical_context_continue_on_top_block_clock_mismatch 
	# is set to 'false' the read_timing_context command will assert an error 
	# condition if any of the top-level clocks could not be matched with a 
	# block-level clock. Processing of the current script will stop. If timing_hierarchical_context_continue_on_top_block_clock_mismatch 
	# is set to 'true', script processing will be allowed to continue despite 
	# any mismatch between top and block-level clocks. Mismatches will be reported 
	# in the file: timing_context_clock_mapping_data.rpt. You should examine 
	# this file to determine if corrections or additions are required to the 
	# clock mapping file.