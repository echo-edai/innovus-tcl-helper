Usage: unsetPinConstraint [-help] [[-global | -cell <cell_name> | -all_user ] [-global | -pin <pin_name_list> | -area {x1 y1 x2 y2} | -all_area | -side <side_names>] [-global | -layer ] [-global | -loc | -edge | -corner <corner_number>] [[-pin <pin_name_list> [-loc ] [-edge ]] | [-corner_to_pin_distance [-corner <corner_number>]]] [{-pin <pin_name_list> | -pinTemplate {layer_id_or_name_list}} -width ] [{-pin <pin_name_list> | -pinTemplate {layer_id_or_name_list}} -depth ] [-layer | -pinTemplate {layer_id_or_name_list}] [-spacing [-area {x1 y1 x2 y2}] [-all_area ]] ] [-depth [-special_wire ]] [-all_user ]

-help                                    # Prints out the command usage
-all_area                                # Specifies that spacing constraints
                                         # on all area should be removed.
                                         # (bool, optional)
-all_user                                # Specifies that all user constraints
                                         # should be removed. (bool, optional)
-area {x1 y1 x2 y2}                      # Specifies an area overlapping with
                                         # partition where spacing constraint
                                         # should be removed. (box, optional)
-cell <cell_name>                        # Specifies the name of the cell of
                                         # partition or top. You can use
                                         # wildcards with this parameter.
                                         # (string, optional)
-corner <corner_number>                  # Specifies the corner of the
                                         # partition block. (int, optional)
-corner_to_pin_distance                  # Specifies that the corner to pin
                                         # distance constraints should be
                                         # removed. (bool, optional)
-depth                                   # Specifies that the pin depth related
                                         # constraints should be removed.
                                         # (bool, optional)
-edge                                    # Specifies that the edge-related
                                         # constraints should be removed.
                                         # (bool, optional)
-global                                  # Specifies to reset global
                                         # constraints. (bool, optional)
-layer                                   # Specifies that the layer-related
                                         # constraints should be removed.
                                         # (bool, optional)
-loc                                     # Specifies that the location-related
                                         # constraints should be removed.
                                         # (bool, optional)
-pin <pin_name_list>                     # Specifies the name of the partition
                                         # pin. You can use wildcards with this
                                         # parameter. (string, optional)
-pinTemplate {layer_id_or_name_list}     # Specifies the metal layers for the
                                         # width, depth and spacing constraints
                                         # at global level and cell level.
                                         # (string, optional)
-side <side_names>                       # Specifies name of the sides. Valid
                                         # values are { N S E W } or { L B T R
                                         # } or all (string, optional)
-spacing                                 # Specifies that the spacing-related
                                         # constraints should be removed.
                                         # (bool, optional)
-special_wire                            # Specifies that the depth constraint
                                         # that is set and honored for special
                                         # wire pins should be removed
                                         # (bool, optional)
-width                                   # Specifies that the pin width related
                                         # constraints should be removed.
                                         # (bool, optional)