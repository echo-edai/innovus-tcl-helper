Usage: validate_pg_library [-help] [-activity <string>] -cell <string>
                           [-clock <string>]
                           [-disable_rail_analysis {true false}]
                           [-dynamic_analysis_duration <string>]
                           [-enable_xp {true false}]
                           [-extraction_include_file <string>]
                           [-extraction_tech_file <string>]
                           [-frequency <string>]
                           [-input_pin_set_case_analysis_high <string>]
                           [-input_pin_set_case_analysis_low <string>]
                           [-liberty <string>] [-max_ir_drop <float>]
                           [-net_capacitance <string>] [-output <string>]
                           [-pgv_mode_dynamic_switch_pattern <string>]
                           [-pin_capacitance <string>]
                           -power_grid_library_path <string>
                           [-power_grid_library_view <string>]
                           [-power_include_file <string>]
                           [-power_pad_size <float>]
                           [-rail_analysis_type <string>]
                           [-rail_include_file_begin <string>]
                           [-rail_include_file_end <string>]
                           [-rail_trigger_switching_pattern <string>]
                           [-sdc_file <string>]
                           [-set_power_switching_pattern <string>]
                           [-set_total_power <string>] [-step_size <string>]
                           [-supply_voltage <float>] [-tech_lef_file <string>]
                           [-temperature <string>] [-transition_time <string>]
                           [-twf_path <string>]
                           [-user_defined_ploc_file <string>]

-help                                 # Prints out the command usage
-activity <string>                    # <default:0.2> (string, optional)
-cell <string>                        # <cellname> (string, required)
-clock <string>                       # <pin_list> (string, optional)
-disable_rail_analysis {true false}   # <default:false> (enum, optional)
-dynamic_analysis_duration <string>   # <default:10ns> (string, optional)
-enable_xp {true false}               # <default:false> (enum, optional)
-extraction_include_file <string>     # <extraction_include_file>
                                      # (string, optional)
-extraction_tech_file <string>        # <extraction_tech_file>
                                      # (string, optional)
-frequency <string>                   # <default:200MHz> (string, optional)
-input_pin_set_case_analysis_high <string>
                                      # <pin_list> (string, optional)
-input_pin_set_case_analysis_low <string>
                                      # <pin_list> (string, optional)
-liberty <string>                     # <library_name> (string, optional)
-max_ir_drop <float>                  # <default:5 (in %)> (float, optional)
-net_capacitance <string>             # <default:1pf> (string, optional)
-output <string>                      # <outputdirectory> (string, optional)
-pgv_mode_dynamic_switch_pattern <string>
                                      # <pgv_mode_dynamic_switch_pattern> (string, optional)
-pin_capacitance <string>             # <default:1pf> (string, optional)
-power_grid_library_path <string>     # <power_grid_library_path>
                                      # (string, required)
-power_grid_library_view <string>     # <view_name> (string, optional)
-power_include_file <string>          # <power_include_file> (string, optional)
-power_pad_size <float>               # <default:50> (float, optional)
-rail_analysis_type <string>          # <static/dynamic> (string, optional)
-rail_include_file_begin <string>     # <rail_include_file_begin>
                                      # (string, optional)
-rail_include_file_end <string>       # <rail_include_file_end>
                                      # (string, optional)
-rail_trigger_switching_pattern <string>
                                      # <trigger_switching_pattern> (string, optional)
-sdc_file <string>                    # <sdc_file_path> (string, optional)
-set_power_switching_pattern <string> # <mode_dynamic_switch_pattern>
                                      # (string, optional)
-set_total_power <string>             # <default:0.001> (string, optional)
-step_size <string>                   # <default:20ps> (string, optional)
-supply_voltage <float>               # <default:1 (V)> (float, optional)
-tech_lef_file <string>               # <tech_lef_file> (string, optional)
-temperature <string>                 # <default:125> (string, optional)
-transition_time <string>             # <default:1(100ps)> (string, optional)
-twf_path <string>                    # <twf_location> (string, optional)
-user_defined_ploc_file <string>      # <user_defined_ploc_file>
                                      # (string, optional)