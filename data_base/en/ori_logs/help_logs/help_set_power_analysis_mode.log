-help                                    # Prints out the command usage
-reset                                   # Resets all or specified options to default value
-add_simulation {true|false}             # Add simulation for design coverage
                                         # (bool, default=false)
-adjust_input_activity_in_iterations {true|false}
                                         # Adjust input activity in state
                                         # propagation. (bool, default=true)
-adjust_macro_activity_in_iterations {true|false}
                                         # Adjust macro activity in state
                                         # propagation. (bool, default=true)
-annotation_detail_report {true|false}   # Generate detailed annotation report
                                         # showing objects in their specific
                                         # type blocks. (bool, default=false)
-auto_twf_delay_annotation {true|false}  # Auto detect zero delay vectors
                                         # (bool, default=false)
-average_rise_fall_cap {true|false}      # When set to true, the software uses
                                         # the average of rise and fall
                                         # capacitance from the liberty file.
                                         # (bool, default=false)
-binary_db_name <std::string>            # Specifies the name of the binary
                                         # power database file ( filename.db ).
                                         # (string, default="")
-block_independent_peakpower {true|false}
                                         # Power profiling done independently
                                         # for each vector, design block
                                         # (bool, default=false)
-boundary_gate_leakage_file <std::string>
                                         # liberty side file required for
                                         # boundary gate leakage calculation
                                         # (string, default="")
-boundary_gate_leakage_report {true|false}
                                         # generate verbose report for boundary
                                         # gate leakage calculation
                                         # (bool, default=false)
-boundary_leakage_cell_property_file <std::string>
                                         # Cell properties file for boundary
                                         # leakage flow (string, default="")
-boundary_leakage_edge_annotation_file <std::string>
                                         # read edge annotation summary file
                                         # for boundary gate leakage flow
                                         # (string, default="")
-boundary_leakage_multi_pgpin_support {true|false}
                                         # Support for computing boundary
                                         # leakage power for cells with
                                         # multiple pg-pins by selecting the
                                         # pg-pin connected to M0 rail
                                         # (bool, default=false)
-boundary_leakage_pessimism_removal {true|false}
                                         # Support for S-FCs-S pessimism
                                         # removal feature in boundary leakage
                                         # calculation (bool, default=true)
-boundary_leakage_PXE_support {true|false}
                                         # Support for PXE feature in boundary
                                         # leakage calculation
                                         # (bool, default=false)
-bulk_pins <bulk pin list>               # Defines power and ground bulk LEF
                                         # pins for the design.
                                         # (string, default="")
-capacity {low|medium|high}              # Specifies the segment count for
                                         # profiler
                                         # (enums={low medium high}, default=low)
-case_insensitive_mapping {true|false}   # Case insensitive auto-mapping,
                                         # ignoring the case(upper or lower) of
                                         # a character while matching rtl with
                                         # design names. (bool, default=false)
-clock_source_as_clock {true|false}      # Specifies to use the correct clock
                                         # frequency for activity calculation.
                                         # (bool, default=false)
-comprehensive_automapping {true|false}  # Comprehensively perform instance
                                         # name mapping between the RTL netlist
                                         # and GATE level netlist.
                                         # (bool, default=false)
-constant_override {true|false}          # Specifies to give higher precedence
                                         # to propagated constants defined
                                         # using the set_case_analysis command.
                                         # (bool, default=false)
-corner <std::string>                    # Defines the library corner (for
                                         # non-MMMC setup). (string, default="")
-create_binary_db {true|false}           # A value of true creates a binary
                                         # database of power results.
                                         # (bool, default=false)
-create_driver_db {true|false}           # Specifies to determine all the
                                         # drivers/receivers on the ground net.
                                         # (bool, default=false)
-create_gui_db {true|false}              # A value of true creates a binary
                                         # database of power results for gui.
                                         # (bool, default=true)
-current_generation_method <type>        # choose avg or peak current
                                         # generation method (string, default=avg)
-decap_cell_list <decap list>            # Specifies the physical only cells,
                                         # such as decap cells, to include in
                                         # the power report. (string, default="")
-default_frequency <double>              # Specifies to set the default
                                         # frequency in the MHz unit for net
                                         # not annotated by TWF.
                                         # (float, default=-1)
-default_slew <value>                    # Specifies to set the default slew in
                                         # the ns unit for net not annotated by
                                         # TWF. (string, default="")
-default_supply_voltage <value>          # Specifies to set a default voltage
                                         # for power nets in a scenario where
                                         # the power engine cannot determine
                                         # the voltage of these nets.
                                         # (string, default="")
-detailed_view_current_only {true|false}
                                         # Ignore switching current for
                                         # instances with detailed view
                                         # (bool, default=true)
-disable_clock_gate_clipping {true|false}
                                         # Specifies to enable clock gate
                                         # output clipping so that the output
                                         # transition density of an ICG cell
                                         # does not exceed the input clock pin
                                         # transition density.
                                         # (bool, default=true)
-disable_leakage_scaling {true|false}    # Specifies to exclude leakage power
                                         # during scaling factor computation
                                         # when target power is specified using
                                         # the set_power command.
                                         # (bool, default=false)
-disable_static {true|false}             # When set to true in the dynamic
                                         # vector-based or dynamic vectorless
                                         # flows, the command performs only
                                         # dynamic analysis and turns-off
                                         # static power calculation.
                                         # (bool, default=false)
-distribute_switching_power {true|false}
                                         # distribute switching power to all
                                         # connected I/O instances if the net
                                         # does not have a driver instance
                                         # (bool, default=false)
-distributed_combine_report_format <format>
                                         # control which power report files
                                         # need to be combined
                                         # (string, default=reduced)
-distributed_setup <file-name>           # Specifies a file containing the
                                         # customized setup details for running
                                         # power analysis in the distributed
                                         # mode. (string, default="")
-domain_based_clipping {true|false}      # Determines the frequency to be used
                                         # to clip propagated activity that is
                                         # too high. (bool, default=false)
-dynamic_glitch_filter <double>          # set absolute time threshold value
                                         # (in ns) for dynamic glitch filter
                                         # (float, default=-1)
-dynamic_scale_clock_by_frequency <clock_freq>
                                         # set clock frequency scaling ratio by
                                         # frenquency value (string, default="")
-dynamic_scale_clock_by_name <clock_freq>
                                         # set clock frequency scaling ratio by
                                         # clock name (string, default="")
-dynamic_vectorless_ranking_methods <method>
                                         # choose ranking options from: load,
                                         # slack, clock and vector_activity
                                         # (string, default="")
-enable_auto_mapping {true|false}        # Specifies to automatically perform
                                         # instance name mapping between the
                                         # RTL netlist and GATE level netlist.
                                         # (bool, default=false)
-enable_auto_queue {true|false}          # Automatically assign power job to
                                         # proper queue (bool, default=false)
-enable_disk_mapping {true|false}        # Enable disk caching of toggles.
                                         # (bool, default=false)
-enable_duty_prop_with_global {true|false}
                                         # Specifies to propagate duty cycle
                                         # with the global switching activity
                                         # setting for all data nets in the
                                         # dynamic vectorless analysis flow.
                                         # (bool, default=false)
-enable_dynamic_current_slew_load_interpolation {true|false}
                                         # enable dynamic current slew load
                                         # interpolation (bool, default=false)
-enable_dynamic_scaling {true|false}     # Enables set_power scaling for
                                         # dynamic power analysis.
                                         # (bool, default=false)
-enable_flop_state_propagation {true|false}
                                         # Enable flop state propagation (bool, default=false)
-enable_force_propagation {true|false}   # Enable force propagation
                                         # (bool, default=false)
-enable_generated_clock {true|false}     # Specifies to get generated clock
                                         # frequency during activity
                                         # propagation for static power
                                         # analysis. (bool, default=true)
-enable_input_net_power {true|false}     # Specifies to calculate the switching
                                         # power of input nets.
                                         # (bool, default=false)
-enable_interactive_reports {true|false}
                                         # Enable voltus interactive reports (bool, default=true)
-enable_mt_in_vectorbasedflow {true|false}
                                         # Specifies to enable multi-threading
                                         # for the VCD/FSDB based dynamic
                                         # vector-based flows.
                                         # (bool, default=true)
-enable_mt_reports {true|false}          # to enable multithreaded power report
                                         # generation (bool, default=false)
-enable_mt_state_propagation {true|false}
                                         # Enable Multithreading in state
                                         # propagation (bool, default=true)
-enable_pba_for_tempus_pi {true|false}   # ensure path based timing analysis in
                                         # tempus-pi flow. (bool, default=true)
-enable_power_target_flow {true|false}   # enable vectorless state propagation
                                         # with power target (bool, default=false)
-enable_rtl_vectorbased_dynamic_analysis {true|false}
                                         # Specifies to take an RTL or partial
                                         # VCD/FSDB file as input and use that
                                         # for dynamic vector-based flow.
                                         # (bool, default=false)
-enable_scan_report {true|false}         # enable scan report automatical
                                         # generation (bool, default=false)
-enable_single_cycle_scheduling {true|false}
                                         # Stage-propagation based vectorless
                                         # flow schedules new flops/macros
                                         # every cycle to achieve faster toggle
                                         # coverage. (bool, default=false)
-enable_slew_based_ccs_pin_cap {true|false}
                                         # honor ccs pin cap (bool, default=false)
-enable_stable_clock_gating {true|false}
                                         # Use stable clock gate in vless flow (bool, default=false)
-enable_stable_flop_scheduling {true|false}
                                         # Enable stable flop scheduling (bool, default=false)
-enable_state_propagation {true|false}   # enable vectorless state propagation
                                         # dynamic analysis (bool, default=false)
-enable_tempus_pi {true|false}           # enable timing critical path analysis
                                         # in state propagation based
                                         # vectorless flow. (bool, default=false)
-enable_xp {true|false}                  # standalone power analysis in
                                         # voltus-XP (bool, default=false)
-enhanced_blackbox_avg {true|false}      # Specifies to use the average toggle
                                         # rate of related inputs for enhanced
                                         # blackbox propagation.
                                         # (bool, default=false)
-enhanced_blackbox_max {true|false}      # Specifies to use the maximum toggle
                                         # rate of related inputs for enhanced
                                         # blackbox propagation.
                                         # (bool, default=false)
-equivalent_annotation {true|false}      # Enable Qbar annotation
                                         # (bool, default=false)
-event_based_leakage_power {true|false}  # Event based leakage power
                                         # (bool, default=false)
-external_load_config_file <external load config file>
                                         # Allow user to provide external load
                                         # file to set external load manually.
                                         # (string, default="")
-extraction_tech_file <std::string>      # technology file for exaction
                                         # (string, default="")
-extractor_include <std::string>         # extraction include file
                                         # (string, default="")
-fanout_limit <integer>                  # Specifies the fanout limit for nets.
                                         # (int, default=-1)
-flatten_xpgv_block_instances <file>     # Identify text file containing name
                                         # of block instances which need to use
                                         # DEF while already having PGV
                                         # (string, default="")
-force_library_merging {true|false}      # force library merging even if there
                                         # is some error during merging
                                         # (bool, default=false)
-from_x_transition_factor <double>       # activity count for x to 0/1
                                         # transition (float, default=0.5)
-from_z_transition_factor <double>       # activity count for z to 0/1
                                         # transition (float, default=0.25)
-generate_activity_mapping_report {true|false}
                                         # turn on/off generation of
                                         # activity_mapping.rpt
                                         # (bool, default=false)
-generate_current_for_rail <railnames>   # Generates current files for the
                                         # specified rail. (string, default="")
-generate_flop_ranking_data <output dir>
                                         # Specifies the name of the dir
                                         # containing the ranking data.
                                         # (string, default="")
-generate_leakage_power_map_based_on_calculated_leakage {true|false}
                                         # Print leakage power table based on
                                         # calculated leakage power.
                                         # (bool, default=false)
-generate_static_report_from_state_propagation {true|false}
                                         # generate static report from state
                                         # propagation flow (bool, default=false)
-handle_glitch {true|false}              # A transition is defined as a glitch
                                         # when the time difference between two
                                         # sequential toggles are less than
                                         # half of the rise transition time +
                                         # fall transition time in the
                                         # vector-based static power
                                         # calculation. (bool, default=false)
-handle_transport_glitch {true|false}    # Enable transport glitch support
                                         # (bool, default=false)
-handle_tri_state {true|false}           # When set to true , all tristate
                                         # device enable pin values will be
                                         # taken into account when determining
                                         # the propagation of the activity
                                         # through tristate gates.
                                         # (bool, default=false)
-hier_delimiter <char>                   # Specifies the hierarchical delimiter
                                         # in the DEF file. The default
                                         # hierarchical delimiter is a forward
                                         # slash ( / ) but can be changed by
                                         # setting the -hier_delimiter
                                         # parameter. (string, default="")
-honor_combinational_logic_on_clock_net {true|false}
                                         # Specifies the behavior of
                                         # combination logic on clock net.
                                         # (bool, default=true)
-honor_negative_energy {true|false}      # A value of true specifies that
                                         # Voltus will keep negative internal
                                         # energy numbers from the .lib
                                         # internal power table.
                                         # (bool, default=true)
-honor_net_activity {true|false}         # honor net activity from activity
                                         # file (bool, default=true)
-honor_non_mission_leakage {true|false}  # Option to activate Non-Mission
                                         # leakage flow (bool, default=false)
-hybrid_analysis {true|false}            # Vbased + Vless runs done separately
                                         # and results combined
                                         # (bool, default=false)
-ignore_control_signals {true|false}     # A value of true specifies that
                                         # control signals will be ignored when
                                         # propagating activity.
                                         # (bool, default=true)
-ignore_data_phase_for_clk {true|false}  # (bool, default=false)
-ignore_end_toggles_in_profile {true|false}
                                         # ignore toggles on end boundary in
                                         # profiler analysis (bool, default=false)
-ignore_glitches_at_same_time_stamp {true|false}
                                         # Specifies to ignore glitches at the
                                         # same transient time in the
                                         # vector-based static and dynamic
                                         # power analysis flow.
                                         # (bool, default=true)
-ignore_inout_pin_cap {true|false}       # When set to true , ignores the
                                         # bidirectional pin capacitances (
                                         # direction : inout ) defined for I/O
                                         # cells in the .lib file, when
                                         # calculating switching power and
                                         # internal power. (bool, default=false)
-ignore_macro_leakage_scale_for_temp {true|false}
                                         # Option for ignoring leakage power
                                         # scaling on macro cell
                                         # (bool, default=false)
