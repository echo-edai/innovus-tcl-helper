Usage: report_area [-help] [-detail] [-hierarchical_instance <hInst>]
                   [-include_physical] [-min_area <float>]
                   [-min_count <integer>] [-out_file <string>]
                   [-show_leaf_cells] [-show_msv_cells]
                   [-sort_by {name count area}]
                   [-table_style {horizontal vertical}] [-summary  | -depth <integer>]

-help                              # Prints out the command usage
-depth <integer>                   # Only include hierarchical instance with a
                                   # number of level <= the argument.
                                   # (int, optional)
-detail                            # Report break down of cell type (buffer,
                                   # inverter, combinational, flop, latch,
                                   # clock_gate, macro, physical) (bool, optional)
-hierarchical_instance <hInst>     # Reports the area of the leaf instances in
                                   # the specified hierarchical instance. User
                                   # can use -depth option to control the
                                   # analysis depth of specified hierarchical
                                   # instance. ((hInst), optional)
-include_physical                  # Include physical cells in the area
                                   # calculation and report (bool, optional)
-min_area <float>                  # Min area threshold for module to be
                                   # reported (float, optional)
-min_count <integer>               # Specify the minimum instance count per
                                   # hierarchical instance to be considered.
                                   # (int, optional)
-out_file <string>                 # Output file name. (string, optional)
-show_leaf_cells                   # Show the leaf cells that exist at the
                                   # design level and each hinst level.
                                   # (bool, optional)
-show_msv_cells                    # Include multiple supply voltage cells in
                                   # the the report; only supported with
                                   # "-table_by vertical" (bool, optional)
-sort_by {name count area}         # How to sort hinst names (enum, optional)
-summary                           # It will print the area summary for the
                                   # design. It will be equivalent as doing
                                   # "-depth 0" (bool, optional)
-table_style {horizontal vertical} # Table styles (enum, optional)