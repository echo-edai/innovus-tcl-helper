Usage: pull_block_constraint [-help] [-file <report_file_name>] [-override] {-all_blocks  | -block <list_of_blocks> | -inst <list_of_instances> | -cellview {list of <libName cellName viewName>}}

-help                               # Prints out the command usage
-all_blocks                         # all the blocks' constraints must be
                                    # pulled up (bool, required)
-block <list_of_blocks>             # Specifies one or more blocks whose
                                    # constraints need to be pulled up
                                    # (string, required)
-cellview {list of <libName cellName viewName>}
                                    # List of library, cell and view from which
                                    # constraints need to be pulled.
                                    # (string, required)
-file <report_file_name>            # report file containing all the details of
                                    # constraints (string, optional)
-inst <list_of_instances>           # Specifies one or more instances whose
                                    # constraints need to be pulled up
                                    # (string, required)
-override                           # override top block's constraints
                                    # (bool, optional)