Usage: getAnalysisMode [-help] [-aging] [-analysisType] [-aocv] [-asyncChecks]
                       [-caseAnalysis] [-checkType] [-clkNetsMarking]
                       [-clkSrcPath] [-clockGatingCheck] [-clockPropagation]
                       [-cppr] [-honorActiveLogicView] [-honorClockDomains]
                       [-log] [-multi_input_switching_mode] [-propSlew]
                       [-sequentialConstProp] [-skew] [-slackBalancing] [-socv]
                       [-timeBorrowing] [-timing_robustness] [-timingEngine]
                       [-timingSelfLoopsNoSkew] [-usefulSkew] [-useOutputPinCap]
                       [-warn] [-quiet] [-nonDefault]

-help                                      # Prints out the command usage
-aging                                     # Aging Analysis
                                           # (bool, default=false)
-analysisType                              # Single or BCWC or OCV
                                           # TimingAnalysis type
                                           # (enums={single bcwc onChipVariation}, default=bcwc)
-aocv                                      # AOCV Analysis
                                           # (bool, default=false)
-asyncChecks                               # Async checks
                                           # (enums={async noAsync asyncOnly auto}, default=auto)
-caseAnalysis                              # caseAnalysis (bool, default=true)
-checkType                                 # Report Violations for hold, setup
                                           # (enums={setup hold}, default=setup)
-clkNetsMarking                            # clkNetsMarking
                                           # (enums={beforeConstProp afterConstProp}, default=beforeConstProp)
-clkSrcPath                                # clkSrcPath (bool, default=true)
-clockGatingCheck                          # clockGatingCheck
                                           # (bool, default=true)
-clockPropagation                          # Timing arc attributes effect on
                                           # timing analysis
                                           # (enums={sdcControl forcedIdeal autoDetectClockTree}, default=sdcControl)
-cppr                                      # Removes pessimism from clock paths
                                           # that have a portion of the clock
                                           # network in common between the
                                           # clock source and clock destination
                                           # paths
                                           # (enums={both none setup hold}, default=none)
-honorActiveLogicView                      # Honor Active Logic View
                                           # (bool, default=false)
-honorClockDomains                         # Honor Clock Domains
                                           # (bool, default=false)
-log                                       # log (bool, default=true)
-multi_input_switching_mode                # Specify MIS mode: 0,Simultaneous
                                           # input switching is not considered
                                           # 1,MIS analysis consider cells for
                                           # which multiple inputs of a cell
                                           # tied together (tied-inputs) 2,MIS
                                           # analysis consider both tied-inputs
                                           # and inputs of a cells switching
                                           # independent to each other 3,derate
                                           # based MIS analysis
                                           # (int, default=0, min=0, max=3)
-propSlew                                  # Controls interconnect slew
                                           # degradation for early paths.
                                           # (bool, default=true)
-sequentialConstProp                       # sequentialConstProp
                                           # (bool, default=false)
-skew                                      # skew (bool, default=true)
-slackBalancing                            # (bool, default=false)
-socv                                      # SOCV Analysis
                                           # (bool, default=false)
-timeBorrowing                             # timeBorrowing (bool, default=true)
-timing_robustness                         # Timing Robustness Analysis
                                           # (bool, default=false)
-timingEngine                              # Statistical or Static or Rql
                                           # (enums={statistical static rql}, default=static)
-timingSelfLoopsNoSkew                     # Eliminates clock skew due to clock
                                           # uncertainty for a path starting
                                           # and ending at the same register.
                                           # If the clock skew is not
                                           # eliminated, the timing for such
                                           # paths is pessimistic
                                           # (bool, default=false)
-usefulSkew                                # UsefulSkew (bool, default=false)
-useOutputPinCap                           # useOutputPinCap
                                           # (bool, default=true)
-warn                                      # warn (bool, default=true)
-quiet                                     # Displays the current settings in Tcl list format only
-nonDefault                                # Displays the current settings which are not default settings