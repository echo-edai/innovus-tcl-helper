Usage: createInterfaceLogic [-help] [-allowIlmEco] [-ignorePorts <string>]
                            [-keepAll] [-keepSelected]
                            [-modelType {timing si all}] [-noInterClockPath]
                            [-optStage {preCTS postCTS}] [-overwrite]
                            [-removePowerGround] [-dir <string> | -cellview <string>]

-help                                 # Prints out the command usage
-allowIlmEco                          # <allowIlmEco> (bool, optional)
-cellview <string>                    # <library cell view> (string, optional)
-dir <string>                         # <Output directory name>
                                      # (string, optional)
-ignorePorts <string>                 # <listOfPortNames> (string, optional)
-keepAll                              # <keepAll> (bool, optional)
-keepSelected                         # <keepSelected> (bool, optional)
-modelType {timing si all}            # <model types> (enum, optional)
-noInterClockPath                     # <noInterClockPath> (bool, optional)
-optStage {preCTS postCTS}            # <preCTS, postCTS> (enum, optional)
-overwrite                            # <overwrite existing files>
                                      # (bool, optional)
-removePowerGround                    # <removePowerGround> (bool, optional)