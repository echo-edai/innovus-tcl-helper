Usage: ungroup [-help] [<hInst>+] [-check_only] [-exclude <hinst>+] [-flatten]
               [-honor_dont_touch] [-threshold <int>] [-verbose] [-simple  | -prefix <prefix> | -escaped ] [-force  | -only_user_hierarchy ]

-help                 # Prints out the command usage
<hInst>+              # Specifies the hinst(s) to be ungrouped.
                      # ((hInst)+, optional)
-check_only           # to check all constraints on specified hinsts to be
                      # ungroup. No actual ECO operation. (bool, optional)
-escaped              # Flattened names use escaped hinst names (h1/i1 becomes
                      # \h1/i1 in Verilog and h1\/i1 in DEF). (bool, optional)
-exclude <hinst>+     # Excludes specified hinst(s) as ungroup targets.
                      # ((hInst)+, optional)
-flatten              # Ungroups recursively below the specified hinst(s)
                      # (bool, optional)
-force                # to ungroup all hierarchy, mapped or not, and override
                      # ungroup_allowed if set false. (bool, optional)
-honor_dont_touch     # to skips hinst that's marked as dont touch.
                      # (bool, optional)
-only_user_hierarchy  # to ungroup only user hierarchy, synthesized module will
                      # not be ungrouped. (bool, optional)
-prefix <prefix>      # Flattened names use a prefix (h1/i1 becomes
                      # <prefix>_i1). (string, optional)
-simple               # Flattened names use the base_name (h1/i1 becomes i1).
                      # (bool, optional)
-threshold <int>      # Ungroups only those hinsts that have an inst count less
                      # than or equal to the specified integer. (int, optional)
-verbose              # to print the names of hinst being ungroup.
                      # (bool, optional)