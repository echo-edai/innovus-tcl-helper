Usage: map_dies [-help] [-3dic_design_stack_file <string>]
                [-component_config_file <string>] [-config <string>]
                [-die_pad_file_pair <string>] [-map_search_distance <string>]
                [-mode <string>] [-output <string>]
                [-stacked_die_mapping <string>]

-help                                # Prints out the command usage
-3dic_design_stack_file <string>     # <XML file for placement of 3DIC design>
                                     # (string, optional)
-component_config_file <string>      # <sanity check : config file>
                                     # (string, optional)
-config <string>                     # <JSON config file for create_xml mode>
                                     # (string, optional)
-die_pad_file_pair <string>          # <die pad file pair> (string, optional)
-map_search_distance <string>        # <sanity check : legal mapping distance
                                     # range> (string, optional)
-mode <string>                       # <mode> (string, optional)
-output <string>                     # <output directory of mapping results>
                                     # (string, optional)
-stacked_die_mapping <string>        # <sanity check : mapping result for
                                     # check> (string, optional)