Usage: sroute [-help] [-allowJogging <0|1>] [-allowLayerChange <0|1>]
              [-area {x1 y1 x2 y2}]
              [-blockPin {useLef all onBoundary leftBoundary rightBoundary topBoundary bottomBoundary abutPins}]
              [-blockPinLayerRange {minLayerName maxLayerName}]
              [-blockPinTarget {nearestTarget boundaryWithPin farthestPadRing blockring ring stripe padring ringpin blockpin}]
              [-blockPinWidthRange {min max}]
              [-connect [blockPin corePin padPin padRing floatingStripe secondaryPowerPin]]
              [-connectAlignedBlockAndPadPin {padPinAsTarget blockPinAsTarget}]
              [-connectInsideArea] [-corePinCheckStdcellGeoms]
              [-corePinLayer <layerNameList>]
              [-corePinTarget {firstAfterRowEnd boundaryWithPin farthestPadRing none blockring ring stripe padring ringpin blockpin}]
              [-corePinWidth <real>] [-crossoverViaLayerRange <bot top>]
              [-deleteExistingRoutes] [-detailed_log]
              [-floatingStripeTarget {blockring ring stripe padring ringpin blockpin followpin}]
              [-inst {block/pad insts}]
              [-layerChangeRange {bottomLayerName topLayerName}]
              [-nets {net_list}] [-noBlockPinOneAmongOverlappedPins]
              [-padCellSkipRoutingOnPadSide {top bottom left right}]
              [-padPinLayerRange {minLayerName maxLayerName}]
              [-padPinPortConnect {onePort allPort oneGeom allGeom preferLayer}]
              [-padPinTarget {nearestTarget blockring ring stripe ringpin blockpin followpin}]
              [-padPinWidth <real>] [-padRingLayer {layerNameList}]
              [-padRingWidth <real>] [-powerDomains <powerDomainName>]
              [-secondaryPinNet <net>+] [-secondaryPinRailLayer <layerName>]
              [-secondaryPinRailVerticalStripeGrid {layerName width pitch}]
              [-stripeLayerRange {minLayerName maxLayerName}]
              [-targetObjListFile <objectListFileName>+]
              [-targetViaLayerRange <bot top>] [-uda <subclass_string>]

-help                                  # Prints out the command usage
-allowJogging <0|1>                    # Allow jogging (bool, optional)
-allowLayerChange <0|1>                # Allow layer change (bool, optional)
-area {x1 y1 x2 y2}                    # Coordinates of area (box, optional)
-blockPin {useLef all onBoundary leftBoundary rightBoundary topBoundary bottomBoundary abutPins}
                                       # Block pins to connect (enum_list, optional)
-blockPinLayerRange {minLayerName maxLayerName}
                                       # Block pin layer range (string, optional)
-blockPinTarget {nearestTarget boundaryWithPin farthestPadRing blockring ring stripe padring ringpin blockpin}
                                       # Blockpin target (enum_list, optional)
-blockPinWidthRange {min max}          # Block pin width range
                                       # (string, optional)
-connect [blockPin corePin padPin padRing floatingStripe secondaryPowerPin]
                                       # Objects to route (enum_list, optional)
-connectAlignedBlockAndPadPin {padPinAsTarget blockPinAsTarget}
                                       # Whether block or pad pins can be
                                       # connection targets for aligned pad or
                                       # block pins (enum, optional)
-connectInsideArea                     # Connect to targets inside specified
                                       # area only (bool, optional)
-corePinCheckStdcellGeoms              # Check standard cell geometries
                                       # (bool, optional)
-corePinLayer <layerNameList>          # Connect only to standcell pins on
                                       # specified layers (string, optional)
-corePinTarget {firstAfterRowEnd boundaryWithPin farthestPadRing none blockring ring stripe padring ringpin blockpin}
                                       # Target for followpins (enum_list, optional)
-corePinWidth <real>                   # Connect only to standcell pins with
                                       # specified width (float, optional)
-crossoverViaLayerRange <bot top>      # Crossover stack via layer range
                                       # (string, optional)
-deleteExistingRoutes                  # Delete existing connections
                                       # (bool, optional)
-detailed_log                          # Detailed logfile (bool, optional)
-floatingStripeTarget {blockring ring stripe padring ringpin blockpin followpin}
                                       # Target for stripes (enum_list, optional)
-inst {block/pad insts}                # BLOCK/PAD insts to connect
                                       # (string, optional)
-layerChangeRange {bottomLayerName topLayerName}
                                       # Routing layer range (string, optional)
-nets {net_list}                       # Nets to route (string, optional)
-noBlockPinOneAmongOverlappedPins      # Route all pins (including those that
                                       # overlap) (bool, optional)
-padCellSkipRoutingOnPadSide {top bottom left right}
                                       # Skip routing on specified pad sides (enum_list, optional)
-padPinLayerRange {minLayerName maxLayerName}
                                       # Pad pin layer range (string, optional)
-padPinPortConnect {onePort allPort oneGeom allGeom preferLayer}
                                       # Number of connections to multiple
                                       # ports/geometries (enum_list, optional)
-padPinTarget {nearestTarget blockring ring stripe ringpin blockpin followpin}
                                       # Padpin target (enum_list, optional)
-padPinWidth <real>                    # Route only to pad pins with specified
                                       # width (float, optional)
-padRingLayer {layerNameList}          # Route only to pad ring on specified
                                       # layers (string, optional)
-padRingWidth <real>                   # Route only to pins with specified
                                       # width (float, optional)
-powerDomains <powerDomainName>        # Power domain selection
                                       # (string, optional)
-secondaryPinNet <net>+                # Secondary pin nets (string, optional)
-secondaryPinRailLayer <layerName>     # Secondary pin rail layer
                                       # (string, optional)
-secondaryPinRailVerticalStripeGrid {layerName width pitch}
                                       # Secondary pin stripe grid by layer
                                       # name, width and pitch (string, optional)
-stripeLayerRange {minLayerName maxLayerName}
                                       # Floating stripe layer range (string, optional)
-targetObjListFile <objectListFileName>+
                                       # Target object list files (string, optional)
-targetViaLayerRange <bot top>         # Target stack via layer range
                                       # (string, optional)
-uda <subclass_string>                 # User defined attribute subclass for
                                       # wires (string, optional)