Usage: getIlmMode [-help] [-filterInternalPath {true|false}] [-ilm <string>]
                  [-ilmCell <string>] [-keepAsync {true|false}]
                  [-keepFlatten {true|false}]
                  [-keepHighFanoutPorts {true|false}]
                  [-keepInstInSdc {true|false}] [-keepLoopBack {true|false}]
                  [-map {view|corner}] [-maxNumInsts <value>]
                  [-maxNumRegisters <value>] [-resetMap {view|corner}]
                  [-slackDriven {true|false}] [-top <string>]
                  [-quiet] [-nonDefault]

-help                                 # Prints out the command usage
-filterInternalPath {true|false}      # filterInternalPath
                                      # (bool, default=false)
-ilm <string>                         # Specifies a view or corner name of an
                                      # ILM to be mapped to top-level
                                      # (string, default="")
-ilmCell <string>                     # Specifies ILM cell name that has view
                                      # or corner mapping to top-level
                                      # (string, default="")
-keepAsync {true|false}               # Keep paths from asynchronous input
                                      # ports (bool, default=false)
-keepFlatten {true|false}             # Instruct Innovus to keep in flattened
                                      # state (bool, default=true)
-keepHighFanoutPorts {true|false}     # Keep high fanout input port paths
                                      # (bool, default=true)
-keepInstInSdc {true|false}           # Keep instances which have constraints
                                      # on it (bool, default=false)
-keepLoopBack {true|false}            # Keep loop back paths
                                      # (bool, default=false)
-map {view|corner}                    # Specifies view or corner mapping
                                      # (enums={view corner}, default=view)
-maxNumInsts <value>                  # Specify the maximum number of instances
                                      # per port (used to define
                                      # high_fanout_ports) (int, default=1000)
-maxNumRegisters <value>              # Specify the maximum number of registers
                                      # per port (used to define
                                      # high_fanout_ports) (int, default=40)
-resetMap {view|corner}               # reset view or corner mapping
                                      # (enums={view corner}, default=view)
-slackDriven {true|false}             # slackDriven (bool, default=false)
-top <string>                         # Specifies view or corner name of top
                                      # design analysis (string, default="")
-quiet                                # Displays the current settings in Tcl list format only
-nonDefault                           # Displays the current settings which are not default settings