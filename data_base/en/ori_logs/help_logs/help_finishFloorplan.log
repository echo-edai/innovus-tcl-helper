Usage: finishFloorplan [-help] [-mask <integer>] { [[-autoHalo | [-autoHaloBasedOnPitch [-margin <float>]] | -addHalo <float> | [-fillPlaceBlockage <string> [-density <string>] [-excludeFlops ] [-deadArea <float>] [-honor_placement_density ]] | [-fillRouteBlockage <float> [-layer <string>] [-cutLayer <string>] [-fills | -exceptFill ] [-exceptpgnet ] [-spacing <float> | -designRuleWidth <float>] [-deadArea <float>]] | -addCornerBlockage <string> | [-drcRegionLayer <string> [-edgeExtend {x y}] [-edgeShrink {x y}] ] | -addCoreEOLBlockage | -addBoundaryBlockage | -addRowBasedRegionBlockage | -undo ] [-area {x1 y1 x2 y2}] [-namePrefix <string>] ]}

-help                                  # Prints out the command usage
-addBoundaryBlockage                   # add boundary routing blockages
                                       # (bool, optional)
-addCoreEOLBlockage                    # add core end-of-line(EOL) blockages
                                       # (bool, optional)
-addCornerBlockage <string>            # <width> <height> (string, optional)
-addHalo <float>                       # <width> (float, optional)
-addRowBasedRegionBlockage             # add row based region blockages
                                       # (bool, optional)
-area {x1 y1 x2 y2}                    # {x1 y1 x2 y2} (box, optional)
-autoHalo                              # auto add halo (bool, optional)
-autoHaloBasedOnPitch                  # auto add halo based on pitch
                                       # (bool, optional)
-cutLayer <string>                     # specify routeblkg's cutLayerId
                                       # (string, optional)
-deadArea <float>                      # <maxDeadArea>, maximum value of dead
                                       # area (float, optional)
-density <string>                      # <value>, only for partial place blkg
                                       # (string, optional)
-designRuleWidth <float>               # <width> (float, optional)
-drcRegionLayer <string>               # region layer name list
                                       # (string, optional)
-edgeExtend {x y}                      # extend drc region from edges
                                       # (point, optional)
-edgeShrink {x y}                      # shrink drc region from edges
                                       # (point, optional)
-exceptFill                            # set 'exceptFill' attribute. Specifies
                                       # that the routing blockage is to be
                                       # applied to other all net routings but
                                       # not on metal fills (bool, optional)
-exceptpgnet                           # specify if routeblkg exceptPGNet
                                       # (bool, optional)
-excludeFlops                          # flops and latches are excluded from
                                       # the partial placement blockage
                                       # (bool, optional)
-fillPlaceBlockage <string>            # <type> <maxGap> (string, optional)
-fillRouteBlockage <float>             # <maxGap> (float, optional)
-fills                                 # specify if routeblkg is fill
                                       # (bool, optional)
-honor_placement_density               # add std cell density check when adding
                                       # placement blockage (bool, optional)
-layer <string>                        # specify routeblkg's layerId
                                       # (string, optional)
-margin <float>                        # margin for halo based on pitch
                                       # (float, optional)
-mask <integer>                        # specify the mask number when adding
                                       # routing blockages and creating DRC
                                       # region (int, optional)
-namePrefix <string>                   # <name> (string, optional)
-spacing <float>                       # <spaceValue> (float, optional)
-undo                                  # undo recent action (bool, optional)