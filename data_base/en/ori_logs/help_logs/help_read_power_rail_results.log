Usage: read_power_rail_results [-help] [-cell_library <cell lib file>]
                               [-custom_value_inst_file_1 <file>]
                               [-data_type {rail all increment_power}]
                               [-detail_delta_temperature_file <file>]
                               [-effective_resistance_file <file>]
                               [-enable_plots {names}] [-esd_directory <dir>]
                               [-esd_rj <name>] [-force]
                               [-instance_delta_temperature_file <file>]
                               [-instance_voltage_method { best worst avg worstavg worstslidingavg bestslidingavg}]
                               [-instance_voltage_window {timing whole}]
                               [-instances {names}] [-nets {names}]
                               [-power_directory <dir>]
                               [-profiling_power_file <file>] [-reset]
                               [-sem_db <file>] [-short_file <file>]
                               [-suppress_message] [-thermal_file <file>]
                               [-tile_delta_temperature_file <file>]
                               [-tile_thermal_config_file <file>] [ -physical_db <dir> [-top_cell_name <name>]] [ -top_cell_name <name> [-physical_db <dir>]] [ -power_db <file> ] [ -rail_directory <dir> [-die_instance_name <name>]]

-help                                 # Prints out the command usage
-cell_library <cell lib file>         # specify a cell library when load state
                                      # directory (string, optional)
-custom_value_inst_file_1 <file>      # Customized file. (string, optional)
-data_type {rail all increment_power} # Loading data type . (enum, optional)
-detail_delta_temperature_file <file> # Detail temperature file. Required for
                                      # ddt plot (string, optional)
-die_instance_name <name>             # die instance name (string, optional)
-effective_resistance_file <file>     # Effective Resistance file by
                                      # analyze_resistance. Required for effr
                                      # plot (string, optional)
-enable_plots {names}                 # List of plots (string, optional)
-esd_directory <dir>                  # load esd directory (string, optional)
-esd_rj <name>                        # esd rj name (string, optional)
-force                                # Force resetting rail and power
                                      # directory (bool, optional)
-instance_delta_temperature_file <file>    # Instance delta temperature file.
                                           # Required  for idt plot
                                           # (string, optional)
-instance_voltage_method { best worst avg worstavg worstslidingavg bestslidingavg}
                                      # IV Method type : best worst avg
                                      # worstavg worstslidingavg
                                      # bestslidingavg. (string, optional)
-instance_voltage_window {timing whole}    # timing or whole window.
                                           # (string, optional)
-instances {names}                    # List of instances (string, optional)
-nets {names}                         # List of nets (string, optional)
-physical_db <dir>                    # hierarchy db directory. This option
                                      # would trigger 'read_hier_design'
                                      # (string, optional)
-power_db <file>                      # power.db file generate by power
                                      # calculator. If not specified, program
                                      # will use power stored in memory.
                                      # (string, optional)
-power_directory <dir>                # load power directory.
                                      # (string, optional)
-profiling_power_file <file>          # profiling_power_file (*.rpt.density)
                                      # generated ty power calculator. Gui can
                                      # use it to form ptpd plot
                                      # (string, optional)
-rail_directory <dir>                 # load state directory. The state
                                      # directory must have <net>.mhdr file
                                      # (string, optional)
-reset                                # Free the rail and power directory
                                      # (bool, optional)
-sem_db <file>                        # Signal EM DB file (.db)
                                      # (string, optional)
-short_file <file>                    # load short file (string, optional)
-suppress_message                     # Suppress exception messagebox
                                      # (bool, optional)
-thermal_file <file>                  # Thermal file (string, optional)
-tile_delta_temperature_file <file>   # Tile delta temperature file. Required
                                      # for tdt plot (string, optional)
-tile_thermal_config_file <file>      # Thermal file. Required for tile_thermal
                                      # plot (string, optional)
-top_cell_name <name>                 # top cell name. This option would
                                      # trigger 'read_hier_design, need to
                                      # group with -physical_db.
                                      # (string, optional)