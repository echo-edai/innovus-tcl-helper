Usage: delete_feedthru_buffer [-help] [-dontDelDanglingPort]
                              [-non_preferred_keep_nets <netNamePattern>]
                              [-preferred_keep_nets <netNamePattern>] {{-bufInst <bufInstName>} | {-instPrefix <instPrefixName>}}

-help                                     # Prints out the command usage
-bufInst <bufInstName>                    # Specify the feedthrough buffer
                                          # name. (string, optional)
-dontDelDanglingPort                      # This option has no parameters and
                                          # can be used if user don not want
                                          # remove dangling ports created by
                                          # this command. Default value is off
                                          # (bool, optional)
-instPrefix <instPrefixName>              # Specify the feedthrough buffer
                                          # prefix name. All buffers with this
                                          # prefix will be removed.
                                          # (string, optional)
-non_preferred_keep_nets <netNamePattern>
                                          # Specify the non-preferred keep net
                                          # name pattern, the net driving or
                                          # driven by the non-preferred net
                                          # will be drigarded by buffer
                                          # deletion (string, optional)
-preferred_keep_nets <netNamePattern>     # Specify the preferred keep net name
                                          # pattern, the net driving or driven
                                          # by the preferred net will be used
                                          # by buffer deletion (string, optional)