Usage: verify_drc [-help] [-area {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...}]
                  [-check_illegal_trim_shapes]
                  [-check_ndr_spacing {true | false | auto}]
                  [-check_only {all | regular | special | selected_net | selected | cell | default}]
                  [-check_reverse] [-check_routing_halo] [-check_same_via_cell]
                  [-check_short_only] [-check_trim_length] [-check_uncolored]
                  [-enable_post_passive_fill_check] [-exclude_pg_net]
                  [-ignore_fill_wire] [-ignore_trial_route]
                  [-layer_range {layer1 [layer2]}] [-limit <max_error>]
                  [-report <file_name>] [-view_window]

-help                              # Prints out the command usage
-area {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...}
                                   # Specifies one or more areas to check (box_list, optional)
-check_illegal_trim_shapes         # Check illegal trim shapes.
                                   # (bool, optional)
-check_ndr_spacing {true | false | auto}
                                   # Specifies what kind of non-default rule
                                   # spacing to be checked (enum, optional)
-check_only {all | regular | special | selected_net | selected | cell | default}
                                   # Specifies what kind of shapes to be
                                   # checked. (enum, optional)
-check_reverse                     # report CONVEXCORNER REVERSE violation.
                                   # (bool, optional)
-check_routing_halo                # Check routing halo. (bool, optional)
-check_same_via_cell               # Check the cut spacing from the same via
                                   # (bool, optional)
-check_short_only                  # Exclude all DRC check except short.
                                   # (bool, optional)
-check_trim_length                 # Consider max length in the trim shape
                                   # layer. (bool, optional)
-check_uncolored                   # report color change violation when the dpt
                                   # layer shape is free color. (bool, optional)
-enable_post_passive_fill_check    # Check full fill trim. (bool, optional)
-exclude_pg_net                    # Excludes the checking of power and ground
                                   # nets. (bool, optional)
-ignore_fill_wire                  # Ignore metalfill wires when check drc.
                                   # (bool, optional)
-ignore_trial_route                # Ignore trial route when check drc.
                                   # (bool, optional)
-layer_range {layer1 [layer2]}     # Checks between the range of metal layers
                                   # including cut layers in between
                                   # (string, optional)
-limit <max_error>                 # Specifies the maximum number of errors to
                                   # report (int, optional)
-report <file_name>                # Specifies the report file that contains
                                   # the violations informations
                                   # (string, optional)
-view_window                       # Check the current window. (bool, optional)