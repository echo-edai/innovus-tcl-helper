Usage: savePartition [-help] [<partitionName {list}>] [-fplan] [-verilog] [ [-dir <dirName>] [-module_model_tag <model tag >] [ {[-noFPlan | { [-noNetlist ] [-savePlacement ] }] [-def_netlist_for_eco | {[-def [-savePlacement ]]}] [ -defNoCutRow ] [-ptnSite ] [-topLevelNoPtnModule ] } | { { [-ptnLib <ptnLibName>] [-ptnView <ptnViewName>] [-topView <topViewName>] } } ] ] [ -def_no_std_cells ] [ -def_no_trial_route ]

-help                           # Prints out the command usage
<partitionName {list}>          # Specifies list of partition names
                                # (string, optional)
-def                            # Writes out the DEF file (bool, optional)
-defNoCutRow                    # Rows are not cut against placement
                                # obstructions, block halos, or power domain
                                # fence (bool, optional)
-def_netlist_for_eco            # Writes out the DEF file with unplaced netlist
                                # to be used by create_pushdown_eco
                                # (bool, optional)
-def_no_std_cells               # Do not write standard cells in def file
                                # (bool, optional)
-def_no_trial_route             # Do not write trial routed wires def file
                                # (bool, optional)
-dir <dirName>                  # Directory name for partition files
                                # (string, optional)
-fplan                          # Write out incremental floorplan
                                # (bool, optional)
-module_model_tag <model tag >  # Specifies module model tag to be used
                                # (string, optional)
-noFPlan                        # Do not generates a floorplan file
                                # (bool, optional)
-noNetlist                      # Do not generates a netlist file
                                # (bool, optional)
-ptnLib <ptnLibName>            # Specifies an OpenAccess database library
                                # directory (string, optional)
-ptnSite                        # Outputs sites for partitions in the LEF file
                                # (bool, optional)
-ptnView <ptnViewName>          # Specifies view name (string, optional)
-savePlacement                  # Save placement (bool, optional)
-topLevelNoPtnModule            # Suppresses stub verilog modules for
                                # partitions in the top-level partition netlist
                                # (bool, optional)
-topView <topViewName>          # Specifies view name for top design
                                # (string, optional)
-verilog                        # save design as non-binary verilog file
                                # (bool, optional)