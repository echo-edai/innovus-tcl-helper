Usage: get_proto_design_mode [-help] [-cover_fixed_macros] [-effort]
                             [-flexmodel_constraint_type] [-keep_guide]
                             [-place_macro] [-remove_overlap]
                             [-quiet] [-nonDefault]

-help                                      # Prints out the command usage
-cover_fixed_macros                        # force flexModel cover fixed macros
                                           # belong to it when using new
                                           # planDesign algorithm
                                           # (bool, default=false)
-effort                                    # Specifies proto_design effort
                                           # (enums={low medium high}, default=low)
-flexmodel_constraint_type                 # Convert flexModel to the specified
                                           # constraint type in proto_design.
                                           # (enums={guide region fence}, default=region)
-keep_guide                                # -keep_guide {true|false}
                                           # #default=true (bool, default=true)
-place_macro                               # control if do macro placement in
                                           # planDesign (bool, default=true)
-remove_overlap                            # control if do remove overlap in
                                           # planDesign (bool, default=true)
-quiet                                     # Displays the current settings in Tcl list format only
-nonDefault                                # Displays the current settings which are not default settings