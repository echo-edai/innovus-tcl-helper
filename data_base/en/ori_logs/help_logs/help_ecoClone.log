Usage: ecoClone [-help] [-allow_sequential] [-balance <num>]
                [-delete_buffer_trees] [-dont_legalize] [-dont_resize] [-force]
                [-loop <num>] [-max_levels <integer>] [-max_num_loads <integer>]
                [-preview] [-radius <num>] [-same_hier_only] [-verbose]
                [-instances <inst>+ | -nets <net>+ | -to <instTerm|term>+] []
                [-numClones <num> | -to <instTerm|term>+]
                [-numClones <num> | -from <instTerm|term>+]
                [-auto | -cells <libCell/ptnCell>+] [-auto | -terms <string>]
                [-auto | -locs {{x1 y1} {x2 y2}...}]
                [-auto | -numClones <num> | -min_num_loads <integer>]
                [-instances <inst>+ | -nets <net>+ | -auto]
                [-instances <inst>+ | -nets <net>+ | -from <instTerm|term>+]

-help                        # Prints out the command usage
-allow_sequential            # for -auto to try cloning at the sequential gates
                             # too. (bool, optional)
-auto                        # applies cloning and buffering automatically.
                             # (bool, optional)
-balance <num>               # force the number of loads on each clone to be
                             # within <num>%; default balance is 10%.
                             # (int, optional)
-cells <libCell/ptnCell>+    # Cell or cells to use for the clones.
                             # ((libCell/ptnCell)+, optional)
-delete_buffer_trees         # attempt to delete buffer trees driven by
                             # instances to clone. (bool, optional)
-dont_legalize               # may leave cloned instances overlapped with the
                             # original ones. (bool, optional)
-dont_resize                 # do not resize the original nor new instances.
                             # (bool, optional)
-force                       # force instance cloning, even if it worsens QoR
                             # or causes illegal placement. (bool, optional)
-from <instTerm|term>+       # Specified from pins.
                             # ((instTerm|term)+, optional)
-instances <inst>+           # Only analyze these instances.
                             # ((inst)+, optional)
-locs {{x1 y1} {x2 y2}...}   # locations of clones, when numClone is given. if
                             # the list has numClone+1 locations, then the
                             # first one is for the original gate.
                             # (point_list, optional)
-loop <num>                  # repeat cloning at most <num> times, as far as
                             # new instances are being created; original and
                             # new instances within the min/max number of loads
                             # range are valid targets at each iteration.
                             # Default 0, means no limit. (int, optional)
-max_levels <integer>        # traverse back from 'to' at most these many
                             # levels. Default 0 (meaning infinite).
                             # (int, optional)
-max_num_loads <integer>     # skip cloning instances driving more than these
                             # many loads. Default 50000. (int, optional)
-min_num_loads <integer>     # clone instances driving at least these many
                             # loads. (int, optional)
-nets <net>+                 # Only analyze these nets. ((net)+, optional)
-numClones <num>             # specifies the number of clones. (int, optional)
-preview                     # show what would be done, but leave netlist
                             # untouched. (bool, optional)
-radius <num>                # place clones within a radius of <num> rows from
                             # its preferred location based on original
                             # instance location and center of mass of new set
                             # of loads. Default 10. (int, optional)
-same_hier_only              # only consider loads in the same hierarchy as the
                             # driver. (bool, optional)
-terms <string>              # clusters through a list of term lists. The list
                             # is parallel to loc list (string, optional)
-to <instTerm|term>+         # Specified to pins. ((instTerm|term)+, optional)
-verbose                     # display extra information about what is going
                             # on. (bool, optional)