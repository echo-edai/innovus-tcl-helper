Usage: adjustFPlanChannel [-help] [-channelUtil <float>]
                          [-constraints <constraint_file>] [-moveOnly]
                          [-report <output_file>] [-reportOnly [-report_low_utilized_channels <float>] [-type {all fenceToFence fenceToCore fenceToMacro macroToMacro macroToCore}]]

-help                                     # Prints out the command usage
-channelUtil <float>                      # maximum utilization of routing
                                          # tracks in channel (float, optional)
-constraints <constraint_file>            # file to specify constraints for
                                          # floorplan objects (string, optional)
-moveOnly                                 # allow move-only adjustment
                                          # (bool, optional)
-report <output_file>                     # default name <topcell>.channel,
                                          # output the channel congestion,
                                          # targeted channel adjustment, and
                                          # final real floorplan adjustment
                                          # (string, optional)
-reportOnly                               # only report channel congestion, no
                                          # adjustment (bool, optional)
-report_low_utilized_channels <float>     # only report channel congestion with
                                          # low utilization
                                          # (float, optional, min=0, max=1)
-type {all fenceToFence fenceToCore fenceToMacro macroToMacro macroToCore}
                                          # report channel congestion with
                                          # specified types (enum_list, optional)