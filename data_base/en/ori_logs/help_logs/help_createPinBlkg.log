Usage: createPinBlkg [-help] [-cell <string>] [-layer {layerIdList}] { -area {x1 y1 x2 y2} | [-edge <integer> [[-offset_start <float>] [-offset_end <float>]]] | [-abutted_master_clone_channel_access_only  [-feedthru_blockage_file <file_name>]] } [ -name <string> [ -includePinPatterns {pinNamePatternList} | -excludePinPatterns {pinNamePatternList} ]]

-help                                   # Prints out the command usage
-abutted_master_clone_channel_access_only
                                        # Create pin blockages on abutted edges
                                        # of master-clones that abut to its
                                        # parent or other master-clones.
                                        # (bool, optional)
-area {x1 y1 x2 y2}                     # Specifies the lower left x ,lower
                                        # left y,upper right x, and upper right
                                        # y coordinate of the blockage area.
                                        # (box, optional)
-cell <string>                          # Specifies the name of the module.The
                                        # module name is not required if the
                                        # command is run on a top-level module.
                                        # (string, optional)
-edge <integer>                         # Specifies the integer value where
                                        # edge numbering starts from lower-left
                                        # corner of a partition clock-wise.
                                        # (int, optional)
-excludePinPatterns {pinNamePatternList}
                                        # Specifies the pin-list on which this
                                        # pin-blockage is not applicable. Pins
                                        # which are specified in this list can
                                        # be placed in this area legally.
                                        # (string, optional)
-feedthru_blockage_file <file_name>     # Output a file with coordinates of
                                        # blocked edges for pin assignment
                                        # transformed into feedthru
                                        # blockage_file format. (string, optional)
-includePinPatterns {pinNamePatternList}
                                        # Specifies the pin-list on which this
                                        # pin-blockage is applicable. All other
                                        # pins can be placed in this area
                                        # legally. (string, optional)
-layer {layerIdList}                    # Specifies the layer(s) for which the
                                        # pin blockage is specified.
                                        # (string, optional)
-name <string>                          # Specifies the name of the partition
                                        # pin blockage. (string, optional)
-offset_end <float>                     # Specify a distance in microns from
                                        # ending corner of the edge.
                                        # (float, optional, min=0, max=65535)
-offset_start <float>                   # Specify a distance in microns from
                                        # starting corner of the edge.
                                        # (float, optional, min=0, max=65535)