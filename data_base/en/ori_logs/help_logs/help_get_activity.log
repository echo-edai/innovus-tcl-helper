Usage: get_activity [-help] [-instance <string>]
                    [-list_of_nets_based_on_driver <string>]
                    [-list_of_nets_based_on_source_of_activity_info <string>]
                    [-net <string>] [-outfile <string>] [-pin <string>]
                    [-port <string>] [-report_average_switching_activity]
                    [-report_cell_group_activity_summary_report] [-summary]
                    [-tcl_list]

-help                                      # Prints out the command usage
-instance <string>                         # instance name (string, optional)
-list_of_nets_based_on_driver <string>     # list of nets based on driver
                                           # (string, optional)
-list_of_nets_based_on_source_of_activity_info <string>
                                           # list of nets based on source of
                                           # activity info (string, optional)
-net <string>                              # net list to get activity source
                                           # (string, optional)
-outfile <string>                          # output file (string, optional)
-pin <string>                              # pin list to get activity source
                                           # (string, optional)
-port <string>                             # port list to get activity source
                                           # (string, optional)
-report_average_switching_activity         # report average switching activity
                                           # (bool, optional)
-report_cell_group_activity_summary_report
                                           # generate summary report of cell
                                           # group activity (bool, optional)
-summary                                   # turn on type summary
                                           # (bool, optional)
-tcl_list                                  # return tcl list (bool, optional)