Usage: restoreDesign [-help] [<design>] [-dynamic_view <string>]
                     [-hold_views <string>] [-leakage_view <string>]
                     [-lef_tech_file_map <string>] [-noBinaryConstraint]
                     [-noTiming] [-readGlobals <string>] [-setup_views <string>] [{{<session>} | {-cellview <string>}} [-mmmcFile <string>] [-lef_files <list_of_files>] ] [ -noTimingGraph ]

-help                          # Prints out the command usage
<session>                      # Specifies the design directory
                               # (string, optional)
<design>                       # Specifies the top cell name (string, optional)
-cellview <string>             # {<libname> <cellname> <viewname>}
                               # (string, optional)
-dynamic_view <string>         # Specifies the analysis_view for dynamic power
                               # analysis (string, optional)
-hold_views <string>           # Specifies the hold views for loading
                               # (string, optional)
-leakage_view <string>         # Specifies the analysis_view for leakage power
                               # analysis (string, optional)
-lef_files <list_of_files>     # Specifies LEF files for loading if want to
                               # override the existing LEF files in the design
                               # being restored and load different LEF files
                               # instead (string, optional)
-lef_tech_file_map <string>    # LEF-QRCTechfile layer map file
                               # (string, optional)
-mmmcFile <string>             # Specifies the path name to a
                               # viewDefinition.tcl (MMMC) file (string, optional)
-noBinaryConstraint            # Specify not to load binary timing constraint
                               # .tcz file even it's saved to disk in previous
                               # session. (bool, optional)
-noTiming                      # Disables reading timing libraries and
                               # constraints during the restore design process
                               # (bool, optional)
-noTimingGraph                 # Specifies not to load timing graph even it's
                               # saved to disk in previous session
                               # (bool, optional)
-readGlobals <string>          # Specifies the UDM variables to be honored when
                               # restoring the design. User should provide a
                               # tcl file stating the pre-defined UDM variable
                               # names to be honored. (string, optional)
-setup_views <string>          # Specifies the setup views for loading
                               # (string, optional)