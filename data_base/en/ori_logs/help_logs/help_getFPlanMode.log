Usage: getFPlanMode [-help] [-autoSyncMasterClone] [-cellsForExtraSites]
                    [-checkTypes] [-cutOffPlaceBlockageOutsideDie]
                    [-cutOffRouteBlockageOutsideDie]
                    [-defaultBlockageNamePrefix] [-defaultPowerDomainSite]
                    [-defaultRowPatternSite] [-defaultTechSite]
                    [-enableRectilinearDesign] [-extraRowPattern] [-extraSites]
                    [-firstRowSiteIndex] [-includeIoWhenInitArea]
                    [-initAllCompatibleCoreSiteRows]
                    [-keepRowsWhenMovingPowerDomain] [-lastRowSiteIndex]
                    [-maxIoHeight] [-minimumSites]
                    [-move_child_constraint_with_constraint]
                    [-move_macros_with_constraint]
                    [-move_preplaced_std_cell_only]
                    [-move_std_cell_with_constraint] [-narrowChannelThreshold]
                    [-no_cut_row] [-powerRailLayer]
                    [-rowHeightIncrementCornerToCorner]
                    [-rowHeightIncrementIncornerToCorner]
                    [-rowHeightIncrementIncornerToIncorner] [-rowHeightMultiple]
                    [-rowSiteHeight] [-rowSiteWidth] [-skipViolations]
                    [-snap_all_corners_to_grid] [-snapBlockGrid]
                    [-snapConstraintGrid] [-snapCoreGrid] [-snapDieGrid]
                    [-snapIoGrid] [-snapPlaceBlockageGrid]
                    [-snapPlaceBlockageType] [-user_define_grid]
                    [-quiet] [-nonDefault]

-help                                      # Prints out the command usage
-autoSyncMasterClone                       # Specify the objects used to
                                           # sync-up master to clones.
                                           # (enums={busGuides constraints stdcells macros routeBlockages placeBlockages}_list, default="")
-cellsForExtraSites                        # Specify cell names whose related
                                           # sites will be created.
                                           # (string, default="")
-checkTypes                                # Specify the check types for
                                           # checkFPlan. Default is the basic.
                                           # (enums={basic fence oddEvenSiteRow macroPin color alignmentFollowingPin alignmentPartitionClone busGuideConnectivity feedThrough partitionInPartition multiLayerPin powerDomain partition place sameLengthSite narrowChannel blockOnly unifiedVddOnBottom tsv exclusiveGroup all}_list, default=basic)
-cutOffPlaceBlockageOutsideDie             # When creating placement blockages,
                                           # will cut the part outside of die
                                           # and snap it by default.
                                           # (bool, default=true)
-cutOffRouteBlockageOutsideDie             # When creating routing blockages
                                           # around inst/Hinst/Partition, will
                                           # cut the part outside of die and
                                           # snap it by default. If this option
                                           # is set to false, don't cut and
                                           # snap it. (bool, default=true)
-defaultBlockageNamePrefix                 # Name prefix for placement blockage
                                           # and routing blockage.
                                           # (string, default="")
-defaultPowerDomainSite                    # Create rows based on default power
                                           # domain site instead of the
                                           # design's default site.
                                           # (bool, default=false)
-defaultRowPatternSite                     # Specify rows pattern.
                                           # (string, default="")
-defaultTechSite                           # Specify a site as default
                                           # technical site. After setting a
                                           # forced one, the auto-calculating
                                           # default-technical-site
                                           # functionality will be disabled.
                                           # (string, default="")
-enableRectilinearDesign                   # Specify whether design boundary
                                           # can be changed to rectilinear
                                           # shape. (bool, default=false)
-extraRowPattern                           # Specify row pattern site names
                                           # which will be created.
                                           # (string, default="")
-extraSites                                # Specify site names which will be
                                           # created. (string, default="")
-firstRowSiteIndex                         # Specify the first row site to be
                                           # created. (int, default=0)
-includeIoWhenInitArea                     # Include IO cells when calculating
                                           # the area of modules.
                                           # (bool, default=false)
-initAllCompatibleCoreSiteRows             # If true, initCoreRow will create
                                           # all SITE with type core. 
                                           # (bool, default=false)
-keepRowsWhenMovingPowerDomain             # specify whether to keep all
                                           # existing rows in disjoint power
                                           # domain when moving, resizing or
                                           # reshaping a power domain on GUI or
                                           # by command.  (bool, default=false)
-lastRowSiteIndex                          # Specify the last row site to be
                                           # created. (int, default=-1)
-maxIoHeight                               # Use maximum IO height to calculate
                                           # a die box with IO placement. By
                                           # default, minimum IO height is
                                           # used. (bool, default=false)
-minimumSites                              # Specify the number of minimal
                                           # sites (N) that checkFPlan will
                                           # check for the same length site
                                           # rule. When sameLengthSite is
                                           # specified in checkTypes, this
                                           # option is required. (int, default=0)
-move_child_constraint_with_constraint     # Specify child constraints move
                                           # with parent constraint modules at
                                           # the same time. (bool, default=false)
-move_macros_with_constraint               # Specify macros move with
                                           # constraint modules at the same
                                           # time.
                                           # (enums={guide region fence none all}_list, default=fence)
-move_preplaced_std_cell_only              # Specify only pre-placed std cells
                                           # move with constraint modules at
                                           # the same time. (bool, default=false)
-move_std_cell_with_constraint             # Specify std cells move with
                                           # constraint modules at the same
                                           # time.
                                           # (enums={guide region fence none all}_list, default=none)
-narrowChannelThreshold                    # Reports narrow channels whose
                                           # width (in micros) is smaller than
                                           # the specified value. When
                                           # narrowChannel is specified in
                                           # checkTypes, this option is
                                           # required. (float, default=0)
-no_cut_row                                # Specify no need to do cut row
                                           # before other operations.
                                           # (bool, default=false)
-powerRailLayer                            # Specify the layers for calculating
                                           # power/ground on bottom attribute
                                           # of cell or techsite. By default,
                                           # the lowest metal layer is used.
                                           # (string, default="")
-rowHeightIncrementCornerToCorner          # Specify the offset value for user
                                           # defined row height constraint with
                                           # corner to corner edge.
                                           # (int, default=0)
-rowHeightIncrementIncornerToCorner        # Specify the offset value for user
                                           # defined row height constraint with
                                           # incorner to corner edge.
                                           # (int, default=0)
-rowHeightIncrementIncornerToIncorner      # Specify the offset value for user
                                           # defined row height constraint with
                                           # incorner to incorner edge.
                                           # (int, default=0)
-rowHeightMultiple                         # Specify the pitch value for user
                                           # defined row height constraint.
                                           # (int, default=0)
-rowSiteHeight                             # Specify the odd even row height
                                           # constraints.
                                           # (enums={any odd even computed}, default=any)
-rowSiteWidth                              # Specify the odd even row width
                                           # constraints.
                                           # (enums={any odd even}, default=any)
-skipViolations                            # Specify message ID then the
                                           # message will be not reported and
                                           # shown in violation browser. (list,
                                           # optional) (string, default="")
-snap_all_corners_to_grid                  # Specify to snap all corners of
                                           # object to grid. (bool, default=false)
-snapBlockGrid                             # Specify the block snap rules. It
                                           # can be set to snap to manufacture
                                           # grid, instance grid, placement
                                           # grid, user-define grid, layerTrack
                                           # grid, finfet manufacture grid,
                                           # finfet instance grid, finfet
                                           # placement grid. The default is
                                           # manufacturingGrid. For Finfet
                                           # design, the default is
                                           # finfetManufacturingGrid.
                                           # (enums={manufacturing inst placement userDefine LayerTrack finfetInst finfetManufacturing finfetPlacement}, default=manufacturing)
-snapConstraintGrid                        # Specify the constraint snap rules.
                                           # It can be set to snap to
                                           # manufacture grid, instance grid,
                                           # placement grid, user-define grid,
                                           # layerTrack grid, finfet
                                           # manufacture grid, finfet instance
                                           # grid, finfet placement grid. The
                                           # default is instGrid. For Finfet
                                           # design, the default is
                                           # finfetInstGrid.
                                           # (enums={manufacturing inst placement userDefine LayerTrack finfetInst finfetManufacturing finfetPlacement}, default=inst)
-snapCoreGrid                              # Specify the core snap rules. It
                                           # can be set to snap to manufacture
                                           # grid, instance grid, placement
                                           # grid, user-define grid, layerTrack
                                           # grid, finfet manufacture grid,
                                           # finfet instance grid, finfet
                                           # placement grid. The default is
                                           # placementGrid. For Finfet design,
                                           # the default is
                                           # finfetPlacementGrid.
                                           # (enums={manufacturing inst placement userDefine LayerTrack finfetInst finfetManufacturing finfetPlacement}, default=placement)
-snapDieGrid                               # Specify the die snap rules. It can
                                           # be set to snap to manufacture
                                           # grid, instance grid, placement
                                           # grid, user-define grid, layerTrack
                                           # grid, finfet manufacture grid,
                                           # finfet instance grid, finfet
                                           # placement grid. The default is
                                           # placementGrid. For Finfet design,
                                           # the default is
                                           # finfetPlacementGrid.
                                           # (enums={manufacturing inst placement userDefine LayerTrack finfetInst finfetManufacturing finfetPlacement}, default=placement)
-snapIoGrid                                # Specify the IO snap rules. It can
                                           # be set to snap to manufacture
                                           # grid, instance grid, placement
                                           # grid, user-define grid, layerTrack
                                           # grid, finfet manufacture grid,
                                           # finfet instance grid, finfet
                                           # placement grid. The default is
                                           # manufacturingGrid. For Finfet
                                           # design, the default is
                                           # finfetManufacturingGrid.
                                           # (enums={manufacturing inst placement userDefine LayerTrack finfetInst finfetManufacturing finfetPlacement}, default=manufacturing)
-snapPlaceBlockageGrid                     # Specify the placement blockage
                                           # snap rules. The default is inst.
                                           # (enums={manufacturing inst userDefine}, default=inst)
-snapPlaceBlockageType                     # Specify the snapping type.
                                           # (enums={closest upsize sequential}, default=closest)
-user_define_grid                          # Specify the user-define grid.
                                           # Format is {x_offset y_offset
                                           # x_pitch y_pitch}. The x_offset
                                           # y_offset is the offset of
                                           # user-define grid. The x_pitch
                                           # separates the vertical grid lines.
                                           # The y_pitch separates the
                                           # horizontal grid lines. The values
                                           # are in microns.
                                           # (box, default={0 0 0 0})
-quiet                                     # Displays the current settings in Tcl list format only
-nonDefault                                # Displays the current settings which are not default settings