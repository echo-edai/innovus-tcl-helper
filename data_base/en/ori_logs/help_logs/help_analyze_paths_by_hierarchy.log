Usage: analyze_paths_by_hierarchy [-help] [-master <string>] {{-fp_file <string> [-include_macros ]} | {-use_current_floorplan  [-all ] [-types <string>] [-port2port ] [-port2macro ] [-port2bbox ] [-port2hinst ] [-port2stdcell ] [-port2instgrp ] [-macro2port ] [-macro2macro ] [-macro2bbox ] [-macro2hinst ] [-macro2stdcell ] [-macro2instgrp ] [-bbox2port ] [-bbox2macro ] [-bbox2bbox ] [-bbox2hinst ] [-bbox2stdcell ] [-bbox2instgrp ] [-hinst2port ] [-hinst2macro ] [-hinst2bbox ] [-hinst2hinst ] [-hinst2stdcell ] [-hinst2instgrp ] [-stdcell2port ] [-stdcell2macro ] [-stdcell2bbox ] [-stdcell2hinst ] [-stdcell2stdcell ] [-stdcell2instgrp ] [-instgrp2port ] [-instgrp2macro ] [-instgrp2bbox ] [-instgrp2hinst ] [-instgrp2stdcell ] [-instgrp2instgrp ]} | {-partitions <string> | -macros <string>}}

-help                      # Prints out the command usage
-all                       # Creates categories of paths within all types.
                           # Default: All types are categorized. (bool, optional)
-bbox2bbox                 # Creates categories of paths from black box to
                           # black box. (bool, optional)
-bbox2hinst                # Creates categories of paths from black box to
                           # hierarchical instance. (bool, optional)
-bbox2instgrp              # Creates categories of paths from black box to
                           # instance group. (bool, optional)
-bbox2macro                # Creates categories of paths from black box to
                           # macro. (bool, optional)
-bbox2port                 # Creates categories of paths from black box to
                           # port. (bool, optional)
-bbox2stdcell              # Creates categories of paths from black box to
                           # standard cell. (bool, optional)
-fp_file <string>          # Specifies the name of the floorplan file. Default:
                           # Uses the current floorplan file. (string, required)
-hinst2bbox                # Creates categories of paths from hierarchical
                           # instance to black box. (bool, optional)
-hinst2hinst               # Creates categories of paths from instance group to
                           # hierarchical instance. (bool, optional)
-hinst2instgrp             # Creates categories of paths from hierarchical
                           # instance to instance group. (bool, optional)
-hinst2macro               # Creates categories of paths from hierarchical
                           # instance to macro. (bool, optional)
-hinst2port                # Creates categories of paths from hierarchical
                           # instance to port. (bool, optional)
-hinst2stdcell             # Creates categories of paths from hierarchical
                           # instance to standard cell. (bool, optional)
-include_macros            # Includes macros in addition to guides and fences
                           # for creating categories. Default: Macros are not
                           # considered. (bool, optional)
-instgrp2bbox              # Creates categories of paths from instance group to
                           # black box. (bool, optional)
-instgrp2hinst             # Creates categories of paths from instance group to
                           # hierarchical instance. (bool, optional)
-instgrp2instgrp           # Creates categories of paths from instance group to
                           # instance group. (bool, optional)
-instgrp2macro             # Creates categories of paths from instance group to
                           # macro. (bool, optional)
-instgrp2port              # Creates categories of paths from instance group to
                           # port. (bool, optional)
-instgrp2stdcell           # fCreates categories of paths from instance group
                           # to standard cell. (bool, optional)
-macro2bbox                # Creates categories of paths from macro to black
                           # box. (bool, optional)
-macro2hinst               # Creates categories of paths from macro to
                           # hierarchical instance. (bool, optional)
-macro2instgrp             # Creates categories of paths from macro to instance
                           # group. (bool, optional)
-macro2macro               # Creates categories of paths from macro to macro.
                           # (bool, optional)
-macro2port                # Creates categories of paths from macro to port.
                           # (bool, optional)
-macro2stdcell             # Creates categories of paths from macro to standard
                           # cell. (bool, optional)
-macros <string>           # Specifies the names of the macros to be used.
                           # (string, required)
-master <string>           # Specifies that the timing paths should be
                           # categorized only for the specified master
                           # category. (string, optional)
-partitions <string>       # Specifies the names of the partitions to consider
                           # for extracting hierarchical information.
                           # (string, required)
-port2bbox                 # Creates categories of paths from port to black
                           # box. (bool, optional)
-port2hinst                # Creates categories of paths from port to
                           # hierarchical instance. (bool, optional)
-port2instgrp              # Creates categories of paths from port to instance
                           # group. (bool, optional)
-port2macro                # Creates categories of paths from port to macro.
                           # (bool, optional)
-port2port                 # Creates categories of paths from port to port.
                           # (bool, optional)
-port2stdcell              # Creates categories of paths from port to std cell.
                           # (bool, optional)
-stdcell2bbox              # Creates categories of paths from standard cell to
                           # black box. (bool, optional)
-stdcell2hinst             # Creates categories of paths from standard cell to
                           # hierarchical instance. (bool, optional)
-stdcell2instgrp           # Creates categories of paths from standard cell to
                           # instance group. (bool, optional)
-stdcell2macro             # Creates categories of paths from standard cell to
                           # macro. (bool, optional)
-stdcell2port              # Creates categories of paths from standard cell to
                           # port. (bool, optional)
-stdcell2stdcell           # Creates categories of paths from standard cell to
                           # standard cell. (bool, optional)
-types <string>            # Creates categories of paths within the type_list.
                           # Valid types are: port , macro , bbox , hinst
                           # ,stdcell. (string, required)
-use_current_floorplan     # Uses the current floorplan. (bool, required)