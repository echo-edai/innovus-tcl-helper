Usage: report_annotated_check [-help] [<instance_list>]
                              [-check_type <check_type_list>] [-list_annotated]
                              [-list_non_annotated] [-max_line <number>]
                              [-tcl_list] [-view <view_name>]
                              [> <filename[.gz]>] [>> <filename[.gz]>]

-help                             # Prints out the command usage
<instance_list>                   # Limits the reporting to specified instances
                                  # (string, optional)
-check_type <check_type_list>     # Limits the report to the type of check(s)
                                  # in the check_type_list. Valid types are:
                                  # setup, hold, pulse_width, recovery,
                                  # removal, etc.  (string, optional)
-list_annotated                   # Lists the detailed annotation information
                                  # of each check_types (bool, optional)
-list_non_annotated               # Lists the timing checks that do not have
                                  # annotated delay information (bool, optional)
-max_line <number>                # Limits the number of entries reported by
                                  # list_annotated or list_non_annotated
                                  # (int, optional)
-tcl_list                         # Produces the report in Tcl list format
                                  # instead of a tabular format (bool, optional)
-view <view_name>                 # Generates a timing check report for the
                                  # specified analysis view only. By default
                                  # all active views are reported
                                  # (string, optional)
> <filename[.gz]>                 # Redirects output to specified file
                                  # (redirect_operator, optional)
>> <filename[.gz]>                # Redirects output to specified file
                                  # (redirect_operator, optional)