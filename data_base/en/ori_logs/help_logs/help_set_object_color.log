Usage: set_object_color [-help] {[-object_name <InstOrHInstName> | -object_type <typeList>] [-multicolor  | -color_id <colorID>] [-include_children {off color multicolor}] [-reset ]}

-help                              # Prints out the command usage
-color_id <colorID>                # Specifies the color ID
                                   # (int, optional, min=0, max=29)
-include_children {off color multicolor}
                                   # Option to decide whether the children of
                                   # HInst will be colored simultaneously or
                                   # not. off: The child instance will not be
                                   # colored. color: Color-code the child
                                   # instances with the color the same with
                                   # their parent instance. multicolor: Use
                                   # multiple colors to the child instances.
                                   # (enum, optional)
-multicolor                        # Use multiple colors to the objects
                                   # (bool, optional)
-object_name <InstOrHInstName>     # Specifies the Inst, Hinst, PowerDomain or
                                   # InstGroup name, it supports objects list
                                   # (string, optional)
-object_type <typeList>            # Specifies the list of objects such as SDP,
                                   # BusGuide, Module, PowerDomain, InstGroup
                                   # ... (string, optional)
-reset                             # Reset the object color (bool, optional)