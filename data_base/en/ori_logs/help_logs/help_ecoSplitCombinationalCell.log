Usage: ecoSplitCombinationalCell [-help] [-force] [-fullSplit] [-legal]
                                 [-skipRoute] {-inst <combInstName | {{Mbcb1 combCell1} {Mbcb2 combCell2}...}> | -listFile <fileName> | -all } {-preCTS  | -postCTS  | -postRoute  }

-help                                # Prints out the command usage
-all                                 # Split all MBCB instances to SBFF
                                     # instances. Default is false.
                                     # (bool, optional)
-force                               # Force to split the flip-comb regardless
                                     # timing gains. Default is false.
                                     # (bool, optional)
-fullSplit                           # set -fullSplit to completely split to
                                     # single bits. (bool, optional)
-inst <combInstName | {{Mbcb1 combCell1} {Mbcb2 combCell2}...}>
                                     # The names of the comb instance to be
                                     # splitted.
                                     # If the input is a string of MBCB/Cell
                                     # pairs list, it will split the MBCB to
                                     # the spcified Cell without evaluation
                                     # (string, required)
-legal                               # To place the split flip-comb at legal
                                     # location. Default is false.
                                     # (bool, optional)
-listFile <fileName>                 # The file containing names of MBCB
                                     # instances to split. Specify one instance
                                     # on one line. Comment with #. Instance
                                     # name should not contain spaces or
                                     # backslashes. And if Specify one instance
                                     # and one cell on one line, it will split
                                     # the MBCB to the spcified cell without
                                     # evaluation (string, required)
-postCTS                             # Set -postCTS if design stage is postCTS.
                                     # (bool, optional)
-postRoute                           # Set -postRoute if design stage is
                                     # postRoute. (bool, optional)
-preCTS                              # Set -preCTS if design stage is preCTS.
                                     # (bool, optional)
-skipRoute                           # set -skipRoute if stage is postRoute and
                                     # globalDetailRoute is not necessary after
                                     # split. (bool, optional)