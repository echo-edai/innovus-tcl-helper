Description:
writes out file for Conformal LEC

Usage: write_do_lec_innovus [-help]
                            [-checkpoint <string>] [-golden_design <string>]
                            [-log_file <string>] [-no_exit]
                            [-pre_compare <string>] [-pre_exit <string>]
                            [-pre_read <string>] [-revised_design <string>]
                            [-verbose] [-write_session <string>] [-hier  | -flat ] [<out_file> | >]

-help                       # Prints out the command usage
<out_file>                  # The name for the output file to be written.
                            # (string, optional)
-checkpoint <string>        # Name of LEC checkpoint file to save at the end.
                            # (string, optional)
-flat                       # Create a flat comparison script. (bool, optional)
-golden_design <string>     # The user-written netlist file name to use as the
                            # golden design. (string, optional)
-hier                       # Create a hierarchical comparison script.
                            # (bool, optional)
-log_file <string>          # Name of the LEC log file. (string, optional)
-no_exit                    # Skip the exit Command at end of do file.
                            # (bool, optional)
-pre_compare <string>       # An extra dofile to be sourced right before
                            # 'set_system_mode'. (string, optional)
-pre_exit <string>          # An extra dofile to be sourced right before
                            # 'exit'. (string, optional)
-pre_read <string>          # An extra dofile to be sourced right before
                            # reading library/design. (string, optional)
-revised_design <string>    # The user-written netlist file name to use as the
                            # revised design. (string, optional)
-verbose                    # Whether the generated dofile reports verbosely.
                            # (bool, optional)
-write_session <string>     # Name of LEC session to save at the end.
                            # (string, optional)
> <file>                    # The name for the output file to be written.
                            # (redirect_operator, optional)