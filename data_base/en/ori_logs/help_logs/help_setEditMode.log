-help                                    # Prints out the command usage
-reset                                   # Resets all or specified options to default value
-align {true|false}                      # Specifies whether to support align
                                         # objects. (bool, default=true)
-allow_45_degree {true|false}            # Specifies whether to allow creation
                                         # of a 45-degree wire.
                                         # (bool, default=false)
-arrow_increment <value>                 # Specifies the step increments in
                                         # microns to move wires with the arrow
                                         # keys. (float, default=1)
-assign_multi_pattern_color {auto|mask1|mask2|mask3}
                                         # Specifies how to assign the mask
                                         # color on the DPT layer of the wire
                                         # segment to be created.
                                         # (enums={auto mask1 mask2 mask3}, default=auto)
-auto_assign_net {add|copy|move}         # Auto assign the net from touched
                                         # objects to edit wires/vias. Only
                                         # enable this behavior for specified
                                         # edit function.
                                         # (enums={add copy move}_list, default=copy)
-auto_distribute_bus {true|false}        # Auto distribute a group of wires,
                                         # and set same spacing based on option
                                         # -bus_total_width_vertical or
                                         # -bus_total_width_horizontal.
                                         # (bool, default=false)
-auto_split_bus {true|false}             # Splits buses automatically to avoid
                                         # DRC violations. (bool, default=false)
-bus_honor_start_params {true|false}     # Specifies that the wire width and
                                         # spacing of the start points (pins)
                                         # should be honored when drawing
                                         # routes for a bus. (bool, default=false)
-bus_honor_width_setting {true|false}    # Specifies whether the tool should
                                         # adjust the wire width when snapping
                                         # bus wires to pin. (bool, default=false)
-bus_total_width_horizontal <value>      # This option can specify the total
                                         # width of horizontal bus. So when
                                         # tool drawing a bus, tool auto set
                                         # spacing as:wire spacing = (<total
                                         # bus width> - <total wire width>)/
                                         # (<wire number> - 1). (float, default=0)
-bus_total_width_vertical <value>        # This option can specify the total
                                         # width of vertical bus. So when tool
                                         # drawing a bus, tool auto set spacing
                                         # as:wire spacing = (<total bus width>
                                         # - <total wire width>)/ (<wire
                                         # number> - 1). (float, default=0)
-change_order_at_turn {Reverse Order | Keep Order}
                                         # Specifies whether the order of the
                                         # wires changes or stays the same when
                                         # the wire makes a 90-degree turn.
                                         # (Reverse Order | Keep Order)
                                         # (string, default=keep_order)
-check_design_boundary {true|false}      # Specifies whether stop user to
                                         # stretch the wire in the forbidden
                                         # area which defined by
                                         # -pull_back_distance.
                                         # (bool, default=false)
-circle_NDR_vias_only {true|false}       # Specifies that when the Shift + N/P
                                         # bindkey is used, the tool should
                                         # circle through NDR vias only.
                                         # (bool, default=false)
-close_polygons {true|false}             # Specifies whether to close a special
                                         # route structure toward itself.
                                         # (bool, default=false)
-color_align_with_track {true|false}     # Specifies whether the wire color is
                                         # to be changed to match the track
                                         # color during a move or copy
                                         # operation. (bool, default=false)
-connect_pin {in|out|inout|nodir}        # Specifies whether or not generate a
                                         # via on the pin for specified pin
                                         # type.
                                         # (enums={in out inout nodir}_list, default=in out inout nodir)
-connect_with_specified_layer {true|false}
                                         # Specifies whether or not the layer
                                         # of connecting wires should be
                                         # changed as per the -layer_horizontal
                                         # or -layer_vertical setting when
                                         # moving wires. (bool, default=false)
-create_crossover_vias {true|false}      # Specifies whether the software
                                         # creates a via when you draw a wire
                                         # that crosses a wire or pin of the
                                         # same net that is on a different
                                         # layer. (bool, default=true)
-create_is_edit_flag {true|false}        # Specifies whether to create isEdit
                                         # flag for wire edit
                                         # (bool, default=false)
-create_via_on_pin {true|false}          # Specifies whether the software
                                         # creates vias at pins.
                                         # (bool, default=true)
-cut_class <cut_class>                   # Specifies the cut class name of the
                                         # generated via when editing wires.
                                         # (string, default="")
-cut_wire_overlap {regular|special}      # Specifies whether or not overlaps
                                         # are created while cutting specified
                                         # type of wires.
                                         # (enums={regular special}_list, default=regular)
-debug_file <value>                      # Specifies the report file name.
                                         # (string, default="")
-delete_pin_with_wire {true|false}       # Delete Pin with Wire
                                         # (bool, default=true)
-delete_tsv {true|false}                 # Specifies whether to delete the
                                         # items on TSV layer or not.
                                         # (bool, default=false)
-delete_wire_via_deep_through {true|false}
                                         # Delete Wire Via in deep through mode (bool, default=false)
-display_wire_length_with_cursor {true|false}
                                         # Specifies whether display the
                                         # total/current wire length with mouse
                                         # when editing wires.
                                         # (bool, default=true)
-draw_shield {true|false}                # Specifies whether draw a shield net
                                         # only. (bool, default=false)
-draw_with_group_centerline {true|false}
                                         # Turn on this option, tool should
                                         # draw bus along the center-line of
                                         # whole wires. (bool, default=false)
-drawing_wire <value>                    # Specifies which of the nets used
                                         # with the -nets parameter
                                         # corresponding to the mouse pointer
                                         # location when adding an array of
                                         # wires. (int, default=1)
-drc_aware_cross_metal {true|false}      # Specifies whether to stretch or move
                                         # wires back to the closest location
                                         # available before a violation occurs
                                         # with the crossing metal. This option
                                         # only work if "setEditMode
                                         # -stop_at_drc" set to 1.
                                         # (bool, default=true)
-drc_on {true|false}                     # Specifies whether to check DRC rules
                                         # during wire editing.
                                         # (bool, default=true)
-drc_use_non_default_spacing {true|false}
                                         # Specifies whether non-default
                                         # spacing defined in the Non-Default
                                         # Rule of the editing net should be
                                         # used for spacing check during wire
                                         # editing. (bool, default=false)
-extend_wires {start|end|start_cell_boundary|end_cell_boundary}
                                         # Specifies whether, after completing
                                         # a signal or power route, the
                                         # specified boundary of wire segment
                                         # extends and connects to the first
                                         # logical target
                                         # (enums={start end start_cell_boundary end_cell_boundary}_list, default="")
-final_check_with_verify {true|false}    # Specifies whether to do final check
                                         # with verify (bool, default=false)
-ignore_drc {conn_antenna|max_via_stack|min_cut|min_enclosed_area|min_step|protrusion}
                                         # Specifies which violation type
                                         # should be ignored during wire
                                         # editing.
                                         # (enums={conn_antenna max_via_stack min_cut min_enclosed_area min_step protrusion}_list, default="")
-jog_connect_layer <value>               # Specifies the number of layers for
                                         # connecting wires above the  layers
                                         # for moving wires. If set the
                                         # parameter of 'setEditMode
                                         # -connect_with_specified_layer' to 1,
                                         # disable this option. (int, default=0)
-keep_floating_via {true|false}          # Keep floating vias when user
                                         # deleting wires. (bool, default=false)
-keep_status {true|false}                # Specifies whether to keep object
                                         # status during editing.
                                         # (bool, default=true)
-keep_via {true|false}                   # Specifies whether keep original via
                                         # in wire move or change width.
                                         # (bool, default=false)
-lateral_movement_range <value>          # Specified the max lateral movement
                                         # distance to avoid DRC when add a
                                         # wire. (float, default=0)
-layer <layer>                           # Specifies the layer for patch wires
                                         # or polygon wires. (string, default=M1)
-layer_horizontal <layer>                # Specifies the layer for horizontal
                                         # wires. (string, default=M1)
-layer_maximum <layer>                   # Specifies the maximum layer for
                                         # routing.
                                         # (string, default=UNINITIALIZED)
-layer_minimum <layer>                   # Specifies the minimum layer for
                                         # routing.
                                         # (string, default=UNINITIALIZED)
-layer_vertical <layer>                  # Specifies the layer for vertical
                                         # wires. (string, default=M2)
-look_down_layers <value>                # Specifies the number of layers below
                                         # the current layer that added wires
                                         # will connect to with a via.
                                         # (int, default=100)
-look_up_layers <value>                  # Specifies the number of layers above
                                         # the current layer that added wires
                                         # will connect to with a via.
                                         # (int, default=100)
-max_pointer_number <value>              # Specifies the maximum number of
                                         # pointers to be returned by wire edit
                                         # commands. (int, default=100)
-mirror_bus_route {true|false}           # Specifies that whether to reverse
                                         # the net order for bus route.
                                         # (bool, default=false)
-nets <nets>                             # Specifies one or more nets for
                                         # editing. (string, default="")
-no_merge_special_wire {true|false}      # Specifies whether automatically
                                         # merge the added special wires with
                                         # any existing special wires.
                                         # (bool, default=false)
-only_show_edit_layer {true|false}       # Turn on this option, when user
                                         # editing any wires/vias, only show
                                         # the layer from edit objects, and dim
                                         # other objects. (bool, default=true)
-orthogonal_connection_only {true|false}
                                         # Specifies whether to consider wires
                                         # and pins that are in the same
                                         # direction as a target for
                                         # connection. Only special wire is
                                         # supported. (bool, default=true)
-outer_shield_spacing <value>            # Specifies a spacing value in microns
                                         # to be used by the -shield low and
                                         # -shield high parameters.
                                         # (float, default=0)
-outer_shield_width <value>              # Specifies a width value in microns
                                         # to be used for outer shield(s)
                                         # depending on the values of -shield
                                         # low or -shield high parameters.
                                         # (float, default=0)
-override {true|false}                   # Specifies whether to use the
                                         # override specification.
                                         # (bool, default=false)
-partial_overlap_threshold <value>       # Specifies ratio threshold of special
                                         # via creation on partial overlap
                                         # wires. (int, default=0, min=0, max=100)
-pull_back_distance <value>              # Specify the value for forbidden
                                         # distance. Default is Auto, it means
                                         # use the largest min spacing of the
                                         # layer. (string, default=auto)
-reshape {true|false}                    # Specifies that when you add new
                                         # wires, existing redundant wires
                                         # within the route are automatically
                                         # removed. (bool, default=false)
-return_object_pointer {true|false}      # Specifies whether return pointers
                                         # after wire edit operations.
                                         # (bool, default=false)
-rule <value>                            # Uses the specified LEF rule for
                                         # regular wires. (string, default="")
-shape {RING|STRIPE|FOLLOWPIN|IOWIRE|COREWIRE|BLOCKWIRE|PADRING|BLOCKRING|FILLWIRE|FILLWIREOPC|DRCFILL|None}
                                         # Specifies the shape associated with
                                         # the wire you draw.
                                         # (enums={RING STRIPE FOLLOWPIN IOWIRE COREWIRE BLOCKWIRE PADRING BLOCKRING FILLWIRE FILLWIREOPC DRCFILL None}, default=STRIPE)
-shield {high|low|adjacent}              # Specifies whether to add a minimum
                                         # width shield wire for specified
                                         # side.
                                         # (enums={high low adjacent}_list, default="")
-shield_look_down_layers <value>         # Specifies the number of layers below
                                         # the current layer that an added
                                         # shield wire can connect using a via.
                                         # (int, default=100)
-shield_look_up_layers <value>           # Specifies the number of layers above
                                         # the current layer that an added
                                         # shield wire can connect using a via.
                                         # (int, default=100)
-shield_shape {RING|STRIPE|FOLLOWPIN|IOWIRE|COREWIRE|BLOCKWIRE|PADRING|BLOCKRING|FILLWIRE|DRCFILL|None}
                                         # Specifies the shape associated with
                                         # the shield wire you draw.
                                         # (enums={RING STRIPE FOLLOWPIN IOWIRE COREWIRE BLOCKWIRE PADRING BLOCKRING FILLWIRE DRCFILL None}, default=None)
-shielding_nets <nets>                   # Specifies net names for shield
                                         # wires, usually power or ground
                                         # names. (string, default="")
-show_drc_info_for_edit_shape {true|false}
                                         # Turn on this option, when user
                                         # editing any wires/vias and generate
                                         # a violation, tool can display the
                                         # detail information nearby marker.
                                         # (bool, default=true)
-sibling_look_down_layers <value>        # Specifies the number of layers below
                                         # the sibling layers that an added
                                         # shield wire can connect using a via.
                                         # (int, default=1)
-sibling_look_up_layers <value>          # Specifies the number of layers above
                                         # the sibling layers that an added
                                         # shield wire can connect using a via.
                                         # (int, default=1)
-snap {true|false}                       # Specifies whether to enable wire and
                                         # via snap. (bool, default=true)
-snap_align_to {center|low|high|auto}    # Specifies how to align with a pin
                                         # when ending a route.
                                         # (enums={center low high auto}, default=auto)
-snap_bus_to_pin {true|false}            # Specifies whether to change wire
                                         # width, spacing and order according
                                         # to the connected pin.
                                         # (bool, default=false)
-snap_end_to {track_regular|track_special|manufacturing_grid}
                                         # Specifies whether to snap the end of
                                         # wire to specified objects.
                                         # (enums={track_regular track_special manufacturing_grid}_list, default="")
-snap_objects_to_track {special|regular|patch|pin}
                                         # Specifies whether to snap added or
                                         # moved specified wires to the closest
                                         # routing track in the preferred
                                         # direction for the layer
                                         # automatically.
                                         # (enums={special regular patch pin}_list, default=regular patch)
-snap_to {special|pg|pin|row}            # Specifies whether to snap added or
                                         # moved wires to specified objects.
                                         # (enums={special pg pin row}_list, default=special pg pin)
-snap_to_track_honor_color {true|false}  # Specifies whether to snap wires to a
                                         # track with the same color
                                         # automatically. (bool, default=true)
-snap_trim_metal_to_trim_grid {true|false}
                                         # Specify whether snap the trim metal
                                         # to the closest trim grid during trim
                                         # metal editing. (bool, default=true)
-spacing <value>                         # Specifies the distance between
                                         # wires. (string, default="")
-spacing_horizontal <value>              # Specifies the distance between
                                         # horizontal wires. (string, default="")
-spacing_vertical <value>                # Specifies the distance between
                                         # vertical wires. (string, default="")
-status {cover|fixed|noshield|routed|shield|auto}
                                         # Specifies the status associated with
                                         # the wire you draw.
                                         # (enums={cover fixed noshield routed shield auto}, default=fixed)
-stop_at_drc {true|false}                # Specifies whether the software can
                                         # cause a DRC violation by moving or
                                         # stretching a wire. (bool, default=true)
-stretch_end {high|low}                  # Specifies the direction in which to
                                         # stretch or reduce wires.
                                         # (enums={high low}, default=high)
-stretch_with_intersect {true|false}     # Enables wires with intersects to be
                                         # stretched easily. (bool, default=false)
-subclass {subclass}                     # Specifies the subclass name of wires
                                         # and vias. (string, default="")
-turn_at {center_line|wire_edge}         # Specifies the start location of new
                                         # wire when do turn.
                                         # (enums={center_line wire_edge}_list, default=center_line)
-type {regular|special|patch}            # Specifies the type of creating wire.
                                         # (enums={regular special patch}, default="")
-unrestricted_regular_wire_width {true|false}
                                         # Specifies whether the regular wire
                                         # width is unrestricted in edit.
                                         # (bool, default=false)
-update_shield_net {true|false}          # Specifies whether automatically
                                         # update shield net attribute on the
                                         # signal net. (bool, default=false)
-use_fixVia {true|false}                 # Specifies whether to use fixVia for
                                         # special via with minStep DRC
                                         # violation. (bool, default=false)
-use_interleaving_wire_group {true|false}
                                         # Alternates the specified wires in
                                         # the wire group. (bool, default=false)
-use_wire_group {true|false}             # Groups multiple wires from the same
                                         # net. (bool, default=false)
-use_wire_group_bits <value>             # Specifies the number of times to
                                         # replicate a wire in the wire group.
                                         # (int, default=0)
-use_wire_group_reinforcement {true|false}
                                         # Creates slots in the wire group by
                                         # creating wires that connect the
                                         # wires in the wire group, but are
                                         # orthogonal to them.
                                         # (bool, default=false)
-use_wire_group_reinforcement_group_via {true|false}
                                         # Specifies that the wire group uses
                                         # group vias. (bool, default=false)
-use_wire_group_reinforcement_spacing <value>
                                         # Specifies the spacing for the
                                         # orthogonal wires in the wire groups.
                                         # (float, default=0)
-use_wire_group_reinforcement_width <value>
                                         # Specifies the width of the
                                         # orthogonal wires in the wire groups.
                                         # (float, default=0)
-verbose {true|false}                    # (bool, default=false)
-via_allow_geom_drc {true|false}         # Check Geometry DRC
                                         # (bool, default=true)
-via_auto_replace {true|false}           # Controls whether to replace existing
                                         # vias. (bool, default=true)
-via_auto_snap {true|false}              # Controls whether to snap vias to the
                                         # intersection of wires on the same
                                         # net or to the manufacturing grid.
                                         # (bool, default=true)
-via_cell_name <value>                   # Specifies the name of the via cell
                                         # from the LEF or DEF file.
                                         # (string, default="")
-via_columns <value>                     # Specify the rows of via cut.
                                         # (int, default=0)
-via_create_by {viacell|parameters}      # Controls whether to create vias
                                         # based on the -via_cell_name
                                         # parameter or to create vias based on
                                         # the other parameters.
                                         # (enums={viacell parameters}, default=parameters)
-via_cut_layer <value>                   # Specifies the via layer name for the
                                         # via to created or modify.
                                         # (string, default=V12)
-via_exclude_spec <value>                # Specifies the vias to be ignored by
                                         # wire editor. (string, default="")
-via_override_spec <value>               # Specifies the default vias to be
                                         # used by wire editor.
                                         # (string, default="")
-via_rows <value>                        # Specify the columns of via cut.
                                         # (int, default=0)
-via_scale_height <value>                # Specify the via height scale.
                                         # (int, default=100)
-via_scale_width <value>                 # Specify the via width scale.
                                         # (int, default=100)
-via_snap_honor_color {true|false}       # Specifies whether to snap the same
                                         # mask automatically (bool, default=true)
-via_snap_to_intersection {true|false}   # Specifies whether to snap vias to
                                         # the intersection of wires
                                         # (bool, default=true)
-via_type {auto|regular|special}         # Specifies the type of creating via.
                                         # (enums={auto regular special}, default=auto)
-width <value>                           # Specifies the width of patch wires.
                                         # (float, default=0)
-width_horizontal <value>                # Specifies the width for horizontal
                                         # wires. (float, default=0)
-width_vertical <value>                  # Specifies the width of vertical
                                         # wires. (float, default=0)
-wire_override_spec <value>              # Contains the details of the override
                                         # specification. (string, default="")