Usage: set_switching_activity [-help] [-activity <string>]
                              [-bidir_port <string>] [-cell <string>]
                              [-clock <string>] [-comb_clockgate_ratio <string>]
                              [-density <string>] [-duty <string>] [-force]
                              [-hier <string>] [-icg_ratio <string>]
                              [-input_port <string>] [-inst <string>]
                              [-net <string>] [-output_port <string>]
                              [-period <string>] [-pin <string>]
                              [-port <string>] [-quiet] [-reset]
                              [-scale_factor <string>] [-unclocked]

-help                                      # Prints out the command usage
-activity <string>                         # Specifies the number of times the
                                           # net, pin, or port switches in a
                                           # clock cycle. (string, optional)
-bidir_port <string>                       # Specifies the name of the
                                           # bidirectional port.
                                           # (string, optional)
-cell <string>                             # Specifies the activity on all
                                           # output pins for all instances of
                                           # the specified cell.
                                           # (string, optional)
-clock <string>                            # Assigns global activity factor to
                                           # all nets in domain of  clock_name.
                                           # (string, optional)
-comb_clockgate_ratio <string>             # Specifies to set the propagation
                                           # ratio for combinational clock gate
                                           # cell outputs. (string, optional)
-density <string>                          # Specifies the transition density
                                           # for a specific net, pin, or
                                           # top-level port. (string, optional)
-duty <string>                             # Specifies the duty cycle, if it is
                                           # not specified then tool will use
                                           # duty specified by the
                                           # set_default_switching_activity
                                           # command. (string, optional)
-force                                     # pass activity info to dynamic
                                           # engine without verilog netlist
                                           # (bool, optional)
-hier <string>                             # Specifies a hierarchical name that
                                           # an activity is being assigned to.
                                           # (string, optional)
-icg_ratio <string>                        # Specifies to set the propagation
                                           # ratio for integrated clock gate
                                           # (ICG) cell outputs.
                                           # (string, optional)
-input_port <string>                       # Specifies the name of the input
                                           # port. (string, optional)
-inst <string>                             # Specifies the activity on a
                                           # specific instance. (string, optional)
-net <string>                              # Specifies the name of the net.
                                           # (string, optional)
-output_port <string>                      # Specifies the name of the output
                                           # port. (string, optional)
-period <string>                           # Specifies the period that the
                                           # activity is referenced to.
                                           # Default: Default Frequency: The
                                           # time unit is defined in the first
                                           # .lib file read during design
                                           # import. (string, optional)
-pin <string>                              # Specifies the name of a pin.
                                           # (string, optional)
-port <string>                             # Specifies the name of a top-level
                                           # port. (string, optional)
-quiet                                     # Suppress messages.
                                           # (bool, optional)
-reset                                     # Resets all specified options back
                                           # to default values. (bool, optional)
-scale_factor <string>                     # Specifies the scale transition
                                           # density of
                                           # net/pin/port/cell/inst/clock .
                                           # (string, optional)
-unclocked                                 # Applies activity (with reference
                                           # period ) to all nets that doesn't
                                           # have clock domain ( -unclocked).
                                           # (bool, optional)