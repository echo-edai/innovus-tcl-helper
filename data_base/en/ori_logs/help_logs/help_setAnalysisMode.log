Usage: setAnalysisMode [-help] [-reset] [-aging {true|false}]
                       [-analysisType {single|bcwc|onChipVariation}]
                       [-asyncChecks {async|noAsync|asyncOnly|auto}]
                       [-caseAnalysis {true|false}] [-checkType {setup|hold}]
                       [-clkNetsMarking {beforeConstProp|afterConstProp}]
                       [-clkSrcPath {true|false}]
                       [-clockGatingCheck {true|false}]
                       [-clockPropagation {sdcControl|forcedIdeal|autoDetectClockTree}]
                       [-cppr {both|none|setup|hold}]
                       [-honorActiveLogicView {true|false}]
                       [-honorClockDomains {true|false}] [-log {true|false}]
                       [-multi_input_switching_mode <value>]
                       [-propSlew {true|false}]
                       [-sequentialConstProp {true|false}] [-skew {true|false}]
                       [-slackBalancing {true|false}]
                       [-timeBorrowing {true|false}]
                       [-timing_robustness {true|false}]
                       [-timingEngine {statistical|static|rql}]
                       [-timingSelfLoopsNoSkew {true|false}]
                       [-usefulSkew {true|false}]
                       [-useOutputPinCap {true|false}] [-warn {true|false}] [-socv {true|false} | -aocv {true|false}]

-help                                      # Prints out the command usage
-reset                                     # Resets all or specified options to default value
-aging {true|false}                        # Aging Analysis
                                           # (bool, default=false)
-analysisType {single|bcwc|onChipVariation}
                                           # Single or BCWC or OCV
                                           # TimingAnalysis type
                                           # (enums={single bcwc onChipVariation}, default=bcwc)
-aocv {true|false}                         # AOCV Analysis
                                           # (bool, default=false)
-asyncChecks {async|noAsync|asyncOnly|auto}
                                           # Async checks (enums={async noAsync asyncOnly auto}, default=auto)
-caseAnalysis {true|false}                 # caseAnalysis (bool, default=true)
-checkType {setup|hold}                    # Report Violations for hold, setup
                                           # (enums={setup hold}, default=setup)
-clkNetsMarking {beforeConstProp|afterConstProp}
                                           # clkNetsMarking (enums={beforeConstProp afterConstProp}, default=beforeConstProp)
-clkSrcPath {true|false}                   # clkSrcPath (bool, default=true)
-clockGatingCheck {true|false}             # clockGatingCheck
                                           # (bool, default=true)
-clockPropagation {sdcControl|forcedIdeal|autoDetectClockTree}
                                           # Timing arc attributes effect on
                                           # timing analysis
                                           # (enums={sdcControl forcedIdeal autoDetectClockTree}, default=sdcControl)
-cppr {both|none|setup|hold}               # Removes pessimism from clock paths
                                           # that have a portion of the clock
                                           # network in common between the
                                           # clock source and clock destination
                                           # paths
                                           # (enums={both none setup hold}, default=none)
-honorActiveLogicView {true|false}         # Honor Active Logic View
                                           # (bool, default=false)
-honorClockDomains {true|false}            # Honor Clock Domains
                                           # (bool, default=false)
-log {true|false}                          # log (bool, default=true)
-multi_input_switching_mode <value>        # Specify MIS mode: 0,Simultaneous
                                           # input switching is not considered
                                           # 1,MIS analysis consider cells for
                                           # which multiple inputs of a cell
                                           # tied together (tied-inputs) 2,MIS
                                           # analysis consider both tied-inputs
                                           # and inputs of a cells switching
                                           # independent to each other 3,derate
                                           # based MIS analysis
                                           # (int, default=0, min=0, max=3)
-propSlew {true|false}                     # Controls interconnect slew
                                           # degradation for early paths.
                                           # (bool, default=true)
-sequentialConstProp {true|false}          # sequentialConstProp
                                           # (bool, default=false)
-skew {true|false}                         # skew (bool, default=true)
-slackBalancing {true|false}               # (bool, default=false)
-socv {true|false}                         # SOCV Analysis
                                           # (bool, default=false)
-timeBorrowing {true|false}                # timeBorrowing (bool, default=true)
-timing_robustness {true|false}            # Timing Robustness Analysis
                                           # (bool, default=false)
-timingEngine {statistical|static|rql}     # Statistical or Static or Rql
                                           # (enums={statistical static rql}, default=static)
-timingSelfLoopsNoSkew {true|false}        # Eliminates clock skew due to clock
                                           # uncertainty for a path starting
                                           # and ending at the same register.
                                           # If the clock skew is not
                                           # eliminated, the timing for such
                                           # paths is pessimistic
                                           # (bool, default=false)
-usefulSkew {true|false}                   # UsefulSkew (bool, default=false)
-useOutputPinCap {true|false}              # useOutputPinCap
                                           # (bool, default=true)
-warn {true|false}                         # warn (bool, default=true)