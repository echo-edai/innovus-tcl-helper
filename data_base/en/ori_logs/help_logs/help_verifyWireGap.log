Usage: verifyWireGap [-help] [-append] [-area {x1 y1 x2 y2}] [-layers <string>]
                     [-report <string>] [-wireToWire <float>] [ -net <string>] [-wireToBoundary [-chip {v1 v2}] [-core {v1 v2}] [-block {v1 v2}] [-powerdomain {v1 v2}]] [-wireToShape [-ring <float>]]

-help                   # Prints out the command usage
-append                 # specifies that all previous verifyWireGap settings
                        # will be kept (bool, optional)
-area {x1 y1 x2 y2}     # specifies the area to check (box, optional)
-block {v1 v2}          # Specifies the wire to block gap distance
                        # (point, optional)
-chip {v1 v2}           # Specifies the wire to chip boundary gap distance
                        # (point, optional)
-core {v1 v2}           # Specifies the wire to core boundary gap distance
                        # (point, optional)
-layers <string>        # Specifies the metal layers to consider
                        # (string, optional)
-net <string>           # The name of power nets that will be checked
                        # (string, optional)
-powerdomain {v1 v2}    # Specifies the wire to powerdomain gap distance
                        # (point, optional)
-report <string>        # Specifies the report file for verifyWireGap
                        # violations data (string, optional)
-ring <float>           # Specifies the wire to ring gap distance
                        # (float, optional)
-wireToBoundary         # To check wire to boundary gap (bool, optional)
-wireToShape            # To check gap between wire and some specific shapes
                        # (bool, optional)
-wireToWire <float>     # Specifies the wire to wire gap distance
                        # (float, optional)