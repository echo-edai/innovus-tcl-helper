Usage: getFlipChipMode [-help] [-allow_layer_change] [-auto_pairing_file]
                       [-bump_use_oct_shape] [-check_bump_access_directions]
                       [-compaction] [-connectPowerCellToBump] [-constraintFile]
                       [-drop_via_on_all_geometries] [-drop_via_on_power_mesh]
                       [-extraConfig] [-finger_direction] [-finger_max_width]
                       [-finger_min_width] [-finger_target_mesh_layer_range]
                       [-honor_bump_connect_target_constraint]
                       [-ignore_pad_type_check] [-layerChangeBotLayer]
                       [-layerChangeTopLayer] [-lower_layer_prevent_45_routing]
                       [-lower_layer_route_width] [-merge_nearby_pin]
                       [-multi_pad_routing_style] [-multipleConnection]
                       [-pg_mesh_direction] [-pg_mesh_main_width]
                       [-pg_mesh_max_width] [-pg_mesh_width]
                       [-prevent_diagonal_wire_access_bumps]
                       [-prevent_via_under_bump]
                       [-prevent_via_under_bump_extension] [-route_bump_cluster]
                       [-route_pg_style] [-route_style] [-routeWidth]
                       [-via_abut_bump] [-wire_to_pad_honor_min_spacing]
                       [-quiet] [-nonDefault]

-help                                      # Prints out the command usage
-allow_layer_change                        # Specifies if turning on layer
                                           # change feature (bool, default=false)
-auto_pairing_file                         # Specifies the output file name to
                                           # dump out fcroute auto pairing
                                           # information for bump to I/O
                                           # connection (string, default="")
-bump_use_oct_shape                        # fcroute use circumferential
                                           # octagon to replace the complex pin
                                           # shape (bool, default=false)
-check_bump_access_directions              # Specifies whether check the
                                           # special bump access directions
                                           # (bool, default=false)
-compaction                                # Specifies if turning on compaction
                                           # routing (bool, default=false)
-connectPowerCellToBump                    # Connects all power bumps to the
                                           # I/O cell pin. It does not connect
                                           # to a power or ground stripe or
                                           # ring (bool, default=false)
-constraintFile                            # Specifies the file that contains
                                           # constraints for flip chip routing
                                           # (string, default="")
-drop_via_on_all_geometries                # fcroute drop via on all geometries
                                           # (bool, default=false)
-drop_via_on_power_mesh                    # Specifies the metal layer by layer
                                           # number or layer name that the
                                           # software can use to drop via
                                           # (string, default="")
-extraConfig                               # Specifies the name of an extra
                                           # configuration file for flip chip
                                           # routing (string, default="")
-finger_direction                          # Specifies main expansion direction
                                           # for finger routing
                                           # (enums={N E S W}, default=N)
-finger_max_width                          # Specifies the max routing width
                                           # for one wire segment
                                           # (float, default=0)
-finger_min_width                          # Specifies the min routing width
                                           # for one wire segment
                                           # (float, default=0)
-finger_target_mesh_layer_range            # Target mesh layer range for finger
                                           # routing (string, default="")
-honor_bump_connect_target_constraint      # Specifies if enabling port
                                           # numbering routing
                                           # (bool, default=false)
-ignore_pad_type_check                     # Specifies if supporting CLASS PAD
                                           # cells in flipchip flow
                                           # (bool, default=true)
-layerChangeBotLayer                       # Specifies the bottom-most metal
                                           # layer by layer number or layer
                                           # name that the software can use
                                           # when routing bumps
                                           # (string, default="")
-layerChangeTopLayer                       # Specifies the top-most metal layer
                                           # by layer number or layer name that
                                           # the software can use when routing
                                           # bumps (string, default="")
-lower_layer_prevent_45_routing            # Specifies if preventing 45-degree
                                           # routing for lower layer
                                           # (bool, default=false)
-lower_layer_route_width                   # Specifies the different value for
                                           # lower routing layer
                                           # (float, default=0, min=0, max=10000000000)
-merge_nearby_pin                          # Merge pins which are close but not
                                           # touched (bool, default=false)
-multi_pad_routing_style                   # Specifies the routing style for
                                           # multi-pads routing
                                           # (enums={default serial star}, default=default)
-multipleConnection                        # Specifies routing connections
                                           # between multiple pads and bumps.
                                           # Default is no multiple connection
                                           # (enums={multiPadsToBump multiBumpsToPad default}, default=default)
-pg_mesh_direction                         # Specifies the main routing
                                           # direction of PG mesh
                                           # (enums={default horizontal vertical}, default=default)
-pg_mesh_main_width                        # Specifies the main width of PG
                                           # mesh
                                           # (float, default=0, min=0, max=10000000000)
-pg_mesh_max_width                         # Specifies the max width of PG mesh
                                           # (float, default=0, min=0, max=10000000000)
-pg_mesh_width                             # Specify the exact width of PG
                                           # mesh. One value for both
                                           # horizontal and vertical width. And
                                           # with two values, the first value
                                           # for horizontal width and the
                                           # second value for vertical width
                                           # (string, default="")
-prevent_diagonal_wire_access_bumps        # Specifies whether use diagonal
                                           # wire to access bump or not
                                           # (bool, default=false)
-prevent_via_under_bump                    # Specifies if generating vias
                                           # directly under the bump
                                           # (bool, default=false)
-prevent_via_under_bump_extension          # specifies the spacing value around
                                           # bump to avoid dropping vias
                                           # (float, default=-1, min=-2, max=DBL_MAX)
-route_bump_cluster                        # Route bump cluster after bump
                                           # grouped (bool, default=false)
-route_pg_style                            # Specifies the routing pattern for
                                           # fcroute power routing
                                           # (enums={none finger mesh}, default=none)
-route_style                               # Specifies routing style
                                           # (enums={manhattan 45DegreeRoute}, default=45DegreeRoute)
-routeWidth                                # Specifies routing width
                                           # (float, default=0)
-via_abut_bump                             # via abut bump only if it is
                                           # success (bool, default=false)
-wire_to_pad_honor_min_spacing             # Specifies the min spacing between
                                           # bump/pad with wire (float, default=0)
-quiet                                     # Displays the current settings in Tcl list format only
-nonDefault                                # Displays the current settings which are not default settings