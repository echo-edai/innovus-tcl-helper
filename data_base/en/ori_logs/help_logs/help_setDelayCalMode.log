Usage: setDelayCalMode [-help] [-reset] [-accuracy_level <level>]
                       [-advanced_accuracy_mode {medium|high|ultra}]
                       [-advanced_calculation_mode {medium|high}]
                       [-advanced_node_pin_cap_settings {true|false}]
                       [-advanced_pincap_mode {0|1|2}]
                       [-combine_mmmc {none|early_late|early_late_corner}]
                       [-early_irdrop_data_type {best_average|worst|best|average|worst_average}]
                       [-enable_corner_based_beol {true|false}]
                       [-enable_high_fanout {true|false}]
                       [-enable_input_slew_sensitivity_on_constraint {true|false}]
                       [-enable_quiet_receivers_for_hold {true|false}]
                       [-equivalent_waveform_model {none|no_propagation|propagation}]
                       [-equivalent_waveform_model_for_timing_check {true|false}]
                       [-ewm_type {moments|simulation}]
                       [-honorSlewPropConstraint {true|false}]
                       [-ignoreNetLoad {true|false}]
                       [-irdrop_data_type {best_average|worst|best|average|worst_average}]
                       [-irDrop_window_based {none|late|early|both}]
                       [-late_irdrop_data_type {best_average|worst|best|average|worst_average}]
                       [-library_interpolation_mode {linear|non_linear|non_linear_advanced}]
                       [-nonlinear_voltage_scaling_improvements {true|false}]
                       [-ptr_effort <value>] [-reportOutBound {true|false}]
                       [-save_set_inst_voltage_cmd {true|false}]
                       [-SIAware {true|false}]
                       [-signoff_alignment_settings {true|false}]
                       [-skip_slew_merge_from_disabled_path {true|false}]
                       [-slewOutBoundLimitHigh <value>]
                       [-slewOutBoundLimitLow <value>]
                       [-socv_accuracy_mode {low|medium|high|ultra}]
                       [-socv_lvf_mode {moments|early_late}]
                       [-socv_machine_learning_level {0|1|3}]
                       [-socv_use_lvf_tables {all|delay|slew|constraint}]
                       [-use_top_interface_delay_in_context {true|false}]
                       [-view_specific_settings <view:setting:value>]
                       [-voltage_scaling_compatibility_mode {true|false}]
                       [-wire_variation_correlation_mode {statistical|binomial}]
                       [-wire_variation_rc_correlation <value>]

-help                                    # Prints out the command usage
-reset                                   # Resets all or specified options to default value
-accuracy_level <level>                  # set accuracy level for delay
                                         # calculation
                                         # (int, default=0, min=0, max=4)
-advanced_accuracy_mode {medium|high|ultra}
                                         # advanced accuracy level (enums={medium high ultra}, default=medium)
-advanced_calculation_mode {medium|high}
                                         # Enable advanced calculation mode for
                                         # base delay.
                                         # (enums={medium high}, default=medium)
-advanced_node_pin_cap_settings {true|false}
                                         # Enable advanced node pin cap
                                         # settings. (bool, default=false)
-advanced_pincap_mode {0|1|2}            # Enable advanced receiver pin cap
                                         # mode for base delay.
                                         # (enums={0 1 2}, default=0)
-combine_mmmc {none|early_late|early_late_corner}
                                         # Specifies whether delay calculation
                                         # runs are to be combined for delay
                                         # calculation simulations
                                         # (enums={none early_late early_late_corner}, default=early_late_corner)
-early_irdrop_data_type {best_average|worst|best|average|worst_average}
                                         # IRDrop EIV DB EivMethod for early
                                         # corner
                                         # (enums={best_average worst best average worst_average}, default=worst)
-enable_corner_based_beol {true|false}   # Enable Anchor corner based BEOL
                                         # analysis (bool, default=false)
-enable_high_fanout {true|false}         # Enables the default net delay which
                                         # will be annotated on high fanout
                                         # nets (bool, default=false)
-enable_input_slew_sensitivity_on_constraint {true|false}
                                         # Enable input slew ensitivity on
                                         # constraint (bool, default=false)
-enable_quiet_receivers_for_hold {true|false}
                                         # (bool, default=false)
-equivalent_waveform_model {none|no_propagation|propagation}
                                         # Controls the equivalent waveform
                                         # model to be used
                                         # (enums={none no_propagation propagation}, default=none)
-equivalent_waveform_model_for_timing_check {true|false}
                                         # Enable EWM for timing check delay. (bool, default=false)
-ewm_type {moments|simulation}           # Equivalent waveform model type to be
                                         # used
                                         # (enums={moments simulation}, default=simulation)
-honorSlewPropConstraint {true|false}    # Determines whether to propagate the
                                         # slew from the disabled timing arcs
                                         # to the output pin. (bool, default=true)
-ignoreNetLoad {true|false}              # Uses zero-cap, zero-resistance
                                         # wire-load model for estimating
                                         # delays. (bool, default=false)
-irdrop_data_type {best_average|worst|best|average|worst_average}
                                         # IRDrop EIV DB EivMethod (enums={best_average worst best average worst_average}, default=worst)
-irDrop_window_based {none|late|early|both}
                                         # Fetch window based EIV values from
                                         # EIV DB
                                         # (enums={none late early both}, default=both)
-late_irdrop_data_type {best_average|worst|best|average|worst_average}
                                         # IRDrop EIV DB EivMethod for late
                                         # corner
                                         # (enums={best_average worst best average worst_average}, default=worst)
-library_interpolation_mode {linear|non_linear|non_linear_advanced}
                                         # library scaling mode for
                                         # interpolation flow
                                         # (enums={linear non_linear non_linear_advanced}, default=linear)
-nonlinear_voltage_scaling_improvements {true|false}
                                         # Enables non-linear voltage scaling
                                         # improvements (bool, default=false)
-ptr_effort <value>                      # PTR analysis effort. Should be
                                         # between 0 and 1: 0 - lowest accuracy
                                         # and runtime, 1 - highest accuracy
                                         # and runtime (float, default=0.5)
-reportOutBound {true|false}             # Generates a report that contains a
                                         # list of index values (input
                                         # transition) in the delay tables that
                                         # are beyond the index range.
                                         # (bool, default=false)
-save_set_inst_voltage_cmd {true|false}  # Enable set_inst_voltage cmd saving
                                         # in persistant db (bool, default=false)
-SIAware {true|false}                    # Enables SIAware delay calculation
                                         # that also includes cross-talk
                                         # induced delays.
                                         # (enums={true false}, default=false)
-signoff_alignment_settings {true|false}
                                         # Turn on/off signoff alignment
                                         # settings (bool, default=false)
-skip_slew_merge_from_disabled_path {true|false}
                                         # Enable slew merge from disable path (bool, default=false)
-slewOutBoundLimitHigh <value>           # Limits the maximum slew used in the
                                         # analysis to the specified value.
                                         # (float, default=3.40282346638529e+38, min=1, max=3.40282346638529e+38)
-slewOutBoundLimitLow <value>            # Limits the minimum slew used in the
                                         # analysis to the specified value.
                                         # (float, default=0.5, min=0.001, max=1)
-socv_accuracy_mode {low|medium|high|ultra}
                                         # level-based-accuracy-effort in AAE
                                         # for delays and slews
                                         # (enums={low medium high ultra}, default=low)
-socv_lvf_mode {moments|early_late}      # Controls interpretation of LVF data.
                                         # (enums={moments early_late}, default=early_late)
-socv_machine_learning_level {0|1|3}     # Enable socv machine learning mode
                                         # (int, default=0)
-socv_use_lvf_tables {all|delay|slew|constraint}
                                         # Controls which type of variations
                                         # are considered during analysis.
                                         # (string, default=all)
-use_top_interface_delay_in_context {true|false}
                                         # Enables use of output stage delays
                                         # from top analysis in block context
                                         # analysis (bool, default=false)
-view_specific_settings <view:setting:value>
                                         # Spicifies a global variable value or
                                         # macro settings for particle view
                                         # using
                                         # {viewName:eng_global|macro:value}
                                         # (string, default="")
-voltage_scaling_compatibility_mode {true|false}
                                         # Enables voltage scaling
                                         # compatibility mode
                                         # (bool, default=false)
-wire_variation_correlation_mode {statistical|binomial}
                                         # Specify wire variatio inter layer
                                         # correlation
                                         # (enums={statistical binomial}, default=statistical)
-wire_variation_rc_correlation <value>   # Same layer RC correlation for wire
                                         # variation (float, default=1)