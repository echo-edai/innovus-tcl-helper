Usage: gui_highlight_safety_mechanism [-help] {[-dcls {insts nets_internal nets_interface nets_common nets_top} | -tmr {parents clones voters} | -ser {insts}]} [-dcls {insts nets_internal nets_interface nets_common nets_top} [-group <string>]] [-tmr {parents clones voters} [-inst <string>]] [-group <string> [-exclusive_groups ]] [-color <string> | -auto_color ]

-help                            # Prints out the command usage
-auto_color                      # Auto color (bool, optional)
-color <string>                  # Specify color (string, optional)
-dcls {insts nets_internal nets_interface nets_common nets_top}
                                 # Highlight dcls group's insts, internal-nets,
                                 # interface-nets, common-nets or top-nets
                                 # (enum_list, required)
-exclusive_groups                # As well as highlighting the insts/nets of
                                 # the specified group, highlight the same
                                 # features of it's exclusive groups
                                 # (bool, optional)
-group <string>                  # Highlight the features of this dcls group
                                 # only (string, optional)
-inst <string>                   # Highlight the features of this tmr inst only
                                 # (string, optional)
-ser {insts}                     # Highlight all ser insts (enum, required)
-tmr {parents clones voters}     # Highlight tmr parents, tmr clones or tmr
                                 # voters (enum_list, required)