Usage: set_timing_derate [-help] [<object_list>] [<derate_value>] [-add]
                         [-cell_check] [-cell_delay] [-clock]
                         [-clock_period_check] [-corner] [-data] [-dynamic]
                         [-early <float>] [-fall] [-increment]
                         [-input_switching] [-late <float>] [-mean] [-multiply]
                         [-net_delay] [-power_domain <string>]
                         [-pulse_width_check] [-retain_delay] [-rise] [-sigma]
                         [-static] [-statistical] [-transition] [-min  | -max  | -delay_corner <delayCornerName> ]

-help                               # Prints out the command usage
<object_list>                       # Specifies the list of instances, library
                                    # cells, or nets to which the derating will
                                    # be applied (string, optional)
<derate_value>                      # Specifies the derating value to be used
                                    # (float, optional)
-add                                # Incrementally adds or subtracts derates
                                    # (bool, optional)
-cell_check                         # Specifies scaling on timing checks
                                    # (bool, optional)
-cell_delay                         # Specifies scaling on cell delays
                                    # (bool, optional)
-clock                              # Applies the derating factors to clock
                                    # paths only (bool, optional)
-clock_period_check                 # Specifies derate values for clock period
                                    # checks (bool, optional)
-corner                             # Applies derating on cells/nets which are
                                    # modeled as corner data elements
                                    # (bool, optional)
-data                               # Applies the derating factors to data
                                    # paths only (bool, optional)
-delay_corner <delayCornerName>     # Applies the derating factor to the
                                    # specified delay calculation corners
                                    # (string, optional)
-dynamic                            # Applies the specified derating factor to
                                    # the dynamic portion of cell/net delays
                                    # (bool, optional)
-early <float>                      # Specifies that the derating factor
                                    # applies to early paths (float, optional)
-fall                               # Applies the derating factor to the
                                    # falling edge of the paths (bool, optional)
-increment                          # incrementally add the derate value to
                                    # total derate value in all (OCV/AOCV/SOCV)
                                    # mode. (bool, optional)
-input_switching                    # Understand the given derate as
                                    # Simultaneous Switching Input derate
                                    # applicable to early paths only
                                    # (bool, optional)
-late <float>                       # Specifies that the derating factor
                                    # applies to late paths (float, optional)
-max                                # Applies the derating factor to the
                                    # maximum operating condition during
                                    # best-case worst-case analysis
                                    # (bool, optional)
-mean                               # Used in the SOCV analysis flow to specify
                                    # a derating factor for the mean component
                                    # of delay. For cell delays and checks,
                                    # -mean is supported on library_cell and
                                    # instance objects.  For net delays, it is
                                    # supported as a global-level derate
                                    # factor.   The -multiply and -add options
                                    # can be used with -mean to provide an
                                    # incremental adjustment to a previously
                                    # specified -mean base derate.
                                    # (bool, optional)
-min                                # Applies the derating factor to the
                                    # minimum operating condition during
                                    # best-case worst-case analysis
                                    # (bool, optional)
-multiply                           # Incrementally multiplies derates
                                    # (bool, optional)
-net_delay                          # Specifies scaling on net delays
                                    # (bool, optional)
-power_domain <string>              # Allows you to specify a specific power
                                    # domain for the timing derate factors to
                                    # be applied (string, optional)
-pulse_width_check                  # Specifies derate values for pulse width
                                    # checks (bool, optional)
-retain_delay                       # Specifies scaling on retain constructs
                                    # (bool, optional)
-rise                               # Applies the derating factor to the rising
                                    # edge of the paths (bool, optional)
-sigma                              # Used in the SOCV analysis flow to specify
                                    # a derating factor for the variation
                                    # component of delay. For cell delays and
                                    # checks, -sigma is supported on
                                    # library_cell and instance objects.  For
                                    # net delays, it is supported as a
                                    # global-level derate factor.   The
                                    # -multiply and -add options can be used
                                    # with -sigma to provide an incremental
                                    # adjustment to a previously specified
                                    # -sigma base derate. (bool, optional)
-static                             # Applies the specified derating factor to
                                    # the static portion of cell/net delays
                                    # (bool, optional)
-statistical                        # Applies derating on cells/nets which are
                                    # modeled as statistical data elements
                                    # (bool, optional)
-transition                         # Specifies scaling on transitions
                                    # (bool, optional)