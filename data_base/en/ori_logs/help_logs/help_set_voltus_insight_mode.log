Usage: set_voltus_insight_mode [-help] -config <string> [-db_mapping <string>]
                               -domain <string> [-hier_block_instance <string>]
                               [-hierarchical] [-import_analysis_data]
                               [-ir_effort <string>] [-nParallel <integer>]
                               [-scenario_default <string>] [-skip]
                               [-timing_effort <string>] [-watch_box <string>]
                               [-watch_inst <string>]

-help                             # Prints out the command usage
-config <string>                  # config file (string, required)
-db_mapping <string>              # scenario mapping file (string, optional)
-domain <string>                  # domain name (string, required)
-hier_block_instance <string>     # hier block instance list (string, optional)
-hierarchical                     # hierarchical flow (bool, optional)
-import_analysis_data             # indicate if we need to import exsiting rail
                                  # results (bool, optional)
-ir_effort <string>               # effort level for RPG and IRAP
                                  # (string, optional)
-nParallel <integer>              # #dbs for each iteration in multi-db mode
                                  # (int, optional)
-scenario_default <string>        # default scenario list (string, optional)
-skip                             # skip user defined instances or box
                                  # (bool, optional)
-timing_effort <string>           # timing effort for repair flow
                                  # (string, optional)
-watch_box <string>               # instances inside the box will be watched
                                  # (string, optional)
-watch_inst <string>              # defined user specified instances
                                  # (string, optional)