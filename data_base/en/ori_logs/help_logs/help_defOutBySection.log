Usage: defOutBySection [-help] <fileName> [-addHalfWireExtensionOnPin]
                       [-bumpAsPin] [-compPlacement] [-earlyGlobalRoute]
                       [-fills] [-ioRow] [-netRouting] [-noComps] [-noCoreCells]
                       [-noDieArea] [-noNets] [-noPrintWildCard]
                       [-no_virtual_trim] [-nonDefaultRules]
                       [-outputMaskLayers <string>] [-pBlockages] [-pins]
                       [-rBlockages] [-rows] [-scanChains] [-selected]
                       [-specialNetRouting] [-specialNets]
                       [-specialRouteUserClass <string>]
                       [-specialShape [STRIPE RING PADRING BLOCKRING FOLLOWPIN IOWIRE COREWIRE BLOCKWIRE FILLWIRE DRCFILL FILLWIREOPC BLOCKAGEWIRE NOSHAPE]]
                       [-tracks] [-unit <unit_per_micron>] [-unplaced]
                       [-usedVia] [-verilog_from_def_netlist_flow] [-vias] [-groups  [-noPrintGroupRegex ]]

-help                              # Prints out the command usage
<fileName>                         # Output DEF file name (string, required)
-addHalfWireExtensionOnPin         # Forces the zero-extension on pins to the
                                   # default half-width extension (bool, optional)
-bumpAsPin                         # Writes bump cells as top-level pins in the
                                   # PINS section (bool, optional)
-compPlacement                     # Writes component placement and orientation
                                   # information to the COMPONENTS section of
                                   # the DEF file. Output is limited to
                                   # instances with placed/fixed/cover status,
                                   # unless -unplaced is also specified
                                   # (bool, optional)
-earlyGlobalRoute                  # Writes information about the wires
                                   # generated by Early Global Route to the
                                   # NETS section of the DEF file (bool, optional)
-fills                             # Writes metal fill information to the FILLS
                                   # section of the DEF file (bool, optional)
-groups                            # Writes group information to the GROUPS
                                   # section of the DEF file (bool, optional)
-ioRow                             # Generates I/O rows based on I/O pad
                                   # placement, and writes the I/O row
                                   # information to the DEF file (bool, optional)
-netRouting                        # Writes routing data to the NETS section of
                                   # the DEF file (bool, optional)
-noComps                           # Excludes component information from the
                                   # DEF file (bool, optional)
-noCoreCells                       # Excludes core cell information from the
                                   # DEF file to reduce the data size for
                                   # import into APD (bool, optional)
-noDieArea                         # Excludes DIEAREA and associated
                                   # FE_CORE_BOX* properties. (bool, optional)
-noNets                            # Excludes net information from the DEF file
                                   # (bool, optional)
-noPrintGroupRegex                 # Suppresses the use of regular expressions
                                   # to represent instance names (bool, optional)
-noPrintWildCard                   # Suppresses the use of the wildcard format
                                   # to represent special net connectivity
                                   # (bool, optional)
-no_virtual_trim                   # Don't write out virtual trims
                                   # (bool, optional)
-nonDefaultRules                   # (bool, optional)
-outputMaskLayers <string>         # Output MASK data on specified layers only
                                   # (string, optional)
-pBlockages                        # Writes placement blockage information to
                                   # the BLOCKAGES section of the DEF file
                                   # (bool, optional)
-pins                              # Writes pin information to the PINS section
                                   # of the DEF file (bool, optional)
-rBlockages                        # Writes routing blockage information to the
                                   # BLOCKAGES section of the DEF file
                                   # (bool, optional)
-rows                              # Writes row information to the ROWS section
                                   # of the DEF file (bool, optional)
-scanChains                        # Writes scan chain information to the DEF
                                   # file (bool, optional)
-selected                          # Writes only the DEF header and COMPONENT
                                   # section for instances you have selected in
                                   # the EDI System main window (bool, optional)
-specialNetRouting                 # Writes special net routing information to
                                   # the SPECIALNET section of the DEF file
                                   # (bool, optional)
-specialNets                       # Writes special net information to the
                                   # SPECIALNETS section of the DEF file
                                   # (bool, optional)
-specialRouteUserClass <string>    # User Class for special route
                                   # (string, optional)
-specialShape [STRIPE RING PADRING BLOCKRING FOLLOWPIN IOWIRE COREWIRE BLOCKWIRE FILLWIRE DRCFILL FILLWIREOPC BLOCKAGEWIRE NOSHAPE]
                                   # (enum_list, optional)
-tracks                            # Writes routing track information to the
                                   # TRACKS and GCELLGRID statements of the DEF
                                   # file (bool, optional)
-unit <unit_per_micron>            # Unit per micron for the DEF file
                                   # (int, optional)
-unplaced                          # Includes unplaced standard cell instances
                                   # in the COMPONENTS section when combined
                                   # with the -compPlacement option
                                   # (bool, optional)
-usedVia                           # Writes out used vias only to DEF file
                                   # (bool, optional)
-verilog_from_def_netlist_flow     # Reconciles the names in the DEF and
                                   # Verilog files generated by the loadDefFile
                                   # command (bool, optional)
-vias                              # Writes via information to the VIAS section
                                   # of the DEF file (bool, optional)