Usage: editChangeVia [-help] [-net <net>] [-signal_only {1 0}] {[-from <string> [-area {x1 y1 x2 y2} | -at {x y} ]] [-selected ]} {-to <string> | [-via_columns <integer> -via_rows <integer> [-cut_class <string>]]}

-help                   # Prints out the command usage
-area {x1 y1 x2 y2}     # Specifies an area in which to replace vias.
                        # (box, required)
-at {x y}               # Specifies the coordinates for the origin of a via to
                        # replace. (point, required)
-cut_class <string>     # Specifies the cut class for vias (string, optional)
-from <string>          # Specifies a via or list of vias to replace.
                        # (string, required)
-net <net>              # Specifies the net name on which to changes vias
                        # ((net), optional)
-selected               # Specifies whether to replace vias for selected ones
                        # only (bool, optional)
-signal_only {1 0}      # Specifies whether signal vias only or signal and
                        # special vias are changes. (enum, optional)
-to <string>            # Specifies a via or a list of vias to replace the vias
                        # indicated by the -from parameter. (string, required)
-via_columns <integer>  # Specifies the columns for vias (int, optional)
-via_rows <integer>     # Specifies the rows for vias (int, optional)