Usage: update_rc_corner [-help] [-T <temperatureValue>]
                        [-cap_table <newcapTableFile>]
                        -name <existingRcCornerName>
                        [-postRoute_cap {capFactor1 capFactor2 capFactor3}]
                        [-postRoute_clkcap {capFactor1 capFactor2 capFactor3}]
                        [-postRoute_clkres {resFactor1 resFactor2 resFactor3}]
                        [-postRoute_res {resFactor1 resFactor2 resFactor3}]
                        [-postRoute_xcap {xcapFactor1 xcapFactor2 xcapFactor3}]
                        [-preRoute_cap <capFactor>]
                        [-preRoute_clkcap <capFactor>]
                        [-preRoute_clkres <resFactor>]
                        [-preRoute_res <resFactor>]
                        [-qx_tech_file <newFileName>]
                        [-thru_substrate_cell_subckt_file <fileName>]
                        [-via_variation_file <fileName>]

-help                            # Prints out the command usage
-T <temperatureValue>            # Specifies a new temperature, in units of
                                 # Celsius, to use to derate resistance values
                                 # (float, optional)
-cap_table <newcapTableFile>     # Specifies a new capacitance table (file) to
                                 # use for extraction when using this RC corner
                                 # (string, optional)
-name <existingRcCornerName>     # Specifies the name of the existing RC corner
                                 # object to update (string, required)
-postRoute_cap {capFactor1 capFactor2 capFactor3}
                                 # Specifies the capacitance scale factor for
                                 # RC Extraction in post-route mode
                                 # (string, optional)
-postRoute_clkcap {capFactor1 capFactor2 capFactor3}
                                 # Specifies the clock capacitance scale factor
                                 # for RC extraction in post-route mode with
                                 # the effortLevel parameter set to low
                                 # (string, optional)
-postRoute_clkres {resFactor1 resFactor2 resFactor3}
                                 # Specifies the clock resistance scale factor
                                 # for RC extraction in post-route mode with
                                 # the effortLevel parameter set to low
                                 # (string, optional)
-postRoute_res {resFactor1 resFactor2 resFactor3}
                                 # Specifies the resistance scale factor for RC
                                 # extraction in post-route mode with the
                                 # effortLevel parameter set to low
                                 # (string, optional)
-postRoute_xcap {xcapFactor1 xcapFactor2 xcapFactor3}
                                 # Specifies a new cross-coupling capacitance
                                 # scale factor (string, optional)
-preRoute_cap <capFactor>        # Specifies the capacitance scale factor for
                                 # RC Extraction in pre-route mode
                                 # (float, optional)
-preRoute_clkcap <capFactor>     # Specifies the clock capacitance scale factor
                                 # for RC Extraction in pre-route mode
                                 # (float, optional)
-preRoute_clkres <resFactor>     # Specifies the clock resistance scale factor
                                 # for RC Extraction in pre-route mode
                                 # (float, optional)
-preRoute_res <resFactor>        # Specifies the resistance scale factor for RC
                                 # Extraction in pre-route mode (float, optional)
-qx_tech_file <newFileName>      # Specifies a new QRC technology (.tch) file
                                 # which is used to perform sign-off RC
                                 # extraction (string, optional)
-thru_substrate_cell_subckt_file <fileName>
                                 # Specifies file containing subcircuit models
                                 # for FTV cells (string, optional)
-via_variation_file <fileName>   # Specifies a file for modeling via variation
                                 # (string, optional)