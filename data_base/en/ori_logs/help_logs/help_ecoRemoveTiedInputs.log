Usage: ecoRemoveTiedInputs [-help] [-base_cells <libCell/ptnCell>+]
                           [-ignore_base_cells <libCell/ptnCell>+]
                           [-ignore_insts <inst>+] [-insts <inst>+]
                           [-relaxed_placement]
                           [-state {prePlace preCTS postCTS postRoute}]
                           [-term <string>] [-verbose] [ -report ]

-help                                     # Prints out the command usage
-base_cells <libCell/ptnCell>+            # buffer cells to be used for fixing
                                          # ((libCell/ptnCell)+, optional)
-ignore_base_cells <libCell/ptnCell>+     # ignore any instances of these cells
                                          # from fixing
                                          # ((libCell/ptnCell)+, optional)
-ignore_insts <inst>+                     # ignore these instances from fixing
                                          # ((inst)+, optional)
-insts <inst>+                            # only fix these instances (default
                                          # all design minus ignored
                                          # instances/cells) ((inst)+, optional)
-relaxed_placement                        # accept moves even if instances
                                          # cannot be placed (bool, optional)
-report                                   # only report existing tied inputs,
                                          # but no fixing by any method
                                          # (bool, optional)
-state {prePlace preCTS postCTS postRoute}
                                          # current design state (enum, optional)
-term <string>                            # terms to be buffered
                                          # (string, optional)
-verbose                                  # increase the detail of reports and
                                          # fixing details (bool, optional)