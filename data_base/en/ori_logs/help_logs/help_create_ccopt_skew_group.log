Usage: create_ccopt_skew_group [-help] [-constrains <value>]
                               [-from_clocks <clock_names>]
                               [-from_constraint_modes <constraint_mode_names>]
                               [-from_delay_corners <delay_corner>+]
                               -name <skew_group_name>
                               [-target_insertion_delay <string>]
                               [-target_skew <string>] [ -sinks <pins> | -shared_sinks <pins> | -exclusive_sinks <pins> | -auto_sinks  | -filtered_auto_sinks <string> | -balance_skew_groups <skew_groups> ] [ -sources <pins> | -balance_skew_groups <skew_groups> ] [ -rank <rank> | -shared_sinks <pins> | -exclusive_sinks <pins> ]

-help                                   # Prints out the command usage
-auto_sinks                             # automatically determine the target
                                        # sinks (bool, optional)
-balance_skew_groups <skew_groups>      # specifies that the new skew groups
                                        # should be created by merging the
                                        # specified skew groups (string, optional)
-constrains <value>                     # indicates what the skew group should
                                        # constrain - none, default or all
                                        # (string, optional)
-exclusive_sinks <pins>                 # sink pins of the skew group,
                                        # exclusive to this skew group
                                        # (string, optional)
-filtered_auto_sinks <string>           # automatically determine the target
                                        # sinks, from the subset provided
                                        # (string, optional)
-from_clocks <clock_names>              # the clocks this skew group was
                                        # extracted for (string, optional)
-from_constraint_modes <constraint_mode_names>
                                        # the constraint mode this skew group
                                        # was extracted for (string, optional)
-from_delay_corners <delay_corner>+     # the delay corners associated with the
                                        # constraint modes this skew group was
                                        # extracted for
                                        # ((delay_corner)+, optional)
-name <skew_group_name>                 # user-defined identifier for this skew
                                        # group (string, required)
-rank <rank>                            # sets exclusive_sinks_rank property
                                        # for this skew group (int, optional)
-shared_sinks <pins>                    # sink pins of the skew group, shared
                                        # with other skew groups
                                        # (string, optional)
-sinks <pins>                           # sink pins of the skew group
                                        # (string, optional)
-sources <pins>                         # source pins of the skew group
                                        # (string, optional)
-target_insertion_delay <string>        # the insertion delay that clock tree
                                        # synthesis should aim for
                                        # (string, optional)
-target_skew <string>                   # the skew that clock tree synthesis
                                        # should aim for (string, optional)