Usage: setMsvMode [-help] [-reset] [-allowNestedDefaultDomain {true|false}]
                  [-allowPowerDomainMinGapZero {true|false}]
                  [-checkAllNetsForDomainCrossing {true|false}]
                  [-handleBackToBackIsolation {true|false}]
                  [-handlePD {true|false}] [-handlePDComplex {true|false}]
                  [-honorCpfGlobalConnectionSpecForAoBuffer {true|false}]
                  [-honorCpfGlobalConnectionSpecForShifter {true|false}]
                  [-honorDotLibRelatedPGPin {true|false}]
                  [-honorEffectiveDomainForIsoLsInsertion {true|false}]
                  [-markIsoEnablePinAsAlwaysOn {true|false}]
                  [-notUseTopFTermDomainForVoltage {true|false}]
                  [-shareWellAOBufferingSupport {true|false}]
                  [-upf_allow_shifter_voltage_mismatch {true|false}]
                  [-upf_insert_on_floating_pins {true|false}]

-help                                      # Prints out the command usage
-reset                                     # Resets all or specified options to default value
-allowNestedDefaultDomain {true|false}     # Allows a non-default power domain
                                           # member to be logically nested in a
                                           # default power domain
                                           # (bool, default=true)
-allowPowerDomainMinGapZero {true|false}
                                           # (bool, default=true)
-checkAllNetsForDomainCrossing {true|false}
                                           # Checks all the nets for domain
                                           # crossings (bool, default=true)
-handleBackToBackIsolation {true|false}    # Supports back-to-back isolation
                                           # insertion along cross-domain net
                                           # based on power intent ISO rule
                                           # (bool, default=false)
-handlePD {true|false}                     # To route intra-power domain nets
                                           # only within their power domains
                                           # (bool, default=true)
-handlePDComplex {true|false}              # to handle nets belong to multiple
                                           # power domains (bool, default=true)
-honorCpfGlobalConnectionSpecForAoBuffer {true|false}
                                           # Honors connection specs for AO
                                           # buffer based on the power intent
                                           # rules (bool, default=false)
-honorCpfGlobalConnectionSpecForShifter {true|false}
                                           # Honors connection specs for
                                           # shifters based on the CPF rules
                                           # (bool, default=false)
-honorDotLibRelatedPGPin {true|false}      # Honors timing library related PG
                                           # pins (bool, default=true)
-honorEffectiveDomainForIsoLsInsertion {true|false}
                                           # Honors effective domains for
                                           # ISO/LS insertions
                                           # (bool, default=true)
-markIsoEnablePinAsAlwaysOn {true|false}
                                           # To mark all Isolation cell's
                                           # enable pin as always on
                                           # (bool, default=true)
-notUseTopFTermDomainForVoltage {true|false}
                                           # Controls voltage using top fterm
                                           # domain for IO pin voltage
                                           # (bool, default=false)
-shareWellAOBufferingSupport {true|false}
                                           # (bool, default=true)
-upf_allow_shifter_voltage_mismatch {true|false}
                                           # (bool, default=true)
-upf_insert_on_floating_pins {true|false}
                                           # (bool, default=true)