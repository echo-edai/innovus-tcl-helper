Usage: map_activity_file [-help] [-gate_block <string>] [-golden <string>]
                         [-reset] [-rtl2gate <string>] [-rtl_block <string>]
                         [-two_column_mapping_file <string>]

-help                                 # Prints out the command usage
-gate_block <string>                  # Specifies the GATE activity block name
                                      # to map the block-level RTL mapping
                                      # files to the top-level RTL activity
                                      # files. (string, optional)
-golden <string>                      # Specifies whether RTL or Gate is
                                      # Golden. (string, optional)
-reset                                # Specifies to reset and ignore all the
                                      # previous mapping files. (bool, optional)
-rtl2gate <string>                    # Specifies instance name mapping between
                                      # RTL netlist and GATE level netlist.
                                      # (string, optional)
-rtl_block <string>                   # Specifies the RTL activity block name
                                      # to map the block-level RTL mapping
                                      # files to the top-level RTL activity
                                      # files. (string, optional)
-two_column_mapping_file <string>     # Specifies a file that contains the
                                      # instance name mapping between the RTL
                                      # netlist and GATE level netlist
                                      # (string, optional)