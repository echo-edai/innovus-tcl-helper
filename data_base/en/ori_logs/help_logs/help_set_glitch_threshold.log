Usage: set_glitch_threshold [-help] [-absolute] [-cells <string>]
                            [-derate_threshold]
                            [-failure_point {none input internal last}]
                            [-glitch_type {both vl vh vlu vho vl_vh vlu_vho}]
                            [-library_pins <string>] [-nets <string>]
                            [-pin_type {all clock data latch}] [-pins <string>]
                            [-threshold_type {reporting failure propagation}]
                            -value <float> [-views <string>]

-help                                # Prints out the command usage
-absolute                            # Is threshold value absolute
                                     # (bool, optional)
-cells <string>                      # specify list of library cell names
                                     # (list, optional)
-derate_threshold                    # Enable the threshold derating
                                     # (bool, optional)
-failure_point {none input internal last}
                                     # Specifies where the glitch criteria
                                     # applies, default: applies for both-
                                     # internal and last (enum, optional)
-glitch_type {both vl vh vlu vho vl_vh vlu_vho}
                                     # Specifies the glitch type for threshold
                                     # application.  default=both (enum, optional)
-library_pins <string>               # specify list of library pin names
                                     # (list, optional)
-nets <string>                       # specify list of net names
                                     # (list, optional)
-pin_type {all clock data latch}     # Specifies the pin type for threshold
                                     # application. default=all (enum, optional)
-pins <string>                       # specify list of instance pin names
                                     # (list, optional)
-threshold_type {reporting failure propagation}
                                     # Specifies the glitch threshold type (enum, optional)
-value <float>                       # The value (float, required)
-views <string>                      # specify list of view names
                                     # (list, optional)