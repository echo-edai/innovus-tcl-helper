Usage: legalizePin [-help] [-auto_pairing]
                   [-ignore {pin_spacing pin_spacing_constraint pin_spacing_routeBlk pin_width pin_depth pin_layer pin_min_area pin_on_track pin_abutment pin_non_nbr_abutment clones pin_color}]
                   [-internalPin] [-keepLayer] [-keepOrder] [-moveFixedPin]
                   [-pin {pinName | pinNameList}] [-snapToBoundary] [-verbose] [ -ptn <string> ] [-ptn <string> | {-pin_file <fileName> [-exclude_ptn <string>]} | -exclude_pin_file <fileName>]

-help                                      # Prints out the command usage
-auto_pairing                              # Command calculates the channel
                                           # width or distance between pins
                                           # which will be considered for
                                           # pairing (bool, optional)
-exclude_pin_file <fileName>               # Specify pin-list to be excluded
                                           # for partition in a file
                                           # (string, optional)
-exclude_ptn <string>                      # Specifies the list of exluded
                                           # partition for pin-file
                                           # (string, optional)
-ignore {pin_spacing pin_spacing_constraint pin_spacing_routeBlk pin_width pin_depth pin_layer pin_min_area pin_on_track pin_abutment pin_non_nbr_abutment clones pin_color}
                                           # Legalize taking the category(ies)
                                           # of ignore types into account.
                                           # (enum_list, optional)
-internalPin                               # Legalizes internal pins by moving
                                           # them to the closest track on the
                                           # preferred routing layer.
                                           # (bool, optional)
-keepLayer                                 # Maintains the pin layer while
                                           # legalizing the pins. (bool, optional)
-keepOrder                                 # Maintains the pin order while
                                           # legalizing pins irrespective of
                                           # the layers. (bool, optional)
-moveFixedPin                              # If you use this parameter, the
                                           # specified pins with a Fixed status
                                           # can also be moved. (bool, optional)
-pin {pinName | pinNameList}               # Specifies that the command should
                                           # be run on the specified pin(s)
                                           # only. (string, optional)
-pin_file <fileName>                       # Specify pin-list for partition in
                                           # a file (string, optional)
-ptn <string>                              # Specifies the partition for which
                                           # the pins will be checked.
                                           # (string, optional)
-snapToBoundary                            # Snaps internal partition pin(s) to
                                           # its boundary. (bool, optional)
-verbose                                   # Reports all the existing pin
                                           # violations. (bool, optional)