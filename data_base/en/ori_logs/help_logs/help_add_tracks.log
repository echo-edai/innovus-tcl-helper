Usage: add_tracks [-help] [-backside] [-honor_pitch] [-keep_default_width]
                  [-mask_pattern <string>] [-mode {replace append}]
                  [-offsets <string>] [-pitch_pattern <string>]
                  [-pitches <string>] [-rect_only_pattern <string>]
                  [-route_rule <string>] [-snap_m1_track_to_cell_pins]
                  [-width_pitch_pattern <string>]

-help                           # Prints out the command usage
-backside                       # generate tracks on backside layers
                                # (bool, optional)
-honor_pitch                    # honor pitches defined in LEF file
                                # (bool, optional)
-keep_default_width             # keep user specified default width
                                # (bool, optional)
-mask_pattern <string>          # mask pattern (string, optional)
-mode {replace append}          # incremental mode (enum, optional)
-offsets <string>               # offset pattern (string, optional)
-pitch_pattern <string>         # pitch pattern (string, optional)
-pitches <string>               # pitch pattern (string, optional)
-rect_only_pattern <string>     # rect only pattern (string, optional)
-route_rule <string>            # NDR rule name (string, optional)
-snap_m1_track_to_cell_pins     # snap M1 tracks to cell pins (bool, optional)
-width_pitch_pattern <string>   # width pattern (string, optional)