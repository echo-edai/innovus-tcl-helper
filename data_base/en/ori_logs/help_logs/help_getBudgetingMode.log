Usage: getBudgetingMode [-help] [-abutted] [-accumulated]
                        [-boundaryConditionTemplatePath] [-bufferDelayLibCell]
                        [-bufferDelaySelectionEffort] [-ccd] [-constantModel]
                        [-distributeMMMC] [-dontWriteWireLoad]
                        [-driveConstraint] [-fixTopLevelPaths]
                        [-handleComplexSDC] [-honorPortBoundaryCondition]
                        [-honorPortDelays] [-honorReportTimingFormat]
                        [-ignoreDontTouch] [-includeLatency]
                        [-includeWireLoadsInLib] [-inputLoad] [-justify]
                        [-justifyBudgetDir] [-keepPinListsForBlockPorts]
                        [-latencyOnClocks] [-localLatency] [-localUncertainty]
                        [-makeNegativeInputDelayZero] [-makeReducedTimingGraph]
                        [-masterClone] [-noFalsePathsForUnCstrPorts]
                        [-noHoldView] [-noSetupView] [-reportOrModifyBudget]
                        [-rptNegSlackOnPorts] [-sdcContents]
                        [-stageBasedFanoutDrivingFactor]
                        [-stageBasedPartitionMultiplier] [-stageBasedWeight]
                        [-useBoundaryCondition] [-virtualClock]
                        [-virtualOptEngine] [-writeConstraintsForClkOutputPorts]
                        [-writeFPForHold] [-writeLatencyPerClock]
                        [-quiet] [-nonDefault]

-help                                  # Prints out the command usage
-abutted                               # Assumes all partitions are abutted
                                       # (bool, default=false)
-accumulated                           # Write both interface and flat
                                       # constraints for nested partitions
                                       # under if {budget_use_accumulated != 1}
                                       # { } else { } conditions.
                                       # (bool, default=false)
-boundaryConditionTemplatePath         # Directory path containing model files
                                       # to be used with option
                                       # useBoundaryCondition template
                                       # (string, default="")
-bufferDelayLibCell                    # user defined buffer which should be
                                       # used for virtual buffer adjustment
                                       # (string, default="")
-bufferDelaySelectionEffort            # controls the tool effort for
                                       # calculating the buffer delay
                                       # adjustment internally
                                       # (enums={low high none}, default=none)
-ccd                                   # Generates scripts for verification of
                                       # time budgeting top and block
                                       # constraints against pre-budget chip
                                       # constraints using the CCD
                                       # (bool, default=false)
-constantModel                         # Specifies the type of timing model
                                       # created (bool, default=true)
-distributeMMMC                        # Distribute multiple analysis views
                                       # over multiple sessions
                                       # (bool, default=false)
-dontWriteWireLoad                     # write set_load with -wire_load
                                       # information (bool, default=false)
-driveConstraint                       # Driving boundary constraint to be
                                       # written on block input port
                                       # (enums={drive drive_cell input_transition}, default=drive_cell)
-fixTopLevelPaths                      # Slack value for which the top-level
                                       # timing budget is fixed, and remaining
                                       # budget is proportioned only for
                                       # partitions
                                       # (enums={none all negativeOnly positiveOnly}, default=none)
-handleComplexSDC                      # handle sdc files with complex
                                       # constructs and regular expressions in
                                       # push down (bool, default=false)
-honorPortBoundaryCondition            # Push down chip IO constraints to block
                                       # boundary pins which are directly
                                       # connected to chip IO (bool, default=true)
-honorPortDelays                       # Push down chip IO SID SOD values to
                                       # block IO if the two are directly
                                       # connected and abutting.
                                       # (bool, default=true)
-honorReportTimingFormat               # honor set_global report_timing_format
                                       # in justification reports
                                       # (bool, default=true)
-ignoreDontTouch                       # Specifies the handling of don't touch
                                       # objects (bool, default=false)
-includeLatency                        # Specifies whether the clock latency is
                                       # included in the set_input_delay and
                                       # set_output_delay constraints
                                       # (bool, default=true)
-includeWireLoadsInLib                 # Include the wire loads in library
                                       # model pin capacitance
                                       # (bool, default=false)
-inputLoad                             # write set_load for input pins
                                       # (bool, default=false)
-justify                               # controls the type of justification
                                       # (enums={delay exception lib_arc boundary_condition all}_list, default="")
-justifyBudgetDir                      # Alternate directory name for justify
                                       # reports when -justify is given with
                                       # deriveTimingBudget
                                       # (string, default=budget_justify)
-keepPinListsForBlockPorts             # Preserve all fan-in and fan-out lists
                                       # (bool, default=true)
-latencyOnClocks                       # write set_clock_latency on clocks
                                       # (bool, default=true)
-localLatency                          # Write user specific set_clock_latency
                                       # constraints, provided through
                                       # setPtnUserCnsFile command, in
                                       # partition constraint files
                                       # (bool, default=false)
-localUncertainty                      # Use local uncertainty specified
                                       # through setPtnUserCnsFile command for
                                       # partitions (bool, default=false)
-makeNegativeInputDelayZero            # To be backward compatible where
                                       # negative set input delays were made
                                       # zero (bool, default=true)
-makeReducedTimingGraph                # Enable running ART before Budgeting.
                                       # (bool, default=false)
-masterClone                           # controls the tool behaviour for master
                                       # clones
                                       # (enums={masterOnly merged uniqueViewPerHInst}, default=masterOnly)
-noFalsePathsForUnCstrPorts            # do not create false paths for
                                       # unconstrained ports (bool, default=false)
-noHoldView                            # Disable hold view budgeting
                                       # (bool, default=false)
-noSetupView                           # Disable setup view budgeting
                                       # (bool, default=false)
-reportOrModifyBudget                  # Enable the collection of data to use
                                       # the reportBudget and modifyBudget
                                       # commands (bool, default=false)
-rptNegSlackOnPorts                    # save warnings for ports having slack
                                       # less than the specified value
                                       # (float, default=-1000000)
-sdcContents                           # option to control SDC contents
                                       # (enums={full | pushDownOnly | boundaryConstraintsOnly | noBoundaryCondition | noBoundaryConstraints}, default=full)
-stageBasedFanoutDrivingFactor         # Fanout count of the pin, above which
                                       # we will add buffer stages in Timing
                                       # Graph (int, default=-1)
-stageBasedPartitionMultiplier         # List of partition hinsts with its
                                       # corresponding multiplication factor
                                       # (string, default="")
-stageBasedWeight                      # List of weights given for {Sequential
                                       # Combinational Buffer} cells
                                       # (string, default=1 1 1)
-useBoundaryCondition                  # Mechanism used for finding buffers to
                                       # be used as driver/load
                                       # (enums={optimized template actual empty}, default=template)
-virtualClock                          # Create additional virtual clocks for
                                       # budgeting (bool, default=true)
-virtualOptEngine                      # Specifies the virtual optimization
                                       # engine to be used
                                       # (enums={none earlyTimingEngine proto}, default=none)
-writeConstraintsForClkOutputPorts     # Write constraints for clock output
                                       # ports (bool, default=false)
-writeFPForHold                        # write false path -hold for all I/Os in
                                       # setup budgeting (bool, default=false)
-writeLatencyPerClock                  # write latency per clock instead of per
                                       # port (bool, default=false)
-quiet                                 # Displays the current settings in Tcl list format only
-nonDefault                            # Displays the current settings which are not default settings