Usage: fcroute [-help] [-area {x1 y1 x2 y2}] [-connectInsideArea]
               [-connectTsvToBump] [-connectTsvToPad] [-connectTsvToRingStripe]
               [-constraintFile <filename>] [-deleteExistingRoutes]
               [-designStyle {aio pio}] [-doubleBendRoute]
               [-extraConfig <filename>]
               [-jogControl {preferWithChanges preferSameLayer preferDifferentLayer}]
               [-keepDRC] [-layerChangeBotLayer <layerName>]
               [-layerChangeTopLayer <layerName>] [-minEscapeDistance <value>]
               [-msgRate <value>] [-overflowMap] [-routeWidth <float>]
               [-route_pg_style {none finger mesh}] [-spreadWiresFactor <value>]
               [-straightConnections {straightWithDrcClean straightWithChanges}]
               [-subclass <subclass_string>] -type {power signal} [-verbose] [-eco | -incremental ] [-nets <net_list|<filename|~<filename> | -selected_bump ] [-globalOnly ]

-help                                  # Prints out the command usage
-area {x1 y1 x2 y2}                    # Specifies coordinates for area
                                       # (box, optional)
-connectInsideArea                     # Connects inside area (bool, optional)
-connectTsvToBump                      # Connects tsv to bump (bool, optional)
-connectTsvToPad                       # Connects tsv to pad (bool, optional)
-connectTsvToRingStripe                # Connects tsv to ring stripe
                                       # (bool, optional)
-constraintFile <filename>             # (string, optional)
-deleteExistingRoutes                  # Deletes existing routes
                                       # (bool, optional)
-designStyle {aio pio}                 # Specifies design style
                                       # (enum, optional)
-doubleBendRoute                       # Allows double-bend routing
                                       # (bool, optional)
-eco                                   # Enable ECO mode Flipchip routing
                                       # (bool, optional)
-extraConfig <filename>                # Specifies extra config file
                                       # (string, optional)
-globalOnly                            # Runs global routing only
                                       # (bool, optional)
-incremental                           # Runs PIO mode incrementally
                                       # (bool, optional)
-jogControl {preferWithChanges preferSameLayer preferDifferentLayer}
                                       # Specifies jogging preference (enum_list, optional)
-keepDRC                               # Keeps DRC violations (bool, optional)
-layerChangeBotLayer <layerName>       # Specifies bottom-most metal layer
                                       # (string, optional)
-layerChangeTopLayer <layerName>       # specifies top-most metal layer
                                       # (string, optional)
-minEscapeDistance <value>             # Specifies minimum escape distance
                                       # (float, optional)
-msgRate <value>                       # Specifies message rate (int, optional)
-nets <net_list|<filename|~<filename>  # Specifies list of net name or net file
                                       # name (string, optional)
-overflowMap                           # Displays overflow map (bool, optional)
-routeWidth <float>                    # Specifies routing width
                                       # (float, optional)
-route_pg_style {none finger mesh}     # Specifies power routing style
                                       # (enum, optional)
-selected_bump                         # Route the selected bumps
                                       # (bool, optional)
-spreadWiresFactor <value>             # Specifies wire spreading factor
                                       # (float, optional)
-straightConnections {straightWithDrcClean straightWithChanges}
                                       # Specifies straight connections (enum, optional)
-subclass <subclass_string>            # Specific subclass name to be assigned
                                       # to the wires and vias created
                                       # (string, optional)
-type {power signal}                   # Specifies the bump type
                                       # (enum, required)
-verbose                               # Prints each progress message
                                       # (bool, optional)