Usage: trace_obj_connectivity [-help] [-clear_trace] [-level <integer>]
                              [-mode {netlist_based timing_based}]
                              [-out_file <string>] [-insts <string>] | [-ports <string>] | [-selected ] | [-in_files <string>]

-help                                  # Prints out the command usage
-clear_trace                           # clear existing trace result
                                       # (bool, optional)
-in_files <string>                     # load saved trace result
                                       # (string, optional)
-insts <string>                        # specify the macros to be traced
                                       # (string, optional)
-level <integer>                       # specify the trace level, default:1
                                       # (int, optional)
-mode {netlist_based timing_based}     # specify the trace mode.
                                       # netlist_based|timing_based
                                       # (enum, optional)
-out_file <string>                     # save trace result to specified file
                                       # (string, optional)
-ports <string>                        # specify the IO ports to be traced
                                       # (string, optional)
-selected                              # trace the selected macros or IO ports
                                       # (bool, optional)