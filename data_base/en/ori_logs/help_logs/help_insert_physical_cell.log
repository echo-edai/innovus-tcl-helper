Usage: insert_physical_cell [-help] [-cell <string>]
                            [-genTemplateOnly <string>] [-inputFile <string>]
                            [-insertRowAreaBoundary] [-averageWindow  | { [-insertNearBoundary ] [-box {x1 y1 x2 y2}] [-minimalNumberOfTCD <integer>]}] [-verifyWindow {x y} [ [-verifyOnly ] [-xStep <float>] [-yStep <float>] ] ]

-help                             # Prints out the command usage
-averageWindow                    # The size of windows for Insert cell  is
                                  # average of Core box (bool, optional)
-box {x1 y1 x2 y2}                # Insert/Check physical cell's bounding box
                                  # in <llx> <lly> <urx> <ury> (box, optional)
-cell <string>                    # Specify the physical cell name.
                                  # (string, optional)
-genTemplateOnly <string>         # Generate template file to guide how to
                                  # define spec file for DTCD, ICOVL and
                                  # LinerCell. (string, optional)
-inputFile <string>               # Specify the spec file for physical cells.
                                  # (string, optional)
-insertNearBoundary               # Insert physical cells near boundary
                                  # (bool, optional)
-insertRowAreaBoundary            # Specify to insert LinerCell around row area
                                  # boundary. (bool, optional)
-minimalNumberOfTCD <integer>     # the minimal number of DTCD need be
                                  # inserted. If current windows size
                                  # definition(WinSizeX and WinSizeY) cannot
                                  # fit this requirement. we will shrink window
                                  # size automatically. (int, optional)
-verifyOnly                       # Only verify the Insert physical cells, do
                                  # not insert cells  (bool, optional)
-verifyWindow {x y}               # The size of window for verify the Insert
                                  # physical cells (point, optional)
-xStep <float>                    # The moving x step of verify window
                                  # (float, optional)
-yStep <float>                    # The moving y step of verify window
                                  # (float, optional)