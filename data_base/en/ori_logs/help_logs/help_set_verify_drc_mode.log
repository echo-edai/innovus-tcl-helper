Usage: set_verify_drc_mode [-help] [-reset] [-area {lx ly ux uy}]
                           [-check_illegal_trim_shapes {true|false}]
                           [-check_ndr_spacing {true|false|auto}]
                           [-check_only {all|regular|special|selected_net|selected|cell|default}]
                           [-check_reverse {true|false}]
                           [-check_routing_halo {true|false}]
                           [-check_routing_halo_corner {true|false}]
                           [-check_same_via_cell {true|false}]
                           [-check_short_only {true|false}]
                           [-check_trim_length {true|false}]
                           [-check_uncolored {true|false}]
                           [-disable_rules {jog2jog_spacing|eol_spacing|cut_spacing|min_cut|enclosure|color|min_step|protrusion|min_area|out_of_die|off_manufacturing_grid|off_routing_track}]
                           [-enable_post_passive_fill_check {true|false}]
                           [-exclude_pg_net {true|false}]
                           [-ignore_cell_blockage {true|false}]
                           [-ignore_fill_wire {true|false}]
                           [-ignore_non_rectangle_shapes {true|false}]
                           [-ignore_trial_route {true|false}]
                           [-layer_range {layer1 [layer2]}] [-limit <value>]
                           [-max_wrong_way_halo <value>] [-report <file_name>]
                           [-use_min_spacing_on_block_obs {true|false|auto}]

-help                                    # Prints out the command usage
-reset                                   # Resets all or specified options to default value
-area {lx ly ux uy}                      # Specifies the coordinates of the
                                         # area to verify (box, default={0 0 0 0})
-check_illegal_trim_shapes {true|false}  # check illegal trim shapes.
                                         # (bool, default=false)
-check_ndr_spacing {true|false|auto}     # Specifies what kind of non-default
                                         # rule spacing to be checked
                                         # (enums={true false auto}, default=auto)
-check_only {all|regular|special|selected_net|selected|cell|default}
                                         # Specifies what kind of shapes to be
                                         # checked.
                                         # (enums={all regular special selected_net selected cell default}, default=default)
-check_reverse {true|false}              # report CONVEXCORNER REVERSE
                                         # violation. (bool, default=false)
-check_routing_halo {true|false}         # Check routing halo.
                                         # (bool, default=false)
-check_routing_halo_corner {true|false}  # Check routing halo in the corner
                                         # (bool, default=false)
-check_same_via_cell {true|false}        # Check the cut spacing from the same
                                         # via (bool, default=true)
-check_short_only {true|false}           # Exclude all DRC check except short.
                                         # (bool, default=false)
-check_trim_length {true|false}          # Consider max length in the trim
                                         # shape layer. (bool, default=false)
-check_uncolored {true|false}            # report color change violation when
                                         # the dpt layer shape is free color.
                                         # (bool, default=false)
-disable_rules {jog2jog_spacing|eol_spacing|cut_spacing|min_cut|enclosure|color|min_step|protrusion|min_area|out_of_die|off_manufacturing_grid|off_routing_track}
                                         # Disable the rule that from the
                                         # provided rule list. the rule list as
                                         # follow: (jog2jog_spacing |
                                         # eol_spacing cut_spacing min_cut
                                         # enclosure color min_step protrusion
                                         # min_area out_of_die
                                         # off_manufacturing_grid
                                         # off_routing_track)
                                         # (enums={jog2jog_spacing eol_spacing cut_spacing min_cut enclosure color min_step protrusion min_area out_of_die off_manufacturing_grid off_routing_track}_list, default= )
-enable_post_passive_fill_check {true|false}
                                         # Check full fill trim. (bool, default=false)
-exclude_pg_net {true|false}             # Excludes the checking of power and
                                         # ground nets. (bool, default=false)
-ignore_cell_blockage {true|false}       # Ignore geometries of cell blockage.
                                         # (bool, default=false)
-ignore_fill_wire {true|false}           # Ignore metalfill wires when check
                                         # drc. (bool, default=false)
-ignore_non_rectangle_shapes {true|false}
                                         # ignore non-rectangle shapes. (bool, default=false)
-ignore_trial_route {true|false}         # Ignore trial route when check drc.
                                         # (bool, default=false)
-layer_range {layer1 [layer2]}           # Checks between the range of metal
                                         # layers including cut layers in
                                         # between (string, default="")
-limit <value>                           # Specifies the maximum number of
                                         # errors to report (int, default=1000)
-max_wrong_way_halo <value>              # Specifies the maximum wrong way halo
                                         # (float, default=-1)
-report <file_name>                      # Specifies the report file that
                                         # contains the violations information
                                         # (string, default="")
-use_min_spacing_on_block_obs {true|false|auto}
                                         # Use min spacing to check for block
                                         # OBS.
                                         # (enums={true false auto}, default=auto)