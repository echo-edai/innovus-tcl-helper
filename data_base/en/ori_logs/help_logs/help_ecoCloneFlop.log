Usage: ecoCloneFlop [-help] [-batchMode] [-force] -instances <inst names>
                    [-max_num_loads <num>] [-numClones <num>] [-radius <num>]
                    [-verbose]

-help                    # Prints out the command usage
-batchMode               # if several instances are specified, clone them all
                         # with no timing update in between (bool, optional)
-force                   # force instance cloning, even if it worsens QoR.
                         # (bool, optional)
-instances <inst names>  # list of instances to clone (wildcards allowed)
                         # (string, required)
-max_num_loads <num>     # skip cloning instances driving more than these many
                         # loads. Default 50000. (int, optional)
-numClones <num>         # specifies how many clones to have in the end
                         # (int, optional)
-radius <num>            # place clones within a radius of <num> rows from its
                         # preferred location based on original instance
                         # location and center of mass of new set of loads.
                         # Default 10. (int, optional)
-verbose                 # display extra information about what is going on
                         # (bool, optional)