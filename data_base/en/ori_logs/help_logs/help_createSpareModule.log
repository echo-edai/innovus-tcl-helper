Usage: createSpareModule [-help]
                         -cell <cellName [number] [cellName [number] ] ...>
                         [-clock <netName>] -moduleName <moduleName>
                         [-reset <netName:pinName [pinName] ...>]
                         [-tie <tieCellName [tieCellname]>]
                         [-tieLo <cellName:pinName [pinName | *]...>]
                         [-useCellAsPrefix]

-help                                      # Prints out the command usage
-cell <cellName [number] [cellName [number] ] ...>
                                           # (string, required)
-clock <netName>                           # (string, optional)
-moduleName <moduleName>                   # (string, required)
-reset <netName:pinName [pinName] ...>     # (string, optional)
-tie <tieCellName [tieCellname]>           # (string, optional)
-tieLo <cellName:pinName [pinName | *]...>
                                           # (string, optional)
-useCellAsPrefix                           # (bool, optional)