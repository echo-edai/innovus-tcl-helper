Usage: update_bus_guide [-help] [-avoidObstacles]
                        [-layer_horizontal {id | id1:id2}]
                        [-layer_vertical {id | id1:id2}] [-no_snap]
                        [-resize_direction {low high}] [-type {soft hard}] [-width <value> | -net_group <name> | {{-rule <rulename> | {-wire_width <value> -wire_spacing <value>}} [-with_shield ]}]

-help                                # Prints out the command usage
-avoidObstacles                      # Specifies whether to avoid pre-routes
                                     # and blockages (bool, optional)
-layer_horizontal {id | id1:id2}     # Horizontal layer id or a layer range
                                     # (string, optional)
-layer_vertical {id | id1:id2}       # Verticle layer id or a layer range
                                     # (string, optional)
-net_group <name>                    # Specifies net group name.
                                     # ((netGroup), optional)
-no_snap                             # Specifies whether not to snap the
                                     # busguide (bool, optional)
-resize_direction {low high}         # The resize direction (enum, optional)
-rule <rulename>                     # Specifies rule name or default
                                     # (string, optional)
-type {soft hard}                    # Specifies the new constraint type of bus
                                     # guide. (enum, optional)
-width <value>                       # Specifies bus guide width
                                     # (float, optional)
-wire_spacing <value>                # Specifies wire spacing (float, optional)
-wire_width <value>                  # Specifies wire width (float, optional)
-with_shield                         # Specifies whether to add shield wire
                                     # (bool, optional)