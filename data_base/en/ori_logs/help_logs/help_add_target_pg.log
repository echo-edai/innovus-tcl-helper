Usage: add_target_pg [-help] [-area {x1 y1 x2 y2}{x1 y1 x2 y2 x3 y3 x4 y4 ...}]
                     [-force] [-instance {list_of_instances}]
                     -nets {list_of_nets} -pin_layer <layer>
                     [-shape {STRIPE IOWIRE COREWIRE BLOCKWIRE}]
                     [-stack_layer_config {stack_layer_pattern}]
                     [-stack_layer_config_file <filename>] -target_layer <layer>
                     [-uda <subclass_string>]

-help                                   # Prints out the command usage
-area {x1 y1 x2 y2}{x1 y1 x2 y2 x3 y3 x4 y4 ...}
                                        # The instance inside the specified
                                        # area can be connected (string, optional)
-force                                  # Tool will keep the added PG even the
                                        # connection has DRC, and leaves there
                                        # a DRC marker (bool, optional)
-instance {list_of_instances}           # Specify the name of instances to be
                                        # connected (string, optional)
-nets {list_of_nets}                    # Specify the power/ground net names to
                                        # be connected (string, required)
-pin_layer <layer>                      # Specify the layer name of the cell to
                                        # be connected (string, required)
-shape {STRIPE IOWIRE COREWIRE BLOCKWIRE}
                                        # Specifies the wires and vias shape (enum, optional)
-stack_layer_config {stack_layer_pattern}
                                        # The value of this option defines the
                                        # pattern of the stripes on
                                        # intermediate layers between pin layer
                                        # and target layer (string, optional)
-stack_layer_config_file <filename>     # A config file defining the pattern of
                                        # the stripes on intermediate layer
                                        # between pin layer and target layer
                                        # (string, optional)
-target_layer <layer>                   # Specify the layer name of the
                                        # destination power/ground stripe
                                        # (string, required)
-uda <subclass_string>                  # Indicate the user defined attribute
                                        # subcalss of wires to route
                                        # (string, optional)