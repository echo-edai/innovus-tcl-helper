Usage: reportRouteTypeConstraints [-help] [-file <string>] [-svr] [-svrOnly]
                                  [-threshold <float>] [-summary  | -detailed ] [-detailed  [-timing ]]

-help                       # Prints out the command usage
-detailed                   # Print detailed report of layer constraints usage.
                            # (bool, optional)
-file <string>              # Specify the name of the report that will be
                            # generated. (string, optional)
-summary                    # Print summary report of layer constraints usage.
                            # (bool, optional)
-svr                        # Report pins with stack via rule constraints
                            # (bool, optional)
-svrOnly                    # Only report pins with stack via rule constraints
                            # (bool, optional)
-threshold <float>          # Maximum routing adherence for a net to be
                            # included in detailed report (default : 80 which
                            # means only nets with adherence < 80 % will be
                            # included in detailed report). (float, optional)
-timing                     # Extract timing information for nets analyzed.
                            # (bool, optional)