Usage: editPowerVia [-help] [-area <{x1 y1 x2 y2} {x3 y3 x4 y4} ...>]
                    [-bottom_layer <layername>] [-cell_pins <string>]
                    [-create_via_on_merged_target_on_layer <string>]
                    [-create_via_on_merged_target_within <float>]
                    [-create_via_on_signal_pins <0|1>]
                    [-exclude_stack_vias <0|1>]
                    [-followpin_via_stapling {cutclass1 weight1 cutclass2 weight2}]
                    [-nets <string>] [-orthogonal_only <0|1>]
                    [-same_sized_stack_vias <0|1>]
                    [-skip_via_on_pin [pad block cover standardcell physicalpin]]
                    [-skip_via_on_wire_shape [blockring stripe followpin corewire blockwire iowire padring ring fillwire noshape]]
                    [-skip_via_on_wire_status [routed fixed cover shield]]
                    [-split_long_via {threshold step offset length}]
                    [-split_vias <0|1>] [-top_layer <layername>]
                    [-uda <subclass_string>]
                    [-via_using_exact_crossover_size <0|1>] [-add_vias <0|1> | -delete_vias <0|1> | -modify_vias <0|1> ] [-between_selected_wires <0|1> | -selected_blocks <0|1> | -selected_wires <0|1> | -selected_vias <0|1>] [[[-via_columns <integer>] [-via_rows <integer>]] | [[-via_height <float>] [-via_width <float>]] | [[-via_scale_height <float>] [-via_scale_width <float>]]]

-help                                     # Prints out the command usage
-add_vias <0|1>                           # Specifies to add vias
                                          # (bool, optional)
-area <{x1 y1 x2 y2} {x3 y3 x4 y4} ...>   # Specifies to drop vias within areas
                                          # (string, optional)
-between_selected_wires <0|1>             # Specifies to drop vias between
                                          # selected wires (bool, optional)
-bottom_layer <layername>                 # Specifies the bottom-most metal
                                          # layer (string, optional)
-cell_pins <string>                       # Specifies PG terminals or pins to
                                          # drop vias on (string, optional)
-create_via_on_merged_target_on_layer <string>
                                          # Drops vias on merged targets
                                          # instead of original ones
                                          # (string, optional)
-create_via_on_merged_target_within <float>
                                          # Merges the targets within the
                                          # specified distance on the specified
                                          # layer (float, optional)
-create_via_on_signal_pins <0|1>          # Specifies to create vias on signal
                                          # pins (bool, optional)
-delete_vias <0|1>                        # Specifies to delete vias
                                          # (bool, optional)
-exclude_stack_vias <0|1>                 # Specifies to generate stack vias
                                          # (bool, optional)
-followpin_via_stapling {cutclass1 weight1 cutclass2 weight2}
                                          # Defines two cut classes to be tried
                                          # in priority in followpin via
                                          # stapling, weight value is for via
                                          # insertion ratio calculation
                                          # (string, optional)
-modify_vias <0|1>                        # Specifies to modify vias
                                          # (bool, optional)
-nets <string>                            # Specifies the nets to drop vias on
                                          # (string, optional)
-orthogonal_only <0|1>                    # Creates vias only on intersections
                                          # of orthogonal wires and pins
                                          # (bool, optional)
-same_sized_stack_vias <0|1>              # Generates same-sized stacked vias
                                          # (bool, optional)
-selected_blocks <0|1>                    # Specifies to drop vias on selected
                                          # blocks (bool, optional)
-selected_vias <0|1>                      # Specifies to modify selected vias
                                          # (bool, optional)
-selected_wires <0|1>                     # Specifies to drop vias on selected
                                          # wires (bool, optional)
-skip_via_on_pin [pad block cover standardcell physicalpin]
                                          # Skips via creation on pin of
                                          # specified type (enum_list, optional)
-skip_via_on_wire_shape [blockring stripe followpin corewire blockwire iowire padring ring fillwire noshape]
                                          # Skips via creation on wire of
                                          # specified shape (enum_list, optional)
-skip_via_on_wire_status [routed fixed cover shield]
                                          # Skips via creation on wire of
                                          # specified status (enum_list, optional)
-split_long_via {threshold step offset length}
                                          # Split vias longer than <threshold>
                                          # into smaller vias with specified
                                          # <step> and bottom/left end <offset>
                                          # and vertical/horizontal <length>
                                          # (string, optional)
-split_vias <0|1>                         # Specifies whether to split vias
                                          # when obs intervenes (bool, optional)
-top_layer <layername>                    # Specifies the top-most metal layer
                                          # (string, optional)
-uda <subclass_string>                    # Attaches to via the user defined
                                          # attribute subclass (string, optional)
-via_columns <integer>                    # Specifies the number of cuts to
                                          # make in the vias (int, optional)
-via_height <float>                       # Specifies via height
                                          # (float, optional)
-via_rows <integer>                       # Specifies the number of cuts to
                                          # make in the vias (int, optional)
-via_scale_height <float>                 # Specifies the percentage to scale
                                          # on via height (float, optional)
-via_scale_width <float>                  # Specifies the percentage to scale
                                          # on via width (float, optional)
-via_using_exact_crossover_size <0|1>     # Specifies to generate partial vias
                                          # from the exact crossover size
                                          # (bool, optional)
-via_width <float>                        # Specifies via width
                                          # (float, optional)