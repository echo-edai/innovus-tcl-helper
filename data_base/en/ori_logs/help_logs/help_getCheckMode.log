Usage: getCheckMode [-help] [-all] [-checkIlm] [-extraction] [-floorplan]
                    [-globalNet] [-integrity] [-io] [-library] [-mgrid]
                    [-netlist] [-placement] [-route] [-sroute] [-tapeOut]
                    [-timingGraph] [-vcellnetlist] [-quiet] [-nonDefault]

-help                      # Prints out the command usage
-all                       # Performs all checks (bool, default=false)
-checkIlm                  # check ILM model (bool, default=false)
-extraction                # Checks that all data required for extraction are
                           # correct (bool, default=false)
-floorplan                 # Checks floorplan (bool, default=false)
-globalNet                 # After init_design or restoreDesign, will do the
                           # same checks as checkDesign -powerGround
                           # (bool, default=false)
-integrity                 # (bool, default=false)
-io                        # Checks IO (bool, default=false)
-library                   # After init_design or restoreDesign, will do the
                           # same checks as checkDesign -physicalLibrary
                           # -timingLibrary (bool, default=false)
-mgrid                     # Checks that geometries are on the manufacturing
                           # grid (bool, default=false)
-netlist                   # After reading in the netlist, will do the same
                           # checks as checkDesign -netlist (bool, default=false)
-placement                 # Checks placement (bool, default=false)
-route                     # Checks whether power and ground pins are connected
                           # to power and ground nets before power routing
                           # (bool, default=false)
-sroute                    # Checks special route (bool, default=false)
-tapeOut                   # When reading the netlist will error out if there
                           # are undefined instances or ports (rather than
                           # create black_boxes or empty modules)
                           # (bool, default=false)
-timingGraph               # Checks library cells for timing information
                           # (bool, default=false)
-vcellnetlist              # Checks for tie-high and tie-low output pins when
                           # reading the Verilog netlist (bool, default=true)
-quiet                     # Displays the current settings in Tcl list format only
-nonDefault                # Displays the current settings which are not default settings