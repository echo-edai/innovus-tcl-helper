Usage: highlight_pin_connection [-help] -from_pin <pin|port>
                                [-mode {wire_segment whole_net flight_line}]
                                -to_pin <pin|port> [ -with_arrow  | -select_only  ] [ -net_color_index <integer> | -select_only  ] [ -inst_color_index <integer> | -select_only  ]

-help                          # Prints out the command usage
-from_pin <pin|port>           # Specify the from term.
                               # ((instTerm|term), required)
-inst_color_index <integer>    # specify inst color
                               # (int, optional, min=1, max=64)
-mode {wire_segment whole_net flight_line}
                               # specify draw mode (enum, optional)
-net_color_index <integer>     # specify net color
                               # (int, optional, min=1, max=64)
-select_only                   # (bool, optional)
-to_pin <pin|port>             # Specify the to term.
                               # ((instTerm|term), required)
-with_arrow                    # define connection with arrow or not
                               # (bool, optional)