Usage: set_module_model [-help] [-allow_port_mismatch] [-dir <string>]
                        [-hold_views <string>] [-phys_hier]
                        [-setup_views <string>] [-tag <string>] [-type <string>]
                        [-update] {[[[[-cell <string>] [-default_set_options <string>]] | [-top <string> [-logical_only ]]] [-add_ons <string>]] | -default_dir <string> | -default_create_options <string> | -default_commit_options <string> | -active_rc_corners <string> }

-help                                # Prints out the command usage
-active_rc_corners <string>          # <active rc corner> (string, optional)
-add_ons <string>                    # <associated with -type> 1801
                                     # boundary_model etm latency pnr_view
                                     # scan_info spef timing_context
                                     # extraction_context (string, optional)
-allow_port_mismatch                 # Allow top-level I/O ports mismatching
                                     # from the original db (bool, optional)
-cell <string>                       # <module name> (string, optional)
-default_commit_options <string>     # <default commit options>
                                     # (string, optional)
-default_create_options <string>     # <default create options>
                                     # (string, optional)
-default_dir <string>                # <default model data directory>
                                     # (string, optional)
-default_set_options <string>        # <set default options> (string, optional)
-dir <string>                        # <model data directory>
                                     # (string, optional)
-hold_views <string>                 # <hold_views> (string, optional)
-logical_only                        # <read in logical data only>
                                     # (bool, optional)
-phys_hier                           # <setup physical hierarchy>
                                     # (bool, optional)
-setup_views <string>                # <setup views> (string, optional)
-tag <string>                        # <flow tag> (string, optional)
-top <string>                        # <top module name> (string, optional)
-type <string>                       # <type of module model> lef flexIlm ilm
                                     # pnr pnr_shell (string, optional)
-update                              # Forced model update (bool, optional)