Usage: merge_hierarchical_def [-help] <defFiles <...>> [-add_blockage]
                              [-delete_blockages_over_partition_macro]
                              [-ignore_drcfill] [-incremental_ilm_def]
                              [-preserve_shape] [-rdl_def <string>]
                              [-rdl_orientation {N W S E FS FW FN FE}]
                              [-rdl_placement {x y}]
                              [-secondary {{suffix <def file list}...}]
                              [-skipNets] [-skip_filler] [-skip_pg]
                              [-skip_routing <string>] [-to_layer <layer>]
                              [-top_scope]
                              [-topcell_orientation {N W S E FS FW FN FE}]
                              [-topcell_placement {x y}]
                              [-transform_file <string>] [-use_top_def_die_area] [-modules <vCell>+ | -hInsts <hInst>+]

-help                                      # Prints out the command usage
<defFiles <...>>                           # Specifies DEF files to be merged
                                           # (List, required)
-add_blockage                              # indicate it's a reduced netlist
                                           # and undefined instances are
                                           # converted to blockages
                                           # (bool, optional)
-delete_blockages_over_partition_macro     # Delete top design placement and
                                           # routing blockages overlapping
                                           # partition (bool, optional)
-hInsts <hInst>+                           # Read data from def file(s)
                                           # associated to the specified
                                           # hInstance(s) ((hInst)+, optional)
-ignore_drcfill                            # Ignore the special routing with
                                           # DRCFILL shape attribute
                                           # (bool, optional)
-incremental_ilm_def                       # Incremental flatten ILM def
                                           # (bool, optional)
-modules <vCell>+                          # Read data from def file(s)
                                           # associated to the specified
                                           # module(s) ((vCell)+, optional)
-preserve_shape                            # Preserve shapes  (bool, optional)
-rdl_def <string>                          # Specifies RDL def file
                                           # (string, optional)
-rdl_orientation {N W S E FS FW FN FE}     # Specified orientation for RDL def
                                           # (enum, optional)
-rdl_placement {x y}                       # Specifies offset of RDL def
                                           # (point, optional)
-secondary {{suffix <def file list}...}    # Secondary Def file(s) to load
                                           # (string, optional)
-skipNets                                  # Skip merging signal nets section
                                           # (bool, optional)
-skip_filler                               # Skip Merging filler and decap
                                           # cells (bool, optional)
-skip_pg                                   # Skip merging routing on pg nets
                                           # (bool, optional)
-skip_routing <string>                     # Skip merging routing based on the
                                           # setting (string, optional)
-to_layer <layer>                          # Skip the routing on layers from
                                           # top to the specified layer if
                                           # 'high_layer_routing' is specified
                                           # to -skip_routing option, or from
                                           # bottom to the specified layer if
                                           # 'low_layer_routing' is specified
                                           # to -skip_routing option
                                           # ((layer), optional)
-top_scope                                 # Merging routing on top scope nets
                                           # only (bool, optional)
-topcell_orientation {N W S E FS FW FN FE}
                                           # Specifies orientation for topcell (enum, optional)
-topcell_placement {x y}                   # Specifies  placement for topcell
                                           # (point, optional)
-transform_file <string>                   # Report final x and y offsets,
                                           # orient in the top-level of each
                                           # LEF block that got replaced by
                                           # DEF, and block's origin
                                           # (string, optional)
-use_top_def_die_area                      # Use Top Def Die Area
                                           # (bool, optional)