Usage: ecoRoute [-help] [-ignore_route <string>] [-handlePartition ] [-fix_drc [-cut_color_flip {0 1}] [-trim_layer_patch ] [-layer_range <string>] [<area>]] [-fix_filler_drc_with_patch_only [-passive_fill ] [-layer_range <string>] [area]] [ -fix_filler_drc_with_patch_only | -fix_drc ] [-target | -fix_drc | -prototype ] [-modifyOnlyLayers <string> | -fix_drc ]

-help                               # Prints out the command usage
<area>                              # route area (box, optional)
-cut_color_flip {0 1}               # fix cut color drc by flipping
                                    # (enum, optional)
-fix_drc                            # fix drc (bool, optional)
-fix_filler_drc_with_patch_only     # fix filler related drc with metal patch
                                    # only (bool, optional)
-handlePartition                    # turn on handling partition flag
                                    # (bool, optional)
-ignore_route <string>              # eco selected nets with ignoring routes
                                    # (string, optional)
-layer_range <string>               # for -fix_drc within lowerLayer:upperLayer
                                    # (string, optional)
-modifyOnlyLayers <string>          # modify only on frozen metal layers within
                                    # lowerLayer:upperLayer (string, optional)
-passive_fill                       # do passive fill after filler fixing
                                    # (bool, optional)
-prototype                          # Do prototype eco routing (bool, optional)
-target                             # target (bool, optional)
-trim_layer_patch                   # fix trim only (bool, optional)