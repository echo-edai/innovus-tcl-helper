Usage: set_annotated_delay [-help] <delay_value> [-cond <expression>]
                           [-delta_only] [-fall] [-increment] [-max] [-min]
                           [-rise] {-net  | -cell } { [-from <from_pins>]  [-to <to_pins>]}

-help                 # Prints out the command usage
<delay_value>         # Specifies the delay value to be applied
                      # (float, required)
-cell                 # Specifies the annotated delay is to be applied on cell
                      # (bool, optional)
-cond <expression>    # Specifies that annotated delay is applied on arcs which
                      # has this condition as true (string, optional)
-delta_only           # Specifies that annotated delay is applied as
                      # incremental delay (bool, optional)
-fall                 # Specifies the annotated delay is applicable on fall
                      # transisiton (bool, optional)
-from <from_pins>     # Specifies that annotated delay is applied on arcs from
                      # this pin (string, optional)
-increment            # Increments the specified delay value on top of the
                      # existing base delay value (bool, optional)
-max                  # Specifies that annotated delay is applicable on late
                      # paths (bool, optional)
-min                  # Specifies that annotated delay is applicable on early
                      # paths (bool, optional)
-net                  # Specifies the annotated delay is to be applied on net
                      # (bool, optional)
-rise                 # Specifies the annotated delay is applicable on rise
                      # transisiton (bool, optional)
-to <to_pins>         # Specifies that annotated delay is applied on arcs to
                      # this pin (string, optional)