Usage: setRouteMode [-help] [-reset]
                    [-earlyGlobalEffortLevel {low|medium|standard}]
                    [-earlyGlobalHonorMsvRouteConstraint {true|false}]
                    [-earlyGlobalNumTracksPerClockWire <value>]
                    [-earlyGlobalReverseDirection <value>]
                    [-earlyGlobalRouteBumpNets {true|false}]
                    [-earlyGlobalRoutePartitionAllowFeedthru <value>]
                    [-earlyGlobalRoutePartitionHonorFence <value>]
                    [-earlyGlobalRoutePartitionHonorPin <value>]
                    [-earlyGlobalRoutePartitionPinGuide {true|false}]
                    [-earlyGlobalRouteSecondPG {true|false}]
                    [-earlyGlobalRouteSelectedNetsOnly {true|false}]
                    [-earlyGlobalRouteStripeLayerRange <value>]
                    [-earlyGlobalSecondPGMaxFanout <value>]

-help                                     # Prints out the command usage
-reset                                    # Resets all or specified options to default value
-earlyGlobalEffortLevel {low|medium|standard}
                                          # Specifies the congestion effort
                                          # level. Default is "standard", where
                                          # congestion is more accurate and
                                          # runtime is larger. If set to
                                          # "medium", runtime will be much
                                          # smaller and congestion report will
                                          # have less accuracy. Setting to
                                          # "low", it will be faster than
                                          # "medium" however less accurate.
                                          # (enums={low medium standard}, default=standard)
-earlyGlobalHonorMsvRouteConstraint {true|false}
                                          # consider MSV constraints while
                                          # routing (bool, default=false)
-earlyGlobalNumTracksPerClockWire <value>
                                          # Specify special number of tracks
                                          # per clock wires.
                                          # (int, default=0, min=0, max=8)
-earlyGlobalReverseDirection <value>      # Reverse routing direction in the
                                          # given region on the specified
                                          # layer-range. Example: "(x1 y1 x2
                                          # y2) M1:M2 (x3 y3 x4 y4) M3:M4 ..."
                                          # (string, default="")
-earlyGlobalRouteBumpNets {true|false}    # Do not ignore special nets if they
                                          # are connecting bumps
                                          # (bool, default=true)
-earlyGlobalRoutePartitionAllowFeedthru <value>
                                          # Honor partition fences with
                                          # feedthrough for
                                          # <list_of_ptn_cell_names>.
                                          # (string, default="")
-earlyGlobalRoutePartitionHonorFence <value>
                                          # Honor partition fences for
                                          # <list_of_ptn_cell_names>.
                                          # (string, default="")
-earlyGlobalRoutePartitionHonorPin <value>
                                          # Honor partition fences and
                                          # single-entry constraint for
                                          # <list_of_ptn_cell_names>.
                                          # (string, default="")
-earlyGlobalRoutePartitionPinGuide {true|false}
                                          # Honor partition pin guides. Default
                                          # is true (bool, default=true)
-earlyGlobalRouteSecondPG {true|false}    # Specifies whether secondary PG pins
                                          # needs to be routed or not
                                          # (bool, default=false)
-earlyGlobalRouteSelectedNetsOnly {true|false}
                                          # Only route the nets which are
                                          # selected in the DB.
                                          # (bool, default=false)
-earlyGlobalRouteStripeLayerRange <value>
                                          # Route secondary PG pins to access
                                          # to the PG stripes in the given
                                          # layer range. (string, default="")
-earlyGlobalSecondPGMaxFanout <value>     # Specifies the max fanout limit for
                                          # each secondary PG subnet
                                          # (int, default=2147483647, min=1, max=INT_MAX)