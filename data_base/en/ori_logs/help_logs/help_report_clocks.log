Usage: report_clocks [-help] [-adjustment_table] [-arrival_points]
                     [-delay_adjustment_table] [-description] [-generated]
                     [-groups] [-hierarchy] [-insertion] [-phase_shift_table]
                     [-source_insertion] [-tcl_list] [-total_shift_table]
                     [-uncertainty_table] [-view <view_name>] [> <filename>]
                     [>> <filename>] [-clocks <clk_signame> | <clk_signame_list>]

-help                           # Prints out the command usage
<clk_signame_list>              # List of clocks (string, optional)
-adjustment_table               # Tables giving detail of hold and setup cycle
                                # adjustments between clock waveforms
                                # (bool, optional)
-arrival_points                 # Reports only the clock arrival points
                                # (bool, optional)
-clocks <clk_signame>           # Requests information on a specific ideal (or
                                # generated) clock (string, optional)
-delay_adjustment_table         # Tables giving detail of early and late path
                                # delay adjustments between clock waveforms
                                # (bool, optional)
-description                    # Reports only the description of the specified
                                # clock waveform(s) (bool, optional)
-generated                      # Includes information on generated clocks in
                                # the report (bool, optional)
-groups                         # Reports the existing clock groups
                                # (bool, optional)
-hierarchy                      # Reports the inter-clock relationship in tree
                                # style format (bool, optional)
-insertion                      # Reports the network insertion delays
                                # specified on clock waveforms (bool, optional)
-phase_shift_table              # Reports the table that details the phase
                                # shift between clock waveforms (bool, optional)
-source_insertion               # Reports the source insertion delays specified
                                # on clock waveforms (bool, optional)
-tcl_list                       # Produces the report in Tcl list format
                                # instead of a tabular format (bool, optional)
-total_shift_table              # Reports one of the tables (late or early
                                # mode) that details the total relationship
                                # between clock waveforms (bool, optional)
-uncertainty_table              # Reports one of the tables (late mode or early
                                # mode) that detail the uncertainty between
                                # clock waveforms (bool, optional)
-view <view_name>               # Generates a report for the specified analysis
                                # view only (string, optional)
> <filename>                    # Writes the report to the specified file name
                                # (redirect_operator, optional)
>> <filename>                   # Writes the report to the specified file name
                                # (redirect_operator, optional)