Usage: report_route [-help] [-clock] [-em] [-fanout <integer>] [-fill]
                    [-inst <string>] [-multi_cut] [-ndr] [-net <string>]
                    [-net_length <float>] [-patch] [-pg_net <string>]
                    [-secondary_pg_nets <string>] [-selected] [-shield]
                    [-summary] [-tap_cells] [-via_pillar] [-track_utilization  [-area {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...} | -view_window ] [-layer <string>] [-include_regular_routes ]]

-help                           # Prints out the command usage
-area {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...}
                                # specify one or more areas (box_list, optional)
-clock                          # clock net (bool, optional)
-em                             # report EM statistics of nets (bool, optional)
-fanout <integer>               # minimum fanout for limit (int, optional)
-fill                           # patch wire and active fill information
                                # (bool, optional)
-include_regular_routes         # report track utilization (bool, optional)
-inst <string>                  # Instance name (string, optional)
-layer <string>                 # limit report to layer or layer_range as in
                                # -layer <> | -layer <>:<> (string, optional)
-multi_cut                      # multiple cut vias (bool, optional)
-ndr                            # Non Default Rule (bool, optional)
-net <string>                   # net name (string, optional)
-net_length <float>             # minimal net length in um (float, optional)
-patch                          # add patch wire info section (bool, optional)
-pg_net <string>                # PG net name (string, optional)
-secondary_pg_nets <string>     # second pg pin information (string, optional)
-selected                       # selected net (bool, optional)
-shield                         # shielded net (bool, optional)
-summary                        # summary (bool, optional)
-tap_cells                      # report shield with tap cells (bool, optional)
-track_utilization              # report track utilization (bool, optional)
-via_pillar                     # Via Pillar (bool, optional)
-view_window                    # report area in ui_view_box (bool, optional)