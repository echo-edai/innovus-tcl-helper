Usage: compare_model_timing [-help] [-absolute_cap_tolerance <float>]
                            [-absolute_tolerance <float>]
                            [-absolute_tolerance_optimistic <float>]
                            [-absolute_tolerance_pessimistic <float>]
                            [-absolute_tran_tolerance <float>] -compare <string>
                            [-ignore_view] -outFile <string>
                            [-percent_cap_tolerance <float>]
                            [-percent_tolerance <float>]
                            [-percent_tolerance_optimistic <float>]
                            [-percent_tolerance_pessimistic <float>]
                            [-percent_tran_tolerance <float>] -ref <string>

-help                                      # Prints out the command usage
-absolute_cap_tolerance <float>            # Specifies the tolerance value for
                                           # capacitance (as an absolute value)
                                           # while comparing two report files
                                           # (float, optional)
-absolute_tolerance <float>                # Specifies the absolute tolerance
                                           # value (float, optional)
-absolute_tolerance_optimistic <float>     # This switch will specify the
                                           # absolute tolerance limit for
                                           # flagging an optimistic failure. An
                                           # optimistic path violating absolute
                                           # as well as percentage tolerance
                                           # limit will be flagged as FAIL in
                                           # compare_model_timing output
                                           # report. Default value of this
                                           # switch is 15ps. (float, optional)
-absolute_tolerance_pessimistic <float>    # This switch will specify the
                                           # absolute tolerance limit for
                                           # flagging a pessimistic failure. A
                                           # pessimistic path violating
                                           # absolute as well as percentage
                                           # tolerance limit will be flagged as
                                           # FAIL in compare_model_timing
                                           # output report. Default value of
                                           # this switch is 15ps.
                                           # (float, optional)
-absolute_tran_tolerance <float>           # Specifies the tolerance value for
                                           # transition time at ports (as an
                                           # absolute value) while comparing
                                           # two report files (float, optional)
-compare <string>                          # Specifies the name of the report
                                           # file that contains the interface
                                           # timing characteristics extracted
                                           # from the model created using the
                                           # model extraction command
                                           # (string, required)
-ignore_view                               # Compares non-MMMC design
                                           # write_model_timing output report
                                           # with the MMMC design output report
                                           # of write_model_timing command
                                           # (bool, optional)
-outFile <string>                          # Specifies the name of the output
                                           # file in which the comparison
                                           # results will be generated
                                           # (string, required)
-percent_cap_tolerance <float>             # Specifies the tolerance value for
                                           # capacitance (as a percentage)
                                           # while comparing two report files
                                           # (float, optional)
-percent_tolerance <float>                 # Specifies the percentage tolerance
                                           # value for comparing the timing
                                           # data of two report files
                                           # (float, optional)
-percent_tolerance_optimistic <float>      # This switch will specify the
                                           # percentage tolerance limit for
                                           # flagging an optimistic failure. An
                                           # optimistic path violating
                                           # percentage as well as absolute
                                           # tolerance limit will be flagged as
                                           # FAIL in compare_model_timing
                                           # output report. Default value of
                                           # this switch is 3% (float, optional)
-percent_tolerance_pessimistic <float>     # This switch will specify the
                                           # percentage tolerance limit for
                                           # flagging a pessimistic failure. A
                                           # pessimistic path violating
                                           # percentage as well as absolute
                                           # tolerance limit will be flagged as
                                           # FAIL in compare_model_timing
                                           # output report. Default value of
                                           # this switch is 3% (float, optional)
-percent_tran_tolerance <float>            # Specifies the tolerance value for
                                           # transition time at ports (as a
                                           # percentage) while comparing two
                                           # report files (float, optional)
-ref <string>                              # Specifies the name of the
                                           # reference file that is used for
                                           # comparison. This is the report
                                           # file that was generated by using
                                           # the write_model_timing command on
                                           # the original design
                                           # (string, required)