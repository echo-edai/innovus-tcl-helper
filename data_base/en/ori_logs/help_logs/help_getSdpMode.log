Usage: getSdpMode [-help] [-clock_location] [-disable_extended_core]
                  [-honor_dont_use] [-honor_orient] [-legalization]
                  [-legalization_effort] [-max_move_distance] [-num_column]
                  [-place_report] [-pre_fixed_cells_blockage_direction]
                  [-quiet] [-nonDefault]

-help                                  # Prints out the command usage
-clock_location                        # ICG cell location
                                       # (string, default=center)
-disable_extended_core                 # disable the extended core flag
                                       # (bool, default=true)
-honor_dont_use                        # honor dont_use on base_cells during
                                       # EEQ swapping in SDP legalization
                                       # (bool, default=false)
-honor_orient                          # honor user specified orient during
                                       # legalization (bool, default=false)
-legalization                          # Specify fixed corner of sdp box during
                                       # legalizing sdp instance
                                       # (enums={NONE SW SE NW NE AUTO}, default=NONE)
-legalization_effort                   # Specifies the legalization effort in
                                       # placing SDP groups
                                       # (enums={low medium high}, default=low)
-max_move_distance                     # max sdp group move distance, default
                                       # is half perimeter of the core box
                                       # (float, default=0)
-num_column                            # number of column for sdp group
                                       # (int, default=2)
-place_report                          # Output a detailed sdp placement data.
                                       # Use empty string to reset to no output
                                       # (string, default="")
-pre_fixed_cells_blockage_direction    # Specify the direction when covering
                                       # preplaced std cells using placement
                                       # blockages
                                       # (enums={NONE X Y}_list, default=NONE)
-quiet                                 # Displays the current settings in Tcl list format only
-nonDefault                            # Displays the current settings which are not default settings