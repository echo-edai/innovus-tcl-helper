Usage: set_macro_place_constraint [-help] [<array elements>] [-array <string> [-common_hier <string>] [-valid_group_orients {R0 MX MY} ] [-place_order {horizontal vertical}] ] [{-insts <string> | -all_macros } [-orientation <string>] [-common_hier <string>]] [-cells <string> {-cell_obs <string> | -track_adjustment <string>}] [-cpg <string>] [[-max_io_pin_group_keep_out <string> ] [-forbidden_space_to_core <string>] [-forbidden_space_to_macro <string>] [-min_space_to_core <string>] [-min_space_to_macro <string>] [-parallel_run_length <string>] [-horizontal_stacking <string>] [-vertical_stacking <string>] [-honor_strict_spacing_constraint {true false}] [-avoid_abut_macro_edge_with_pins {true false}] [-same_length_site <integer> ] [-pg_resource_model <string>] [-macro_corner_keepout <string>][-halo_sharing {true false}] [-parallel_run_length_for_stacking <string>] [-power_domain_as_core {true false}] ]

-help                                   # Prints out the command usage
<array elements>                        # macro element list (string, optional)
-all_macros                             # indicate that all macros should honor
                                        # the constraints (bool, optional)
-array <string>                         # specify the macro array name
                                        # (string, optional)
-avoid_abut_macro_edge_with_pins {true false}
                                        # not abut macro edges with pins even
                                        # macro distance is within forbidden
                                        # spacing setting, default value is
                                        # true (enum, optional)
-cell_obs <string>                      # specify the layer width pitch to add
                                        # cell obstruction on each macro to
                                        # model power stripes (string, optional)
-cells <string>                         # specify the constraints for all
                                        # instances of a cell. (string, optional)
-common_hier <string>                   # specify the common logic hierarchy
                                        # name (string, optional)
-cpg <string>                           # specify the cpg guide of one instance
                                        # (string, optional)
-forbidden_space_to_core <string>       # specify one or two forbidden space to
                                        # core. If the space between macro and
                                        # core is smaller than this value, abut
                                        # the macros to core.
                                        # Two values are to define separate
                                        # forbidden space on horizontal and
                                        # vertical which should be included in
                                        # {}. (string, optional)
-forbidden_space_to_macro <string>      # specify one or two forbidden space to
                                        # macro. If the space between macros is
                                        # smaller than this value, abut the
                                        # macros.
                                        # Two values are to define separate
                                        # forbidden space on horizontal and
                                        # vertical which should be included in
                                        # {}. (string, optional)
-halo_sharing {true false}              # share halo when two macros are
                                        # abutted (enum, optional)
-honor_strict_spacing_constraint {true false}
                                        # honor forbidden spacing and minimum
                                        # spacing strictly, default value is
                                        # false (enum, optional)
-horizontal_stacking <string>           # specify the max horizontal stack
                                        # depth and the minimum horizontal
                                        # spacing (string, optional)
-insts <string>                         # specify the macros which will be set
                                        # the constraints on. (string, optional)
-macro_corner_keepout <string>          # specify macro corner spacing
                                        # constraint (string, optional)
-max_io_pin_group_keep_out <string>     # specify the max height and
                                        # (optionally) side extension to
                                        # automatically add macro-only
                                        # blockages to IO pins. (string, optional)
-min_space_to_core <string>             # specify one or two minimum space to
                                        # core. If the space between macro and
                                        # core is smaller than this value and
                                        # larger than forbidden space, push
                                        # them away from core to minimum
                                        # space.
                                        # Two values are to define separate
                                        # minimum space on horizontal and
                                        # vertical which should be included in
                                        # {}. (string, optional)
-min_space_to_macro <string>            # specify one or two the minimum space
                                        # to macro. If the space between macros
                                        # is less than this value and larger
                                        # than forbidden space, push them away
                                        # to minimum space.
                                        # Two values are to define separate
                                        # minimum space on horizontal and
                                        # vertical which should be included in
                                        # {}. (string, optional)
-orientation <string>                   # specify the allowable orientation for
                                        # macros. Overwrite the previous
                                        # definition. (string, optional)
-parallel_run_length <string>           # specify the parallel run length to
                                        # enable space checking. Two values are
                                        # to define separate parallel run
                                        # length on horizontal and vertical
                                        # which should be included in {}.
                                        # (string, optional)
-parallel_run_length_for_stacking <string>
                                        # specify one or two parallel run
                                        # length for stacking. Two values are
                                        # to define separate parallel run
                                        # length on horizontal and vertical
                                        # which should be included in {}.
                                        # (string, optional)
-pg_resource_model <string>             # specify the pg resource model
                                        # (string, optional)
-place_order {horizontal vertical}      # specify the place order, default
                                        # value is horizontal (enum, optional)
-power_domain_as_core {true false}      # Specifies that tool needs to treat
                                        # power domain boundary as core
                                        # boundary, default value is false
                                        # (enum, optional)
-same_length_site <integer>             # minimum number of site between
                                        # vertical edge of two macros
                                        # (int, optional, min=0, max=1000)
-track_adjustment <string>              # specify the layer density to add
                                        # track adjustment on each macro
                                        # (string, optional)
-valid_group_orients {R0 MX MY}         # valid orientations for the whole
                                        # group (enum_list, optional)
-vertical_stacking <string>             # specify the max vertical stack depth
                                        # and the minimum vertical spacing
                                        # (string, optional)