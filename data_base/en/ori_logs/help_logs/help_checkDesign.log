Usage: checkDesign [-help] {[-all [-danglingNet [highlight]]] | [[-io ] [-netlist [-danglingNet [highlight]]] [-physicalLibrary ] [-timingLibrary ] [-powerGround ] [-tieHiLo ] [-floorplan ] [-place ] [-spef ] [-assigns ]]} [[[-noText ] [-outdir <string>] [-browser ]] | [-noHtml [-outfile <string>]]]

-help                        # Prints out the command usage
-all                         # check all (bool, optional)
-assigns                     # Will report all assign statements in the
                             # netlist, including assigns to 1'b0/1'b1
                             # (bool, optional)
-browser                     # check browser (bool, optional)
-danglingNet [highlight]     # check dangling net (enum, optional)
-floorplan                   # check floorplan (bool, optional)
-io                          # check IO (bool, optional)
-netlist                     # check netlist (bool, optional)
-noHtml                      # check noHtml (bool, optional)
-noText                      # check noText (bool, optional)
-outdir <string>             # check outdir (string, optional)
-outfile <string>            # check outfile (string, optional)
-physicalLibrary             # check physical library (bool, optional)
-place                       # check place (bool, optional)
-powerGround                 # check PG (bool, optional)
-spef                        # check spef (bool, optional)
-tieHiLo                     # check tie HiLo (bool, optional)
-timingLibrary               # check timing library (bool, optional)