Usage: addAIORow [-help] [-abutRow] [-cluster_halo <space>] [-dx <x_dist>]
                 [-dy <y_dist>] [-esd <esites_no...>] [-noSnap] [-num <integer>]
                 [-orient {R0 R90 R180 R270 MX MX90 MY MY90}] [-rowName <name>]
                 [-shoulder <site_no...>] -site <siteName> [-soft] {-bump <bumpId> | -loc llx lly} [-H  | -V ] [-pitchX <dist> -ptnArrX <integer>] [-pitchY <dist> -ptnArrY <integer>]

-help                              # Prints out the command usage
-H                                 # to create horizontal rows.
                                   # (bool, optional)
-V                                 # to create vertical rows. (bool, optional)
-abutRow                           # to create two abut rows. (bool, optional)
-bump <bumpId>                     # specifies the bump Id (string, required)
-cluster_halo <space>              # specifies the size of halo around the
                                   # boundary of a row cluster (float, optional)
-dx <x_dist>                       # offsets the reference point to the first
                                   # I/O row in x (float, optional)
-dy <y_dist>                       # offsets the reference point to the first
                                   # I/O row in y (float, optional)
-esd <esites_no...>                # reserves the sites in a row as esd cells
                                   # (string, optional)
-loc <llx lly>                     # specifies the lower left x and y
                                   # coordinate reference points of the new I/O
                                   # row (point, required)
-noSnap                            # not snap the row to the standard cell
                                   # placement grid (bool, optional)
-num <integer>                     # specifies the number of sites
                                   # (int, optional)
-orient {R0 R90 R180 R270 MX MX90 MY MY90}
                                   # specifies the orientation for the row (enum, optional)
-pitchX <dist>                     # specifies the distance between I/O row in
                                   # x (float, optional)
-pitchY <dist>                     # specifies the distance between I/O row in
                                   # y (float, optional)
-ptnArrX <integer>                 # specifies the x dimensions of the row
                                   # cluster array size (int, optional)
-ptnArrY <integer>                 # specifies the y dimensions of the row
                                   # cluster array size (int, optional)
-rowName <name>                    # specifies the name or prefix of the area
                                   # I/O row (string, optional)
-shoulder <site_no...>             # reserves the sites in a row as shoulder
                                   # cells (string, optional)
-site <siteName>                   # specifies the site name for the area I/O
                                   # row (string, required)
-soft                              # to create soft I/O rows cluster
                                   # (bool, optional)