Usage: convert_lib_clock_tree_latencies [-help] [-latency_file_prefix <string>]
                                        [-pins <instTerm>+] [-views <string>]
                                        [-override_existing_latencies | -sum_existing_latencies]
                                        [-sum_existing_latencies | -override_existing_latencies_pins <instTerm>+]
                                        [-override_existing_latencies | -sum_existing_latencies_pins <instTerm>+]
                                        [-sum_existing_latencies | -sum_existing_latencies_pins <instTerm>+]
                                        [-override_existing_latencies | -override_existing_latencies_pins <instTerm>+]

-help                             # Prints out the command usage
-latency_file_prefix <string>     # Instead of applying changes, write commands
                                  # to one latency file per analysis view. Any
                                  # pre-existing files are overwritten.
                                  # (string, optional)
-override_existing_latencies      # Include all pins with existing latency
                                  # offsets and overwrite the existing latency
                                  # offsets. (bool, optional)
-override_existing_latencies_pins <instTerm>+
                                  # As per override_existing_latencies, but
                                  # only for the specified list of pins.
                                  # ((instTerm)+, optional)
-pins <instTerm>+                 # Specify clock endpoint pins to consider.
                                  # Defaults to all clock endpoints with the
                                  # max/min_clock_tree_path attributes.
                                  # ((instTerm)+, optional)
-sum_existing_latencies           # Include all pins with existing latency
                                  # offsets and sum the existing latency offset
                                  # with the library specified offset
                                  # (bool, optional)
-sum_existing_latencies_pins <instTerm>+
                                  # As per sum_existing_latencies, but only for
                                  # the specified list of pins.
                                  # ((instTerm)+, optional)
-views <string>                   # Specify the analysis views to operate on.
                                  # Defaults to all active analysis views.
                                  # (string, optional)