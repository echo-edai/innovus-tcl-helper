Usage: report_annotated_parasitics [-help] [-net_file <string>]
                                   [-nets <string>] [-view {viewName}]
                                   [> {write_fileName}] [>> {append_fileName}] [ { [-list_annotated ] [-list_broken_net ] [-list_float_net ] [-list_nodriver_net ] [-list_noload_net ] [-list_not_annotated ] [-list_real_net ] [-list_supply_net ] [-list_zero_cap_net ] [-list_extra_pin_net ] [-max_missing {max_missing_int}]}]

-help                                  # Prints out the command usage
-list_annotated                        # Generates list of annotated nets
                                       # (bool, optional)
-list_broken_net                       # Generates list of broken nets 
                                       # (bool, optional)
-list_extra_pin_net                    # Generates list of nets which have
                                       # extra pins in SPEF but not in Verilog 
                                       # (bool, optional)
-list_float_net                        # Generates list of floating nets 
                                       # (bool, optional)
-list_nodriver_net                     # Lists one terminal nets that has no
                                       # driver  (bool, optional)
-list_noload_net                       # Lists one terminal nets that have no
                                       # load (bool, optional)
-list_not_annotated                    # Generates list of non-annotated nets 
                                       # (bool, optional)
-list_real_net                         # Generates list of real nets
                                       # (bool, optional)
-list_supply_net                       # Lists all supply nets (bool, optional)
-list_zero_cap_net                     # Generates list of zero capacitance
                                       # nets  (bool, optional)
-max_missing {max_missing_int}         # Limits the no. of missing annotations
                                       # to the number specified (int, optional)
-net_file <string>                     # Input to this parameter is the valid
                                       # file name containing list of net names
                                       # for which annotation summary is
                                       # required. Net names in file can be
                                       # specified as one net per line.
                                       # (string, optional)
-nets <string>                         # specify the list of net names for
                                       # which annotation summary is required
                                       # (string, optional)
-view {viewName}                       # reports back annotated parasitics for
                                       # the specified analysis view
                                       # (string, optional)
> {write_fileName}                     # writes the report to the filename
                                       # (redirect_operator, optional)
>> {append_fileName}                   # appends the report to the fileName
                                       # (redirect_operator, optional)