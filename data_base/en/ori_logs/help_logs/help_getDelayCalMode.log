Usage: getDelayCalMode [-help] [-accuracy_level] [-advanced_accuracy_mode]
                       [-advanced_calculation_mode]
                       [-advanced_node_pin_cap_settings] [-advanced_pincap_mode]
                       [-combine_mmmc] [-early_irdrop_data_type]
                       [-enable_corner_based_beol] [-enable_high_fanout]
                       [-enable_input_slew_sensitivity_on_constraint]
                       [-enable_quiet_receivers_for_hold]
                       [-equivalent_waveform_model]
                       [-equivalent_waveform_model_for_timing_check] [-ewm_type]
                       [-honorSlewPropConstraint] [-ignoreNetLoad]
                       [-irdrop_data_type] [-irDrop_window_based]
                       [-late_irdrop_data_type] [-library_interpolation_mode]
                       [-nonlinear_voltage_scaling_improvements] [-ptr_effort]
                       [-reportOutBound] [-save_set_inst_voltage_cmd] [-SIAware]
                       [-signoff_alignment_settings]
                       [-skip_slew_merge_from_disabled_path]
                       [-slewOutBoundLimitHigh] [-slewOutBoundLimitLow]
                       [-socv_accuracy_mode] [-socv_lvf_mode]
                       [-socv_machine_learning_level] [-socv_use_lvf_tables]
                       [-use_top_interface_delay_in_context]
                       [-view_specific_settings]
                       [-voltage_scaling_compatibility_mode]
                       [-wire_variation_correlation_mode]
                       [-wire_variation_rc_correlation] [-quiet] [-nonDefault]

-help                                    # Prints out the command usage
-accuracy_level                          # set accuracy level for delay
                                         # calculation
                                         # (int, default=0, min=0, max=4)
-advanced_accuracy_mode                  # advanced accuracy level
                                         # (enums={medium high ultra}, default=medium)
-advanced_calculation_mode               # Enable advanced calculation mode for
                                         # base delay.
                                         # (enums={medium high}, default=medium)
-advanced_node_pin_cap_settings          # Enable advanced node pin cap
                                         # settings. (bool, default=false)
-advanced_pincap_mode                    # Enable advanced receiver pin cap
                                         # mode for base delay.
                                         # (enums={0 1 2}, default=0)
-combine_mmmc                            # Specifies whether delay calculation
                                         # runs are to be combined for delay
                                         # calculation simulations
                                         # (enums={none early_late early_late_corner}, default=early_late_corner)
-early_irdrop_data_type                  # IRDrop EIV DB EivMethod for early
                                         # corner
                                         # (enums={best_average worst best average worst_average}, default=worst)
-enable_corner_based_beol                # Enable Anchor corner based BEOL
                                         # analysis (bool, default=false)
-enable_high_fanout                      # Enables the default net delay which
                                         # will be annotated on high fanout
                                         # nets (bool, default=false)
-enable_input_slew_sensitivity_on_constraint
                                         # Enable input slew ensitivity on
                                         # constraint (bool, default=false)
-enable_quiet_receivers_for_hold         # (bool, default=false)
-equivalent_waveform_model               # Controls the equivalent waveform
                                         # model to be used
                                         # (enums={none no_propagation propagation}, default=none)
-equivalent_waveform_model_for_timing_check
                                         # Enable EWM for timing check delay. (bool, default=false)
-ewm_type                                # Equivalent waveform model type to be
                                         # used
                                         # (enums={moments simulation}, default=simulation)
-honorSlewPropConstraint                 # Determines whether to propagate the
                                         # slew from the disabled timing arcs
                                         # to the output pin. (bool, default=true)
-ignoreNetLoad                           # Uses zero-cap, zero-resistance
                                         # wire-load model for estimating
                                         # delays. (bool, default=false)
-irdrop_data_type                        # IRDrop EIV DB EivMethod
                                         # (enums={best_average worst best average worst_average}, default=worst)
-irDrop_window_based                     # Fetch window based EIV values from
                                         # EIV DB
                                         # (enums={none late early both}, default=both)
-late_irdrop_data_type                   # IRDrop EIV DB EivMethod for late
                                         # corner
                                         # (enums={best_average worst best average worst_average}, default=worst)
-library_interpolation_mode              # library scaling mode for
                                         # interpolation flow
                                         # (enums={linear non_linear non_linear_advanced}, default=linear)
-nonlinear_voltage_scaling_improvements  # Enables non-linear voltage scaling
                                         # improvements (bool, default=false)
-ptr_effort                              # PTR analysis effort. Should be
                                         # between 0 and 1: 0 - lowest accuracy
                                         # and runtime, 1 - highest accuracy
                                         # and runtime (float, default=0.5)
-reportOutBound                          # Generates a report that contains a
                                         # list of index values (input
                                         # transition) in the delay tables that
                                         # are beyond the index range.
                                         # (bool, default=false)
-save_set_inst_voltage_cmd               # Enable set_inst_voltage cmd saving
                                         # in persistant db (bool, default=false)
-SIAware                                 # Enables SIAware delay calculation
                                         # that also includes cross-talk
                                         # induced delays.
                                         # (enums={true false}, default=false)
-signoff_alignment_settings              # Turn on/off signoff alignment
                                         # settings (bool, default=false)
-skip_slew_merge_from_disabled_path      # Enable slew merge from disable path
                                         # (bool, default=false)
-slewOutBoundLimitHigh                   # Limits the maximum slew used in the
                                         # analysis to the specified value.
                                         # (float, default=3.40282346638529e+38, min=1, max=3.40282346638529e+38)
-slewOutBoundLimitLow                    # Limits the minimum slew used in the
                                         # analysis to the specified value.
                                         # (float, default=0.5, min=0.001, max=1)
-socv_accuracy_mode                      # level-based-accuracy-effort in AAE
                                         # for delays and slews
                                         # (enums={low medium high ultra}, default=low)
-socv_lvf_mode                           # Controls interpretation of LVF data.
                                         # (enums={moments early_late}, default=early_late)
-socv_machine_learning_level             # Enable socv machine learning mode
                                         # (int, default=0)
-socv_use_lvf_tables                     # Controls which type of variations
                                         # are considered during analysis.
                                         # (string, default=all)
-use_top_interface_delay_in_context      # Enables use of output stage delays
                                         # from top analysis in block context
                                         # analysis (bool, default=false)
-view_specific_settings                  # Spicifies a global variable value or
                                         # macro settings for particle view
                                         # using
                                         # {viewName:eng_global|macro:value}
                                         # (string, default="")
-voltage_scaling_compatibility_mode      # Enables voltage scaling
                                         # compatibility mode
                                         # (bool, default=false)
-wire_variation_correlation_mode         # Specify wire variatio inter layer
                                         # correlation
                                         # (enums={statistical binomial}, default=statistical)
-wire_variation_rc_correlation           # Same layer RC correlation for wire
                                         # variation (float, default=1)
-quiet                                   # Displays the current settings in Tcl list format only
-nonDefault                              # Displays the current settings which are not default settings