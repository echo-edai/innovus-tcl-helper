Usage: gui_trace_flightline [-help] -inst <string>
                            [-max_inout_number <integer>] {[-sink  -sink_level <integer> [-sink_color <string>]] | [-source  -source_level <integer> [-source_color <string>]]}

-help                           # Prints out the command usage
-inst <string>                  # Specify the flightline instance name which
                                # starts from  (string, required)
-max_inout_number <integer>     # Specify the max net terms, if the terms of
                                # one net on trace flightline exceed this
                                # value, flightline will be interrupted from
                                # this net. default : 50 (int, optional)
-sink                           # Always trace from output pin (bool, optional)
-sink_color <string>            # Speicify the color of sink trace
                                # (string, optional)
-sink_level <integer>           # Specify the sink trace level (int, optional)
-source                         # Always trace from input pin (bool, optional)
-source_color <string>          # Speicify the color of source trace
                                # (string, optional)
-source_level <integer>         # Specify the source trace level
                                # (int, optional)