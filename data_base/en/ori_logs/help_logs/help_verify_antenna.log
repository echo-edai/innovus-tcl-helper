Usage: verify_antenna [-help] [-detailed] [-limit <integer>]
                      [-no_max_float_area]
                      [-use {all | signal | power | clock | analog}] [ -nets <string> | -selected ] [-report <string> ]

-help                         # Prints out the command usage
-detailed                     # Generates a report containing the specified
                              # information for all nets, including those with
                              # no violations (bool, optional)
-limit <integer>              # Specifies the maximum number of error messages
                              # to report (int, optional)
-nets <string>                # Reports specified nets (string, optional)
-no_max_float_area            # Specifies disable verifying the max floating
                              # area violation (bool, optional)
-report <string>              # Specifies the report file. The file can contain
                              # PAE violation information (string, optional)
-selected                     # Reports selected nets (bool, optional)
-use {all | signal | power | clock | analog}
                              # Specifies what kind of net to be checked (enum, optional)