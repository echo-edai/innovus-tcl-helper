Usage: add_clock_tree_source_group_roots [-help] -cell <driverCell>
                                         [-locations {{x1 y1} {x2 y2}...}]
                                         -name <prefix> -pin <rootPin> [-grid {columns rows} [[-adjust_grid_for_aspect_ratio ] [-grid_rect {lx ly ux uy}] [-grid_search_area {width height}] [-grid_exclusion_rects {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...}]]]

-help                             # Prints out the command usage
-adjust_grid_for_aspect_ratio     # If necessary, exchange rows and columns to
                                  # match the aspect ratio (bool, optional)
-cell <driverCell>                # Driver cell to use for new source group
                                  # roots ((libCell/ptnCell), required)
-grid {columns rows}              # Specifies a grid for source group roots
                                  # (integer, optional)
-grid_exclusion_rects {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...}
                                  # Rectangles describing areas that should not
                                  # contain source group roots
                                  # (box_list, optional)
-grid_rect {lx ly ux uy}          # The area that the grid should cover
                                  # (box, optional)
-grid_search_area {width height}  # Size of search area around each grid point
                                  # (point, optional)
-locations {{x1 y1} {x2 y2}...}   # List of target root locations
                                  # (point_list, optional)
-name <prefix>                    # Naming prefix for new objects created by
                                  # this command, including the source group,
                                  # skew group, clock trees, and root instances
                                  # (string, required)
-pin <rootPin>                    # Pin that will drive the source group roots
                                  # ((instTerm|term), required)