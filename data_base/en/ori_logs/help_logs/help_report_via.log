Usage: report_via [-help] [-on_clock_nets] [-on_selected_nets] [-regular]
                  [-special] [ -detail ]

-help              # Prints out the command usage
-detail            # report detail info for every via (bool, optional)
-on_clock_nets     # If specified, the command reports vias only on clock nets
                   # in the design. If not specified, the command reports vias
                   # on all nets in the design by default. The option can be
                   # used with -detail, -special and -regular options.
                   # (bool, optional)
-on_selected_nets  # If specified, the command reports vias only on the nets
                   # selected by user. If not specified, the command reports
                   # vias on all nets in the design by default. The option can
                   # be used with -detail, -special and -regular options.
                   # (bool, optional)
-regular           # report regular routing vias (bool, optional)
-special           # report special routing vias (bool, optional)