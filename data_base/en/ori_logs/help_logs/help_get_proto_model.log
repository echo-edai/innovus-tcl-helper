Usage: get_proto_model [-help] [-committed] [-create_optimize_effort]
                       [-exclude <string>] [-file <string>] [-flip_table]
                       [-include_default] [-tcl] {-all | -model <string> | {[-type_match {flex_module flex_instgroup}] [-source_match {user auto}] }} [-name | [-type ] | [-create_total_area ] | [-create_gate_area ] | [-create_gate_count ] | [-create_area_per_gate ] | [-create_extra_macro ] | [-planDesign_target_util ] | [-flexfiller_route_blockage ] ]

-help                                # Prints out the command usage
-all                                 # Shows data for all specified models.
                                     # (bool, optional)
-committed                           # Reports attributes of committed models
                                     # only. (bool, optional)
-create_area_per_gate                # Reports the specified area per gate
                                     # value. (bool, optional)
-create_extra_macro                  # Reports the specified additional macros.
                                     # (bool, optional)
-create_gate_area                    # Reports the specified gate area value.
                                     # (bool, optional)
-create_gate_count                   # Reports the specified gate count value.
                                     # (bool, optional)
-create_optimize_effort              # Disabling/enabling optimization with
                                     # different effort. (bool, optional)
-create_total_area                   # Reports the total area value.
                                     # (bool, optional)
-exclude <string>                    # Excludes specified option.
                                     # (string, optional)
-file <string>                       # Specifies output file name.
                                     # (string, optional)
-flexfiller_route_blockage           # Reports percentages of flexFiller route
                                     # blockage. (bool, optional)
-flip_table                          # Flip the table output (rows to columns).
                                     # (bool, optional)
-include_default                     # Output default values (in parenthesis).
                                     # (bool, optional)
-model <string>                      # Reports attributes of specified model.
                                     # (string, optional)
-name                                # Reports model name only.
                                     # (bool, optional)
-planDesign_target_util              # Reports target utilization value that
                                     # will be used by planDesign.
                                     # (bool, optional)
-source_match {user auto}            # Specifies source type for reporting.
                                     # Default is {user auto}
                                     # (enum_list, optional)
-tcl                                 # Reports models as TCL list. Default is
                                     # table print. (bool, optional)
-type                                # Reports model type. (bool, optional)
-type_match {flex_module flex_instgroup}
                                     # Specify the type match for reporting.
                                     # Default is {flex_module}
                                     # (enum_list, optional)