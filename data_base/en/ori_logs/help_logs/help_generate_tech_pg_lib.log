Usage: generate_tech_pg_lib [-help] [-decap_cells <string>]
                            [-default_power_voltage <string>]
                            [-esd_cells <string>] [-filler_cells <string>]
                            [-keep {true false}] [-lef_layermap <string>]
                            [-output_dir <string>] [-power_gate_file <string>]
                            [-tech_file <string>] [-tech_only {true false}]

-help                               # Prints out the command usage
-decap_cells <string>               # <cell list> (string, optional)
-default_power_voltage <string>     # <power voltage> (string, optional)
-esd_cells <string>                 # <cell list> (string, optional)
-filler_cells <string>              # <cell list> (string, optional)
-keep {true false}                  # <true|false> (enum, optional)
-lef_layermap <string>              # <file name> (string, optional)
-output_dir <string>                # <output directory> (string, optional)
-power_gate_file <string>           # <file name> (string, optional)
-tech_file <string>                 # <file name> (string, optional)
-tech_only {true false}             # <true|false> (enum, optional)