Usage: verifyEndCap [-help] [-area <box>] [-coreBoundaryOnly]
                    [-error <integer>] [-ignore_macro <SCLA,...>]
                    [-powerDomain <string>] [-report <string>] [-row <string>]
                    [-tripleWell] [-wrongLocation]

-help                     # Prints out the command usage
-area <box>               # Area in which endcaps are to be verified
                          # (box, optional)
-coreBoundaryOnly         # Verify endcaps only at the core-boundary and not
                          # abutting obstructions (bool, optional)
-error <integer>          # Specifies the maximum number of errors to report
                          # (uint, optional)
-ignore_macro <SCLA,...>  # Specify which macro should be ignored
                          # (string, optional)
-powerDomain <string>     # Specify the power domain to check
                          # (string, optional)
-report <string>          # Specify the report file name. (string, optional)
-row <string>             # Specify the row to check. (string, optional)
-tripleWell               # Check triple well insertion. Only check the cell
                          # lists are specified in setEndMode. (bool, optional)
-wrongLocation            # Check the cells which are not in right location
                          # also. They are not check by default. (bool, optional)