Usage: editDelete [-help] [-area {x1 y1 x2 y2}] [-direction {H V 45 135}]
                  [-duplicate_via] [-floating_via] [-layer <string>]
                  [-nets <net>*] [-parallel_routing] [-physical_pin_only]
                  [-regular_wire_with_drc] [-selected]
                  [-shape {RING STRIPE FOLLOWPIN IOWIRE COREWIRE BLOCKWIRE PADRING BLOCKRING FILLWIRE FILLWIREOPC DRCFILL None}]
                  [-shield] [-shield_only]
                  [-status {FIXED NOSHIELD ROUTED SHIELD UNKNOWN}]
                  [-subclass <string>] [-trim_metal]
                  [-type {Regular Special Patch}] [-use {CLOCK POWER SIGNAL}]
                  [-via_cell <string>] [-with_edit_flag {0 1}] [-object_type {Wire Via} ]

-help                             # Prints out the command usage
-area {x1 y1 x2 y2}               # Specifies the coordinates for the area from
                                  # which to delete the wires. (box, optional)
-direction {H V 45 135}           # Specifies the orientation of the wires to
                                  # delete. (enum, optional)
-duplicate_via                    # Specifies delete duplicate vias
                                  # (bool, optional)
-floating_via                     # Specifies floating vias (bool, optional)
-layer <string>                   # Specifies the layers from which to delete
                                  # wires. (string, optional)
-nets <net>*                      # Specifies the net or list of nets from
                                  # which to delete wires. ((net)*, optional)
-object_type {Wire Via}           # Specified whether to select wires or vias
                                  # (enum_list, optional)
-parallel_routing                 # Specifies whether to delete parallel
                                  # routing (bool, optional)
-physical_pin_only                # Specifies physical pins (bool, optional)
-regular_wire_with_drc            # Specifies whether to delete regular wires
                                  # with violation markers. (bool, optional)
-selected                         # Specifies whether to delete the selected
                                  # wires. (bool, optional)
-shape {RING STRIPE FOLLOWPIN IOWIRE COREWIRE BLOCKWIRE PADRING BLOCKRING FILLWIRE FILLWIREOPC DRCFILL None}
                                  # Specifies the shapes of the wires to
                                  # delete. (enum_list, optional)
-shield                           # Specifies whether to delete the wires and
                                  # vias of nets specified by -nets and the
                                  # wires and vias shielding the nets specified
                                  # by the -nets parameter. (bool, optional)
-shield_only                      # Specifies whether to delete the wires and
                                  # vias shielding the nets specified by the
                                  # -nets parameter. (bool, optional)
-status {FIXED NOSHIELD ROUTED SHIELD UNKNOWN}
                                  # Specifies the status of wires to delete. (enum_list, optional)
-subclass <string>                # Specifies the subclass name of the wires to
                                  # be deleted. (string, optional)
-trim_metal                       # Specifies whether to delete trim metal.
                                  # (bool, optional)
-type {Regular Special Patch}     # Specifies whether to delete regular wires
                                  # or special wires or patch wires.
                                  # (enum, optional)
-use {CLOCK POWER SIGNAL}         # Specifies the use of wires will be deleted.
                                  # (enum, optional)
-via_cell <string>                # Specifies the via cells of vias to be
                                  # selected (string, optional)
-with_edit_flag {0 1}             # Specifies whether to delete the wires with
                                  # specified value of property "isEdit" on the
                                  # net (enum, optional)