Usage: deleteBufferTree [-help] [-excNetFile <excFileName>]
                        [-footprint <footPrintName>] [-preserveRoute] [-verbose] [ -selNetFile <selFileName> | -net {list of nets} ] [ -selNetFile <selFileName> ]

-help                                # Prints out the command usage
-excNetFile <excFileName>            # Specifies the file that contains the
                                     # names of hierarchical nets to exclude
                                     # from buffer removal.  (string, optional)
-footprint <footPrintName>           # Specifies the footprint of buffers to
                                     # remove. (string, optional)
-net {list of nets}                  # Specifies the  hierarchical nets to
                                     # include during buffer removal.
                                     # (string, optional)
-preserveRoute                       # preserveRoute (bool, optional)
-selNetFile <selFileName>            # Specifies the file that contains the
                                     # names of hierarchical nets to include
                                     # during buffer removal. (string, optional)
-verbose                             # verbose (bool, optional)