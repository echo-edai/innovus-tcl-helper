Usage: assignPtnPin [-help] [-basedOnMasterOnly] [-blackbox] [-debugPinAll]
                    [-debugPinFile <fileName>] [-dumpVirtualPinGuide]
                    [-ignoreAbuttedCheck] [-improvePinOrder] [-improveSI]
                    [-layerPriority {layeridList}] [-markFixed]
                    [-printPinMovementStatistics] [-skipAutoBusBitOrder]
                    [-skipPlaceExternalUnconnectedPin] [-unplacedOnly] [<partitionName> | {{{-ptn <partitionName> {-pin {pinName list}}} | {-pin_file <fileName> [-exclude_ptn <string>]} | {-exclude_pin_file <fileName>}} [-moveFixedPin ] [ -ignore_group_pins ]}] [ -alignFeedThruPinsOptWithMasterClone ] [ -autoBusGroup ] [ -enforceRoute | -enforceRouteLegal | -enforceFlyline ]

-help                                    # Prints out the command usage
<partitionName {list}>                   # Specifies list of partition names
                                         # (string, optional)
-alignFeedThruPinsOptWithMasterClone     # Place pins such that the pins are
                                         # aligned on different partitions
                                         # across buffers on master/clone.
                                         # (bool, optional)
-autoBusGroup                            # Specifies for automatic grouping of
                                         # bus. (bool, optional)
-basedOnMasterOnly                       # Consider only master partition
                                         # (bool, optional)
-blackbox                                # Assign pins of blackbox.
                                         # (bool, optional)
-debugPinAll                             # Specify debugging for all pins
                                         # (bool, optional)
-debugPinFile <fileName>                 # Specify pin-list for partition or
                                         # net in a file for debugging
                                         # (string, optional)
-dumpVirtualPinGuide                     # Write virtual pinGuide for netGroup
                                         # and pinGroup in
                                         # <topCell>_virtualPinGuide.tcl file.
                                         # (bool, optional)
-enforceFlyline                          # Follow fly-lines and ignores pin
                                         # constraints (bool, optional)
-enforceRoute                            # Follow routing cross-point and
                                         # ignores pin constraints
                                         # (bool, optional)
-enforceRouteLegal                       # Try to place pins close to routing
                                         # cross point but at legal location.
                                         # Call earlyGlobalRoute internally to
                                         # re-routes nets not placed at initial
                                         # routing cross point. (bool, optional)
-exclude_pin_file <fileName>             # Specify pin-list to be excluded for
                                         # partition in a file (string, optional)
-exclude_ptn <string>                    # Specifies the list of exluded
                                         # partition for pin-file
                                         # (string, optional)
-ignoreAbuttedCheck                      # For faster pin assignment on abutted
                                         # design, ignore abutted check.
                                         # (bool, optional)
-ignore_group_pins                       # Partial non
                                         # #optimizeOrder#opt_order# pinGroup
                                         # or netGroup pins ignored during
                                         # selected pin assignment.
                                         # (bool, optional)
-improvePinOrder                         # Reduces flight line crossing
                                         # (bool, optional)
-improveSI                               # Place pins as checkerboard on Mx+2
                                         # and Mx-2 layers to reduce
                                         # signal-integrity problems down the
                                         # flow. (bool, optional)
-layerPriority {layeridList}             # Specifies the metal layer(s) should
                                         # be used with priority.
                                         # (string, optional)
-markFixed                               # Assigned pins have a Fixed status
                                         # (bool, optional)
-moveFixedPin                            # Assign specified pin with a Fixed
                                         # status (bool, optional)
-pin {pinName list}                      # Specifies list of pins, option can
                                         # be repeated (string, optional)
-pin_file <fileName>                     # Specify pin-list for partition in a
                                         # file (string, optional)
-printPinMovementStatistics              # Prints a summary of the deviation
                                         # (bool, optional)
-ptn <partitionName>                     # Specifies name of the partition,
                                         # option can be repeated
                                         # (string, optional)
-skipAutoBusBitOrder                     # Skip automatic order of bus bits.
                                         # (bool, optional)
-skipPlaceExternalUnconnectedPin         # Skip placing pins which are not
                                         # connected at top level.
                                         # (bool, optional)
-unplacedOnly                            # Assign only unplaced pins.
                                         # (bool, optional)