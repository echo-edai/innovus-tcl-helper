Usage: read_activity_file [-help] [<name>] [-block <string>] [-cell <string>]
                          [-end <string>] [-format <string>]
                          [-hier_separator <string>]
                          [-name_mapping_rule <string>] [-reset] [-rtl <string>]
                          [-scale_duration <string>] [-scope <string>]
                          [-set_net_freq {true false}] [-start <string>]
                          [-start_time_shift <string>] [-weight <string>]
                          [-zero_delay <string>]

-help                             # Prints out the command usage
<name>                            # Specify the name of the activity file.
                                  # (string, optional)
-block <string>                   # Specifies the name of the
                                  # VCD/FSDB/TCF/SHM/PHY block to map a
                                  # sub-block activity file with a top level
                                  # Verilog/Def file. (string, optional)
-cell <string>                    # master call name (string, optional)
-end <string>                     # Specifies the end time as time-value pairs
                                  # to report the average power across
                                  # non-overlapping multiple windows specified
                                  # in the VCD/FSDB/SHM/PHY file for a block,
                                  # level of hierarchy, or other part of the
                                  # design. (string, optional)
-format <string>                  # Specifies the net activity of the design
                                  # using an activity file in VCD, TCF, FSDB,
                                  # PHY or SAIF format. (string, optional)
-hier_separator <string>          # Specifies the separator character in the
                                  # hierarchical net names, bus names, and pin
                                  # names for the block or other part of the
                                  # design. (string, optional)
-name_mapping_rule <string>       # Specifies the input rule-based mapping to
                                  # map RTL vectors to gate-level netlist.
                                  # These rules will apply to all the RTL
                                  # activity files specified. (string, optional)
-reset                            # Specifies to reset and ignore all the
                                  # previous activity files. (bool, optional)
-rtl <string>                     # This option should be set when RTL vector
                                  # is specified. (string, optional)
-scale_duration <string>          # Scales the VCD/FSDB/TCF/SHM/PHY duration
                                  # value by the specified scale factor.
                                  # (string, optional)
-scope <string>                   # Specifies the VCD/FSDB/TCF/SHM/PHY scope,
                                  # that is, the name of the module within the
                                  # activity file associated with the block or
                                  # other part of the design. (string, optional)
-set_net_freq {true false}        # This option should be set when an activity
                                  # from a VCD/FSDB/TCF/SHM/PHY file needs to
                                  # be used to capture net frequency for signal
                                  # EM analysis.  Default : false (enum, optional)
-start <string>                   # Specifies the start time as time-value
                                  # pairs to report the average power across
                                  # non-overlapping multiple windows specified
                                  # in the VCD/FSDB/SHM/PHY file for a block,
                                  # level of hierarchy, or other part of the
                                  # design. (string, optional)
-start_time_shift <string>        # Specifies to shift the start time of the
                                  # specified activity files. (string, optional)
-weight <string>                  # Specifies the weight number of the TCF
                                  # file. Default : 1.0 (string, optional)
-zero_delay <string>              # This option should be set when Zero Delay
                                  # Vector File is specified. (string, optional)