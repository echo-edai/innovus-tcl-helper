Usage: connectMacroFeedthrough [-help] [-abutment <float>]
                               [-abutmentFile <string>]
                               [-floatingPortList <string>]
                               [-maxSearchDistance <float>] [-portMap <string>]
                               [-searchAllSides] [-verbose] [ -selectNet <string> | -excludeNet <string> | -selectMarkedNet ] [ -selectInst <string> | -excludeInst <string> ] [ -ecoFile <string> | -checkOnly ]

-help                               # Prints out the command usage
-abutment <float>                   # Specifies the distance that pins on the
                                    # same track and layer must have from one
                                    # another so as to be considered as
                                    # abutted. (float, optional)
-abutmentFile <string>              # Reports, in the file specified, the list
                                    # of pins that are considered as abutted.
                                    # (string, optional)
-checkOnly                          # Specifies that only a report of the
                                    # messages should be displayed but no
                                    # changes should be made to the netlist.
                                    # (bool, optional)
-ecoFile <string>                   # Specifies the name of the ECO file that
                                    # will contain a report of the changes.
                                    # (string, optional)
-excludeInst <string>               # Prevents feedthrough buffers from being
                                    # added for the specified instance.
                                    # (string, optional)
-excludeNet <string>                # Prevents feedthrough buffers from being
                                    # added to the specified net.
                                    # (string, optional)
-floatingPortList <string>          # Specifies that the list of unused ports
                                    # should be saved in the specified file.
                                    # (string, optional)
-maxSearchDistance <float>          # Specifies the distance in microns from
                                    # the wire crossing till which the command
                                    # should search to find a connected
                                    # feedthrough. (float, optional)
-portMap <string>                   # Specifies the name of the file that
                                    # contains the feedthrough connectivity
                                    # definitions. (string, optional)
-searchAllSides                     # Specifies that if the closest available
                                    # feedthrough pin on the same side cannot
                                    # be connected,command should search other
                                    # sides as well. (bool, optional)
-selectInst <string>                # Specifies that feedthrough buffers should
                                    # be added only for the specified
                                    # instances. (string, optional)
-selectMarkedNet                    # Specifies that feedthrough buffers should
                                    # be added only to the nets that are
                                    # currently selected. (bool, optional)
-selectNet <string>                 # Specifies that feedthrough buffers should
                                    # be added only to the specified nets.
                                    # (string, optional)
-verbose                            # Provides additional messages, for example
                                    # net-specific messages. (bool, optional)