Usage: set_twf_attribute [-help] [-clear_twf_attr] [-clock <string>]
                         [-clock_edge <string>] [-clock_freq <string>]
                         [-fall_delay <string>] [-fall_slack <string>]
                         [-fall_slew <string>] [-net <string>] [-pin <string>]
                         [-reset] [-rise_delay <string>] [-rise_slack <string>]
                         [-rise_slew <string>] [-shift_arrival_time <string>]
                         [-type <string>]

-help                            # Prints out the command usage
-clear_twf_attr                  # Clears the attributes set on net or pin
                                 # (bool, optional)
-clock <string>                  # Specifies the clock name which caused the
                                 # timing window on the net or pin
                                 # (string, optional)
-clock_edge <string>             # Specifies the capturing clock edge
                                 # direction: rise or fall (string, optional)
-clock_freq <string>             # Specifies the clock frequency
                                 # (string, optional)
-fall_delay <string>             # Specifies the fall delay for net or pin
                                 # (string, optional)
-fall_slack <string>             # Specifies the fall slack for net or pin
                                 # (string, optional)
-fall_slew <string>              # Specifies the fall slew for net or pin
                                 # (string, optional)
-net <string>                    # Specifies the net name (string, optional)
-pin <string>                    # Specifies the pin name (string, optional)
-reset                           # Resets all specified options back to default
                                 # values (bool, optional)
-rise_delay <string>             # Specifies the rise delay for net or pin
                                 # (string, optional)
-rise_slack <string>             # Specifies the rise slack for net or pin
                                 # (string, optional)
-rise_slew <string>              # Specifies the rise slew for net or pin
                                 # (string, optional)
-shift_arrival_time <string>     # Specifies to filter the idle period of the
                                 # current waveform in the zero-delay VCD flow.
                                 # The parameter allows to offset idle period
                                 # from the TWF delay values (string, optional)
-type <string>                   # Specifies whether the net or pin is part of
                                 # the clock or data network (string, optional)