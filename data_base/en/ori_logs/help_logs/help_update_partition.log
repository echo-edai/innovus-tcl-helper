Usage: update_partition [-help] [-pinLocation] [-postECOSuffix <string>] {-flexIlmECO } { -goldenBlockDir <string>} -flexIlmDir <string> [-ecoDir <string>] [-fullNetlistWithECODir <string> -flexILMECODir <string> ]

-help                               # Prints out the command usage
-ecoDir <string>                    # <directory to run ECO job>
                                    # (string, optional)
-flexILMECODir <string>             # <directory to store ECO job>
                                    # (string, optional)
-flexIlmDir <string>                # <postOpt FlexILM data directory>
                                    # (string, optional)
-flexIlmECO                         # <perform ECO on FlexILM modules>
                                    # (bool, optional)
-fullNetlistWithECODir <string>     # <directory to store full netllist ECO
                                    # result> (string, optional)
-goldenBlockDir <string>            # <original block directory>
                                    # (string, optional)
-pinLocation                        # <update pin location in golden DB>
                                    # (bool, optional)
-postECOSuffix <string>             # <user specified post ECO DB suffix>
                                    # (string, optional)