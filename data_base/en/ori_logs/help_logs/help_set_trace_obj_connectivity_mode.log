Usage: set_trace_obj_connectivity_mode [-help] [-reset]
                                       [-macro_pins <list_of_pins>]
                                       [-max_fanin_fanout <number>]
                                       [-register_inputs <list_of_pins>]
                                       [-register_outputs <list_of_pins>]

-help                               # Prints out the command usage
-reset                              # Resets all or specified options to default value
-macro_pins <list_of_pins>          # specify macro pin name patterns in
                                    # regular expression (string, default="")
-max_fanin_fanout <number>          # Specify the maximum number of a pin's
                                    # fanin/fanout,a pin will be ignored in
                                    # tracing connectivity if its fanin/fanout
                                    # larger than the specified number
                                    # (int, default=1000)
-register_inputs <list_of_pins>     # Specify register input pin names
                                    # (string, default="")
-register_outputs <list_of_pins>    # Specify register output pin names
                                    # (string, default="")