Usage: check_noise [-help] [-all]
                   [-check_only {receiver_no_propagation_model receiver_no_dc_tolerence driver_no_current_source_model driver_no_model}]
                   [-instance_list <string>] [-instance_only {true false}]
                   [-pin_list <string>] [-type {receiver_model driver_model}]
                   [-unique {true false}] [-verbose] [-view <string>] [ [ > | >> ] ]

-help                                   # Prints out the command usage
-all                                    # Display all the debug information
                                        # (bool, optional)
-check_only {receiver_no_propagation_model receiver_no_dc_tolerence driver_no_current_source_model driver_no_model}
                                        # Checks the warning name. Following
                                        # warnings are checked:
                                        # 
                                        # receiver_no_propagation_model :
                                        # Specifies how many design pins are
                                        # missing the receiver model for
                                        # propagation.
                                        # 
                                        # receiver_no_dc_tolerence : Specifies
                                        # how many pins have no DC VH/VL
                                        # tolerance specified.
                                        # 
                                        # driver_no_current_source_model :
                                        # Specifies how many design pins are
                                        # missing from the current source
                                        # model. 
                                        # driver_no_model : Specifies how many
                                        # design pins are missing from the
                                        # driver model. (enum, optional)
-instance_list <string>                 # Specifies a list of instance names
                                        # (list, optional)
-instance_only {true false}             # Print each instance only once
                                        # (enum, optional)
-pin_list <string>                      # Specifies the instance pin names
                                        # (list, optional)
-type {receiver_model driver_model}     # Checks the presence of a valid model
                                        # type - receiver_model or
                                        # driver_model. If the specified model
                                        # is missing, a warning will be issued.
                                        # (enum, optional)
-unique {true false}                    # Report unique cells or pins for each
                                        # power domain (enum, optional)
-verbose                                # Generates verbose details
                                        # (bool, optional)
-view <string>                          # Specifies the view name
                                        # (string, optional)
> <filename>                            # Redirect output to file
                                        # (redirect_operator, optional)
>> <filename>                           # Append to output file
                                        # (redirect_operator, optional)