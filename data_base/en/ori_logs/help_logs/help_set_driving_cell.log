Usage: set_driving_cell [-help] <port_list> [-fall] [-from_pin <from_pin_name>]
                        [-input_transition_fall <fall_slew_value>]
                        [-input_transition_rise <rise_slew_value>]
                        -lib_cell <cell_name> [-library <library_name>] [-max]
                        [-min] [-multiply_by <factor>] [-no_design_rule]
                        [-pin <pin_name>] [-rise]

-help                     # Prints out the command usage
<port_list>               # List of ports (string, required)
-fall                     # Annotates the falling drive assertion
                          # (bool, optional)
-from_pin <from_pin_name> # Specifies the name of the input port of the driver
                          # cell that has an arc to the output port of the
                          # driver cell (string, optional)
-input_transition_fall <fall_slew_value>
                          # Specifies the slew value for the falling signal at
                          # the input of the drive cell (float, optional)
-input_transition_rise <rise_slew_value>
                          # Specifies the slew value for the rising signal at
                          # the input of the drive cell (float, optional)
-lib_cell <cell_name>     # Specifies the name of the driver cell
                          # (string, required)
-library <library_name>   # Specifies the name of the library that contains the
                          # driving cell (string, optional)
-max                      # Annotates the late drive assertion (bool, optional)
-min                      # Annotates the early drive assertion
                          # (bool, optional)
-multiply_by <factor>     # Specifies a multiplier for the drive
                          # (float, optional)
-no_design_rule           # Do not transfer design rules from the driving cell
                          # to the port (bool, optional)
-pin <pin_name>           # Specifies the name of the output port of the driver
                          # cell that drives the signal at the input port
                          # (string, optional)
-rise                     # Annotates the rising drive assertion
                          # (bool, optional)