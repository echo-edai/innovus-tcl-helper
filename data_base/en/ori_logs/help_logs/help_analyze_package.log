Usage: analyze_package [-help] [-computer_resources <string>]
                       [-output <string>] [-result_name <string>]
                       [-spd_file <string>] -type {dc transient} { [<domain> [-workspace <string>] [-pkg_die_name <string>] [-pkg_bga_name <string>] [-pkg_pin_current_file <string>] ]}

-help                                   # Prints out the command usage
<domain>                                # <rail analysis domain name>
                                        # (string, required)
-computer_resources <string>            # <set up computer resources>
                                        # (string, optional)
-output <string>                        # <output directory of package model>
                                        # (string, optional)
-pkg_bga_name <string>                  # <specify bga circuit>
                                        # (string, optional)
-pkg_die_name <string>                  # <specify die circuit>
                                        # (string, optional)
-pkg_pin_current_file <string>          # <specify pin current file from rail
                                        # analysis, or {{ckt_name1 file1}
                                        # {ckt_name2 file2}} for multi-die
                                        # case> (string, optional)
-result_name <string>                   # <tool will generate
                                        # output/result_name.xml>
                                        # (string, optional)
-spd_file <string>                      # <package extraction spd file>
                                        # (string, optional)
-type {dc transient}                    # <specify one type of dc|transient>
                                        # (enum, required)
-workspace <string>                     # <package analysis workspace>
                                        # (string, optional)