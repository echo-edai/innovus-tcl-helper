Usage: report_socv_library [-help] [-categories <string>] [-coverage_verbose]
                           [-list_not_annotated] [ -libset <string> | { -delay_corner <string> [ -power_domain <string>] }| { -view <string> [-power_domain <string>]}] [ -libs <string> | -lib_cells <string> ] { -coverage }

-help                      # Prints out the command usage
-categories <string>       # Allow the user to control what types of table data
                           # to check  delay arcs, transition arcs, and check
                           # arcs.  Default is all. (string, optional)
-coverage                  # Control for reporting  coverage library data.
                           # (bool, required)
-coverage_verbose          # Generated detailed report table per cell.
                           # (bool, optional)
-delay_corner <string>     # Check all libraries defined in the specified
                           # library_set. (string, optional)
-lib_cells <string>        # The allowed format is “library/cell” name or
                           # pattern or collection. This would typically be
                           # done for drill-down debugging of problems.
                           # (string, optional)
-libs <string>             # Allow the user to select which library.  If
                           # -library_set, -delay_corner, or –view is not
                           # specified then all libraries matching the library
                           # name across the MMMC configuration will get
                           # checked. (string, optional)
-libset <string>           # Check all libraries defined in the specified
                           # library_set. (string, optional)
-list_not_annotated        # Allow the user to control what types of table data
                           # to check  delay arcs, transition arcs, and check
                           # arcs.  Default is all. (bool, optional)
-power_domain <string>     # Check in the Power Domain Specified.
                           # (string, optional)
-view <string>             # Check all delay_corners associated with the view.
                           # (string, optional)