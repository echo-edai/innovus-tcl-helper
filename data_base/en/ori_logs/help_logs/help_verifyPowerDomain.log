Usage: verifyPowerDomain [-help] [-allInstInPD] [-antennaDiode {fileName ...}]
                         [-aoBufferType] [-bind] [-cell_bind {cell ...}]
                         [-drcFile <string>] [-isoNetPD {fileName ...}]
                         [-libBindingVoltage] [-noFTermIsoC] [-noFTermShifter]
                         [-powerSwitch {fileName ...}] [-pwrWithinMinGap]
                         [-retention {fileName ...}] [-xNetPD {fileName ...}] [-place  [-place_rpt <string>]] [-gconn {module ...} [-aobBiasConn ]]

-help                                    # Prints out the command usage
-allInstInPD                             # all insts are in domain
                                         # (bool, optional)
-antennaDiode {fileName ...}             # verify antenna diode
                                         # (string, optional)
-aoBufferType                            # check AOB type in domain
                                         # (bool, optional)
-aobBiasConn                             # check AOB bias net connection
                                         # (bool, optional)
-bind                                    # verify library binding
                                         # (bool, optional)
-cell_bind {cell ...}                    # list of cells (string, optional)
-drcFile <string>                        # create Design Rule Checking (DRC)
                                         # violation markers and save them in
                                         # the specified file (string, optional)
-gconn {module ...}                      # list of modules (string, optional)
-isoNetPD {fileName ...}                 # verify isolation (string, optional)
-libBindingVoltage                       # check voltage against binding
                                         # library (bool, optional)
-noFTermIsoC                             # ignore iso fterm (bool, optional)
-noFTermShifter                          # ignore shifter fterm
                                         # (bool, optional)
-place                                   # check placement (bool, optional)
-place_rpt <string>                      # placement output file
                                         # (string, optional)
-powerSwitch {fileName ...}              # verify power_switch
                                         # (string, optional)
-pwrWithinMinGap                         # check ring in minGap
                                         # (bool, optional)
-retention {fileName ...}                # verify retention (string, optional)
-xNetPD {fileName ...}                   # verify shifter (string, optional)