Usage: ecoDesign [-help] <sessionDirectory> <design> <netListFile>
                 [-allow_to_load_binary_timing_file] [-def <string>]
                 [-ecoMMMC <string>] [-ecoSDC <string>] [-keepInstLoc]
                 [-lef_files <string>] [-noAddFiller] [-noEcoPlace]
                 [-noEcoRoute] [-noTiming] [-place_detail_use_GA_filler_groups]
                 [-reportFile <string>] [-skipCcopt] [-fillerPrefix <string> | -noDeleteFiller ] [-postMask  [[-suffix <string>] [-spareCells <string>] [-modifyOnlyLayers <string>] [-tieCell <string> [-addHierPortForTieOff ]]]] [-cpfFile <string> | -1801File <string>] [-useGACells <string> | -useGAFillerCells <string>]

-help                                  # Prints out the command usage
<sessionDirectory>                     # Specifies the directory from which to
                                       # load the design. (string, required)
<design>                               # Specifies the design name.
                                       # (string, required)
<netListFile>                          # Specifies the name of new netlist
                                       # file. (string, required)
-1801File <string>                     # Specifies the name of the new 1801
                                       # file (string, optional)
-addHierPortForTieOff                  # Allows tie cells to connect to the tie
                                       # pins across hierarchical boundaries if
                                       # other constraints. (bool, optional)
-allow_to_load_binary_timing_file      # Turn on this option to allow tool load
                                       # the binary timing graph or timing
                                       # constraint file. (bool, optional)
-cpfFile <string>                      # Specifies the name of the new CPF file
                                       # (string, optional)
-def <string>                          # Force loading DEF file which is
                                       # previously saved under the design
                                       # directory. (string, optional)
-ecoMMMC <string>                      # Specifies the name of the ECO view
                                       # definition file. (string, optional)
-ecoSDC <string>                       # Specifies the name of the new SDC
                                       # file. (string, optional)
-fillerPrefix <string>                 # Specifies the prefix of the cell
                                       # instances to delete. (string, optional)
-keepInstLoc                           # Keep instance location when loading
                                       # place file. (bool, optional)
-lef_files <string>                    # Specifies the LEF files name for
                                       # loading. Use this option if you want
                                       # to replace the existing LEF files in
                                       # the original design with new LEF files
                                       # instead. Refer to restoreDesign
                                       # -lef_files for more details and
                                       # limitations. (string, optional)
-modifyOnlyLayers <string>             # Specifies the layer range that are
                                       # allowed to be modified during eco
                                       # route. <MLb:MLt> (string, optional)
-noAddFiller                           # Skips filler insertion in pre-mask eco
                                       # flow. (bool, optional)
-noDeleteFiller                        # Do not remove physical cell instances,
                                       # such as filler cells, end-cap cells,
                                       # and well-tap cells. (bool, optional)
-noEcoPlace                            # Skips eco place & eco route processes.
                                       # (bool, optional)
-noEcoRoute                            # Prevents routing during the ECO
                                       # process. (bool, optional)
-noTiming                              # Ignores timing libraries and MMMC
                                       # configuration (bool, optional)
-place_detail_use_GA_filler_groups     # Specifies that filler cell instances
                                       # will only be replaced by logic
                                       # instances that belong to the same GA
                                       # groups. (bool, optional)
-postMask                              # Specifies that the changes are being
                                       # made on a post-mask design.
                                       # (bool, optional)
-reportFile <string>                   # Specifies the name of the report file.
                                       # (string, optional)
-skipCcopt                             # Skips restore ccopt config, for
                                       # signoffTimeDesign (bool, optional)
-spareCells <string>                   # Specifies the name of the spare cell
                                       # to use during the ECO process.
                                       # (string, optional)
-suffix <string>                       # Specifies the suffix to be appended to
                                       # the spare cells. (string, optional)
-tieCell <string>                      # Specifies the existing tie cells to be
                                       # reused to make tie connections for
                                       # newly created SPARE instance in the
                                       # design. You can only specify a maximum
                                       # of two tie-cells, where one cell must
                                       # be a tie-high driver, and the other a
                                       # tie-low driver. The two tie-cell names
                                       # must be surrounded by quotation marks.
                                       # (string, optional)
-useGACells <string>                   # Specifies the site name of the gate
                                       # array cell. (string, optional)
-useGAFillerCells <string>             # Specifies a list of Gate Array
                                       # (GA)-style filler cells that the tool
                                       # can replace with GA cells during
                                       # post-mask ECO. You can only use this
                                       # parameter in a post-mask ECO flow.
                                       # (string, optional)