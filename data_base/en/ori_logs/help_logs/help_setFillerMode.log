Usage: setFillerMode [-help] [-reset] [-add_fillers_with_drc {true|false}]
                     [-avoid_abutment_patterns { 1:1 1:2 ...}]
                     [-check_signal_drc {true|false}]
                     [-check_trim_rule {true|false}]
                     [-core {{list-of-cells1} {list-of-cells2} ...}]
                     [-corePrefix <filler-prefix>] [-createRows {true|false}]
                     [-diffCellViol {true|false}]
                     [-distribute_implant_evenly {true|false}]
                     [-double_height_filler_insertion {true|false}]
                     [-ecoMode {true|false}]
                     [-enable_restore_filler_flow {true|false}]
                     [-fitGap {true|false}] [-honorPrerouteAsObs {true|false}]
                     [-horizontal_exception_cell {fillerCell ...}]
                     [-horizontal_max_length <value>]
                     [-horizontal_repair_cell {fillCell ...}]
                     [-keepFixed {true|false}] [-preserveUserOrder {true|false}]
                     [-scheme {locationFirst|cellFirst}]
                     [-swap_cell {{cell swap pair1} {cell swap pair2} ...}]
                     [-vertical_stack_exception_cell <ListOfCellNames>]
                     [-vertical_stack_left_edge_exception_cell <ListOfCellNames>]
                     [-vertical_stack_max_length <value>]
                     [-vertical_stack_repair_cell {fillerCell ...}]
                     [-vertical_stack_repair_edge {left|right}]
                     [-vertical_stack_right_edge_exception_cell <ListOfCellNames>]
                     [-y_flip_type { integer : { first | last } ... }]

-help                                      # Prints out the command usage
-reset                                     # Resets all or specified options to default value
-add_fillers_with_drc {true|false}         # call second addFiller without drc
                                           # checking (bool, default=true)
-avoid_abutment_patterns { 1:1 1:2 ...}    # illegal abutment patterns
                                           # (string, default="")
-check_signal_drc {true|false}             # DRC checking after filler
                                           # insertion (bool, default=true)
-check_trim_rule {true|false}              # check trim-2-trim rule between
                                           # cell trim and routing trim.
                                           # (bool, default=false)
-core {{list-of-cells1} {list-of-cells2} ...}
                                           # List of filler cells (string, default="")
-corePrefix <filler-prefix>                # Prefix of filler cells
                                           # (string, default="")
-createRows {true|false}                   # Create rows for filler cell
                                           # techSites which do not have rows
                                           # in the floor plan
                                           # (bool, default=true)
-diffCellViol {true|false}                 # Check violations between different
                                           # cell types (bool, default=false)
-distribute_implant_evenly {true|false}    # distribute implant evenly for
                                           # fillers (bool, default=false)
-double_height_filler_insertion {true|false}
                                           # enable double height filler during
                                           # filler insertion.
                                           # (bool, default=false)
-ecoMode {true|false}                      # Fillers inserted in ecoFlow
                                           # (bool, default=false)
-enable_restore_filler_flow {true|false}
                                           # enable restore filler flow. (bool, default=true)
-fitGap {true|false}                       # Filler command fit 1-site gap
                                           # (bool, default=true)
-honorPrerouteAsObs {true|false}           # Filler command honors
                                           # setPrerouteAsObs value
                                           # (bool, default=false)
-horizontal_exception_cell {fillerCell ...}
                                           # List of exceptional cells for
                                           # horizontal stack checking
                                           # (string, default="")
-horizontal_max_length <value>             # specify instance max length (in
                                           # micron) aligned in horizontal
                                           # direction
                                           # (float, default=0, min=0, max=50000)
-horizontal_repair_cell {fillCell ...}     # List of filler cells to fix
                                           # horizontal max length violation
                                           # (string, default="")
-keepFixed {true|false}                    # 'FIXED' fillers are kepted
                                           # (bool, default=false)
-preserveUserOrder {true|false}            # Instruct tool to insert fillers by
                                           # the user defined order
                                           # (bool, default=false)
-scheme {locationFirst|cellFirst}          # Instruct tool to select
                                           # locationFirst|cellFirst scheme
                                           # (enums={locationFirst cellFirst}, default=locationFirst)
-swap_cell {{cell swap pair1} {cell swap pair2} ...}
                                           # swap cell pairs (string, default="")
-vertical_stack_exception_cell <ListOfCellNames>
                                           # List of exceptional cells for
                                           # vertical stack checking
                                           # (string, default="")
-vertical_stack_left_edge_exception_cell <ListOfCellNames>
                                           # List of cells only check right
                                           # edge for vertical stack violation
                                           # (string, default="")
-vertical_stack_max_length <value>         # specify instance max length (in
                                           # micron) aligned in vertical
                                           # direction
                                           # (float, default=0, min=0, max=20000)
-vertical_stack_repair_cell {fillerCell ...}
                                           # List of filler cells to fix
                                           # vertical stack violation
                                           # (string, default="")
-vertical_stack_repair_edge {left|right}
                                           # specify the edge to use of
                                           # vertical repair cell
                                           # (enums={left right}, default="")
-vertical_stack_right_edge_exception_cell <ListOfCellNames>
                                           # List of cells only check left edge
                                           # for vertical stack violation
                                           # (string, default="")
-y_flip_type { integer : { first | last } ... }
                                           # Defines first or last cell with
                                           # certain cell size should be
                                           # y-flipped (string, default="")