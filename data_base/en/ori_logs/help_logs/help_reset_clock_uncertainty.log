Usage: reset_clock_uncertainty [-help] [-full_cycle_jitter]
                               [-half_cycle_jitter] [-hold] [-setup] { { {-from <clksig_from_list> | -rise_from <clksig_from_list> | -fall_from <clksig_from_list>} {-to <clksig_to_list> | -rise_to <clksig_to_list> | -fall_to <clksig_to_list>} } |  <pin_or_clock_list> }

-help                             # Prints out the command usage
<pin_or_clock_list>               # List of clocks or pins for target
                                  # uncertainty (string, optional)
-fall_from <clksig_from_list>     # Removes the uncertainty value only from the
                                  # falling edge of the launching clocks
                                  # (string, optional)
-fall_to <clksig_to_list>         # Removes the uncertainty value only from the
                                  # falling edge of the capture clocks
                                  # (string, optional)
-from <clksig_from_list>          # Removes the uncertainty value from both the
                                  # rising and falling edges of the launching
                                  # clocks (string, optional)
-full_cycle_jitter                # Provides the full cycle jitter
                                  # (bool, optional)
-half_cycle_jitter                # Provides the half cycle jitter
                                  # (bool, optional)
-hold                             # Clock uncertainty applies to hold checks
                                  # (bool, optional)
-rise_from <clksig_from_list>     # Removes the uncertainty value only from the
                                  # rising edge of the launching clocks
                                  # (string, optional)
-rise_to <clksig_to_list>         # Removes the uncertainty value only from the
                                  # rising edge of the capture clocks
                                  # (string, optional)
-setup                            # Clock uncertainty applies to setup checks
                                  # (bool, optional)
-to <clksig_to_list>              # Removes the uncertainty value from both the
                                  # rising and falling edges of the capture
                                  # clocks (string, optional)