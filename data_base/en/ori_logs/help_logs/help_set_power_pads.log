Usage: set_power_pads [-help] {-reset  | {[-format {defpin padcell xy xyiv boundary} [-file <string>] [-short_pin_nodes {true false}]] [-net <string>] [-auto_voltage_source_creation {true false} [-tile <string>] [-region <string>] [-layer <string>] [-number_of_voltage_source <integer>] [-def_shape_only {true false}] [-consider_partial_small_tiles_for_vsrc {true false}] [-enable_switchnet_ploc_generation {true false}]] [-die_instance_name <string>]}}

-help                                   # Prints out the command usage
-auto_voltage_source_creation {true false}
                                        # <true | false> (enum, required)
-consider_partial_small_tiles_for_vsrc {true false}
                                        # <true | false> (enum, optional)
-def_shape_only {true false}            # <true | false> (enum, optional)
-die_instance_name <string>             # <die instance name>
                                        # (string, optional)
-enable_switchnet_ploc_generation {true false}
                                        # <true | false> (enum, optional)
-file <string>                          # <power pad file> (string, optional)
-format {defpin padcell xy xyiv boundary}
                                        # <format: defpin | padcell | xy | xyiv
                                        # | boundary> (enum, optional)
-layer <string>                         # <via layer name> (string, optional)
-net <string>                           # <net name> (string, optional)
-number_of_voltage_source <integer>     # <restrict max number of bump>
                                        # (int, optional)
-region <string>                        # region {llx lly urx ury} (um)
                                        # (string, optional)
-reset                                  # <reset all previous set_power_pads
                                        # commands> (bool, optional)
-short_pin_nodes {true false}           # <true | false> (enum, optional)
-tile <string>                          # tile {x y} (um) (string, optional)