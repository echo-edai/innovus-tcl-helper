Usage: set_proto_design_mode [-help] [-reset]
                             [-cover_fixed_macros {true|false}]
                             [-effort {low|medium|high}]
                             [-flexmodel_constraint_type {guide|region|fence}]
                             [-keep_guide {true|false}]
                             [-place_macro {true|false}]
                             [-remove_overlap {true|false}]

-help                                      # Prints out the command usage
-reset                                     # Resets all or specified options to default value
-cover_fixed_macros {true|false}           # force flexModel cover fixed macros
                                           # belong to it when using new
                                           # planDesign algorithm
                                           # (bool, default=false)
-effort {low|medium|high}                  # Specifies proto_design effort
                                           # (enums={low medium high}, default=low)
-flexmodel_constraint_type {guide|region|fence}
                                           # Convert flexModel to the specified
                                           # constraint type in proto_design.
                                           # (enums={guide region fence}, default=region)
-keep_guide {true|false}                   # -keep_guide {true|false}
                                           # #default=true (bool, default=true)
-place_macro {true|false}                  # control if do macro placement in
                                           # planDesign (bool, default=true)
-remove_overlap {true|false}               # control if do remove overlap in
                                           # planDesign (bool, default=true)