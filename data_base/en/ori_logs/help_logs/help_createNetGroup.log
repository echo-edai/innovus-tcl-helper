Usage: createNetGroup [-help] [-mixed_signal] [-spacing <minSpace in tracks>] [ {[-optimizeOrder ]} | -spreadPin | -compact_area ] [-excludePin {allLayer sameLayer allLayerInGuidedArea} [-keep_out_spacing <integer>]] { [<netGroupName> [-net <netNameList>]] }

-help                                     # Prints out the command usage
<netGroupName>                            # Specifies name of the created net
                                          # group name (string, required)
-compact_area                             # Specifies that pins in the group
                                          # are assigned tightly together.
                                          # (bool, optional)
-excludePin {allLayer sameLayer allLayerInGuidedArea}
                                          # Specifies that pins in the group
                                          # exclude foreign pins on all layers
                                          # or same layer. (enum, optional)
-keep_out_spacing <integer>               # Specifies minimum spacing between
                                          # the pins placed oustide of this
                                          # group, in number of tracks or
                                          # pitch.
                                          # (int, optional, min=0, max=65535)
-mixed_signal                             # Specifies to identify mixed signal
                                          # group. (bool, optional)
-net <netNameList>                        # Specifies name of the net(s),
                                          # wildcard can be specified
                                          # (string, optional)
-optimizeOrder                            # Pins in the group are reordered to
                                          # optimize wire length. (bool, optional)
-spacing <minSpace in tracks>             # Specifies minimum spacing between
                                          # the pins of the net group
                                          # (int, optional)
-spreadPin                                # Specifies that pins in the group
                                          # are distributed evenly.
                                          # (bool, optional)