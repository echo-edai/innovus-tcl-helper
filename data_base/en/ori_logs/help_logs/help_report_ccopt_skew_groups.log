Usage: report_ccopt_skew_groups [-help] [-exclude_pin_insertion_delay]
                                [-exclude_source_latency] [-file <name>]
                                [-from <string>] [-histograms] [-no_invalidate]
                                [-skip_timing_update] [-through <string>]
                                [-to <string>] [ -skew_groups <string> | -include_reporting_only_skew_groups ] [ -delay_corners <delay_corner>+ | -views <analysis_view>+ ] [ -early | -late ] [ -summarize_stage_depth <cell_type_list> ] [ -paths <num> ] [{ -tcl_list }] [ -include_voltage <include_voltage> | -summary ]

-help                                   # Prints out the command usage
-delay_corners <delay_corner>+          # Restricts the report to the specified
                                        # delay corners
                                        # ((delay_corner)+, optional)
-early                                  # Only report on the early half of the
                                        # delay corners (bool, optional)
-exclude_pin_insertion_delay            # Excludes the pin insertion delay
                                        # (bool, optional)
-exclude_source_latency                 # Excludes the source latency
                                        # (bool, optional)
-file <name>                            # Save a copy of the contents of the
                                        # report to the specified file name
                                        # (string, optional)
-from <string>                          # List of sources of skew_group to
                                        # consider for the report. If
                                        # specified, only paths beginning at
                                        # one of the sources specified will be
                                        # reported. (string, optional)
-histograms                             # Displays histograms of key
                                        # information (bool, optional)
-include_reporting_only_skew_groups     # Additionally include the
                                        # reporting-only skew groups in the
                                        # report. (bool, optional)
-include_voltage {on off auto}          # Turns on voltage column
                                        # (enum, optional)
-late                                   # Only report on the late half of the
                                        # delay corners (bool, optional)
-no_invalidate                          # Do not invalidate the timing engine.
                                        # (bool, optional)
-paths <num>                            # Number of paths to report on for each
                                        # timing corner. The default is 1.
                                        # (int, optional, min=1, max=INT_MAX)
-skew_groups <string>                   # Restricts the report to the specified
                                        # skew groups. By default, all
                                        # delay-constraining skew groups are
                                        # displayed. (string, optional)
-skip_timing_update                     # Do not update the timing engine.
                                        # (bool, optional)
-summarize_stage_depth <cell_type_list> # Report by the number of cells of the
                                        # given tcl list of cell types rather
                                        # than delay. Possible values are
                                        # buffer, inverter, logic, clock_gate,
                                        # generator or *. (list, optional)
-summary                                # Displays just the summary tables
                                        # (bool, optional)
-tcl_list                               # Return the report as a Tcl value.
                                        # (bool, optional)
-through <string>                       # List of pin objects representing
                                        # points that all paths reported must
                                        # pass through. The paths must pass
                                        # through one of the pins specified.
                                        # (string, optional)
-to <string>                            # List of pin objects representing all
                                        # the sinks of skew_groups to consider
                                        # for the report. If specified, only
                                        # paths terminating at one of the sinks
                                        # specified will be reported.
                                        # (string, optional)
-views <analysis_view>+                 # Restricts the report to the delay
                                        # corners associated with the specified
                                        # views ((analysis_view)+, optional)