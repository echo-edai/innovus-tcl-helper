Usage: showPtnWireX [-help] [<ptnName>] [-allNets] [-delta] [-excludeClock]
                    [-excludeHighFan <integer>] [-excludeNet <string>]
                    [-excludeTri] [-outfile <string>]

-help                              # Prints out the command usage
<ptnName>                          # Specifies the name of the partition to
                                   # show wire crossing. (string, optional)
-allNets                           # Reports nets that cross partitions that
                                   # also connect to the ports of partitions.
                                   # (bool, optional)
-delta                             # Reports the total segment length of the
                                   # wires crossing the block in the X and Y
                                   # directions. (bool, optional)
-excludeClock                      # Excludes clock nets from the wire crossing
                                   # information. (bool, optional)
-excludeHighFan <integer>          # Excludes nets with fanouts over nrFan from
                                   # the display. (int, optional)
-excludeNet <string>               # Specifies the file name that contains nets
                                   # to be excluded from the display.
                                   # (string, optional)
-excludeTri                        # Excludes  tristate nets from the display.
                                   # (bool, optional)
-outfile <string>                  # Specifies the name of the output file of
                                   # wire crossing information. (string, optional)