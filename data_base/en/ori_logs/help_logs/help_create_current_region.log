Usage: create_current_region [-help] [-die_instance_name <string>]
                             [-file <string>] [-label <string>]
                             [-series_resistance <string>]
                             [-current <string> | -current_pwl_file <string>]

-help                               # Prints out the command usage
-cell <string>                      # cell name (string, optional)
-current <string>                   # mA for static, {{#ns #mA }...} for
                                    # dynamic (string, optional)
-current_pwl_file <string>          # file_name for dynamic (string, optional)
-die_instance_name <string>         # Name of die to apply current region to
                                    # (string, optional)
-file <string>                      # Name of file to merge with params,
                                    # including die name (string, optional)
-gndnet <string>                    # ground net name (string, optional)
-instance <string>                  # instance name (string, optional)
-intrinsic_cap <string>             # intrinsic capacitance (pf)
                                    # (string, optional)
-label <string>                     # Label of current region
                                    # (string, optional)
-layer <string>                     # layer name (string, optional)
-loading_cap <string>               # loading capacitance (pf)
                                    # (string, optional)
-net <string>                       # net name (string, optional)
-polygon <string>                   # polygon <x1 y1 x2 y2 x3 y3 .....> (um)
                                    # (string, optional)
-pwrnet <string>                    # power net name (string, optional)
-region <string>                    # region <x1 y1 x2 y2> (um)
                                    # (string, required)
-reset                              # reset all options (bool, optional)
-series_resistance <string>         # series resistance (ohm)
                                    # (string, optional)