                                         # (string, optional)
-sub_net <sub_net_name>                  # Subnet name (string, optional)
-top_preferred_routing_layer <layer_number>
                                         # Top routing layer for the object (string, optional)
-top_preferred_shielding_layer <layer_number>
                                         # Top shielding layer for the object (string, optional)
-weight <integer>                        # Routing weight of the object
