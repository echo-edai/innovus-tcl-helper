Usage: setAttribute [-help] [-max_fanout <integer>] [-reset]
                    [-stripe_layer_range <integer:integer>] {-net <net_name> | -cell_pin <cell_name:pin_name> } [-sub_net <sub_net_name> [-comp_pin <comp<:pin_name> list>][-inst_pin <instance<:pin_name> list>]] [-weight <integer>] [-non_default_rule <rule_name>] [-non_default_rule_effort {auto|soft|hard|no_taper}] [-shield_net <special_net_name(s)>] [-shield_side <one_side|two_sides>] [[[-em_ndr_rule <rule_name>] [-em_ndr_dist <double>]] | [-em_width_rule <layer width:dist pairs>]] [-ndr_si_length_limit <layer dist pairs>] [-coaxial_shielded_layers <layer_number:layer_number>] [-coaxial_shield_limit <layer_number:layer_number>] [-coaxial_shield_interval <[integer|{layer_name:integer ...}]>] [-pattern {steiner|trunk}] [-top_preferred_routing_layer <layer_number>] [-bottom_preferred_routing_layer <layer_number>] [-top_preferred_shielding_layer <layer_number>] [-bottom_preferred_shielding_layer <layer_number>] [-preferred_routing_layer_effort {low|medium|high|hard}] [-preferred_extra_space <integer>] [-avoid_detour {true|false}] [-skip_routing {true|false}] [-skip_antenna_fix {true|false}] [-multi_cut_via_effort {low|medium|high}] [-si_post_route_fix {true|false}] [-min_stack_layer <layer_number>] [-stack_distance <distance>] [-mask <integer>] [-layer_mask <integer:integer>] [-one_side_spacing <integer:integer>]

-help                                    # Prints out the command usage
-avoid_detour {true|false}               # Avoid routing detours for a net
                                         # (string, optional)
-bottom_preferred_routing_layer <layer_number>
                                         # Bottom routing layer for the object (string, optional)
-bottom_preferred_shielding_layer <layer_number>
                                         # Bottom shielding layer for the
                                         # object (string, optional)
-cell_pin <cell_name:pin_name>           # Cell pin name (string, optional)
-coaxial_shield_interval <[integer|{layer_name:integer ...}]>
                                         # Number of empty tracks between two
                                         # crossties, 0..63, default is 0 or
                                         # every track (string, optional)
-coaxial_shield_limit <layer_number:layer_number>
                                         # Bottom and top routing layer limit
                                         # for coaxial shields (string, optional)
-coaxial_shielded_layers <layer_number:layer_number>
                                         # Bottom and top routing layer for
                                         # coaxial shields (string, optional)
-comp_pin <comp<:pin_name> list>         # Componet name and pin list
                                         # (string, optional)
-em_ndr_dist <double>                    # EM ndr rule source to sink distance
                                         # (float, optional)
-em_ndr_rule <rule_name>                 # EM no default rule name
                                         # (string, optional)
-em_width_rule <layer width:dist pairs>  # Table of layer width:distance pairs,
                                         # "M1 1.0:0.5, M2 2.0:1.0"
                                         # (string, optional)
-inst_pin <instance<:pin_name> list>     # Instance name and pin list
                                         # (string, optional)
-layer_mask <integer:integer>            # Specify the layer range that the
                                         # mask constraint should be applied
                                         # on. For example, 3:4 means that the
                                         # constraint should be applied on M3
                                         # and M4. (string, optional)
-mask <integer>                          # Mask constraint setting for the net.
                                         # Legal values are from 0 to the mask
                                         # number for the layers. A value of
                                         # 0indicates that there is no
                                         # maskconstraint on the net. A
                                         # non-zero valueindicates that all
                                         # wiring on the netshould be created
                                         # on the specified mask.Layers that do
                                         # not support the specifiedvalue will
                                         # be treated as unconstrained. 
                                         # (string, optional)
-max_fanout <integer>                    # Track pin num control
                                         # (string, optional)
-min_stack_layer <layer_number>          # Minium stacking layer
                                         # (string, optional)
-multi_cut_via_effort {low|medium|high}  # Multi-cut via effort
                                         # (string, optional)
-ndr_si_length_limit <layer dist pairs>  # Table of layer length pairs, "M1
                                         # 1.0, M2 2.0" (string, optional)
-net <net_name>                          # Net name, wild card, or net type
                                         # (string, optional)
-non_default_rule <rule_name>            # Non default rule name
                                         # (string, optional)
-non_default_rule_effort {auto|soft|hard|no_taper}
                                         # Non default rule effort (string, optional)
-one_side_spacing <integer:integer>      # Specify the layer range that the
                                         # onesidespacing constraint should be
                                         # applied on. For example, 3:4 means
                                         # that the constraint should be
                                         # applied on M3 and M4.
                                         # (string, optional)
-pattern {steiner|trunk}                 # Routing pattern type
                                         # (string, optional)
-preferred_extra_space <integer>         # Preferred extra spacing for nets
                                         # (string, optional)
-preferred_routing_layer_effort {low|medium|high|hard}
                                         # Routing effort level (string, optional)
-reset                                   # Reset all fields (bool, optional)
-shield_net <special_net_name(s)>        # Shield name(s) for the net
                                         # (string, optional)
-shield_side <one_side|two_sides>        # Number of sides to route shield
                                         # (string, optional)
-si_post_route_fix {true|false}          # Post route si fix (string, optional)
-skip_antenna_fix {true|false}           # Skip antenna fix for this net
                                         # (string, optional)
-skip_routing {true|false}               # Skip routing of this net
                                         # (string, optional)
-stack_distance <distance>               # Stacking distance (string, optional)
-stripe_layer_range <integer:integer>    # Specify the layer range that
                                         # accommodate different
