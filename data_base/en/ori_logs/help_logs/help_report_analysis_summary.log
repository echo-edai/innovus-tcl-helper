Usage: report_analysis_summary [-help] [-csv <string>] [-merged_views]
                               [-retime {path_slew_propagation aocv_path_slew_propagation}]
                               [-retime_mode {exhaustive}] [-view <viewName>]
                               [> <filename[.gz]>] [>> <filename[.gz]>] [-early   | -late ] [-expanded_summary_clocks   | -merged_groups ]

-help                         # Prints out the command usage
-csv <string>                 # CSV file output name (string, optional)
-early                        # Generates the timing report for early paths
                              # (bool, optional)
-expanded_summary_clocks      # Generates report in terms of each possible
                              # clock domain pair separately. (bool, optional)
-late                         # Generates the timing report for late paths
                              # (bool, optional)
-merged_groups                # Merges all the clock groups for a consolidated
                              # timing summary. (bool, optional)
-merged_views                 # Generates merged report across all views.
                              # (bool, optional)
-retime {path_slew_propagation aocv_path_slew_propagation}
                              # Reanalyzes the specified set of paths using the
                              # specified method (enum, optional)
-retime_mode {exhaustive}     # Reanalyzes the specified set of paths using the
                              # specified retime mode (enum, optional)
-view <viewName>              # Generates a timing report for the specified
                              # analysis view only. By default all active views
                              # are analyzed (string, optional)
> <filename[.gz]>             # Redirects output to specified file
                              # (redirect_operator, optional)
>> <filename[.gz]>            # Redirects output to specified file
                              # (redirect_operator, optional)