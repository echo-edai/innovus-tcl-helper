Usage: attachIOBuffer [-help] [-baseName <string>]
                      [-dishonorUpfDomainBoundaryCheckForIsoLsStrategy]
                      [-excNetFile <string>] [-excludeClockNet] [-port]
                      [-prePlace] [-selNetFile <string>] [-skipRefinePlace]
                      [-suffix <string>] { [-in <string>] [-out <string>] } [ -status {placed fixed softfixed} ]

-help                                # Prints out the command usage
-baseName <string>                   # base name of the added buffer and net
                                     # (string, optional)
-dishonorUpfDomainBoundaryCheckForIsoLsStrategy
                                     # dishonour power-domain boundary check
                                     # for isolation/level-shifter instances
                                     # (bool, optional)
-excNetFile <string>                 # file containing list of excluded nets
                                     # (string, optional)
-excludeClockNet                     # exclude clock nets while buffering
                                     # (bool, optional)
-in <string>                         # cell name(s) to buffer input ports
                                     # (string, optional)
-out <string>                        # cell name(s) to buffer output ports
                                     # (string, optional)
-port                                # prepend port name to buffer and net
                                     # names when base name is not given
                                     # (bool, optional)
-prePlace                            # inverter connected to the port is
                                     # legally placed and the other inverter is
                                     # left unplaced (bool, optional)
-selNetFile <string>                 # file containing list of selected nets
                                     # (string, optional)
-skipRefinePlace                     # skip legalization of the new
                                     # buffer/inverter (incremental placement
                                     # needs to be run later to legalize it)
                                     # (bool, optional)
-status {placed fixed softfixed}     # specifies the placement status of the
                                     # added buffer (placed/fixed/softfixed)
                                     # (enum, optional)
-suffix <string>                     # suffix to use in buffer and net names
                                     # (string, optional)