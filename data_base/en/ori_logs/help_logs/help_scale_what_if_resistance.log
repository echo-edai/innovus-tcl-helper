Usage: scale_what_if_resistance [-help] -reset | {-net <string> {-global | -region <string> | -cell <string> | -instance <string> | -file <string>} [-auto_scale_adjacent_via_layers {true false}] {{ {-scale <string> } {-layer <string> }} | -scale_ron <string>} }

-help                                     # Prints out the command usage
-auto_scale_adjacent_via_layers {true false}
                                          # Auto Scale Adjacent Via Layers
                                          # <true|false> (enum, optional)
-cell <string>                            # cell name (string, required)
-file <string>                            # file name (string, required)
-global                                   # is global (bool, required)
-instance <string>                        # instance name (string, required)
-layer <string>                           # layer name (string, required)
-net <string>                             # net name (string, required)
-region <string>                          # region <x1 y1 x2 y2> (um)
                                          # (string, required)
-reset                                    # reset all scale resistance options
                                          # (bool, optional)
-scale <string>                           # scale factor (string, optional)
-scale_ron <string>                       # scale powergate on resistance
                                          # factor (string, required)