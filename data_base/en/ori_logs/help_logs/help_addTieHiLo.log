Usage: addTieHiLo [-help] [-cell <tieCell-list>] [-createHierPort {true|false}]
                  [-keepExisting {true|false}] [-matchingPDs {true|false}]
                  [-postMask {true|false}] [-powerDomain <powerDomain name>]
                  [-prefix <tie-prefix>] [-reportHierPort {true|false}] [-cellPin value | -instancePin file name | -excludePin file name]

-help                                    # Prints out the command usage
-cell <tieCell-list>                     # list of maximum 2 tie-cells to be
                                         # used by addTieHiLo command
                                         # (string, default="")
-cellPin <value>                         # cell pins that to be tied
                                         # (string, default="")
-createHierPort {true|false}             # Add tie-cells in different hierarchy
                                         # than tie-off pins when possible
                                         # (bool, default=false)
-excludePin <file name>                  # excludePin file name
                                         # (string, default="")
-instancePin <file name>                 # instance pins file name
                                         # (string, default="")
-keepExisting {true|false}               # keep existing tieHiLo connections
                                         # (bool, default=false)
-matchingPDs {true|false}                # insert tie-cells in all power
                                         # domains (bool, default=false)
-postMask {true|false}                   # insert tie cells in post mask flow
                                         # (bool, default=false)
-powerDomain <powerDomain name>          # Power domain name
                                         # (string, default="")
-prefix <tie-prefix>                     # Prefix of tie cell instances
                                         # (string, default="")
-reportHierPort {true|false}             # Report created ports when
                                         # createHierPort is set
                                         # (bool, default=false)