Usage: report_clock_timing [-help] [-absolute_compare] [-clock <clock_list>]
                           [-cppr_relative] [-format <column_list>]
                           [-from <from_list>] [-from_clock <from_clock_list>]
                           [-greater_than <lower_limit>]
                           [-latency_greater_than <lower_limit>]
                           [-nworst <worst_entries>] [-tcl_list] [-to <to_list>]
                           [-to_clock <to_clock_list>]
                           -type {skew interclock_skew jitter summary latency cppr_stage_count}
                           [-verbose] [-view <view_list>] [> <filename>]
                           [>> <filename>] [-early  | -late ] [ [-rise  | -fall ] [-launch  | -capture ] | [-histogram  [-histogram_range <interval_size>]] [-logic_level  [-source {clock_root | generated_clock}]] ]

-help                                   # Prints out the command usage
-absolute_compare                       # Reports skews with values compared in
                                        # absolute form (bool, optional)
-capture                                # When specified with -type latency,
                                        # generates a report of capture latency
                                        # values (-capture) (bool, optional)
-clock <clock_list>                     # List of clocks to be reported
                                        # (string, optional)
-cppr_relative                          # Reports the latencies in skew
                                        # reports, from the cppr common pin
                                        # (bool, optional)
-early                                  # Uses hold skew to generate the report
                                        # (bool, optional)
-fall                                   # Active transition at sequential
                                        # devices clock pins on falling edge
                                        # (bool, optional)
-format <column_list>                   # Columns to display for path reports,
                                        # and the order in which they should
                                        # appear (string, optional)
-from <from_list>                       # List of sequential device clock pins
                                        # or ports to consider as from-pins in
                                        # the generated report (string, optional)
-from_clock <from_clock_list>           # List of from-clocks to be used in
                                        # generating the current interclock
                                        # skew report (string, optional)
-greater_than <lower_limit>             # Reports skews with values greater
                                        # than the lower_limit value
                                        # (float, optional)
-histogram                              # Generates a textual histogram of the
                                        # latency report (bool, optional)
-histogram_range <interval_size>        # Generates the histogram report at the
                                        # specified intervals. (float, optional)
-late                                   # Uses setup skew to generate the
                                        # report (bool, optional)
-latency_greater_than <lower_limit>     # When specified with type (skew |
                                        # interclock_skew | cppr_stage_count),
                                        # the reports are filtered for latency
                                        # (in case of skew/interclock_skew)
                                        # greater than provided value or depth
                                        # (in case of cppr_stage_count) greater
                                        # than provided value (float, optional)
-launch                                 # When specified with -type latency,
                                        # generates a report of launch latency
                                        # values (-launch) (bool, optional)
-logic_level                            # Reports the levels (the stage count
                                        # of gates) between the clock root, or
                                        # generated clock root, and the
                                        # capturing register (bool, optional)
-nworst <worst_entries>                 # Number of entries to be reported per
                                        # clock domain (int, optional)
-rise                                   # Active transition at sequential
                                        # devices clock pins on rising edge
                                        # (bool, optional)
-source {clock_root generated_clock}    # Reports the latency from either the
                                        # master clock, or the generated clock
                                        # that was derived from it
                                        # (enum, optional)
-tcl_list                               # Produces the report in Tcl list
                                        # format instead of a tabular format
                                        # (bool, optional)
-to <to_list>                           # List of sequential device clock pins
                                        # or ports to consider as to-pins in
                                        # the generated report (string, optional)
-to_clock <to_clock_list>               # List of to-clocks to be used in
                                        # generating the current interclock
                                        # skew report (string, optional)
-type {skew interclock_skew jitter summary latency cppr_stage_count}
                                        # Type of report to generate (enum, required)
-verbose                                # Generates a report that contains the
                                        # full clock path from the clock source
                                        # to the sink pin (bool, optional)
-view <view_list>                       # Generates a report for the specified
                                        # analysis view only (string, optional)
> <filename>                            # Writes the report to the specified
                                        # file name (redirect_operator, optional)
>> <filename>                           # Writes the report to the specified
                                        # file name (redirect_operator, optional)