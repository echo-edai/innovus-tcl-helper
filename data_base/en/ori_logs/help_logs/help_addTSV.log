Usage: addTSV [-help] [-noRouteBlkg] {[-frontBump <string>] [-backBump <string>] [-tsvViaName <string>]} [-frontBump <string> [-loc_type {geometry_center|cell_center} -prefix <string>] [-stackViaUnderBump <string>]] [-backBump <string>  [-loc_type {geometry_center|cell_center} -prefix <string>]] [-tsvViaName <string> [-noPlaceBlkg  | -spacing <float>] [[[-tsvFeedthru {x y} [-stackViaTopLayer <string>]] | [-stripeNet <string> -stripeLayer <string>]] | [-stackViaName <string> [[-stackViaMarkerLayer <string>] [-stack_via_array <arraySizePairList> -stack_via_pitch <pitchSizePairList>]]]]] {[-lowerLeftLoc {x y}] [-relative_bump_cell <string> | -relative_selected_bump ]} {[-pitchxy {x y}] [-relative_bump_cell <string> | -relative_selected_bump ]} {[-upperRightLoc {x y} | -numxy {x y}] [-relative_bump_cell <string> | -relative_selected_bump ]} [{-relative_bump_cell <string> | -relative_selected_bump } [-relative_min_pitch <float>] [-relative_offset {x y}] [-relative_bump_type {signal power ground}]] [-perim <integer>] [-stagger ]

-help                                    # Prints out the command usage
-backBump <string>                       # create back bumps 
                                         # (string, optional)
-frontBump <string>                      # create front bumps 
                                         # (string, optional)
-loc_type {geometry_center cell_center}  # Specify the location type for bump
                                         # creation (enum, optional)
-lowerLeftLoc {x y}                      # Lower left TSV array location
                                         # (point, optional)
-noPlaceBlkg                             # dont create placement blockage
                                         # (bool, optional)
-noRouteBlkg                             # dont create routing blockage
                                         # (bool, optional)
-numxy {x y}                             # x and y size of TSV array
                                         # (point, optional)
-perim <integer>                         # specifies the perim ring number
                                         # (int, optional)
-pitchxy {x y}                           # x and y pitch  (point, optional)
-prefix <string>                         # add prefix name for bump during bump
                                         # creation and bump mapping
                                         # (string, optional)
-relative_bump_cell <string>             # specify the relative bump cell, TSV
                                         # or bumps are created by default at
                                         # the geometry center of bumps with
                                         # specified bump cell (string, optional)
-relative_bump_type {signal power ground}
                                         # Specify the relative bump type, TSV
                                         # or bumps are created by default at
                                         # the geometry center of bumps with
                                         # specified bump type (enum, optional)
-relative_min_pitch <float>              # Specify min pitch between the
                                         # created bumps/TSVs. The pitch
                                         # between all the created bumps/TSV
                                         # should be larger than specified min
                                         # pitch (float, optional)
-relative_offset {x y}                   # Specify the offset of created
                                         # bump/TSV location compared with the
                                         # relative bump. The geometry center
                                         # of the created bump/TSV is the
                                         # geometry center of the relative
                                         # bumps plus the offset (point, optional)
-relative_selected_bump                  # specify the relative selected bump,
                                         # TSV or bumps are created by default
                                         # at the geometry center of selected
                                         # bumps (bool, optional)
-spacing <float>                         # spacing between TSV cut and ajacent
                                         # cell (float, optional)
-stackViaMarkerLayer <string>            # mark layer name (string, optional)
-stackViaName <string>                   # stack via name (string, optional)
-stackViaTopLayer <string>               # top metal layer for stacked via
                                         # (string, optional)
-stackViaUnderBump <string>              # under front bump stack via name
                                         # (string, optional)
-stack_via_array <arraySizePairList>     # specify the number of columns and
                                         # rows (string, optional)
-stack_via_pitch <pitchSizePairList>     # specify the pitch_x and pitch_y of
                                         # stackVia (string, optional)
-stagger                                 # staggered array (bool, optional)
-stripeLayer <string>                    # stripe LEF layer name or layer
                                         # number (-1 for backside metal1, 1
                                         # for Metal1, etc) (string, optional)
-stripeNet <string>                      # nets for connecting P/G stripes
                                         # (string, optional)
-tsvFeedthru {x y}                       # x and y size  (point, optional)
-tsvViaName <string>                     # TSV via master name
                                         # (string, optional)
-upperRightLoc {x y}                     # Upper right TSV array location
                                         # (point, optional)