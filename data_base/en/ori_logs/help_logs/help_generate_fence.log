Usage: generate_fence [-help] [-flow {2G simple_hinsts_shaping}]
                      [-for_partition] [-rectangle_shape]
                      [-target_util <string>] [ [-hInst <string>] | [-module <string>] | [-inst_group <string>] ]

-help                                     # Prints out the command usage
-flow {2G simple_hinsts_shaping}          # Specify the auto-fence generation
                                          # flow (enum, optional)
-for_partition                            # Specify this option for partition
                                          # fence generation. For power domain
                                          # fence generation by default.
                                          # (bool, optional)
-hInst <string>                           # specifies list of hinst names.
                                          # Create new fence for specified
                                          # hInsts (string, optional)
-inst_group <string>                      # specifies list of inst group names.
                                          # Create new fence for specified
                                          # groups (string, optional)
-module <string>                          # specifies list of cell names.
                                          # Create new fence for hInsts with
                                          # specified cell name (string, optional)
-rectangle_shape                          # Only generate rectangle shape
                                          # fences (bool, optional)
-target_util <string>                     # Specify fence target utilization.
                                          # Default: Core Utilization.
                                          # (string, optional)