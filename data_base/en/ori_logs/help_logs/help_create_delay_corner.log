Usage: create_delay_corner [-help]
                           [-early_estimated_worst_irdrop_factor <percent>]
                           [-early_irdrop_data <files_or_directories>]
                           [-early_irdrop_file <libSetObj>]
                           [-early_library_set <libSetObj>]
                           [-early_opcond <opCondName>]
                           [-early_opcond_library <libName>]
                           [-early_rc_corner <rcCornerObj>]
                           [-early_temp_file <tempName>]
                           [-irdrop_data <files_or_directories>]
                           [-irdrop_file <list_of_files>]
                           [-late_estimated_worst_irdrop_factor <percent>]
                           [-late_irdrop_data <files_or_directories>]
                           [-late_irdrop_file <list_of_files>]
                           [-late_library_set <libSetObj>]
                           [-late_opcond <opCondName>]
                           [-late_opcond_library <libName>]
                           [-late_rc_corner <rcCornerObj>]
                           [-late_temp_file <tempName>]
                           [-library_set <libSetObj>] -name <delayCornerName>
                           [-opcond <opcondName>] [-opcond_library <libName>]
                           [-pg_net_voltages <voltage_pairs>]
                           [-rc_corner <rcCornerObj>] [-si_enabled <true|false>]
                           [-temp_file <tempName>]

-help                                   # Prints out the command usage
-early_estimated_worst_irdrop_factor <percent>
                                        # Early voltage derating factor (float, optional)
-early_irdrop_data <files_or_directories>
                                        # Specifies the IR drop files or
                                        # directories to apply when calculating
                                        # early arrival times at a single delay
                                        # corner (string, optional)
-early_irdrop_file <libSetObj>          # Specifies the list of IR drop files
                                        # to apply when calculating early
                                        # arrival times at a single delay
                                        # corner (string, optional)
-early_library_set <libSetObj>          # Specifies the library set to
                                        # associate with this delay corner
                                        # object for calculating early arrival
                                        # times at a single delay corner
                                        # (string, optional)
-early_opcond <opCondName>              # Specifies the operating condition
                                        # name to use for calculating early
                                        # arrival times at a single delay
                                        # corner (string, optional)
-early_opcond_library <libName>         # Specifies the internal library name
                                        # for the library in which the early
                                        # operating condition is defined. This
                                        # is not the library file name
                                        # (string, optional)
-early_rc_corner <rcCornerObj>          # Specifies the RC corner object to
                                        # associate with this delay corner
                                        # object (string, optional)
-early_temp_file <tempName>             # Specifies the temperature filename
                                        # for temperature aware delay
                                        # calculation for early corner
                                        # (string, optional)
-irdrop_data <files_or_directories>     # Specifies the IR drop files or
                                        # directories to apply to both early
                                        # and late delay calculation for this
                                        # delay corner object (string, optional)
-irdrop_file <list_of_files>            # Specifies the list of IR drop files
                                        # to apply to both early and late delay
                                        # calculation for this delay corner
                                        # object (string, optional)
-late_estimated_worst_irdrop_factor <percent>
                                        # Late voltage derating factor (float, optional)
-late_irdrop_data <files_or_directories>
                                        # Specifies the IR drop files or
                                        # directories to apply when calculating
                                        # late arrival times at a single delay
                                        # corner (string, optional)
-late_irdrop_file <list_of_files>       # Specifies the list of IR drop files
                                        # to apply when calculating late
                                        # arrival times at a single delay
                                        # corner (string, optional)
-late_library_set <libSetObj>           # Specifies the library set to
                                        # associate with this delay corner
                                        # object for calculating late arrival
                                        # times at a single delay corner
                                        # (string, optional)
-late_opcond <opCondName>               # Specifies the operating condition
                                        # name to use for calculating late
                                        # arrival times at a single delay
                                        # corner (string, optional)
-late_opcond_library <libName>          # Specifies the internal library name
                                        # for the library in which the late
                                        # operating condition is defined. This
                                        # is not the library file name
                                        # (string, optional)
-late_rc_corner <rcCornerObj>           # Specifies the RC corner object to
                                        # associate with this delay corner
                                        # object (string, optional)
-late_temp_file <tempName>              # Specifies the temperature filename
                                        # for temperature aware delay
                                        # calculation for late corner
                                        # (string, optional)
-library_set <libSetObj>                # Specifies the library set to
                                        # associate with this delay corner
                                        # object (string, optional)
-name <delayCornerName>                 # Specifies the name for the delay
                                        # corner object being created
                                        # (string, required)
-opcond <opcondName>                    # Specifies the operating condition
                                        # name to use for setup and hold
                                        # analysis (string, optional)
-opcond_library <libName>               # Specifies the internal library name
                                        # for the library in which the
                                        # operating condition is defined. This
                                        # is not the library file name
                                        # (string, optional)
-pg_net_voltages <voltage_pairs>        # Power/ground net voltages to use for
                                        # both early/late analysis
                                        # (string, optional)
-rc_corner <rcCornerObj>                # Specifies the RC corner object to
                                        # associate with this delay corner
                                        # object (string, optional)
-si_enabled <true|false>                # Option to control SI behavior
                                        # (string, optional)
-temp_file <tempName>                   # Specifies the temperature filename
                                        # for temperature aware delay
                                        # calculation for single corner
                                        # (string, optional)