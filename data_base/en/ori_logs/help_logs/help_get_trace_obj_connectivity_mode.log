Usage: get_trace_obj_connectivity_mode [-help] [-macro_pins]
                                       [-max_fanin_fanout] [-register_inputs]
                                       [-register_outputs]
                                       [-quiet] [-nonDefault]

-help                               # Prints out the command usage
-macro_pins                         # specify macro pin name patterns in
                                    # regular expression (string, default="")
-max_fanin_fanout                   # Specify the maximum number of a pin's
                                    # fanin/fanout,a pin will be ignored in
                                    # tracing connectivity if its fanin/fanout
                                    # larger than the specified number
                                    # (int, default=1000)
-register_inputs                    # Specify register input pin names
                                    # (string, default="")
-register_outputs                   # Specify register output pin names
                                    # (string, default="")
-quiet                              # Displays the current settings in Tcl list format only
-nonDefault                         # Displays the current settings which are not default settings