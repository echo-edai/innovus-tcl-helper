Usage: place_opt_design [-help] [-expanded_views] [-incremental]
                        [-incremental_timing] [-num_paths <string>]
                        [-out_dir <string>] [-predict_prects] [-prefix <string>]
                        [-timing_debug_report]

-help                         # Prints out the command usage
-expanded_views               # Expanded views (bool, optional)
-incremental                  # Incremental place_opt_design (bool, optional)
-incremental_timing           # Incremental timing optimization
                              # (bool, optional)
-num_paths <string>           # Specify number of paths reported
                              # (string, optional)
-out_dir <string>             # Output file directory (string, optional)
-predict_prects               # Perform optimization specific to physical
                              # synthesis exchange (bool, optional)
-prefix <string>              # Output file name prefix (string, optional)
-timing_debug_report          # Generate timing debug report (bool, optional)