Usage: reportPowerDomain [-help] [-bindLib] [-file <string>] [-isoInst]
                         [-module <inst|hinst>+]
                         [-partitionHports <pin|port|hpin>+] [-pgNet]
                         [-pin <pin|port|hpin>+]
                         [-powerDomainBoundaryPort <string>]
                         [-powerDomainCoverage <pd1 pd2>] [-shifter]
                         [-supplyCrossing <supp1 supp2>] [-verbose] [-voltage] [-powerDomain <pd> [-checkPgScope ] ] [-net <net>+} ] [-inst <inst>+ ]

-help                                 # Prints out the command usage
-bindLib                              # report library binding (bool, optional)
-checkPgScope                         # pg should connect to scope net only
                                      # (bool, optional)
-file <string>                        # output file (string, optional)
-inst <inst>+                         # list of insts ((inst)*, optional)
-isoInst                              # report isolation (bool, optional)
-module <inst|hinst>+                 # list of modules
                                      # ((inst|hInst)*, optional)
-net <net>+}                          # list of nets ((net)*, optional)
-partitionHports <pin|port|hpin>+     # list of hier. pins
                                      # ((instTerm|term|hInstTerm)*, optional)
-pgNet                                # report PG nets (bool, optional)
-pin <pin|port|hpin>+                 # list of pins
                                      # ((instTerm|term|hInstTerm)*, optional)
-powerDomain <pd>                     # power domain name ((pd), optional)
-powerDomainBoundaryPort <string>     # port name (string, optional)
-powerDomainCoverage <pd1 pd2>        # (string, optional)
-shifter                              # report shifter (bool, optional)
-supplyCrossing <supp1 supp2>         # (string, optional)
-verbose                              # print out detail infomation
                                      # (bool, optional)
-voltage                              # report domain voltages (bool, optional)