Usage: get_well_tap_mode [-help] [-abut_boundary_tap_distance]
                         [-antenna_tap_break_cell] [-antenna_tap_cell]
                         [-antenna_tap_left_cell] [-antenna_tap_pitch]
                         [-antenna_tap_right_cell]
                         [-antenna_tap_right_top_edge_cell]
                         [-avoid_vertical_well_abutment] [-avoidAbutment]
                         [-block_boundary_only] [-bottom_tap_cell]
                         [-bottom_termination_cell] [-cell] [-channel_offset]
                         [-check_channel] [-column_cell] [-create_rows]
                         [-disable_check_zone_at_boundary] [-inRowOffset]
                         [-insert_cells] [-rule] [-siteOffset]
                         [-tap_function_cells] [-tap_termination_alignment]
                         [-termination_align] [-termination_cell]
                         [-top_tap_cell] [-top_termination_cell]
                         [-vertical_boundary_spacing] [-well_cut_cell]
                         [-quiet] [-nonDefault]

-help                                  # Prints out the command usage
-abut_boundary_tap_distance            # Specifies boundary cells and their tap
                                       # distance when they are vertically
                                       # abutted (string, default="")
-antenna_tap_break_cell                # Specifies cells can break antenna tap
                                       # (string, default="")
-antenna_tap_cell                      # Specifies normal antenna tap cell
                                       # (string, default="")
-antenna_tap_left_cell                 # Specifies antenna tap cell for left
                                       # edge (string, default="")
-antenna_tap_pitch                     # Specifies the pitch of antenna tap
                                       # cell (float, default=0)
-antenna_tap_right_cell                # Specifies antenna tap cell for right
                                       # edge (string, default="")
-antenna_tap_right_top_edge_cell       # Specifies antenna tap cell for right
                                       # top edge (string, default="")
-avoid_vertical_well_abutment          # Specifies which type of well-tap cells
                                       # to be forbidden from vertical abutment
                                       # (enums={none ntap ptap all_tap}, default=none)
-avoidAbutment                         # Specifies whether the inserted taps
                                       # should avoid horizontal and vertical
                                       # abutment  (bool, default=false)
-block_boundary_only                   # Specifies whether inserting
                                       # termination cells on the core boundary
                                       # (bool, default=false)
-bottom_tap_cell                       # Cell to be used as bottom tap for
                                       # addEndCap boundary cell insertion flow
                                       # (string, default="")
-bottom_termination_cell               # Specifies the list of bottom
                                       # termination cells to be used
                                       # (string, default="")
-cell                                  # Cell to be used as welltap
                                       # (string, default="")
-channel_offset                        # Specifies the offset value between
                                       # taps and blockage in channel
                                       # (float, default=0, min=0, max=1.79769313486232e+308)
-check_channel                         # Specifies whether checking blockage
                                       # channel (bool, default=false)
-column_cell                           # Specifies the list of cells which can
                                       # be replaced by termination cell
                                       # (string, default="")
-create_rows                           # Create rows for welltap cell techSites
                                       # which do not have rows in the floor
                                       # plan (bool, default=false)
-disable_check_zone_at_boundary        # disable check zone at bounadry
                                       # (enums={none vdd vss both}, default=none)
-inRowOffset                           # Specifies the distance between the
                                       # first wellTap in a row and the start
                                       # of the row
                                       # (float, default=0, min=0, max=1.79769313486232e+308)
-insert_cells                          # Insert well-taps based on cell, layer
                                       # and inertval (string, default="")
-rule                                  # Specifies the well latch-up rule
                                       # (float, default=0)
-siteOffset                            # Specifies the offset value in number
                                       # of sites that vertical taps need to be
                                       # aware of
                                       # (int, default=1, min=1, max=INT_MAX)
-tap_function_cells                    # Specifies the list of tap function
                                       # cells to be used (string, default="")
-tap_termination_alignment             # Specifies whether to align well-taps
                                       # and termination cells
                                       # (bool, default=false)
-termination_align                     # Specifies the termination cell align
                                       # (enums={left right center}, default=left)
-termination_cell                      # Specifies the list of termination
                                       # cells to be used (string, default="")
-top_tap_cell                          # Cell to be used as top tap for
                                       # addEndCap boundary cell insertion flow
                                       # (string, default="")
-top_termination_cell                  # Specifies the list of top termination
                                       # cells to be used (string, default="")
-vertical_boundary_spacing             # Specifies the spacing between center
                                       # of tap cell and vertical boundary
                                       # (float, default=-1, min=-1, max=1.79769313486232e+308)
-well_cut_cell                         # Specifies the list of cells with the
                                       # well cuts (string, default="")
-quiet                                 # Displays the current settings in Tcl list format only
-nonDefault                            # Displays the current settings which are not default settings