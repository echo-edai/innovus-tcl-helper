Usage: reportSpecialRoute [-help] [<reportName>] [-center_line]
                          [-net <netName>] [-interposer_shielding_ratio [-exclude_nets <netName>]] [-interposer_ndr_check [-exclude_nets <netName>]] [-interposer_route [-exclude_nets <netName>]] [-interposer_route [[-interposer_route_constraint_file <ircFileName>] [-interposer_layers <layerName>]]] [[ [-summary ] [-wirelength ] [-wire_segment ] [-selected ] [-highlight45layer <layerName>] [-lengththreshold <value>] [-resfile <resFileName>] [-by_layer ]] | [-interposer_route ] | [-interposer_ndr_check ] | [-interposer_shielding_ratio ]]

-help                             # Prints out the command usage
<reportName>                      # Specifies report file name
                                  # (string, optional)
-by_layer                         # Specifies the layer (bool, optional)
-center_line                      # Routing length is calculated by center line
                                  # (bool, optional)
-exclude_nets <netName>           # Specifies exclude net name
                                  # (string, optional)
-highlight45layer <layerName>     # Specifies the layer to highlight nets with
                                  # 45-degree routing (string, optional)
-interposer_layers <layerName>    # Specifies interposer layers
                                  # (string, optional)
-interposer_ndr_check             # interposer routing ndr rule and missing
                                  # shield check (bool, optional)
-interposer_route                 # Reports interposer route (bool, optional)
-interposer_route_constraint_file <ircFileName>
                                  # Specifies interposer route constraint file
                                  # name (string, optional)
-interposer_shielding_ratio       # Reports interposer shielding ratio
                                  # (bool, optional)
-lengththreshold <value>          # Specifies length threshold
                                  # (float, optional)
-net <netName>                    # Specifies net name (string, optional)
-resfile <resFileName>            # Specifies resistance file name
                                  # (string, optional)
-selected                         # Reports the length of the selected wire
                                  # segmnets of SPECIALNET (bool, optional)
-summary                          # Summarizes the wire length and VIAs for
                                  # special nets (bool, optional)
-wire_segment                     # Reports on wire segments of each SPECIALNET
                                  # (bool, optional)
-wirelength                       # Reports wire length (bool, optional)