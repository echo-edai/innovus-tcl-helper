Usage: createPlaceBlockage [-help] [-pushdown] {  {    [-box {x1 y1 x2 y2} | -polygon {{x1 y1} {x2 y2}...} | -boxList {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...} | -allPartition  | -allMacro ]    [-inst <inst> | -hinst <hInst>]  }   [-name <string> | -prefixOn ]  [{-type {hard soft partial macroOnly}} [-density <integer>] [-excludeFlops ]]  [-noCutByCore ]  [-snapToSite ] } [       {-inst <inst>  | -hinst <hInst> | -allPartition  | -allMacro }       [-cover ]        [-innerRingBySide {<left> <bottom> <right> <top>} | -innerRingByEdge {<edge1> <edge2> ...}]        [-outerRingBySide {<left> <bottom> <right> <top>} | -outerRingByEdge {<edge1> <edge2> ...}]  ]

-help                                   # Prints out the command usage
-allMacro                               # placement blockage to be created
                                        # around all macros (bool, optional)
-allPartition                           # placement blockage to be created
                                        # around all partitions (bool, optional)
-box {x1 y1 x2 y2}                      # placement blockage's box in <llx>
                                        # <lly> <urx> <ury> (box, optional)
-boxList {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...}
                                        # placement blockage's box list: llx1
                                        # lly1 urx1 ury1 ... (box_list, optional)
-cover                                  # create a obstruction around instance
                                        # (bool, optional)
-density <integer>                      # density of partial or soft placement
                                        # blockage (int, optional, min=5, max=100)
-excludeFlops                           # flops and latches are excluded from
                                        # the partial placement blockage
                                        # (bool, optional)
-hinst <hInst>                          # placement blockage to be created
                                        # around this HInstance
                                        # ((hInst), optional)
-innerRingByEdge {<edge1> <edge2> ...}  # distance from inner placement
                                        # blockage border to
                                        # instance/hinstance/partition border
                                        # for every edge (string, optional)
-innerRingBySide {<left> <bottom> <right> <top>}
                                        # distance from inner placement
                                        # blockage border to
                                        # instance/hinstance/partition border
                                        # at <left> <bottom> <right> <top>
                                        # (box, optional)
-inst <inst>                            # placement blockage to be created
                                        # around this instance ((inst), optional)
-name <string>                          # name of placement blockage
                                        # (string, optional)
-noCutByCore                            # do not cut placement blockage by row
                                        # area in core (bool, optional)
-outerRingByEdge {<edge1> <edge2> ...}  # distance from outer placement
                                        # blockage border to
                                        # instance/hinstance/partition border
                                        # for every edge (string, optional)
-outerRingBySide {<left> <bottom> <right> <top>}
                                        # distance from outer placement
                                        # blockage border to
                                        # instance/hinstance/partition border
                                        # at <left> <bottom> <right> <top>
                                        # (box, optional)
-polygon {{x1 y1} {x2 y2}...}           # placement blockage's polygon: x1 y1
                                        # x2 y2 ... (point_list, optional)
-prefixOn                               # name blockage with prefix
                                        # (bool, optional)
-pushdown                               # set 'pushdown' attribute. Specify the
                                        # blockage is pushed down into the
                                        # block from the top level of the
                                        # design (bool, optional)
-snapToSite                             # placement blockage newly created will
                                        # snap to row site (bool, optional)
-type {hard soft partial macroOnly}     # type of the placement blockage to
                                        # create (enum, optional)