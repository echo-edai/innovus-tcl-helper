Usage: set_min_delay [-help] <value> [-comment <string>] [-fall]
                     [-fall_through <through_list>] [-no_segment] [-rise]
                     [-rise_through <through_list>] [-through <through_list>] [-combinational_from_to  | -ignore_clock_latency ] [-from <from_list> | -rise_from <from_list> | -fall_from <from_list>] [-to <to_list]> | -rise_to <to_list> | -fall_to <to_list]>]

-help                            # Prints out the command usage
<value>                          # Minimum delay value (float, required)
-combinational_from_to           # Defines path defined by -from/to pins as
                                 # combinational (bool, optional)
-comment <string>                # Not supported option (string, optional)
-fall                            # Apply the assertion at the falling edge of
                                 # the signal on the path endpoints
                                 # (bool, optional)
-fall_from <from_list>           # Applies the minimum delay constraint at the
                                 # falling edge of the signal on the from pins
                                 # (string, optional)
-fall_through <through_list>     # Applies the assertion at the falling edge of
                                 # the signal on the through pins
                                 # (string, optional)
-fall_to <to_list]>              # Applies the minimum delay constraint at the
                                 # falling edge of the signal on the to pins
                                 # (string, optional)
-from <from_list>                # Applies the minimum delay constraint to all
                                 # paths originating from the from_list list
                                 # (string, optional)
-ignore_clock_latency            # Defines path as combinational w/o
                                 # launch/capture clock latencies (bool, optional)
-no_segment                      # Specifies constraint as non segmenting
                                 # (bool, optional)
-rise                            # Applies the assertion at the rising edge of
                                 # the signal on the path endpoints
                                 # (bool, optional)
-rise_from <from_list>           # Applies the minimum delay constraint at the
                                 # rising edge of the signal on the from pins
                                 # (string, optional)
-rise_through <through_list>     # Applies the assertion at the rising edge of
                                 # the signal on the through pins
                                 # (string, optional)
-rise_to <to_list>               # Applies the minimum delay constraint at the
                                 # rising edge of the signal on the to pins
                                 # (string, optional)
-through <through_list>          # Applies the constraint to both the rising
                                 # and the falling edges (string, optional)
-to <to_list]>                   # Applies the minimum delay constraint to all
                                 # paths ending in the -to pin list
                                 # (string, optional)