Usage: report_noise_propagation [-help] [-level {VL VH worst all}]
                                [-max_paths <integer>] [-max_slack <float>]
                                [-nets <string>] [-nworst <integer>]
                                [-pins <string>] [-source_depth <integer>]
                                [-views <string>] [ [ > | >> ] ]

-help                              # Prints out the command usage
-level {VL VH worst all}           # Reports paths for specified glitch level.
                                   # Allowed values are: VL, VH, worst, or all
                                   # (enum, optional)
-max_paths <integer>               # Reports the specified no of paths
                                   # (int, optional)
-max_slack <float>                 # Reports paths with glitch slack equal to
                                   # or lesser than specified value
                                   # (float, optional)
-nets <string>                     # Reports paths with endpoint being all the
                                   # input pins connected to this net
                                   # (string, optional)
-nworst <integer>                  # Max no. of sources per endpoint for which
                                   # paths need to be reported (int, optional)
-pins <string>                     # Reports the paths for specified endpoint
                                   # pins (string, optional)
-source_depth <integer>            # Max number of sources to be traced in any
                                   # given branch in the fanin cone of
                                   # violation (int, optional)
-views <string>                    # Reports the paths for the specified view
                                   # (string, optional)
> <filename>                       # Redirect output to file
                                   # (redirect_operator, optional)
>> <filename>                      # Append to output file
                                   # (redirect_operator, optional)