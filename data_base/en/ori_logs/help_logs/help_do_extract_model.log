Usage: do_extract_model [-help] <model_filename> [-abs_tol_val <float>]
                        [-abs_tol_val_optimistic <float>]
                        [-abs_tol_val_pessimistic <float>]
                        [-assertions <constraint filename>]
                        [-cell_name <cell_name>]
                        [-clock_slews {<clk_slew1 clk_slew2>...}]
                        [-format <string>] [-gain <integer>]
                        [-include_aocv_weights] [-include_power]
                        [-input_slews {<input_slew1 input_slew2>...}]
                        [-lib_name <lib_name>] [-max_num_loads <value>]
                        [-max_num_slews <value>]
                        [-output_loads {<output_load1 output_load2>...}]
                        [-per_tol_val <float>] [-per_tol_val_optimistic <float>]
                        [-per_tol_val_pessimistic <float>] [-pg]
                        [-precision <integer>] [-resolution <float>]
                        [-tolerance <float>] [-validate <string>]
                        [-verilog_shell_file <filename>]
                        [-verilog_shell_module <top_module_name>]
                        [-view <string>] [] [-check]

-help                                      # Prints out the command usage
<model_filename>                           # Specifies the name of the output
                                           # file (string, required)
-abs_tol_val <float>                       # Specifies the absolute tolerance
                                           # value to be used during the
                                           # validation of extracted ETM. For
                                           # more details refer
                                           # 'compare_model_timing
                                           # -absolute_tolerance'. This can be
                                           # used only when '-validate' is used
                                           # with model extraction. The integer
                                           # value specified with this switch
                                           # is read as ns/ps depending upon
                                           # the time unit. Default 3ps
                                           # (float, optional)
-abs_tol_val_optimistic <float>            # This switch will specify the
                                           # absolute tolerance limit for
                                           # flagging an optimistic failure. An
                                           # optimistic path violating absolute
                                           # as well as percentage tolerance
                                           # limit will be flagged as FAIL in
                                           # compare_model_timing output
                                           # report. Default value of this
                                           # switch is 15ps. This can be used
                                           # only when '-validate' is used with
                                           # model extraction. (float, optional)
-abs_tol_val_pessimistic <float>           # This switch will specify the
                                           # absolute tolerance limit for
                                           # flagging a pessimistic failure. A
                                           # pessimistic path violating
                                           # absolute as well as percentage
                                           # tolerance limit will be flagged as
                                           # FAIL in compare_model_timing
                                           # output report. Default value of
                                           # this switch is 15ps. This can be
                                           # used only when '-validate' is used
                                           # with model extraction.
                                           # (float, optional)
-assertions <constraint filename>          # Dumps the constraints for model,
                                           # which is used in validation flow
                                           # (string, optional)
-cell_name <cell_name>                     # Specifies the cell name used in
                                           # the timing model (string, optional)
-check                                     # Checks the generated ETM library
                                           # using Valus. (bool, optional)
-clock_slews {<clk_slew1 clk_slew2>...}    # Specifies a range of slew values
                                           # used at all clock pins
                                           # (string, optional)
-format <string>                           # Specifies the format for extracted
                                           # model in tlf, dotlib, syntech
                                           # (string, optional)
-gain <integer>                            # Represents an increase in the
                                           # number of delay arcs if a pin is
                                           # removed (int, optional)
-include_aocv_weights                      # writes stage weights on individual
                                           # arcs (bool, optional)
-include_power                             # Writes information of power
                                           # consumed by the block
                                           # (bool, optional)
-input_slews {<input_slew1 input_slew2>...}
                                           # Specifies a range of slew values
                                           # used at all data input ports
                                           # (string, optional)
-lib_name <lib_name>                       # Specifies the library name used in
                                           # the timing model (string, optional)
-max_num_loads <value>                     # Specifies the maximum number of
                                           # output load values (int, optional)
-max_num_slews <value>                     # Specifies the maximum number of
                                           # input slews or clock slews
                                           # (int, optional)
-output_loads {<output_load1 output_load2>...}
                                           # Specifies a range of load values
                                           # used at all output ports
                                           # (string, optional)
-per_tol_val <float>                       # Specifies the percentage tolerance
                                           # value to be used during the
                                           # validation of extracted ETM. For
                                           # more details refer
                                           # 'compare_model_timing
                                           # -percent_tolerance'. This can be
                                           # used only when '-validate' is used
                                           # with model extraction. Default 3%
                                           # (float, optional)
-per_tol_val_optimistic <float>            # This switch will specify the
                                           # percentage tolerance limit for
                                           # flagging an optimistic failure. An
                                           # optimistic path violating
                                           # percentage as well as absolute
                                           # tolerance limit will be flagged as
                                           # FAIL in compare_model_timing
                                           # output report. Default value of
                                           # this switch is 3%. This can be
                                           # used only when '-validate' is used
                                           # with model extraction.
                                           # (float, optional)
-per_tol_val_pessimistic <float>           # This switch will specify the
                                           # percentage tolerance limit for
                                           # flagging a pessimistic failure. A
                                           # pessimistic path violating
                                           # percentage as well as absolute
                                           # tolerance limit will be flagged as
                                           # FAIL in compare_model_timing
                                           # output report. Default value of
                                           # this switch is 3%. This can be
                                           # used only when '-validate' is used
                                           # with model extraction.
                                           # (float, optional)
-pg                                        # Writes the power ground
                                           # information for pins (bool, optional)
-precision <integer>                       # Specifies the floating point
                                           # precision used for the timing
                                           # model (int, optional)
-resolution <float>                        # Specifies the magnitude of delay
                                           # difference that can be ignored in
                                           # extraction (float, optional)
-tolerance <float>                         # Specifies the accuracy level of
                                           # extractor in percent
                                           # (float, optional)
-validate <string>                         # This switch enables the validation
                                           # of generated ETM for corresponding
                                           # view and displays number of
                                           # failures at the end of validation.
                                           # It is mandatory to specify the
                                           # name of validation directory with
                                           # this option (-validate valDir),
                                           # this contains the
                                           # write_model_timing,
                                           # compare_model_timing and summary
                                           # reports. (string, optional)
-verilog_shell_file <filename>             # Generates a Verilog shell file
                                           # that instantiates the timing model
                                           # (string, optional)
-verilog_shell_module <top_module_name>    # Specifies the top module name of
                                           # the Verilog shell file
                                           # (string, optional)
-view <string>                             # Specifies the view for which model
                                           # needs to extracted (string, optional)