Usage: place_connected [-help] -attractor <inst/IO NameList>
                       [-attractor_pin <pinNameList>] [-fixed] [-move_fixed]
                       [-placed] {-level <#> | -sequential <all_connected | direct_connected> | -stop_points <instName> | -before_points <instName> | -instance_pin <inst/pin>} [{ -stop_points <instName> | -key_cell <cellName> }] [{ -before_points <instName> | -key_cell <cellName> }] [{ -instance_pin <inst/pin> | -key_cell <cellName> }]

-help                                  # Prints out the command usage
-attractor <inst/IO NameList>          # attractor list (string, required)
-attractor_pin <pinNameList>           # only pull instances that have
                                       # connection with certain pins.
                                       # (string, optional)
-before_points <instName>              # the attracting is stopped before these
                                       # instances (string, optional)
-fixed                                 # set placement status as fixed
                                       # (bool, optional)
-instance_pin <inst/pin>               # instances to force attract
                                       # (string, optional)
-key_cell <cellName>                   # type of cell to be pulled close
                                       # (string, optional)
-level <#>                             # logic level of connection
                                       # (int, optional)
-move_fixed                            # attract fixed instances as well
                                       # (bool, optional)
-placed                                # set placement status as placed
                                       # (bool, optional)
-sequential {all_connected direct_connected}
                                       # pull only directly connected or all
                                       # sequential cells (enum, optional)
-stop_points <instName>                # instances to stop by
                                       # (string, optional)