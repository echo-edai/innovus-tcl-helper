Usage: set_output_delay [-help] <delay_value> <port_or_pin_list> [-add_delay]
                        [-clock <clock_name>] [-clock_fall] [-fall]
                        [-group_path <group_name>] [-level_sensitive] [-max]
                        [-min] [-network_latency_included]
                        [-reference_pin <pin_name>] [-rise]
                        [-source_latency_included]

-help                         # Prints out the command usage
<delay_value>                 # The value for the path delay (float, required)
<port_or_pin_list>            # List of input port or pin names
                              # (string, required)
-add_delay                    # Adds delay information to the existing output
                              # delay (bool, optional)
-clock <clock_name>           # The delay is relative to the specified clock
                              # (string, optional)
-clock_fall                   # The delays are with respect to the falling edge
                              # of the clock waveform (bool, optional)
-fall                         # The output delay refers to the falling edge of
                              # the signal at specified ports or pins
                              # (bool, optional)
-group_path <group_name>      # The group name where paths ending at the
                              # specified ports or pins are to be added
                              # (string, optional)
-level_sensitive              # Models input delay that is launched by a
                              # positive level sensitive latch (bool, optional)
-max                          # The delay refers to the setup analysis
                              # (bool, optional)
-min                          # The delay refers to the hold analysis
                              # (bool, optional)
-network_latency_included     # The clock network latency should not be added
                              # to the output delay value (bool, optional)
-reference_pin <pin_name>     # Adds source and network latency of the
                              # specified reference pin to the output delay
                              # value in propagated mode (string, optional)
-rise                         # The output delay refers to the rising edge of
                              # the signal at the specified ports or pins
                              # (bool, optional)
-source_latency_included      # The clock source latency should not be added to
                              # the output delay value (bool, optional)