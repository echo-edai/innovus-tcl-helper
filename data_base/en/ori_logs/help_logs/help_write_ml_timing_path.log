Usage: write_ml_timing_path [-help] [-anchor_file <string>] [-begin_end_pair]
                            [-chain_levels <int>] [-chain_path] [-each_endpoint]
                            [-from <pin_list>] [-gen_anchor] [-hpin] [-io_only]
                            [-max_paths <int>] [-max_slack <float>]
                            [-nworst <int>] [-partitions <partition_list>]
                            [-path_group <string>] [-per_partition]
                            -prefix <string>
                            [-retime {aocv ssta path_slew_propagation aocv_path_slew_propagation}]
                            [-retime_mode {path exhaustive}]
                            [-start_pathid <int>] [-to <pin_list>] [-verbose]
                            [-views <view_list>]

-help                              # Prints out the command usage
-anchor_file <string>              # Input anchor file name (string, optional)
-begin_end_pair                    # Report all violation between unique source
                                   # and target register pairs (bool, optional)
-chain_levels <int>                # chain level if chain_path is enabled
                                   # (int, optional)
-chain_path                        # Get chained paths (bool, optional)
-each_endpoint                     # Whether to dump at least one path for each
                                   # end point (bool, optional)
-from <pin_list>                   # Dump data from the specified pin(s).
                                   # (tcl_obj, optional)
-gen_anchor                        # Generate anchor file (bool, optional)
-hpin                              # Dump hpin in timing points
                                   # (bool, optional)
-io_only                           # io path only (bool, optional)
-max_paths <int>                   # max_paths for report_timing
                                   # (int, optional)
-max_slack <float>                 # max_slack for report_timing
                                   # (float, optional)
-nworst <int>                      # nworst for report_timing, default: 1
                                   # (int, optional)
-partitions <partition_list>       # partition list if per_partition is set
                                   # (tcl_obj, optional)
-path_group <string>               # the path_group for report_timing
                                   # (string, optional)
-per_partition                     # Only dump paths through top level
                                   # partitions (bool, optional)
-prefix <string>                   # Prefix for output files (string, required)
-retime {aocv ssta path_slew_propagation aocv_path_slew_propagation}
                                   # retime for report_timing (enum, optional)
-retime_mode {path exhaustive}     # retime_mode for report_timing
                                   # (enum, optional)
-start_pathid <int>                # Starting path id, default is 1
                                   # (int, optional)
-to <pin_list>                     # Dump data to the specified pin(s).
                                   # (tcl_obj, optional)
-verbose                           # Display performance message
                                   # (bool, optional)
-views <view_list>                 # Dump timing path for the specified
                                   # analysis view(s). (tcl_obj, optional)