Usage: report_ccopt_cell_filtering_reasons [-help]
                                           [-cell_type {buffer inverter logic delay clock_gate flop latch}]
                                           [-clock_trees <string>]
                                           [-file <name>] [-power_domain <pd>]
                                           [-tcl_list]

-help                     # Prints out the command usage
-cell_type {buffer inverter logic delay clock_gate flop latch}
                          # Restrict the report the specified lib cell type (enum, optional)
-clock_trees <string>     # Restricts the report to the specified clock trees
                          # (string, optional)
-file <name>              # Save a copy of the contents of the report to the
                          # specified file name (string, optional)
-power_domain <pd>        # Restricts the report to the specified power domain
                          # ((pd), optional)
-tcl_list                 # Returns the report as Tcl formatted data, and
                          # formats the -file as tcl if specified (bool, optional)