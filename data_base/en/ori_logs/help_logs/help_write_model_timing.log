Usage: write_model_timing [-help] [<model_timing_report_file>]
                          [-inputs <string>] [-nworst <integer>]
                          [-outputs <string>]
                          [-slew_propagation {worst path_based}]
                          [-type {arc slack}] [-verbose] [-view <string>] -setup <string> | -hold <string>

-help                                    # Prints out the command usage
<model_timing_report_file>               # Specifies the name of the interface
                                         # timing model report file that will
                                         # be generated with the interface
                                         # timing characteristics of the loaded
                                         # design (string, optional)
-hold <string>                           # To write the paths corresponding to
                                         # early analysis. (string, optional)
-inputs <string>                         # Restricts the write_model_timing
                                         # report to the input ports specified
                                         # with this parameter (string, optional)
-nworst <integer>                        # Specifies the number of paths to be
                                         # enumerated for each end point
                                         # (int, optional)
-outputs <string>                        # Restricts the write_model_timing
                                         # report to the output ports specified
                                         # with this parameter (string, optional)
-setup <string>                          # To write the paths corresponding to
                                         # late analysis. (string, optional)
-slew_propagation {worst path_based}     # Sets the slew propagation mode to
                                         # use for dumping the timing
                                         # characteristics of the design
                                         # (enum, optional)
-type {arc slack}                        # Determines whether to report arc
                                         # delay values or the worst-slack
                                         # values (enum, optional)
-verbose                                 # Prints the command progress details
                                         # (bool, optional)
-view <string>                           # Specifies a view name. The report
                                         # can be generated for a specifc view
                                         # name (string, optional)