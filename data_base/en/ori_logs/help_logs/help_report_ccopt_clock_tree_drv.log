Usage: report_ccopt_clock_tree_drv [-help] [-clock_trees {string1 string2 ...}]
                                   [-delay_corners <delay_corner>+]
                                   [-drv_types {transition max_cap max_source_to_sink_net_length}]
                                   [-early]
                                   [-exclude_violation_types {dont_touch_nets pre_routed_nets}]
                                   [-file <name>] [-late] [-num_nets <num|all>]
                                   [-views <analysis_view>+]

-help                              # Prints out the command usage
-clock_trees {string1 string2 ...} # Restricts the report to the specified
                                   # clock trees (list, optional)
-delay_corners <delay_corner>+     # Filter for a specific constrained delay
                                   # corner. Default all
                                   # ((delay_corner)+, optional)
-drv_types {transition max_cap max_source_to_sink_net_length}
                                   # Filter to choose what types of violation
                                   # to report on. Default all (enum, optional)
-early                             # Only report on the early half of the delay
                                   # corners (bool, optional)
-exclude_violation_types {dont_touch_nets pre_routed_nets}
                                   # Choose to exclude certain nets if they are
                                   # known to be not fixable. Default, include
                                   # everything (enum, optional)
-file <name>                       # Save a copy of the contents of the report
                                   # to the specified file name (string, optional)
-late                              # Only report on the late half of the delay
                                   # corners (bool, optional)
-num_nets <num|all>                # Specify for how many nets the detailed
                                   # reporting should report on. Default 10
                                   # (string, optional)
-views <analysis_view>+            # Restricts the report to the delay corners
                                   # associated with the specified views
                                   # ((analysis_view)+, optional)