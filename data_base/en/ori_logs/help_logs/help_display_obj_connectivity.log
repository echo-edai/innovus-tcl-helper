Usage: display_obj_connectivity [-help] [-direction <string>]
                                [-level <integer>] [-line_to_ports]
                                [-min_connection <num>] {-insts <string> | -ports <string> | -selected  | -reset } [-through_registers  [-all_registers ]]

-help                     # Prints out the command usage
-all_registers            # display all registers found during the analysis,
                          # even those which do not drive to other macros. It
                          # must be used with -through_registers (bool, optional)
-direction <string>       # specify the pin direction of objects to be
                          # displayed (in|out|all), default:all (string, optional)
-insts <string>           # specify the macros to be displayed
                          # (string, optional)
-level <integer>          # specify the trace level (1 to 10), default:1
                          # (int, optional)
-line_to_ports            # display paths from/to primary ports
                          # (bool, optional)
-min_connection <num>     # specify the trace mimimum connection, default: 1 
                          # (int, optional)
-ports <string>           # specify the IO ports to be displayed
                          # (string, optional)
-reset                    # clear display trace macros (bool, optional)
-selected                 # trace the selected macros (bool, optional)
-through_registers        # display flightlines going through registers
                          # (bool, optional)