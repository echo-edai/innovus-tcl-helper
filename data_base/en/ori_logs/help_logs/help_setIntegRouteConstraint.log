Usage: setIntegRouteConstraint [-help]
                               -type {bus diffPair match NDR netClass shield simpleNet additional} {-net {<net1 net2 ...>} | -busSinkGroups <string> | -file <string>} [[-file <string>] | [[-name <string>] [-rule <NDR name>] [-shieldNet {<net1 net2>}] [-shieldType {unspecified side bottom bottomSide top topSide topBottom coaxial tandemSplit interleaved crosstie tandemSplitFull tandemSplitFullCoaxial tandemSplitNearBy tandemSplitSpecial none}] [-shieldGap {<layer1 gap1> <layer2[:layerN] gap2> ...}] [-shieldWidth {<layer1 width1> <layer2[:layerN] width2>...}] [-tandemWidth {<layer1 width1> <layer2[:layerN] width2>...}] [-tandemCapWidth {<layer1 width1> <layer2[:layerN] width2>...}] [-tandemOverhang {<layer1 width1> <layer2[:layerN] width2>...}] [-tandemSideOverhang {<layer1 width1> <layer2[:layerN] width2>...}] [-tandemAggressorAdjacentLayerSeparation {number_of_tracks}] [-tandemAggressorSameLayerTrackDistance {<layer1 n1> <layer2[:layerN] n2>...}] [-tandemNearbyNonAggressorType {typeNameString}] [-tandemNearbyNonAggressorExceptByName {nameString}] [-tandemNearbyNonAggressorNets {nameString}] [-groupToOutsideSpacing {<layer1 spacing1> <layer2[:layerN] spacing2>...}] [-busGroupWidth <integer>] [-hierarchicalScope {local local_below local_above local_above_below}] [-layerGap {<layer1 gap1> <layer2[:layerN] gap2>...}] [-matchGap {<layer1 gap1> <layer2[:layerN] gap2>...}] [-tolerance <float>] [-shieldTolerance {<net1 value1> <net2 value2> ...}] [-minRes <float>] [-maxRes <float>] [-matchStyle {accordion trombone coil}] [-topLayer <string>] [-bottomLayer <string>] [-connectSupply {float anyPoint}] [-layerMatch ] [-hard ] [-noshareshield ] [-minLength <float>] [-maxLength <float>] [-cornerStyle {none crossover river}] [-minBusBit <integer>] [-intergroupGap {<layer1 spacing1> <layer2[:layerN] spacing2>...}] [-accessStyle {none straight clustered}] [-busSinkGroups <string>] [-crossTieShieldInterval <string>] [-crossTieShieldedLayers <string>] [-crossTieShieldLayerLimit <string>] [-accessStyle {none straight clustered}] [-matchType {length resistance maxResistance}] [-bus_bit_order ]]]

-help                                     # Prints out the command usage
-accessStyle {none straight clustered}    # Indicates the preferred style for
                                          # routing the bus after connecting to
                                          # the bus pins. (enum, optional)
-bottomLayer <string>                     # Indicates the bottom-most routing
                                          # layer to use (string, optional)
-busGroupWidth <integer>                  # specifies the width of the
                                          # busgroup, to be split in, integer.
                                          # (int, optional)
-busSinkGroups <string>                   # List of busSinkGroup elements
                                          # (string, optional)
-bus_bit_order                            # Route the nets in the same order as
                                          # provided with -nets option in the
                                          # bus constraint. (bool, optional)
-connectSupply {float anyPoint}           # Indicates how the shield wires will
                                          # be connected to the supply line.
                                          # Default=anyPoint. (enum, optional)
-cornerStyle {none crossover river}       # Indicates the style of diffpair
                                          # route when changing direction.
                                          # (enum, optional)
-crossTieShieldInterval <string>          # {integer | {<layer1 interval1>
                                          # <layer2[:layerN] interval2>...}}
                                          # The number of tracks between the
                                          # crosstie wires for opportunistic
                                          # coaxial shielding. 0 = all tracks,
                                          # 1 = one track between, 2 = two
                                          # tracks between, ..{N} This
                                          # attribute is optional and the
                                          # default value is 0 (string, optional)
-crossTieShieldLayerLimit <string>        # {layer_number:layer_number} The
                                          # layer range that will be used as
                                          # cross tie shield net
                                          # (string, optional)
-crossTieShieldedLayers <string>          # {layer:layer} The layer range that
                                          # will get shielding above and below
                                          # (string, optional)
-file <string>                            # specifies the additionalConstraint
                                          # file path. (string, optional)
-groupToOutsideSpacing {<layer1 spacing1>  <layer2[:layerN] spacing2>...}
                                          # specifies the spacing per layer(in
                                          # micron) between nets of this group
                                          # with the other nets in the design
                                          # (string, optional)
-hard                                     # Specifies whether the created
                                          # topLayer/bottomLayer constraint
                                          # would be hard/soft type. Default is
                                          # soft. (bool, optional)
-hierarchicalScope {local local_below local_above local_above_below}
                                          # specifies whether a particular
                                          # constraint is local, or can be
                                          # pushed(below) or pulled(above)
                                          # across the hierarchy. Default=local
                                          # (enum, optional)
-intergroupGap {<layer1 spacing1>  <layer2[:layerN] spacing2>...}
                                          # Specifies the gap between the split
                                          # busgroups. (string, optional)
-layerGap {<layer1 gap1> <layer2[:layerN] gap2>...}
                                          # Indicates the layer names and the
                                          # gap-spacing values in micron for
                                          # the nets routed as diffPair. For
                                          # any layer not listed, the minimum
                                          # legal spacing for that layer is
                                          # used (string, optional)
-layerMatch                               # Specifies whether each separate
                                          # layer should be matched for match
                                          # nets. By default only the total
                                          # length is matched (bool, optional)
-matchGap {<layer1 gap1> <layer2[:layerN] gap2>...}
                                          # Indicates the spacing between the
                                          # two rises of accordion. This
                                          # applied only when type is match and
                                          # matchStyle is accordion.
                                          # (string, optional)
-matchStyle {accordion trombone coil}     # Indicates the routing topology to
                                          # be used for matching the nets
                                          # routed as match. Default=accordion
                                          # (enum, optional)
-matchType {length resistance maxResistance}
                                          # Indicates the topology to be used
                                          # for matching the nets routed as
                                          # match. (enum, optional)
-maxLength <float>                        # Indicates the maximum length the
                                          # router should route a net.
                                          # (float, optional)
-maxRes <float>                           # Indicates the maximum resistance to
                                          # be used for the specific net being
                                          # routed, or for the nets with match
                                          # constraint if -type is match.
                                          # (float, optional)
-minBusBit <integer>                      # Indicates the minimum bits allowed
                                          # for the router to split a bus
                                          # (int, optional)
-minLength <float>                        # Indicates the the minimum length
                                          # the router should route a net.
                                          # (float, optional)
-minRes <float>                           # Indicates the minimum resistance to
                                          # be used for the specific net being
                                          # routed, or for the nets with match
                                          # constraint if -type is match.
                                          # (float, optional)
-name <string>                            # indicates the name of the
                                          # constraint group being created,
                                          # changing the default name given to
                                          # the constraint by Innovus
                                          # (string, optional)
-net {<net1 net2 ...>}                    # List of net names to be routed
                                          # (string, optional)
-noshareshield                            # Specifies whether there will be
                                          # common or individual shields
                                          # between nets in bus constraint.
                                          # (bool, optional)
-rule <NDR name>                          # The routing rule to be used for
                                          # routing the particular type of net,
                                          # default is "default"
                                          # (string, optional)
-shieldGap {<layer1 gap1> <layer2[:layerN] gap2> ...}
                                          # specifies the spacing(in micron)
                                          # between the shielded wire and the
                                          # shield net. For any layer not
                                          # listed, the minimum legal spacing
                                          # for that layer is used
                                          # (string, optional)
-shieldNet {<net1 net2>}                  # Indicates the netGroup should be
                                          # shielded by nets with given names.
                                          # (string, optional)
-shieldTolerance {<net1 value1> <net2 value2> ...}
                                          # Indicates the percentage of length
                                          # of the net that can remain
                                          # unshielded, default=20.0
                                          # (string, optional)
-shieldType {unspecified side bottom bottomSide top topSide topBottom coaxial tandemSplit interleaved crosstie tandemSplitFull tandemSplitFullCoaxial tandemSplitNearBy tandemSplitSpecial none}
                                          # Used to specify the type of
                                          # shielding for the net(s) being
                                          # routed (enum, optional)
-shieldWidth {<layer1 width1> <layer2[:layerN] width2>...}
                                          # specifies the width(in micron) of
                                          # the shield wire per layer for side
                                          # shielding. For any layer not
                                          # listed, the minimum legal width for
                                          # that layer is used (string, optional)
-tandemAggressorAdjacentLayerSeparation {number_of_tracks}
                                          # specifies the minimum distance
                                          # between the given signal layer and
                                          # the above/below layers where the
                                          # aggressors are. (int, optional)
-tandemAggressorSameLayerTrackDistance {<layer1 n1> <layer2[:layerN] n2>...}
                                          # specifies the minimum pitch tracks
                                          # (distance) between the given signal
                                          # net and any aggressors on the same
                                          # layer. (string, optional)
-tandemCapWidth {<layer1 width1> <layer2[:layerN] width2>...}
                                          # specifies the wire width(in micron)
                                          # of tandem cap shield  beyond the
                                          # edge of the route being shielded.
                                          # For any layer not listed, the
                                          # minimum legal width for that layer
                                          # is used (string, optional)
-tandemNearbyNonAggressorExceptByName {nameString}
                                          # specifies that all nets, except the
                                          # ones mentioned, are not considered
                                          # as aggressors for shielding.
                                          # (string, optional)
-tandemNearbyNonAggressorNets {nameString}
                                          # specifies the net names that are
                                          # not considered as aggressors for
                                          # shielding. (string, optional)
-tandemNearbyNonAggressorType {typeNameString}
                                          # specifies those signal types that
                                          # are not considered as signal types
                                          # of aggressors. Even if they exist
                                          # within a certain range, the signal
                                          # net does not need to be protected
                                          # by shielding. (string, optional)
-tandemOverhang {<layer1 width1> <layer2[:layerN] width2>...}
                                          # specifies the overhang value (in
                                          # micron) tandem shield.
                                          # (string, optional)
-tandemSideOverhang {<layer1 width1> <layer2[:layerN] width2>...}
                                          # specifies the overhang value (in
                                          # micron) tandem side shield.
                                          # (string, optional)
-tandemWidth {<layer1 width1> <layer2[:layerN] width2>...}
                                          # specifies the width(in micron) of
                                          # the top and bottom shields, beyond
                                          # the edge of the route being
                                          # shielded. For any layer not listed,
                                          # the minimum legal width for that
                                          # layer is used (string, optional)
-tolerance <float>                        # Indicates the percentage difference
                                          # in length that is allowed when
                                          # routing nets as match, default=20.0
                                          # (float, optional, min=0, max=100)
-topLayer <string>                        # Indicates the top-most routing
                                          # layer to use (string, optional)
-type {bus diffPair match NDR netClass shield simpleNet additional}
                                          # Indicates the type of routing
                                          # constraints to be created
                                          # (enum, required)