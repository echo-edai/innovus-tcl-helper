Usage: check_pg_library [-help] <power_library_name> [-cell_list_file <string>]
                        [-check_parameters] [-command_dump] [-integrity_check]
                        [-list] [-metal_density_map] [-output <string>]
                        [-report] [-report_detail_multiple_voltage_cap]
                        [-rule_file <string>] [-skip_layer_list_file <string>]
                        [-skip_signal_net_check <string>] [-summary]
                        [-tap_node_text_dump] [-tech_layers] [-total_currents]
                        [-check_compatibility | -lef_consistency]

-help                                   # Prints out the command usage
<power_library_name>                    # <absolute power library path(s)>
                                        # (string, required)
-cell_list_file <string>                # <file containing list of cells to be
                                        # used in lef consistency check>
                                        # (string, optional)
-check_compatibility                    # <check compatibility of a list of
                                        # PGVs> (bool, optional)
-check_parameters                       # <check PGV electrical parameters>
                                        # (bool, optional)
-command_dump                           # <dump commands with which .cl is
                                        # formed> (bool, optional)
-integrity_check                        # <integrity check> (bool, optional)
-lef_consistency                        # <check lef pgv compatibility>
                                        # (bool, optional)
-list                                   # <list the libraries and cells>
                                        # (bool, optional)
-metal_density_map                      # <generate metal density information>
                                        # (bool, optional)
-output <string>                        # <output directory where the reports
                                        # have to be written> (string, optional)
-report                                 # <generate report> (bool, optional)
-report_detail_multiple_voltage_cap     # <Reports multiple voltage cap table>
                                        # (bool, optional)
-rule_file <string>                     # <rule file for parameter checking>
                                        # (string, optional)
-skip_layer_list_file <string>          # <to skip layer checks for list of
                                        # layer> (string, optional)
-skip_signal_net_check <string>         # <to skip signal net check in
                                        # check_pg_library> (string, optional)
-summary                                # <generate summary> (bool, optional)
-tap_node_text_dump                     # dump detailed report on tap nodes>
                                        # (bool, optional)
-tech_layers                            # <dump tech layers> (bool, optional)
-total_currents                         # <dump total current of each
                                        # power/ground net for DDV>
                                        # (bool, optional)