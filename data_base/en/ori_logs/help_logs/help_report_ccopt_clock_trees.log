Usage: report_ccopt_clock_trees [-help] [-clock_trees {string1 string2 ...}]
                                [-file <name>] [-histograms]
                                [-list_special_pins] [-no_invalidate]
                                [-num_cap_violating_pins <num>]
                                [-num_fanout_violating_nets <num>]
                                [-num_length_violating_nets <num>]
                                [-num_resistance_violating_nets <num>]
                                [-num_slew_violating_pins <num>]
                                [-skip_timing_update] [-summary] [-tcl_list] [ -delay_corners <delay_corner>+ | -views <analysis_view>+ ] [ -early | -late ]

-help                                  # Prints out the command usage
-clock_trees {string1 string2 ...}     # Restricts the report to the specified
                                       # clock trees (list, optional)
-delay_corners <delay_corner>+         # Restricts the report to the specified
                                       # delay corners ((delay_corner)+, optional)
-early                                 # Only report on the early half of the
                                       # delay corners (bool, optional)
-file <name>                           # Save a copy of the contents of the
                                       # report to the specified file name
                                       # (string, optional)
-histograms                            # Displays histograms of key information
                                       # (bool, optional)
-late                                  # Only report on the late half of the
                                       # delay corners (bool, optional)
-list_special_pins                     # List individual pins that are stop,
                                       # ignore, min or other special types
                                       # (bool, optional)
-no_invalidate                         # Do not invalidate the timing engine.
                                       # (bool, optional)
-num_cap_violating_pins <num>          # Maximum number of maximum output
                                       # capacitance violating pins to display.
                                       # The default is 10. (int, optional)
-num_fanout_violating_nets <num>       # Maximum number of fanout violating
                                       # nets to display. The default is 10.
                                       # (int, optional)
-num_length_violating_nets <num>       # Maximum number of
                                       # max_source_to_sink_net_length
                                       # violating nets to display. The default
                                       # is 10. (int, optional)
-num_resistance_violating_nets <num>   # Maximum number of
                                       # max_source_to_sink_net_resistance
                                       # violating nets to display. The default
                                       # is 10. (int, optional)
-num_slew_violating_pins <num>         # Maximum number of slew violating pins
                                       # to display. The default is 10.
                                       # (int, optional)
-skip_timing_update                    # Do not update the timing engine.
                                       # (bool, optional)
-summary                               # Displays just the summary tables
                                       # (bool, optional)
-tcl_list                              # Returns the report as Tcl formatted
                                       # data, and formats the -file as tcl if
                                       # specified (bool, optional)
-views <analysis_view>+                # Restricts the report to the delay
                                       # corners associated with the specified
                                       # views ((analysis_view)+, optional)