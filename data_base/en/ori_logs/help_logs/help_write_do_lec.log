Description:
Writes a script and verification information for use by the Conformal Logical
Equivalence Checking tool.

Usage: write_do_lec [-help]
                    [-1801_golden <string>] [-1801_revised <string>]
                    [-checkpoint <string>] [-cpf_golden <string>]
                    [-cpf_revised <string>] [-cw_sim <string>]
                    [-dft_constraint_file <string>] [-env_var <string>]
                    [-fastelab2gen] [-fastgen2fvmap] [-fastrtl2elab]
                    [-golden_design <string>] [-gzip_fv_json]
                    [-log_file <string>] [-low_power_analysis] [-no_dft]
                    [-no_exit] [-no_insert_iso_in_dof] [-no_lp]
                    [-post_compare <string>] [-post_read_power_intent <string>]
                    [-pre_compare <string>] [-pre_exit <string>]
                    [-pre_read <string>] [-pre_read_design <string>]
                    [-pre_read_power_intent <string>]
                    [-pre_verification_information <string>]
                    [-revised_design <string>] [-rtl_revised]
                    [-sim_lib <string>] [-sim_plus_liberty] [-smart]
                    [-tmp_dir <string>] [-top <string>] [-verbose]
                    [-write_session <string>] [-hier  | -flat ] [<out_file> | >]

-help                                      # Prints out the command usage
<out_file>                                 # The name of the LEC dofile to be
                                           # written. (string, optional)
-1801_golden <string>                      # The name of the golden 1801 file.
                                           # (string, optional)
-1801_revised <string>                     # The name of the revised 1801 file.
                                           # (string, optional)
-checkpoint <string>                       # The name of the LEC checkpoint
                                           # file to write at the end.
                                           # (string, optional)
-cpf_golden <string>                       # The name of the golden CPF file.
                                           # (string, optional)
-cpf_revised <string>                      # The name of the revised CPF file.
                                           # (string, optional)
-cw_sim <string>                           # Specifies the simulation language
                                           # for ChipWare components. Valid
                                           # options are
                                           # 'V1995|V2001|SV|VHDL1987|VHDL1993'.
                                           # (string, optional)
-dft_constraint_file <string>              # Specifies a DFT constraints file
                                           # to be sourced from the LEC dofile
                                           # just before the comparison.
                                           # (string, optional)
-env_var <string>                          # The names and values of UNIX
                                           # environment variables to be used
                                           # in library, design and log file
                                           # names in the LEC dofile.
                                           # (string, optional)
-fastelab2gen                              # Generate an abbreviated LEC dofile
                                           # for quick elaborated-to-generic
                                           # comparisons. (bool, optional)
-fastgen2fvmap                             # Generate an abbreviated LEC dofile
                                           # for quick generic-to-fv_map
                                           # comparisons. (bool, optional)
-fastrtl2elab                              # Generate an abbreviated LEC dofile
                                           # for quick RTL-to-elaborated
                                           # netlist comparisons. (bool, optional)
-flat                                      # Use a flat LEC comparison.
                                           # (bool, optional)
-golden_design <string>                    # The path to the golden design.
                                           # (string, optional)
-gzip_fv_json                              # Compress the implementation
                                           # information file (requires
                                           # Conformal 19.10-s300 or newer).
                                           # (bool, optional)
-hier                                      # Use a hierarchial LEC comparison.
                                           # (bool, optional)
-log_file <string>                         # The name of the LEC log file.
                                           # (string, optional)
-low_power_analysis                        # Add Conformal Low Power commands
                                           # to compare the golden and revised
                                           # power domains. Power intent must
                                           # be present. (bool, optional)
-no_dft                                    # Do not write DFT constraints in
                                           # the LEC dofile. (bool, optional)
-no_exit                                   # Skip the exit command at end of
                                           # the LEC dofile. (bool, optional)
-no_insert_iso_in_dof                      # Do not insert isolation in the LEC
                                           # dofile. (bool, optional)
-no_lp                                     # Do not check power intent
                                           # equivalency. (bool, optional)
-post_compare <string>                     # Specifies a dofile to be sourced
                                           # from the LEC dofile just after the
                                           # comparison. (string, optional)
-post_read_power_intent <string>           # Specifies a dofile to be sourced
                                           # from the LEC dofile just after
                                           # 'read_power_intent'.
                                           # (string, optional)
-pre_compare <string>                      # Specifies a dofile to be sourced
                                           # from the LEC dofile just before
                                           # the comparison. (string, optional)
-pre_exit <string>                         # Specifies a dofile to be sourced
                                           # from the LEC dofile just before
                                           # exiting. (string, optional)
-pre_read <string>                         # Specifies a dofile to be sourced
                                           # from the LEC dofile just before
                                           # reading the library.
                                           # (string, optional)
-pre_read_design <string>                  # Specifies a dofile to be sourced
                                           # from the LEC dofile just before
                                           # 'read_design'. (string, optional)
-pre_read_power_intent <string>            # Specifies a dofile to be sourced
                                           # from the LEC dofile just before
                                           # 'read_power_intent'.
                                           # (string, optional)
-pre_verification_information <string>     # Specifies a dofile to be sourced
                                           # from the LEC dofile just before
                                           # 'set_verification_information'.
                                           # (string, optional)
-revised_design <string>                   # The path to the revised design.
                                           # (string, optional)
-rtl_revised                               # The revised design is
                                           # DFT-inserted, back-annotated RTL.
                                           # (bool, optional)
-sim_lib <string>                          # The Verilog-1995 simulation
                                           # library. (string, optional)
-sim_plus_liberty                          # Add the simulation library to the
                                           # synthesis library. (bool, optional)
-smart                                     # Add adaptive-proof commands and
                                           # information on parallel
                                           # hierarchical comparisons to the
                                           # LEC dofile (requires Conformal
                                           # Smart LEC license). (bool, optional)
-tmp_dir <string>                          # The name of the output LEC
                                           # directory. (string, optional)
-top <string>                              # The name of the top-level design.
                                           # (string, optional)
-verbose                                   # Specifies that the LEC dofile
                                           # reports verbose information.
                                           # (bool, optional)
-write_session <string>                    # The name of the LEC session to
                                           # write at the end. (string, optional)
> <file>                                   # The name of the LEC dofile to be
                                           # written.
                                           # (redirect_operator, optional)