Usage: remove_assigns [-help] [-buffer <bufName>] [-ignorePortConstraints]
                      [-includeClockPath] [-prefix <bufNamePreFix>] [-report] [ -net <netName> [-netBuffer <netBufName>] ] [ -buffering [-buffer_tie_assigns ] [-includeIdealNets ] ] [ -honorDontTouch ] [ -net <netName> ]

-help                             # Prints out the command usage
-buffer <bufName>                 # Name of buffer specified for all assign
                                  # nets, disable automatical buffer selection
                                  # (string, optional)
-buffer_tie_assigns               # Allow to buffer tie assigns.
                                  # (bool, optional)
-buffering                        # This option enables assign net buffering.
                                  # The buffer can be automatically selected
                                  # unless buffer is specified by user.
                                  # (bool, optional)
-honorDontTouch                   # honor dont_touch (bool, optional)
-ignorePortConstraints            # Allow to ignore all port constraints during
                                  # assign removal (bool, optional)
-includeClockPath                 # remove assigns on clock path
                                  # (bool, optional)
-includeIdealNets                 # remove assigns on ideal nets
                                  # (bool, optional)
-net <netName>                    # Name of net. Single or list of names,
                                  # scalar or bus names, wildcart * is allowed
                                  # (string, optional)
-netBuffer <netBufName>           # Name of buffer specified for specific net
                                  # given in option -net. This option, if
                                  # specified, should come after option -net.
                                  # (string, optional)
-prefix <bufNamePreFix>           # User specified prefix for buffer names
                                  # (string, optional)
-report                           # Report list of all buffers and assign nets
                                  # that were replaced by the buffers.
                                  # (bool, optional)