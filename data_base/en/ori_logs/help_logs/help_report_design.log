Usage: report_design [-help] [-view <view_name>] [-early  | -late ] [ [ > | >> ] | [ -tcl_list  ] ]

-help                 # Prints out the command usage
-early                # Reports mimimum operating conditions in 'bcwc' or
                      # 'onChipVariation' analysis mode (bool, optional)
-late                 # Reports maximum operating conditions (bool, optional)
-tcl_list             # Output will be reported in tcl list format
                      # (bool, optional)
-view <view_name>     # Reports view specific operating condition
                      # (string, optional)
> <file_name>         # Redirect output to file (redirect_operator, optional)
>> <file_name>        # Redirect output to file (redirect_operator, optional)