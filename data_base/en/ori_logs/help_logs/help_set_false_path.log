Usage: set_false_path [-help] [-fall] [-fall_through <through_list>] [-hold]
                      [-rise] [-rise_through <through_list>] [-setup]
                      [-through <through_list>] [-from <from_list> | -rise_from <from_list> | -fall_from <from_list>] [-to <to_list]> | -rise_to <to_list> | -fall_to <to_list]>]

-help                            # Prints out the command usage
-fall                            # Apply the assertion at the falling edge of
                                 # the signal on the path endpoints
                                 # (bool, optional)
-fall_from <from_list>           # Applies the false path constraint at the
                                 # falling edge of the signal on the from pins
                                 # (string, optional)
-fall_through <through_list>     # Applies the assertion at the falling edge of
                                 # the signal on the through pins
                                 # (string, optional)
-fall_to <to_list]>              # Applies the false path constraint at the
                                 # falling edge of the signal on the to pins
                                 # (string, optional)
-from <from_list>                # Applies the false path constraint to all
                                 # paths originating from the from_list list
                                 # (string, optional)
-hold                            # False paths for hold analysis
                                 # (bool, optional)
-rise                            # Applies the assertion at the rising edge of
                                 # the signal on the path endpoints
                                 # (bool, optional)
-rise_from <from_list>           # Applies the false path constraint at the
                                 # rising edge of the signal on the from pins
                                 # (string, optional)
-rise_through <through_list>     # Applies the assertion at the rising edge of
                                 # the signal on the through pins
                                 # (string, optional)
-rise_to <to_list>               # Applies the false path constraint at the
                                 # rising edge of the signal on the to pins
                                 # (string, optional)
-setup                           # False paths for setup analysis
                                 # (bool, optional)
-through <through_list>          # Applies the assertion to both the rising and
                                 # the falling edges (string, optional)
-to <to_list]>                   # Applies the false path constraint to all
                                 # paths ending in the -to pin list
                                 # (string, optional)