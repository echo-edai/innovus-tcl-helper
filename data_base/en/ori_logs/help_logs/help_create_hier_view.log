Usage: create_hier_view [-help] [-cell_name <string>]
                        [-cluster_via1_ports {true false}]
                        [-cluster_via_rule <string>]
                        [-cluster_via_size <integer>]
                        [-compress_powergrid_database {true false}]
                        [-extraction_mode {fast accurate}]
                        [-force_library_merging {true false}]
                        [-ground_nets <string>] [-ignore_decaps {true false}]
                        [-ignore_fillers {true false}]
                        [-ignore_shorts {true false}]
                        [-libgen_command_file <string>] -library_name <string>
                        [-max_viacluster_mode {true false}]
                        [-output_dir <string>]
                        [-parasitic_extractor_command_file <string>]
                        [-power_nets <string>]
                        [-powergrid_view_libraries <string>]
                        [-block_lef <string> | -block_gds <string>]
                        {-def <string> | -extraction_work_directory <string>}
                        [-block_lef <string> | -oaRef <string>]
                        [-block_lef <string> | -gds_port_file <string>]

-help                                   # Prints out the command usage
-block_gds <string>                     # <gds file> (string, optional)
-block_lef <string>                     # <lef file> (string, optional)
-cell_name <string>                     # cell name (string, optional)
-cluster_via1_ports {true false}        # <enable clustering equidistant vias
                                        # on VIA1 layer > (enum, optional)
-cluster_via_rule <string>              # <{{<via layer> <number of equidistant
                                        # vias>}+}>  (string, optional)
-cluster_via_size <integer>             # <via cluster size>  (int, optional)
-compress_powergrid_database {true false}
                                        # <true|false> (enum, optional)
-def <string>                           # list of block def files
                                        # (string, required)
-extraction_mode {fast accurate}        # <fast | accurate> (enum, optional)
-extraction_work_directory <string>     # <dir name> (string, required)
-force_library_merging {true false}     # <true|false> (enum, optional)
-gds_port_file <string>                 # <gds port file> (string, optional)
-ground_nets <string>                   # <ground nets for
                                        # hier_extraction_view> (string, optional)
-ignore_decaps {true false}             # <ignore decap cells> (enum, optional)
-ignore_fillers {true false}            # <ignore filler cells>
                                        # (enum, optional)
-ignore_shorts {true false}             # <ignore shorts> (enum, optional)
-libgen_command_file <string>           # <file> (string, optional)
-library_name <string>                  # <library name> (string, required)
-max_viacluster_mode {true false}       # <true|false> (enum, optional)
-oaRef <string>                         # read the OA reference libraries
                                        # (string, optional)
-output_dir <string>                    # <dir name> (string, optional)
-parasitic_extractor_command_file <string>
                                        # <file> (string, optional)
-power_nets <string>                    # <power nets and values for
                                        # hier_extraction_view net1 value1 net2
                                        # value2 ...> (string, optional)
-powergrid_view_libraries <string>      # <list of cell libraries for
                                        # hier_extraction_view> (string, optional)