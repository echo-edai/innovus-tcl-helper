Usage: create_power_pads [-help] [-append_to_vsrc_file]
                         [-format {padcell xy tsv}] [-layer <layerName>]
                         [-package_capacitance <value>]
                         [-package_inductance <value>]
                         [-package_resistance <value>] [-vsrc_file <string>] [[-net <string> -region {x1 y1 x2 y2} -region_pitch {x y}] | [-net <string> -auto_fetch ] | [-net <string> -instance {instanceName +}] | [-net <string> -instance_pin {{<instName> <instPinName>}+}] | [-net <string> -cell {cellName +}] | [-net <string> -cell_pin {{<cellName> <cellPinName>}+}] | [-net <string> -add ] | [-net <string> -delete ]] [-snap_distance <value> | -honor_pin_connection ] [-clear   | -display  ] [-net <string>  | -clear  |  -list  ] [[-add  | -delete ] -loc {x y}]

-help                               # Prints out the command usage
-add                                # adding a vsrc source (bool, optional)
-append_to_vsrc_file                # output file name (bool, optional)
-auto_fetch                         # auto fetch vsrc (bool, optional)
-cell {cellName +}                  # cell names (string, optional)
-cell_pin {{<cellName> <cellPinName>}+}    # cellName and cellPin name
                                           # (string, optional)
-clear                              # clear display (bool, optional)
-delete                             # deleting a vsrc source (bool, optional)
-display                            # display the outfile (bool, optional)
-format {padcell xy tsv}            # output file format, default is xy
                                    # (enum, optional)
-honor_pin_connection               # honor pin connection (bool, optional)
-instance {instanceName +}          # instance names (string, optional)
-instance_pin {{<instName> <instPinName>}+}
                                    # instName and instPin input (string, optional)
-layer <layerName>                  # the lowest layer to snap
                                    # (string, optional)
-list                               #  list all vsrc in memory (bool, optional)
-loc {x y}                          # location on which vsrc is to be added
                                    # (point, optional)
-net <string>                       # net name (string, optional)
-package_capacitance <value>        # package capacitance (float, optional)
-package_inductance <value>         # package inductance (float, optional)
-package_resistance <value>         # package resistance (float, optional)
-region {x1 y1 x2 y2}               # Generate dc sources in specified area.
                                    # (box, optional)
-region_pitch {x y}                 # region pitch in x and y direction.
                                    # (point, optional)
-snap_distance <value>              # the snapping distance
                                    # (float, optional, min=0, max=1.79769313486232e+308)
-vsrc_file <string>                 # vsrc file name (string, optional)