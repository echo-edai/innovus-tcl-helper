Usage: report_case_analysis [-help] [<pins_and_ports_list>] [-all] [-dir]
                            [-nosplit] [-sequential_propagation] [-tcl_list]
                            [-verbose] [-view <view_name>] [> <filename[.gz]>]
                            [>> <filename[.gz]>] [-propagated ]

-help                       # Prints out the command usage
<pins_and_ports_list>       # Limits the reporting to specified pins and ports
                            # (string, optional)
-all                        # Specifies that the Logic Constant Value table
                            # report set_logic constants, constants in the
                            # netlist, and output pins with a constant function
                            # (bool, optional)
-dir                        # Specifies that the report include the direction
                            # of the pin or port (bool, optional)
-nosplit                    # Specifies that reports with long names will not
                            # be split into multiple lines (bool, optional)
-propagated                 # Generates a report that includes all constant
                            # pins, including pins with propagated constants
                            # (bool, optional)
-sequential_propagation     # Print Instances with user asserted sequential
                            # propagation  (bool, optional)
-tcl_list                   # Produces the report in Tcl list format instead of
                            # a tabular format (bool, optional)
-verbose                    # Generates a report in which each pin is listed on
                            # a separate line with a cause (bool, optional)
-view <view_name>           # Generates a case analysis report for the
                            # specified analysis view only. By default all
                            # active views are reported (string, optional)
> <filename[.gz]>           # Redirects output to specified file
                            # (redirect_operator, optional)
>> <filename[.gz]>          # Redirects output to specified file
                            # (redirect_operator, optional)