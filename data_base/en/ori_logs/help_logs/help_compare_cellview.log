Usage: compare_cellview [-help] [-ignore {pin_purpose}]
                        [-log <report_file_name>] { {{-source {sourceLib sourceCell sourceView} -compare {compareLib compareCell compareView}} | {-lib <lib> -cell <cell> -view {sourceView compareView}}} }

-help                              # Prints out the command usage
-cell <cell>                       # Specify cell to compare 2 views
                                   # (abstract/layout) (string, optional)
-compare {compareLib compareCell compareView}
                                   # Specify the lib/cell/view to compare
                                   # target design (string, optional)
-ignore {pin_purpose}              # Specify list of attributes to be excluded
                                   # from cell comparison (enum_list, optional)
-lib <lib>                         # Specify lib to compare 2 views
                                   # (abstract/layout) (string, optional)
-log <report_file_name>            # Report file containing all the comparison
                                   # detail (string, optional)
-source {sourceLib sourceCell sourceView}
                                   # Specify the lib/cell/view to compare
                                   # source design (string, optional)
-view {sourceView compareView}     # Specify different view of same lib/cell
                                   # (string, optional)