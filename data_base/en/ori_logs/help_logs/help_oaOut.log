Usage: oaOut [-help] <lib> <cell> <view> [-autoRemaster] [-copyTechFromReflib]
             [-cutRows] [-early_global_route]
             [-leafViewNames {<lefView1> <lefView2> ...}] [-noOverwriteAbstract]
             [-refLibs {<refLib1> <refLib2>....}] [-noConnectivity [-noStdCells ] ] [-noConnectivity ]

-help                                  # Prints out the command usage
<lib>                                  # Specifies the target library name
                                       # (string, required)
<cell>                                 # Specifies the target cell name
                                       # (string, required)
<view>                                 # Specifies the target view name
                                       # (string, required)
-autoRemaster                          # Binds the cell to it's layout view
                                       # (bool, optional)
-copyTechFromReflib                    # Copies the technology file to the
                                       # current design library (bool, optional)
-cutRows                               # Specifies that rows are cut against
                                       # placement obstructions and block halos
                                       # (bool, optional)
-early_global_route                    # Writes out a design containing
                                       # early_global_route data (bool, optional)
-leafViewNames {<lefView1> <lefView2> ...}
                                       # Specifies a list of view names to be
                                       # searched for during leaf cell instance
                                       # binding (string, optional)
-noConnectivity                        # Writes out a design that contains
                                       # instances and physical shapes but
                                       # without nets, pins or instance pins
                                       # (bool, optional)
-noOverwriteAbstract                   # Prevents the software from overwriting
                                       # abstracts of partitions and blackboxes
                                       # (bool, optional)
-noStdCells                            # Instances of core cells are not saved
                                       # in OpenAccess database. But if
                                       # instance is either fixed or covered
                                       # then it is saved. (bool, optional)
-refLibs {<refLib1> <refLib2>....}     # Specifies the names of the reference
                                       # libraries (string, optional)