Usage: checkPartitionSdc [-help] {[-chip <string> -partition_dir <string> ] | [-chip <string> -module_model_tag <string> [-add_ons <string>] [-accumulated ] [-overwrite_tag ] ] | [-compare_only ]} [-validate_boundary_condition ] [-cells <string>] [-master_only ] [-no_top ] [-out_dir <string>]

-help                            # Prints out the command usage
-accumulated                     # Run comparision for accumulated Budgeting
                                 # mode (bool, optional)
-add_ons <string>                # Specify the supplement model that can be
                                 # additionally loaded, while loading the
                                 # blocks (string, optional)
-cells <string>                  # List of cell names for which sdc comparison
                                 # is to be done. Default: All cells
                                 # (string, optional)
-chip <string>                   # TCL file which loads chip database
                                 # (string, required)
-compare_only                    # Will just compare the already dumped data
                                 # from the previous run (bool, optional)
-master_only                     # Dumps and compares constraints for checking
                                 # only the master partitions for the
                                 # master-clone designs. In case this parameter
                                 # is not used, the tool dumps and compares
                                 # constraints taking clones also in
                                 # consideration. (bool, optional)
-module_model_tag <string>       # Module model tag for the cell on which sdc
                                 # comparison is to be done. (string, optional)
-no_top                          # No checking for TOP cell would be done
                                 # (bool, optional)
-out_dir <string>                # directory where validation comparison
                                 # reports and log files will be output.
                                 # Default: ./cps (string, optional)
-overwrite_tag                   # Regenerate the design for accumulated
                                 # Budgeting mode (bool, optional)
-partition_dir <string>          # directory which contains partition(s)
                                 # database (string, required)
-validate_boundary_condition     # (bool, optional)