Usage: set_vt_skew_derate [-help] [-delay_corner <string>] [-fast <float>]
                          [-hold] [-mean] [-resetViewListVTSkew] [-setup]
                          [-sigma] [-slow <float>]
                          [-threshold_voltage_group <group name>]
                          [-viewListVTSkew <string>]

-help                                     # Prints out the command usage
-delay_corner <string>                    # delay corner list
                                          # (string, optional)
-fast <float>                             # fast derate factor
                                          # (float, optional)
-hold                                     # derate applied for hold
                                          # (bool, optional)
-mean                                     # derate applied to mean component
                                          # (bool, optional)
-resetViewListVTSkew                      # VT skew view list (bool, optional)
-setup                                    # derate applied for setup
                                          # (bool, optional)
-sigma                                    # derate applied to sigma component
                                          # (bool, optional)
-slow <float>                             # slow derate factor
                                          # (float, optional)
-threshold_voltage_group <group name>     # VT group for which derates are to
                                          # be applied (string, optional)
-viewListVTSkew <string>                  # VT skew view list
                                          # (string, optional)