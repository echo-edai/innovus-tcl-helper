Usage: getScanReorderMode [-help] [-addScanPortPrefix] [-clkAware] [-compLogic]
                          [-enable_for_partition] [-keepPDPorts] [-keepPort]
                          [-preferH] [-preferV] [-scanEffort] [-skipMode]
                          [-swapEffort] [-quiet] [-nonDefault]

-help                                     # Prints out the command usage
-addScanPortPrefix                        # prefix of scan hport
                                          # (string, default="")
-clkAware                                 # Clock tree aware reorder
                                          # (bool, default=false)
-compLogic                                # trace considering multiple input
                                          # logic (bool, default=false)
-enable_for_partition                     # enable scanReorder for design with
                                          # partition (bool, default=false)
-keepPDPorts                              # Maintains hierarchical ports
                                          # without adding or deleting shifters
                                          # (bool, default=true)
-keepPort                                 # Specifies filename which contains
                                          # HInsts (string, default="")
-preferH                                  # Makes horizontal scan chain
                                          # connections if possible
                                          # (bool, default=false)
-preferV                                  # Makes vertical scan chain
                                          # connections if possible
                                          # (bool, default=false)
-scanEffort                               # Specifies effort level for
                                          # scanReorder
                                          # (enums={low medium high auto}, default=auto)
-skipMode                                 # Specifies method for handling
                                          # buffers and inverters
                                          # (enums={skipNone skipBuffer skipFloatingBuffer}, default=skipNone)
-swapEffort                               # Specifies effort level for
                                          # scanReorder different chains
                                          # swapping
                                          # (enums={low medium high}, default=high)
-quiet                                    # Displays the current settings in Tcl list format only
-nonDefault                               # Displays the current settings which are not default settings