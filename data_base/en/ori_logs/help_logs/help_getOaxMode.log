Usage: getOaxMode [-help] [-allowAnalysisOnly] [-allowBitConnection]
                  [-allowTechUpdate] [-bindkeyFile] [-compressLevel]
                  [-convertTo] [-cutRows] [-displayDrfFile]
                  [-displayDrfInLibrary] [-drcFillPurpose]
                  [-encloseQuickAbstractPins] [-fullLayerList] [-fullPath]
                  [-hybridRows] [-instPlacedIfUnknown] [-libCreateMode]
                  [-locking] [-logicOnlyImport] [-merge_trim]
                  [-nonRectilinearShapes] [-pinPurpose] [-pushPinConstraint]
                  [-quickAbstractForCustomCells] [-readSystemReservedLayers]
                  [-saveCdsFixedVias] [-saveMaskDataLocked] [-saveNetVoltage]
                  [-saveRelativePath] [-saveRestoreFile]
                  [-silently_ignore_unsupported_vias] [-textPurpose] [-tieNet]
                  [-updateMode] [-useVirtuosoBindkey] [-useVirtuosoColor]
                  [-viewSubType] [-quiet] [-nonDefault]

-help                                      # Prints out the command usage
-allowAnalysisOnly                         # Allow analysis only flow
                                           # (bool, default=false)
-allowBitConnection                        # Whether to create instance
                                           # terminal creations bitwise, if bus
                                           # not found in OA.
                                           # (bool, default=false)
-allowTechUpdate                           # Whether to allow the tech.db to be
                                           # updated or not. (bool, default=true)
-bindkeyFile                               # Virtuoso bind key file
                                           # (string, default="")
-compressLevel                             # OA Database compression level
                                           # (int, default=1, min=0, max=9)
-convertTo                                 # Whether to convert non-conforming
                                           # pathsegs/paths to polygon or
                                           # convert the endStyle to truncate
                                           # on orthogonal and to custom on
                                           # diagonal pathsegs
                                           # (enums={polygon defaultStyle}, default=polygon)
-cutRows                                   # Whether to use cutRows or not 
                                           # (bool, default=false)
-displayDrfFile                            # Display resource file
                                           # (string, default="")
-displayDrfInLibrary                       # Whether to use display resource
                                           # file in the tech library
                                           # (bool, default=false)
-drcFillPurpose                            # Whether to save drcFill shapes to
                                           # gap_fill or drawing purpose. By
                                           # default DEF routes with + SHAPE
                                           # DRCFILL are mapped to the OA
                                           # 'gapFill' purpose. Some OA
                                           # techfiles do not have this purpose
                                           # defined, and require these shapes
                                           # be mapped to 'drawing' purpose. In
                                           # that case, they get an additional
                                           # internal attribute so they can
                                           # round-trip back to DRCFILL shapes
                                           # properly.
                                           # (enums={gap_fill drawing}, default=gap_fill)
-encloseQuickAbstractPins                  # Include shapes that enclose layout
                                           # pin shapes (bool, default=true)
-fullLayerList                             # Whether to support full list of
                                           # layer import  (bool, default=true)
-fullPath                                  # Whether to use full path or not 
                                           # (bool, default=false)
-hybridRows                                # Read hybrid rows from PDK 
                                           # (bool, default=false)
-instPlacedIfUnknown                       # Whether to map OA Placement status
                                           # oacNonePlacementStatus of an
                                           # instance to Placed(true)/
                                           # Unplaced(false). 
                                           # (bool, default=true)
-libCreateMode                             # Library creation method during
                                           # saveDesign for newly created
                                           # libraries
                                           # (enums={none attach copy reference}, default=reference)
-locking                                   # Whether to lock the OA database
                                           # during restoreDesign
                                           # (enums={false true errorIfLocked}, default=false)
-logicOnlyImport                           # Whether to run oaIn after
                                           # init_design or not
                                           # (bool, default=false)
-merge_trim                                # Merge the trim metal shapes during
                                           # save when the trim metal gap less
                                           # than or equal to the max_gap in
                                           # micron. (bool, default=true)
-nonRectilinearShapes                      # Translates non-rectilinear shapes
                                           # to rectilinear shapes.
                                           # (enums={bbox approximate}, default=bbox)
-pinPurpose                                # Whether to set Pin Purpose as Pin
                                           # or not (bool, default=false)
-pushPinConstraint                         # whether saveDesign to push
                                           # interoperable pin constraint into
                                           # its corresponding blackbox
                                           # abstract cellview.
                                           # Note: Interoperable pin constraint
                                           # means pin constraints that are
                                           # understood by Innovus, Virtuoso
                                           # and PVS. (bool, default=false)
-quickAbstractForCustomCells               # Trim design shapes of Custom Cells
                                           # (enums={pcells stdcells all off}, default=all)
-readSystemReservedLayers                  # Read system reserved layers from
                                           # PDK
                                           # (enums={ all text off }, default=all)
-saveCdsFixedVias                          # Save fixed via 
                                           # (enums={new_vias_only off}, default=new_vias_only)
-saveMaskDataLocked                        # Whether to save colored shapes
                                           # with locked attribute
                                           # (bool, default=false)
-saveNetVoltage                            # Whether to allow saveDesign to
                                           # write voltage information to the
                                           # oaBitNet's voltage attribute
                                           # (bool, default=false)
-saveRelativePath                          # Whether to save relative path in
                                           # config file.  (bool, default=true)
-saveRestoreFile                           # Whether to save the view.inn file
                                           # (bool, default=false)
-silently_ignore_unsupported_vias          # Whether restoreDesign should issue
                                           # messages about vias that are not
                                           # supported in Innovus.
                                           # (bool, default=false)
-textPurpose                               # Specify the purpose name that will
                                           # be used when text labels
                                           # (add_text) are written.
                                           # (string, default=drawing)
-tieNet                                    # tieHigh tieLow net names
                                           # (string, default="")
-updateMode                                # Whether to use
                                           # (save/restore)OaDesign in update
                                           # mode or not  (ternary, default=false)
-useVirtuosoBindkey                        # Whether to use Virtuoso bind keys
                                           # (bool, default=false)
-useVirtuosoColor                          # Whether to use Virtuoso color and
                                           # stipple (bool, default=false)
-viewSubType                               # Subtype of view of the OA design
                                           # (enums={VCE VXL none}, default=VXL)
-quiet                                     # Displays the current settings in Tcl list format only
-nonDefault                                # Displays the current settings which are not default settings