Usage: add_gate_array_filler [-help] [-allow_shift_distance <x y>]
                             [-area <x1 y1 x2 y2>]
                             [-cell_orientation {R0|MX|MY|R180}]
                             [-min_spacing_x <value>] [-min_spacing_y <value>]
                             [-offsetx <value>] [-offsety <value>]
                             [-powerDomain <powerDomainName>]
                             [-prefix <prefixName>] {-cell <cellName> -stepx <value> -stepy <value>}

-help                              # Prints out the command usage
-allow_shift_distance <x y>        # specifies the distance between the new and
                                   # the original position in the x and y
                                   # direction (point, optional)
-area <x1 y1 x2 y2>                # Area in which fillers are to be inserted
                                   # (box, optional)
-cell <cellName>                   # filler cell name (string, optional)
-cell_orientation {R0|MX|MY|R180}  # specify GA fillers orientation
                                   # (string, optional)
-min_spacing_x <value>             # specifies the distance between edges of GA
                                   # fillers in the horizontal direction
                                   # (float, optional)
-min_spacing_y <value>             # specifies the distance between edges of GA
                                   # fillers in the vertical direction
                                   # (float, optional)
-offsetx <value>                   # specifies the offset of GA fillers in the
                                   # horizontal direction (float, optional)
-offsety <value>                   # specifies the offset of GA fillers in the
                                   # vertical direction (float, optional)
-powerDomain <powerDomainName>     # Power domain for which fillers are to be
                                   # inserted (string, optional)
-prefix <prefixName>               # specifies the prefix for filler cell
                                   # (string, optional)
-stepx <value>                     # specifies the distance between GA fillers
                                   # in the horizontal direction (float, optional)
-stepy <value>                     # specifies the distance between GA fillers
                                   # in the vertical direction (float, optional)