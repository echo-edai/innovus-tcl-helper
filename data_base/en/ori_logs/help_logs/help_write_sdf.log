Usage: write_sdf [-help] <file_name> [-abstracted_model]
                 [-adjust_setuphold_for_zero_hold_slack] [-base_delay]
                 [-celltiming {all none nochecks}] [-collapse_internal_pins]
                 [-condelse] [-delimiter <char>] [-delta_delay]
                 [-edges {edged library noedge check_edge}]
                 [-exclude_cells <cell_list>] [-exclude_cells_keep_io_nets]
                 [-exclude_cells_keep_top_level_nets] [-exclude_disabled_arcs]
                 [-exclude_disabled_modes] [-exclude_whatif_arcs] [-filter]
                 [-ideal_clock_network] [-include_variation]
                 [-interconn {all none noport noinport nooutport}]
                 [-map_file {file1 file2 ...}] [-max_view <viewName>]
                 [-merge_arcs] [-min_period_edges {posedge negedge both none}]
                 [-min_view <viewName>] [-no_condition] [-no_derate]
                 [-no_escape] [-nonegchecks] [-precision <non_neg_integer>]
                 [-process <string>] [-recompute_delay_calc]
                 [-recompute_parallel_arcs]
                 [-recrem {merge_always split merge_when_paired}] [-remashold]
                 [-resort_values_min_to_max] [-scale <float>]
                 [-setuphold {merge_always split merge_when_paired}]
                 [-splitrecrem] [-splitsetuphold]
                 [-target_application {sta verilog}] [-temperature <string>]
                 [-timingcheck {order}] [-transform_out_to_out_arcs]
                 [-typ_view <viewName>] [-version {2.1 3.0}] [-view <viewName>]
                 [-voltage <string>]

-help                                  # Prints out the command usage
<file_name>                            # Specifies the name of the SDF output
                                       # file. (string, required)
-abstracted_model                      # Writes out a special SDF file for the
                                       # Gate Level Simulation flow.
                                       # (bool, optional)
-adjust_setuphold_for_zero_hold_slack  # Adjust hold timing check to meet
                                       # non-negative slack. (bool, optional)
-base_delay                            # Writes delay values that do not
                                       # include the delta (SI cross-talk)
                                       # delay component. By default, SDF
                                       # delays include the base and delta
                                       # components plus any applied derating.
                                       # (bool, optional)
-celltiming {all none nochecks}        # Specifies which cell delays and timing
                                       # checks to write out (enum, optional)
-collapse_internal_pins                # Collapses arcs across internal pins to
                                       # a single primary input to primary
                                       # output arc (bool, optional)
-condelse                              # Writes CONDELSE constructs with the
                                       # default value when a COND construct is
                                       # written (bool, optional)
-delimiter <char>                      # Specifies the hierarchy divider
                                       # character to use in the output file
                                       # (string, optional)
-delta_delay                           # Writes out only delta delay (SI
                                       # cross-talk) values to the SDF file.
                                       # (bool, optional)
-edges {edged library noedge check_edge}
                                       # Specifies the edges values (enum, optional)
-exclude_cells <cell_list>             # Specifies a list of leaf-cell or
                                       # hierarchical instances whose timing
                                       # data will be excluded from the the SDF
                                       # file (string, optional)
-exclude_cells_keep_io_nets            # By default, when the -exclude_cells
                                       # option is used, any annotations within
                                       # the excluded cell and any annotations
                                       # to or from the excluded cell are
                                       # filtered from the SDF.  Using the
                                       # -exclude_cells_keep_io_nets will
                                       # restrict the filtering to just the
                                       # annotations which are completely
                                       # enclosed by the cell. Annotations to
                                       # or from the cell will be preserved.
                                       # (bool, optional)
-exclude_cells_keep_top_level_nets     # The -exclude_cells_keep_top_level_nets
                                       # allows you to configure the handling
                                       # of top-level interconnect annotations
                                       # to an instance that has been excluded
                                       # from the SDF via the -exclude _cells
                                       # option.  By default, no interconnect
                                       # arcs to the instance are included. 
                                       # When
                                       # -exclude_cells_keep_top_level_nets  is
                                       # specified, interconnect arcs which
                                       # span to the ports of the instance will
                                       # be included in the SDF. The delay
                                       # annotated will be the worst-case
                                       # delays of the top-level nets to/from
                                       # the first level sink/source pins
                                       # within the block that traverse a given
                                       # input/output port of the instance
                                       # respectively. See also the
                                       # -exclude_cells_keep_io_nets option.
                                       # (bool, optional)
-exclude_disabled_arcs                 # Excludes disabled arcs in the SDF file
                                       # (bool, optional)
-exclude_disabled_modes                # Excludes timing arcs that have been
                                       # disabled due to an active library mode
                                       # setting from appearing in the SDF file
                                       # (bool, optional)
-exclude_whatif_arcs                   # Excludes IO path arcs created by
                                       # WhatIf commands (bool, optional)
-filter                                # Converts all negative IOPATH delays to
                                       # zero (bool, optional)
-ideal_clock_network                   # Marks delays of delay arcs, that are
                                       # on the ideal clock networks, as 0 in
                                       # the SDF file (bool, optional)
-include_variation                     # When the selected analysis type is
                                       # SOCV, the -include_variation option
                                       # can be used to export SDF delay and
                                       # check values with the variation
                                       # component. By default, SDF delays and
                                       # check values will not have the mean +
                                       # N*sigma value. (bool, optional)
-interconn {all none noport noinport nooutport}
                                       # Specifies which interconnect delays to
                                       # write (enum, optional)
-map_file {file1 file2 ...}            # Specifies a list of sdf map files
                                       # (string, optional)
-max_view <viewName>                   # Uses the late delay from the specified
                                       # analysis view to populate the SDF max
                                       # slot, when in multi-mode multi-corner
                                       # analysis mode. (string, optional)
-merge_arcs                            # Merges two arcs that are related to
                                       # the same internal pin and forms one
                                       # timing arc (bool, optional)
-min_period_edges {posedge negedge both none}
                                       # Specifies how to write out minimum
                                       # PERIOD checks. Default: both.
                                       # (enum, optional)
-min_view <viewName>                   # Uses the early delay from the
                                       # specified analysis view to populate
                                       # the SDF min slot, when in multi-mode
                                       # multi-corner analysis mode.
                                       # (string, optional)
-no_condition                          # Suppresses the COND statements in the
                                       # SDF file (bool, optional)
-no_derate                             # Writes non-derated delays to the
                                       # Standard Delay Format (SDF) file. By
                                       # default, the set_timing_derate command
                                       # writes scaled delays to the SDF file.
                                       # (bool, optional)
-no_escape                             # Writes out object names without
                                       # escaping hierarchical dividers
                                       # (bool, optional)
-nonegchecks                           # Converts all negative timing check
                                       # values to 0.0 (bool, optional)
-precision <non_neg_integer>           # Controls the number of digits
                                       # appearing after the decimal point in
                                       # the output SDF file. The default
                                       # precision is the value of the
                                       # report_precision. The maximum
                                       # precision that can be specified is 8.
                                       # (int, optional)
-process <string>                      # Specifies one or a combination of the
                                       # following process names that will
                                       # appear in the header of the generated
                                       # SDF file (string, optional)
-recompute_delay_calc                  # Specifying the option
                                       # -recompute_delay_calc  instructs the
                                       # software to recompute any necessary
                                       # data required for a complete SDF file
                                       # before exporting. (bool, optional)
-recompute_parallel_arcs               # Instructs the software to temporarily
                                       # recompute delays with separate delay
                                       # calculation for parallel arcs. This is
                                       # recommended for SDF being used for
                                       # simulation. (bool, optional)
-recrem {merge_always split merge_when_paired}
                                       # Specifies whether Recovery and Removal
                                       # constraints are merged into a unified
                                       # RECREM construct - or kept as separate
                                       # checks. Default: merge_always.
                                       # (enum, optional)
-remashold                             # Converts the SDF v2.1 unsupported
                                       # REMOVAL to HOLD checks when used with
                                       # the -version 2.1 option (bool, optional)
-resort_values_min_to_max              # Sorts values in the SDF delay triplets
                                       # into ascending order (bool, optional)
-scale <float>                         # Specifies a multiplier to the delay
                                       # values used in the SDF file
                                       # (float, optional)
-setuphold {merge_always split merge_when_paired}
                                       # Determines how SETUP and HOLD timing
                                       # checks are written (enum, optional)
-splitrecrem                           # Splits the RECREM checks into a
                                       # RECOVERY check and a REMOVAL check
                                       # (bool, optional)
-splitsetuphold                        # Splits the SETUPHOLD timing checks
                                       # into separate SETUP and HOLD checks
                                       # (bool, optional)
-target_application {sta verilog}      # Allows customization of the SDF output
                                       # for use with STA or Verilog
                                       # applications (enum, optional)
-temperature <string>                  # Defines the temperature values that
                                       # will appear in the header of the
                                       # generated SDF file (string, optional)
-timingcheck {order}                   # Sorts the check delays in OCV analysis
                                       # (enum, optional)
-transform_out_to_out_arcs             # Writes out all output-to-output timing
                                       # arcs as input-to-output arcs
                                       # (bool, optional)
-typ_view <viewName>                   # Uses the late delay from the specified
                                       # analysis view to populate the SDF typ
                                       # slot (string, optional)
-version {2.1 3.0}                     # Specifies whether to generate the SDF
                                       # V2.1 or V3.0 (enum, optional)
-view <viewName>                       # Uses the early and late delays for the
                                       # specified analysis view to populate
                                       # the min and max SDF triplet slots
                                       # (string, optional)
-voltage <string>                      # Defines the voltage values that will
                                       # appear in the header of the generated
                                       # SDF file (string, optional)