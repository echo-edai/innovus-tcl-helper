Usage: editResize [-help] [-keep_center_line {0 1 auto}] [-no_conn] [-polygon_edge_start {x y} | -to <float>] {[[[-direction {x y diag45 diag135} -side {high low}] | [-polygon_edge_start {x y} -polygon_edge_end {x y}]] [-offset <float> | -to <float>]] | [-corner {low_left low_right up_left up_right} -dx <float> -dy <float>]}

-help                               # Prints out the command usage
-corner {low_left low_right up_left up_right}
                                    # Specifies the start corner to stretch the
                                    # wire (enum, optional)
-direction {x y diag45 diag135}     # Specifies the direction (enum, optional)
-dx <float>                         # Specifies the distance to stretch the
                                    # wire in x direction. (float, optional)
-dy <float>                         # Specifies the distance to stretch the
                                    # wire in y direction. (float, optional)
-keep_center_line {0 1 auto}        # Specifies whether resize the pin/wire
                                    # with center line unchanged. (enum, optional)
-no_conn                            # Specifies whether resize the wire without
                                    # auto via/wire creation and DRC.
                                    # (bool, optional)
-offset <float>                     # Specifies the distance to change the wire
                                    # size, in microns. (float, optional)
-polygon_edge_end {x y}             # End point for the polyon edge {x y}. This
                                    # is only used to resize a polygon.
                                    # (point, optional)
-polygon_edge_start {x y}           # Start point for the polyon edge {x y}.
                                    # This is only used to resize a polygon.
                                    # (point, optional)
-side {high low}                    # Specifies the enlarge/shrink side. High
                                    # means enlarge/shrinks the wire from top
                                    # or right. Low means enlarge /shrinks the
                                    # wire from bottom or left. (enum, optional)
-to <float>                         # Specifies destination height/width
                                    # (float, optional)