Usage: setFPlanMode [-help] [-reset]
                    [-autoSyncMasterClone {busGuides|constraints|stdcells|macros|routeBlockages|placeBlockages}]
                    [-cellsForExtraSites <string>]
                    [-checkTypes {basic|fence|oddEvenSiteRow|macroPin|color|alignmentFollowingPin|alignmentPartitionClone|busGuideConnectivity|feedThrough|partitionInPartition|multiLayerPin|powerDomain|partition|place|sameLengthSite|narrowChannel|blockOnly|unifiedVddOnBottom|tsv|exclusiveGroup|all}]
                    [-cutOffPlaceBlockageOutsideDie {true|false}]
                    [-cutOffRouteBlockageOutsideDie {true|false}]
                    [-defaultBlockageNamePrefix <string>]
                    [-defaultPowerDomainSite {true|false}]
                    [-defaultRowPatternSite <string>]
                    [-defaultTechSite <string>]
                    [-enableRectilinearDesign {true|false}]
                    [-extraRowPattern <string>] [-extraSites <string>]
                    [-firstRowSiteIndex <value>]
                    [-includeIoWhenInitArea {true|false}]
                    [-initAllCompatibleCoreSiteRows {true|false}]
                    [-keepRowsWhenMovingPowerDomain {true|false}]
                    [-lastRowSiteIndex <value>] [-maxIoHeight {true|false}]
                    [-minimumSites <value>]
                    [-move_child_constraint_with_constraint {true|false}]
                    [-move_macros_with_constraint {guide|region|fence|none|all}]
                    [-move_preplaced_std_cell_only {true|false}]
                    [-move_std_cell_with_constraint {guide|region|fence|none|all}]
                    [-narrowChannelThreshold <value>] [-no_cut_row {true|false}]
                    [-powerRailLayer <string>]
                    [-rowHeightIncrementCornerToCorner <value>]
                    [-rowHeightIncrementIncornerToCorner <value>]
                    [-rowHeightIncrementIncornerToIncorner <value>]
                    [-rowHeightMultiple <value>]
                    [-rowSiteHeight {any|odd|even|computed}]
                    [-rowSiteWidth {any|odd|even}] [-skipViolations <string>]
                    [-snap_all_corners_to_grid {true|false}]
                    [-snapBlockGrid {manufacturing|inst|placement|userDefine|LayerTrack|finfetInst|finfetManufacturing|finfetPlacement}]
                    [-snapConstraintGrid {manufacturing|inst|placement|userDefine|LayerTrack|finfetInst|finfetManufacturing|finfetPlacement}]
                    [-snapCoreGrid {manufacturing|inst|placement|userDefine|LayerTrack|finfetInst|finfetManufacturing|finfetPlacement}]
                    [-snapDieGrid {manufacturing|inst|placement|userDefine|LayerTrack|finfetInst|finfetManufacturing|finfetPlacement}]
                    [-snapIoGrid {manufacturing|inst|placement|userDefine|LayerTrack|finfetInst|finfetManufacturing|finfetPlacement}]
                    [-snapPlaceBlockageGrid {manufacturing|inst|userDefine}]
                    [-snapPlaceBlockageType {closest|upsize|sequential}]
                    [-user_define_grid {lx ly ux uy}]

-help                                      # Prints out the command usage
-reset                                     # Resets all or specified options to default value
-autoSyncMasterClone {busGuides|constraints|stdcells|macros|routeBlockages|placeBlockages}
                                           # Specify the objects used to
                                           # sync-up master to clones.
                                           # (enums={busGuides constraints stdcells macros routeBlockages placeBlockages}_list, default="")
-cellsForExtraSites <string>               # Specify cell names whose related
                                           # sites will be created.
                                           # (string, default="")
-checkTypes {basic|fence|oddEvenSiteRow|macroPin|color|alignmentFollowingPin|alignmentPartitionClone|busGuideConnectivity|feedThrough|partitionInPartition|multiLayerPin|powerDomain|partition|place|sameLengthSite|narrowChannel|blockOnly|unifiedVddOnBottom|tsv|exclusiveGroup|all}
                                           # Specify the check types for
                                           # checkFPlan. Default is the basic.
                                           # (enums={basic fence oddEvenSiteRow macroPin color alignmentFollowingPin alignmentPartitionClone busGuideConnectivity feedThrough partitionInPartition multiLayerPin powerDomain partition place sameLengthSite narrowChannel blockOnly unifiedVddOnBottom tsv exclusiveGroup all}_list, default=basic)
-cutOffPlaceBlockageOutsideDie {true|false}
                                           # When creating placement blockages,
                                           # will cut the part outside of die
                                           # and snap it by default.
                                           # (bool, default=true)
-cutOffRouteBlockageOutsideDie {true|false}
                                           # When creating routing blockages
                                           # around inst/Hinst/Partition, will
                                           # cut the part outside of die and
                                           # snap it by default. If this option
                                           # is set to false, don't cut and
                                           # snap it. (bool, default=true)
-defaultBlockageNamePrefix <string>        # Name prefix for placement blockage
                                           # and routing blockage.
                                           # (string, default="")
-defaultPowerDomainSite {true|false}       # Create rows based on default power
                                           # domain site instead of the
                                           # design's default site.
                                           # (bool, default=false)
-defaultRowPatternSite <string>            # Specify rows pattern.
                                           # (string, default="")
-defaultTechSite <string>                  # Specify a site as default
                                           # technical site. After setting a
                                           # forced one, the auto-calculating
                                           # default-technical-site
                                           # functionality will be disabled.
                                           # (string, default="")
-enableRectilinearDesign {true|false}      # Specify whether design boundary
                                           # can be changed to rectilinear
                                           # shape. (bool, default=false)
-extraRowPattern <string>                  # Specify row pattern site names
                                           # which will be created.
                                           # (string, default="")
-extraSites <string>                       # Specify site names which will be
                                           # created. (string, default="")
-firstRowSiteIndex <value>                 # Specify the first row site to be
                                           # created. (int, default=0)
-includeIoWhenInitArea {true|false}        # Include IO cells when calculating
                                           # the area of modules.
                                           # (bool, default=false)
-initAllCompatibleCoreSiteRows {true|false}
                                           # If true, initCoreRow will create
                                           # all SITE with type core. 
                                           # (bool, default=false)
-keepRowsWhenMovingPowerDomain {true|false}
                                           # specify whether to keep all
                                           # existing rows in disjoint power
                                           # domain when moving, resizing or
                                           # reshaping a power domain on GUI or
                                           # by command.  (bool, default=false)
-lastRowSiteIndex <value>                  # Specify the last row site to be
                                           # created. (int, default=-1)
-maxIoHeight {true|false}                  # Use maximum IO height to calculate
                                           # a die box with IO placement. By
                                           # default, minimum IO height is
                                           # used. (bool, default=false)
-minimumSites <value>                      # Specify the number of minimal
                                           # sites (N) that checkFPlan will
                                           # check for the same length site
                                           # rule. When sameLengthSite is
                                           # specified in checkTypes, this
                                           # option is required. (int, default=0)
-move_child_constraint_with_constraint {true|false}
                                           # Specify child constraints move
                                           # with parent constraint modules at
                                           # the same time. (bool, default=false)
-move_macros_with_constraint {guide|region|fence|none|all}
                                           # Specify macros move with
                                           # constraint modules at the same
                                           # time.
                                           # (enums={guide region fence none all}_list, default=fence)
-move_preplaced_std_cell_only {true|false}
                                           # Specify only pre-placed std cells
                                           # move with constraint modules at
                                           # the same time. (bool, default=false)
-move_std_cell_with_constraint {guide|region|fence|none|all}
                                           # Specify std cells move with
                                           # constraint modules at the same
                                           # time.
                                           # (enums={guide region fence none all}_list, default=none)
-narrowChannelThreshold <value>            # Reports narrow channels whose
                                           # width (in micros) is smaller than
                                           # the specified value. When
                                           # narrowChannel is specified in
                                           # checkTypes, this option is
                                           # required. (float, default=0)
-no_cut_row {true|false}                   # Specify no need to do cut row
                                           # before other operations.
                                           # (bool, default=false)
-powerRailLayer <string>                   # Specify the layers for calculating
                                           # power/ground on bottom attribute
                                           # of cell or techsite. By default,
                                           # the lowest metal layer is used.
                                           # (string, default="")
-rowHeightIncrementCornerToCorner <value>
                                           # Specify the offset value for user
                                           # defined row height constraint with
                                           # corner to corner edge.
                                           # (int, default=0)
-rowHeightIncrementIncornerToCorner <value>
                                           # Specify the offset value for user
                                           # defined row height constraint with
                                           # incorner to corner edge.
                                           # (int, default=0)
-rowHeightIncrementIncornerToIncorner <value>
                                           # Specify the offset value for user
                                           # defined row height constraint with
                                           # incorner to incorner edge.
                                           # (int, default=0)
-rowHeightMultiple <value>                 # Specify the pitch value for user
                                           # defined row height constraint.
                                           # (int, default=0)
-rowSiteHeight {any|odd|even|computed}     # Specify the odd even row height
                                           # constraints.
                                           # (enums={any odd even computed}, default=any)
-rowSiteWidth {any|odd|even}               # Specify the odd even row width
                                           # constraints.
                                           # (enums={any odd even}, default=any)
-skipViolations <string>                   # Specify message ID then the
                                           # message will be not reported and
                                           # shown in violation browser. (list,
                                           # optional) (string, default="")
-snap_all_corners_to_grid {true|false}     # Specify to snap all corners of
                                           # object to grid. (bool, default=false)
-snapBlockGrid {manufacturing|inst|placement|userDefine|LayerTrack|finfetInst|finfetManufacturing|finfetPlacement}
                                           # Specify the block snap rules. It
                                           # can be set to snap to manufacture
                                           # grid, instance grid, placement
                                           # grid, user-define grid, layerTrack
                                           # grid, finfet manufacture grid,
                                           # finfet instance grid, finfet
                                           # placement grid. The default is
                                           # manufacturingGrid. For Finfet
                                           # design, the default is
                                           # finfetManufacturingGrid.
                                           # (enums={manufacturing inst placement userDefine LayerTrack finfetInst finfetManufacturing finfetPlacement}, default=manufacturing)
-snapConstraintGrid {manufacturing|inst|placement|userDefine|LayerTrack|finfetInst|finfetManufacturing|finfetPlacement}
                                           # Specify the constraint snap rules.
                                           # It can be set to snap to
                                           # manufacture grid, instance grid,
                                           # placement grid, user-define grid,
                                           # layerTrack grid, finfet
                                           # manufacture grid, finfet instance
                                           # grid, finfet placement grid. The
                                           # default is instGrid. For Finfet
                                           # design, the default is
                                           # finfetInstGrid.
                                           # (enums={manufacturing inst placement userDefine LayerTrack finfetInst finfetManufacturing finfetPlacement}, default=inst)
-snapCoreGrid {manufacturing|inst|placement|userDefine|LayerTrack|finfetInst|finfetManufacturing|finfetPlacement}
                                           # Specify the core snap rules. It
                                           # can be set to snap to manufacture
                                           # grid, instance grid, placement
                                           # grid, user-define grid, layerTrack
                                           # grid, finfet manufacture grid,
                                           # finfet instance grid, finfet
                                           # placement grid. The default is
                                           # placementGrid. For Finfet design,
                                           # the default is
                                           # finfetPlacementGrid.
                                           # (enums={manufacturing inst placement userDefine LayerTrack finfetInst finfetManufacturing finfetPlacement}, default=placement)
-snapDieGrid {manufacturing|inst|placement|userDefine|LayerTrack|finfetInst|finfetManufacturing|finfetPlacement}
                                           # Specify the die snap rules. It can
                                           # be set to snap to manufacture
                                           # grid, instance grid, placement
                                           # grid, user-define grid, layerTrack
                                           # grid, finfet manufacture grid,
                                           # finfet instance grid, finfet
                                           # placement grid. The default is
                                           # placementGrid. For Finfet design,
                                           # the default is
                                           # finfetPlacementGrid.
                                           # (enums={manufacturing inst placement userDefine LayerTrack finfetInst finfetManufacturing finfetPlacement}, default=placement)
-snapIoGrid {manufacturing|inst|placement|userDefine|LayerTrack|finfetInst|finfetManufacturing|finfetPlacement}
                                           # Specify the IO snap rules. It can
                                           # be set to snap to manufacture
                                           # grid, instance grid, placement
                                           # grid, user-define grid, layerTrack
                                           # grid, finfet manufacture grid,
                                           # finfet instance grid, finfet
                                           # placement grid. The default is
                                           # manufacturingGrid. For Finfet
                                           # design, the default is
                                           # finfetManufacturingGrid.
                                           # (enums={manufacturing inst placement userDefine LayerTrack finfetInst finfetManufacturing finfetPlacement}, default=manufacturing)
-snapPlaceBlockageGrid {manufacturing|inst|userDefine}
                                           # Specify the placement blockage
                                           # snap rules. The default is inst.
                                           # (enums={manufacturing inst userDefine}, default=inst)
-snapPlaceBlockageType {closest|upsize|sequential}
                                           # Specify the snapping type. (enums={closest upsize sequential}, default=closest)
-user_define_grid {lx ly ux uy}            # Specify the user-define grid.
                                           # Format is {x_offset y_offset
                                           # x_pitch y_pitch}. The x_offset
                                           # y_offset is the offset of
                                           # user-define grid. The x_pitch
                                           # separates the vertical grid lines.
                                           # The y_pitch separates the
                                           # horizontal grid lines. The values
                                           # are in microns.
                                           # (box, default={0 0 0 0})