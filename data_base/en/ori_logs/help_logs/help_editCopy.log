Usage: editCopy [-help] [-objects <string>]
                [-orientation {R0 R90 R180 R270 MX MX90 MY MY90}] [-net <net> | -net_group <string> | -keep_net_name ] [-rotate_point {x y} | -times <integer>] [-rotate_point {x y} | [<dx> <dy>]]

-help                 # Prints out the command usage
<dx>                  # Specifies the dx distance to move the copied object in
                      # microns (float, required)
<dy>                  # Specifies the dy distance to move the copied object in
                      # microns (float, required)
-keep_net_name        # Specifies to retain the net name from the original
                      # object (bool, optional)
-net <net>            # Specifies net the copied object to be assigned to
                      # ((net), optional)
-net_group <string>   # Allow user assign a new net group name to all new bus
                      # guide. (string, optional)
-objects <string>     # Specifies the object pointers to be copied
                      # (string, optional)
-orientation {R0 R90 R180 R270 MX MX90 MY MY90}
                      # The orientation (enum, optional)
-rotate_point {x y}   # Rotates around user specified point {x y}.
                      # (point, optional)
-times <integer>      # Specifies the copy times for one editCopy operation.
                      # (int, optional, min=1, max=INT_MAX)