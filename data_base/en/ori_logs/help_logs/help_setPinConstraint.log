Usage: setPinConstraint [-help] {[-global | -cell <cell_name> | -matchEarlyGlobalRoute ] [-global | -pin <pin_name_list> | -area {x1 y1 x2 y2} | -side <side_names> | -matchEarlyGlobalRoute ] [-global | -layer {layer_id_or_name_list} | -loc {<x> <y> <z>}] [-global | -loc {<x> <y> <z>} | -edge <edge_numbers> | -corner <corner_number>] [[-pin <pin_name_list> [-loc {<x> <y> <z>}] [-edge <edge_numbers>]] | [ [-loc {<x> <y> <z>}] [-edge <edge_numbers>]] | [-corner_to_pin_distance <pin_distance> [-corner <corner_number>]]] [{-pin <pin_name_list> | -pinTemplate {layer_id_or_name_list}} [-use_min_width_as_depth | -depth <depth>] [-width <width>]] [[-layer {layer_id_or_name_list} [-side <side_names>]] | [-pinTemplate {layer_id_or_name_list} [-use_min_width_as_depth ]]] [-spacing <spacing> [-area {x1 y1 x2 y2}] [-side <side_names>]]} [-depth <depth> [-special_wire ]]

-help                                    # Prints out the command usage
-area {x1 y1 x2 y2}                      # Specifies an area overlapping with
                                         # partition where spacing constraint
                                         # applied. (box, optional)
-cell <cell_name>                        # Specifies the name of the cell,
                                         # wildcard can be specified. The cell
                                         # name is not required if the command
                                         # is run on a top-level cell.
                                         # (string, optional)
-corner <corner_number>                  # Specifies the corner of the
                                         # partition block. (int, optional)
-corner_to_pin_distance <pin_distance>   # Specifies the corner to pin distance
                                         # in tracks. (int, optional)
-depth <depth>                           # Specifies the pin depth in microns.
                                         # (float, optional)
-edge <edge_numbers>                     # Specifies the integer value where
                                         # edge numbering starts from
                                         # lower-left corner of a partition
                                         # clock-wise. (string, optional)
-global                                  # Specifies to set global constraints.
                                         # (bool, optional)
-layer {layer_id_or_name_list}           # Specifies the metal layers for the
                                         # partition pin. (string, optional)
-loc {<x> <y> <z>}                       # Specifies the x and y locations and
                                         # z layer number of the partition pin.
                                         # (string, optional)
-matchEarlyGlobalRoute                   # Specifies to change pin constraints
                                         # for co-relation with flat
                                         # earlyGlobalRoute. (bool, optional)
-pin <pin_name_list>                     # Specifies the name of the partition
                                         # pin. You can use wildcards with this
                                         # parameter. (string, optional)
-pinTemplate {layer_id_or_name_list}     # Specifies the metal layers for the
                                         # width, depth and spacing constraints
                                         # at global level and cell level.
                                         # (string, optional)
-side <side_names>                       # Specifies name of the sides. Valid
                                         # values are { N S E W } or { L B T R
                                         # } or all (string, optional)
-spacing <spacing>                       # Specifies the minimum spacing
                                         # between pins in pin pitch value.
                                         # (int, optional)
-special_wire                            # Specifies the depth constraint to be
                                         # set and honored by the partition
                                         # command only for special wire pins
                                         # (bool, optional)
-use_min_width_as_depth                  # Minimum width should be used as the
                                         # pin depth (bool, optional)
-width <width>                           # Specifies the pin width in microns.
                                         # (float, optional)