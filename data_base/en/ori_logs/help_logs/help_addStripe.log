-help                                     # Prints out the command usage
-all_blocks <0|1>                         # generate stripes over all blocks
                                          # (bool, optional)
-allow_snapping_override_custom_spacing <0|1>
                                          # allow stripes snapping override the
                                          # specified spacing (bool, optional)
-area <x1 y1 x2 y2 ...>                   # the area to generate stripes
                                          # (string, optional)
-area_blockage < {x1 y1 x2 y2}... {x1 y1 x2 y2 x3 y3 x4 y4 ...} ...>
                                          # one or multiple rectilinear area
                                          # blockage (string, optional)
-between_bumps <0|1>                      # generate stripes between bumps
                                          # (bool, optional)
-block_ring_bottom_layer_limit <layer>    # lef layer name (string, optional)
-block_ring_top_layer_limit <layer>       # lef layer name (string, optional)
-create_pins <0|1>                        # create IO pins for each stripes
                                          # (bool, optional)
-direction {horizontal vertical}          # the stripe direction
                                          # (enum, optional)
-extend_to {design_boundary first_padring last_padring all_domains}
                                          # the stripe boundary (enum, optional)
-insts <instance_name>                    # specify the instance name to
                                          # generate stripe (string, optional)
-layer <layer>                            # lef layer name (string, required)
-master <master_cell>                     # master cell name (string, optional)
-max_same_layer_jog_length <real_value>   # the maximum jog length
                                          # (float, optional)
-merge_stripes_value <auto|value>         # the threshold to merge strips
                                          # (string, optional)
-narrow_channel <0|1>                     # generate stripe over narrow channel
                                          # area (bool, optional)
-nets <list_of_nets>                      # net name list (string, required)
-number_of_sets <integer_value>           # the number of stripe sets
                                          # (int, optional)
-over_bumps <0|1>                         # generate stripes over bump
                                          # (bool, optional)
-over_physical_pins <0|1>                 # generate stripes over physical p/g
                                          # terms (bool, optional)
-over_pins <0|1>                          # generate stripes over p/g pins
                                          # (bool, optional)
-over_power_domain <0|1>                  # generate stripes only within
