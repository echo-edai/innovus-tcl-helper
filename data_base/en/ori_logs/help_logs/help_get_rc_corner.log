Usage: get_rc_corner [-help] <rcCornerName> {-cap_table | -T | -qx_tech_file | -preRoute_res | -preRoute_cap | -postRoute_res | -postRoute_cap | -postRoute_xcap | -preRoute_clkres | -preRoute_clkcap | -postRoute_clkres | -postRoute_clkcap | -via_variation_file | -thru_substrate_cell_subckt_file }

-help                                # Prints out the command usage
<rcCornerName>                       # Name of the RC corner to query
                                     # (string, required)
-T                                   # Temperature, in units of Celsius, to use
                                     # to derate resistance values
                                     # (bool, optional)
-cap_table                           # Capacitance table to use for extraction
                                     # when using this RC corner (bool, optional)
-postRoute_cap                       # Capacitance scale factor for RC
                                     # extraction in post-route mode
                                     # (bool, optional)
-postRoute_clkcap                    # Scale factor for capacitance of clock
                                     # nets in the postroute extraction mode
                                     # (bool, optional)
-postRoute_clkres                    # Scale factor for resistance of clock
                                     # nets in the postroute extraction mode
                                     # (bool, optional)
-postRoute_res                       # Resistance scale factor for RC
                                     # extraction in post-route mode
                                     # (bool, optional)
-postRoute_xcap                      # Cross-coupling capacitance scale factor
                                     # for RC extraction in postroute mode
                                     # (bool, optional)
-preRoute_cap                        # Capacitance scale factor for RC
                                     # extraction in post-route mode
                                     # (bool, optional)
-preRoute_clkcap                     # Scale factor for capacitance of clock
                                     # nets in preroute mode (bool, optional)
-preRoute_clkres                     # Scale factor for resistance of clock
                                     # nets in preroute mode (bool, optional)
-preRoute_res                        # Resistance scale factor for RC
                                     # extraction in pre-route mode
                                     # (bool, optional)
-qx_tech_file                        # Name of an QRC technology (.tch) file
                                     # used by TQRC/IQRC or QRC sign-off RC
                                     # extraction (bool, optional)
-thru_substrate_cell_subckt_file     # Return file containing subcircuit models
                                     # for FTV cells (bool, optional)
-via_variation_file                  # Option specified is -via_variation_file
                                     # (bool, optional)