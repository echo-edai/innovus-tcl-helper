Usage: violationBrowserReport [-help] [-aclimit] [-all] [-area {x1 y1 x2 y2}]
                              [-connectivity] [-density]
                              [-filter <filterString>]
                              [-filter_mode {AND|OR|NOT}] [-geometry]
                              [-max_error_per_type <integer>]
                              [-no_display_false] [-overlap] [-process_antenna]
                              [-report <filename>] [-search_desc] [-short]

-help                         # Prints out the command usage
-aclimit                      # Reports AC limit violations. (bool, optional)
-all                          # Reports all violations. (bool, optional)
-area {x1 y1 x2 y2}           # Specifies the coordinates of the area for which
                              # to report violations. (string, optional)
-connectivity                 # Reports connectivity violations.
                              # (bool, optional)
-density                      # Reports metal density violations.
                              # (bool, optional)
-filter <filterString>        # Specifies a text string in the violation
                              # message. Violation Browser searches the message
                              # of each violation and displays only the
                              # violations whose messages match the search
                              # conditions. (string, optional)
-filter_mode {AND|OR|NOT}     # Specifies the condition for searching multiple
                              # strings in the violation browser. You cannot
                              # filter complex expressions because the AND, OR,
                              # and NOT parameters are mutually exclusive.
                              # (string, optional)
-geometry                     # Reports geometry violations. (bool, optional)
-max_error_per_type <integer> # Specify the error marker number limit for each
                              # type. (int, optional)
-no_display_false             # Prohibits the EDI System software from
                              # displaying false violations. (bool, optional)
-overlap                      # Reports overlap violations. (bool, optional)
-process_antenna              # Reports process antenna violations.
                              # (bool, optional)
-report <filename>            # Specifies the report file for the violation
                              # information. (string, optional)
-search_desc                  # Searches the description field for each marker
                              # in addition to the table entries. (bool, optional)
-short                        # Reports short violations. (bool, optional)