Usage: getEcoMode [-help] [-addPortAsNeeded] [-batchMode] [-delayCalcEffort]
                  [-honorDontTouch] [-honorDontUse] [-honorFixedNetWire]
                  [-honorFixedStatus] [-honorPowerIntent] [-inheritNetAttr]
                  [-LEQCheck] [-modifyOnlyLayers] [-prefixName]
                  [-preserveModuleFunction] [-refinePlace] [-spreadInverter]
                  [-updateTiming] [-quiet] [-nonDefault]

-help                                  # Prints out the command usage
-addPortAsNeeded                       # Determines whether to add hierarchical
                                       # module ports during buffering. It only
                                       # works for manual ECO commands.
                                       # (bool, default=true)
-batchMode                             # Enter/Exit batch mode
                                       # (bool, default=false)
-delayCalcEffort                       # Delay calculation effort level { low |
                                       # medium | high } used in timing update
                                       # (string, default=high)
-honorDontTouch                        # Check dont_touch on instances, cells
                                       # and nets (bool, default=true)
-honorDontUse                          # Skip library cells marked dont_use
                                       # (bool, default=true)
-honorFixedNetWire                     # Honor fixed wires of nets
                                       # (bool, default=true)
-honorFixedStatus                      # Honor fixed (placement) instances
                                       # (bool, default=true)
-honorPowerIntent                      # Perform MSV checks during ECO: Do not
                                       # allow resize of regular cell with
                                       # always-on cell (and vice-versa), do
                                       # not change cells belonging to
                                       # different power domains, do not allow
                                       # adding buffer to a power domain it
                                       # doesn't belong to, do not buffer a
                                       # cross power domain net, do not allow
                                       # deletion of an always-on buffer, a
                                       # level-shifter, or a buffer which will
                                       # cause redundant isolation cell.
                                       # (bool, default=true)
-inheritNetAttr                        # New net inherits attributes of
                                       # buffered net (bool, default=true)
-LEQCheck                              # Do logical-equivalence checking
                                       # (bool, default=true)
-modifyOnlyLayers                      # Modify routes only on metal layers in
                                       # this range (both inclusive)
                                       # (string, default="")
-prefixName                            # Prefix name to be used by ECO commands
                                       # (string, default=ECO)
-preserveModuleFunction                # Determines whether to preserve logical
                                       # functions at hierarchical module
                                       # ports. It only works for manual ECO
                                       # commands. (bool, default=false)
-refinePlace                           # Refine placement after ECO
                                       # (bool, default=true)
-spreadInverter                        # Spread inverters on buffered net
                                       # (bool, default=true)
-updateTiming                          # Update timing results after ECO
                                       # (bool, default=true)
-quiet                                 # Displays the current settings in Tcl list format only
-nonDefault                            # Displays the current settings which are not default settings