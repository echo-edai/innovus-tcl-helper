Usage: getUsefulSkewMode [-help] [-opt_skew_apply_delay_limits_to_full_flow]
                         [-opt_skew_delay_pre_cts] [-opt_skew_macro_only]
                         [-opt_skew_max_allowed_delay]
                         [-opt_skew_min_allowed_delay] [-opt_skew_no_boundary]
                         [-quiet] [-nonDefault]

-help                                     # Prints out the command usage
-opt_skew_apply_delay_limits_to_full_flow
                                          # delay limits apply to whole flow (bool, default=false)
-opt_skew_delay_pre_cts                   # delaying mode in preCTS
                                          # (bool, default=true)
-opt_skew_macro_only                      # skew hard blocks
                                          # (bool, default=false)
-opt_skew_max_allowed_delay               # max allowed skewing delay, unit is
                                          # 'ns'
                                          # (float, default=1, min=0, max=1000)
-opt_skew_min_allowed_delay               # min allowed skewing delay, unit is
                                          # 'ns'
                                          # (float, default=0, min=0, max=1000)
-opt_skew_no_boundary                     # consider boundary sequential
                                          # elements (bool, default=false)
-quiet                                    # Displays the current settings in Tcl list format only
-nonDefault                               # Displays the current settings which are not default settings