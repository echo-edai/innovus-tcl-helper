Usage: set_clock_uncertainty [-help] [<uncertainty_value>] [-fall]
                             [-full_cycle_jitter <value>]
                             [-half_cycle_jitter <value>] [-hold] [-rise]
                             [-setup] { { {-from <clksig_from_list> | -rise_from <clksig_from_list> | -fall_from <clksig_from_list>} {-to <clksig_to_list> | -rise_to <clksig_to_list> | -fall_to <clksig_to_list>} } |  <pin_or_clock_list> }

-help                             # Prints out the command usage
<uncertainty_value>               # Uncertainty value to be applied
                                  # (float, optional)
<pin_or_clock_list>               # List of clocks or pins for target
                                  # uncertainty (string, optional)
-fall                             # Falling edge at the capture clock pin on
                                  # which the uncertainty is applied
                                  # (bool, optional)
-fall_from <clksig_from_list>     # Applies the uncertainty value only to the
                                  # falling edge of the launching clocks
                                  # (string, optional)
-fall_to <clksig_to_list>         # Applies the uncertainty value only to the
                                  # falling edge of the capture clocks
                                  # (string, optional)
-from <clksig_from_list>          # Applies the uncertainty value to both the
                                  # rising and falling edges of the launching
                                  # clocks (string, optional)
-full_cycle_jitter <value>        # Provides the full cycle jitter
                                  # (float, optional)
-half_cycle_jitter <value>        # Provides the half cycle jitter
                                  # (float, optional)
-hold                             # Clock uncertainty applies to hold checks
                                  # (bool, optional)
-rise                             # Rising edge at the capture clock pin on
                                  # which the uncertainty is applied
                                  # (bool, optional)
-rise_from <clksig_from_list>     # Applies the uncertainty value only to the
                                  # rising edge of the launching clocks
                                  # (string, optional)
-rise_to <clksig_to_list>         # Applies the uncertainty value only to the
                                  # rising edge of the capture clocks
                                  # (string, optional)
-setup                            # Clock uncertainty applies to setup checks
                                  # (bool, optional)
-to <clksig_to_list>              # Applies the uncertainty value to both the
                                  # rising and falling edges of the capture
                                  # clocks (string, optional)