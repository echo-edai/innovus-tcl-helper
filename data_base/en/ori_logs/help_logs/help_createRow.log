Usage: createRow [-help] [-flip1st] [-limitInCore] [-noCheck] [-noFlip]
                 [-site <string>] [-spacing <float>] [-noAbut  | -noAbut1st ] [-area {x1 y1 x2 y2} | -boxList {{x1 y1} {x2 y2}...} | -polygon {{x1 y1} {x2 y2}...}]

-help                             # Prints out the command usage
-area {x1 y1 x2 y2}               # create rows inside this area(box).
                                  # (box, optional)
-boxList {{x1 y1} {x2 y2}...}     # create rows inside this boxList.
                                  # (point_list, optional)
-flip1st                          # flip the first row  (bool, optional)
-limitInCore                      # limit new rows inside of core
                                  # (bool, optional)
-noAbut                           # no abut any row  (bool, optional)
-noAbut1st                        # not abut the first row (bool, optional)
-noCheck                          # donot align row to existing row and not
                                  # support redo undo (bool, optional)
-noFlip                           # Specifies that the rows should not be
                                  # flipped. The Rows are flipped if the option
                                  # isn't specified.  (bool, optional)
-polygon {{x1 y1} {x2 y2}...}     # create rows inside this boxList.
                                  # (point_list, optional)
-site <string>                    # site name for new rows (string, optional)
-spacing <float>                  # spacing between rows (float, optional)