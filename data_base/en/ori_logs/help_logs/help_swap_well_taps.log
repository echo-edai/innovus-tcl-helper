Usage: swap_well_taps [-help] [-both_violation <cellName>] [-cells <cellList>]
                      [-check_only] [-default_cell <cellName>]
                      -diffusion_forbidden_spacing <float>
                      [-left_violation <cellName>] [-right_violation <cellName>]
                      [-skip_cells <cellList>] [-swap_report <fileName>]
                      [-violation_report <fileName>]

-help                                    # Prints out the command usage
-both_violation <cellName>               # Specify well taps to swap if only
                                         # violating rules on both side.
                                         # (string, optional)
-cells <cellList>                        # Specify well taps to swap if
                                         # violating rules. (string, optional)
-check_only                              # Check only without swapping
                                         # (bool, optional)
-default_cell <cellName>                 # Swap to default well tap first. Must
                                         # be one of cells. (string, optional)
-diffusion_forbidden_spacing <float>     # Specify forbidden spacing rule
                                         # (unit:um) (float, required)
-left_violation <cellName>               # Specify well taps to swap if only
                                         # violating rules on left side.
                                         # (string, optional)
-right_violation <cellName>              # Specify well taps to swap if only
                                         # violating rules on right side.
                                         # (string, optional)
-skip_cells <cellList>                   # Specify cells to skip rule check.
                                         # (string, optional)
-swap_report <fileName>                  # Report swapped instances.
                                         # (string, optional)
-violation_report <fileName>             # Report violated instances.
                                         # (string, optional)