Usage: setCheckMode [-help] [-reset] [-all {true|false}]
                    [-checkIlm {true|false}] [-extraction {true|false}]
                    [-floorplan {true|false}] [-globalNet {true|false}]
                    [-integrity {true|false}] [-io {true|false}]
                    [-library {true|false}] [-mgrid {true|false}]
                    [-netlist {true|false}] [-placement {true|false}]
                    [-route {true|false}] [-sroute {true|false}]
                    [-tapeOut {true|false}] [-timingGraph {true|false}]
                    [-vcellnetlist {true|false}]

-help                      # Prints out the command usage
-reset                     # Resets all or specified options to default value
-all {true|false}          # Performs all checks (bool, default=false)
-checkIlm {true|false}     # check ILM model (bool, default=false)
-extraction {true|false}   # Checks that all data required for extraction are
                           # correct (bool, default=false)
-floorplan {true|false}    # Checks floorplan (bool, default=false)
-globalNet {true|false}    # After init_design or restoreDesign, will do the
                           # same checks as checkDesign -powerGround
                           # (bool, default=false)
-integrity {true|false}    # (bool, default=false)
-io {true|false}           # Checks IO (bool, default=false)
-library {true|false}      # After init_design or restoreDesign, will do the
                           # same checks as checkDesign -physicalLibrary
                           # -timingLibrary (bool, default=false)
-mgrid {true|false}        # Checks that geometries are on the manufacturing
                           # grid (bool, default=false)
-netlist {true|false}      # After reading in the netlist, will do the same
                           # checks as checkDesign -netlist (bool, default=false)
-placement {true|false}    # Checks placement (bool, default=false)
-route {true|false}        # Checks whether power and ground pins are connected
                           # to power and ground nets before power routing
                           # (bool, default=false)
-sroute {true|false}       # Checks special route (bool, default=false)
-tapeOut {true|false}      # When reading the netlist will error out if there
                           # are undefined instances or ports (rather than
                           # create black_boxes or empty modules)
                           # (bool, default=false)
-timingGraph {true|false}  # Checks library cells for timing information
                           # (bool, default=false)
-vcellnetlist {true|false} # Checks for tie-high and tie-low output pins when
                           # reading the Verilog netlist (bool, default=true)