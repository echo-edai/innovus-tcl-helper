Usage: commit_power_intent [-help] [-clpLog <string>] [-eco <string>]
                           [-isolation] [-keepRows] [-level_shifter]
                           [-power_domain] [-power_switch] [-state_retention] [-verbose ]

-help                         # Prints out the command usage
-clpLog <string>              # CLP logfile (string, optional)
-eco <string>                 # eco CPF file (string, optional)
-isolation                    # commit isolation (bool, optional)
-keepRows                     # keep rows (bool, optional)
-level_shifter                # commit level_shifter (bool, optional)
-power_domain                 # commit power_domain (bool, optional)
-power_switch                 # commit power_switch (bool, optional)
-state_retention              # commit state_retention (bool, optional)
-verbose                      # verbose mode (bool, optional)