Usage: get_pins [-help] [-filter <expr>] [-hierarchical] [-hsc <char>] [-leaf]
                [-nocase] [-quiet] [-regexp] [ <patterns> | -of_objects <object_list> ]

-help                         # Prints out the command usage
<patterns>                    # Patterns for pin names. Patterns include the *
                              # and ? wildcard characters and collections of
                              # pins (string, optional)
-filter <expr>                # Filters the collection with the specified
                              # expression (string, optional)
-hierarchical                 # Patterns should match hierarchically
                              # (bool, optional)
-hsc <char>                   # Hierarchical delimiter for patterns
                              # (string, optional)
-leaf                         # Return leaf pins only (bool, optional)
-nocase                       # Pattern matching is not case sensitive
                              # (bool, optional)
-of_objects <object_list>     # Collection of all pins associated with the
                              # specified cells or nets (string, optional)
-quiet                        # Suppresses all error and warning messages
                              # generated when the get_pins command is run
                              # (bool, optional)
-regexp                       # Treats the specified patterns as a regular
                              # expression patterns (bool, optional)