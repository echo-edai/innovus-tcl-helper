Usage: report_narrow_channel [-help] { -width <float> [-ignore_placement_blockage ] [-no_merge_channel_check ] [-direction {x y xy}] [-active_objects {macro macroHalo ioPad ioCell core fence hardBlkg softBlkg partialBlkg routeBlkg row}] }

-help                          # Prints out the command usage
-active_objects {macro macroHalo ioPad ioCell core fence hardBlkg softBlkg partialBlkg routeBlkg row}
                               # Active objects for narrow channel checking.
                               # The default is "core macro macroHalo hardBlkg"
                               # (enum_list, optional)
-direction {x y xy}            # Control for narrow channel checking direction.
                               # It could be x, y, xy. The default is xy
                               # (enum, optional)
-ignore_placement_blockage     # Specify to ignore placement blockages when
                               # computing channel widths (bool, optional)
-no_merge_channel_check        # Specify to merge narrow channel error boxes
                               # into contiguous error box (bool, optional)
-width <float>                 # Specify the checking channel width
                               # (float, required, min=0, max=100000)