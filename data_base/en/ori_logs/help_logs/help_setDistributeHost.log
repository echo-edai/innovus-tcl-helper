Usage: setDistributeHost [-help] [-add <string>] [-args <string>] [-custom]
                         [-custom_script <string>]
                         [-custom_script_list <string>]
                         [-custom_script_local <string>] [-env_script <string>]
                         [-local] [-local_as_remote] [-lsf] [-nc]
                         [-noWaitTaskComeUp] [-queue <string>]
                         [-remove <string>] [-reportLsfInfo]
                         [-resource <string>] [-shellTimeout <integer>]
                         [-single_cpu_lsf_args <string>] [-ssh]
                         [-timeOut <integer>]

-help                             # Prints out the command usage
-add <string>                     # List of hosts to be added to the host list
                                  # for rsh/ssh distribured processing
                                  # (string, optional)
-args <string>                    # Additional arguments to specify along with
                                  # submit command for LSF/SGE (-P -W etc)
                                  # (string, optional)
-custom                           # Use custom job submission script for
                                  # distributed processing (bool, optional)
-custom_script <string>           # Custom job submission script and arguments
                                  # for "custom" distributed processing mode
                                  # (string, optional)
-custom_script_list <string>      # Custom job submission script list and
                                  # arguments for "custom" distributed
                                  # processing mode(example: {{{stringCommand1}
                                  # count1} {{stringCommand2} count2} ...
                                  # {{stringCommandN} countN}}) (string, optional)
-custom_script_local <string>     # Custom job submission script and arguments
                                  # for "local" distributed processing mode
                                  # (string, optional)
-env_script <string>              # Custom environment script for slaves start
                                  # up (string, optional)
-local                            # Run distributed processing job on the local
                                  # machine (bool, optional)
-local_as_remote                  # Use local host as remote when there is gpu
                                  # queue (bool, optional)
-lsf                              # Use LSF for distributed processing
                                  # (bool, optional)
-nc                               # Use nc commands (Network Computer from
                                  # RTDA) for distributed processing
                                  # (bool, optional)
-noWaitTaskComeUp                 # Do not wait forever if a task does not come
                                  # up (bool, optional)
-queue <string>                   # Queue name for LSF or SGE (Sun Grid Engine)
                                  # (string, optional)
-remove <string>                  # List of hosts to be removed from the host
                                  # list for rsh/ssh distributed processing
                                  # (string, optional)
-reportLsfInfo                    # Collect the lsf slave info after edp finish
                                  # (bool, optional)
-resource <string>                # Resource string for LSF (-R) or SGE (Sun
                                  # Grid Engine) (string, optional)
-shellTimeout <integer>           # Timeout value to check rsh/ssh machine
                                  # response time (default = 5 seconds)
                                  # (int, optional)
-single_cpu_lsf_args <string>     # Same as " -args", for single cpu
                                  # distributed application specially
                                  # (string, optional)
-ssh                              # Use ssh for distributed processing
                                  # (bool, optional)
-timeOut <integer>                # Timeout period for jobs which never start
                                  # Default: (3600 seconds) (int, optional)