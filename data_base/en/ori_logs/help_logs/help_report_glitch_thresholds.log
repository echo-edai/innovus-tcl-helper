Usage: report_glitch_thresholds [-help] [-failure_point {input output}]
                                [-glitch_type <string>]
                                [-instance_pins <string>]
                                [-library_pins <string>]
                                [-list_unannotated_instance_pins]
                                [-list_unannotated_library_pins]
                                [-view <string>]

-help                              # Prints out the command usage
-failure_point {input output}      # Specifies if threshold failure point is
                                   # input or output. default=input
                                   # (enum, optional)
-glitch_type <string>              # specify space seperated glitch types to be
                                   # reported. Option: vl vh vlu vho all
                                   # (list, optional)
-instance_pins <string>            # specify list of instance pin names
                                   # (list, optional)
-library_pins <string>             # specify list of library pin names
                                   # (list, optional)
-list_unannotated_instance_pins    # list un-annotated instance pins
                                   # (bool, optional)
-list_unannotated_library_pins     # list un-annotated library pins
                                   # (bool, optional)
-view <string>                     # view name (string, optional)