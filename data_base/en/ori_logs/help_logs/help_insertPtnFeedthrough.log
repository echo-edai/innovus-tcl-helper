-help                                  # Prints out the command usage
-allLowercase                          # Specifies all lowercase characters for
                                       # the inserted feedthrough buffer and
                                       # feedthrough net names. (bool, optional)
-autoSelectNetsByCongestion            # specify the option for congestion
                                       # aware feedthrough insertion flow
                                       # (bool, optional)
-autoSelectNetsBySlack                 # specify the option for timing driven
                                       # feedthrough insertion flow
                                       # (bool, optional)
-blockageFile <string>                 # Specifies a file that contains the
                                       # coordinates of line segments that are
                                       # considered as blockages for placement
                                       # based feedthrough insertion.
                                       # (string, optional)
-blockedEdgesFile <string>             # Specifies a file that contains the
                                       # names of the partitions followed by
                                       # the edge numbers for the partition
                                       # which are considered as blocked for
                                       # the purpose of this command.
                                       # (string, optional)
-bufCell {cellName | cellNameList}     # Specifies the name of the feedthrough
                                       # buffer cell type. (string, optional)
-checkOnly                             # Specifies that the feedthrough buffers
                                       # are not inserted. (bool, optional)
-doubleBuffer                          # Adds a buffer close to the feedthrough
                                       # input pin and adds a buffer close to
                                       # the feedthrough output pin. 
                                       # (bool, optional)
-ecoFile <string>                      # Specifies the file for logging ECO
                                       # directives. (string, optional)
-excludeNet <string>                   # Specifies a file that contains net
                                       # names to be excluded from being a
                                       # feedthrough net for a partition.
                                       # (string, optional)
-excludePtnList {ptnName | ptnNameList}    # Specifies that feedthrough buffers
                                           # should not be added to the
                                           # specified partitions.
                                           # (string, optional)
-instPrefix <string>                   # Specifies a prefix for the newly
                                       # created instances. (string, optional)
-netMapping <string>                   # Generates a file that maps the
                                       # original net name to the new net name
                                       # created for the feedthrough buffers.
                                       # (string, optional)
-netPrefix <string>                    # Specifies a prefix for the newly
                                       # created nets.Specifies a prefix for
                                       # the newly created nets.
                                       # (string, optional)
-noBuffer                              # Generates an ASSIGN statement in the
                                       # netlist instead of inserting a buffer.
                                       # (bool, optional)
-repeatedSymmetricAbuttedFPlan         # Applicable to master clone designs,
                                       # which have repeated components
                                       # arranged in a symmetric configuration
                                       # with a data flow going from the top to
                                       # each component independently.
                                       # (bool, optional)
-reuseBuffer {true false 0 1}          # Reuses inserted buffers across
                                       # multiple instantiation of a module
                                       # within one run. (enum, optional)
-routeBased                            # Will correct routing to preserve
                                       # equivalence, enforce single entry for
                                       # feedthrough path and create nets
                                       # connected to two or less partition
                                       # pins only (bool, optional)
-routeBasedStrict                      # Follows routing strictly and places
                                       # pins. Can break equivalence, does not
                                       # enforce single entry and can create
                                       # nets connected to three or more
                                       # partition pins. (bool, optional)
-saveTopoFile <string>                 # Saves a file with feedthrough buffer
                                       # topology tree information from an
                                       # existing floorplan. (string, optional)
-selectMarkedNet                       # Specifies that feedthrough buffers
                                       # should be inserted on the nets that
                                       # are currently selected in the GUI.
                                       # (bool, optional)
-selectNet <string>                    # Specifies a file that contains net
                                       # names to be feedthrough nets for a
                                       # partition and inserted feedthrough
                                       # buffers. (string, optional)
-topoFile <string>                     # Specifies the file that has the
                                       # topology tree information.
                                       # (string, optional)
-useShortName                          # Specifies the abbreviation of inserted
                                       # feedthrough net names so that the net
                                       # names do not extend too long for
                                       # multiple runs. (bool, optional)
-verbose                               # Specifies that net-specific
                                       # information is included in the logs.
