Usage: gui_set_legend [-help] [-display_range {x y}]
                      [-enable_max_value {true false}]
                      [-enable_min_value {true false}]
                      [-legend_location {ne nw se sw}] [-reset <string>]
                      [-show_legend_on_layout {true false}]
                      -type {inst_density pin_density timing_map metal_density route_congestion temperature}
                      [-value_range {x y}]

-help                                   # Prints out the command usage
-display_range {x y}                    # Specify the display range in {min
                                        # max} format (point, optional)
-enable_max_value {true false}          # Enable the max value of display range
                                        # (enum, optional)
-enable_min_value {true false}          # Enable the min value of display range
                                        # (enum, optional)
-legend_location {ne nw se sw}          # Specify the location of legend
                                        # (enum, optional)
-reset <string>                         # Reset the settings. Use "-reset all"
                                        # to reset all options. Use "-reset
                                        # -display_range|-value_range|-show_legend_on_layout|-legend_location|-enable_min_value|-enable_max_value"
                                        # to reset the specified option.
                                        # (string, optional)
-show_legend_on_layout {true false}     # Show the legend on layout
                                        # (enum, optional)
-type {inst_density pin_density timing_map metal_density route_congestion temperature}
                                        # Legend type (enum, required)
-value_range {x y}                      # Specify the value range in {min max}
                                        # format (point, optional)