Usage: set_power [-help] [<value>] [-ascii_power_file <string>] [-cap <string>]
                 [-cell <string>] [-clock <string>] [-custom_macro_pwl <string>]
                 [-default_dynamic_pgv_mode <string>]
                 [-dynamic_async_mode <string>] [-dynamic_switch_event <string>]
                 [-dynamic_switch_pattern <string>] [-exclude_clock <string>]
                 [-exclude_ddv_modes <string>] [-fanout_limit <string>] [-force]
                 [-include_ddv_modes <string>] [-instance <string>] [-internal]
                 [-leakage] [-no_propagation] [-pg_net <string>]
                 [-pg_pin <string>] [-pin <string>] [-pwl] [-region <string>]
                 [-repeat] [-reset] [-scale_factor <string>]
                 [-signal_net <string>] [-slew <string>] [-static_mode <string>]
                 [-sticky] [-switching] [-trigger_time_adjustment <string>]

-help                                # Prints out the command usage
<value>                              # Specifies power in milliwatts during
                                     # static power calculation or piecewise
                                     # linear ( -pwl ) current waveform in ns
                                     # and mA, during dynamic power calculation
                                     # for cell or instance. (string, optional)
-ascii_power_file <string>           # Specifies the name of an instance list
                                     # file. This file contains the list of
                                     # instances in the format: 'instance_name
                                     # power_value < pin_name >'.
                                     # (string, optional)
-cap <string>                        # Specifies slew to be used for instances
                                     # above fanout_limit (string, optional)
-cell <string>                       # Specifies the cell name. If the cell or
                                     # instance name is not specified, the
                                     # power will be distributed to all rails.
                                     # (string, optional)
-clock <string>                      # Specifies the power value for clock
                                     # networks. list of clocks|all
                                     # (string, optional)
-custom_macro_pwl <string>           # Specifies to use a custom trigger file
                                     # to apply instance or cell PWL waveforms.
                                     # (string, optional)
-default_dynamic_pgv_mode <string>   # default ddv mode (string, optional)
-dynamic_async_mode <string>         # Specifies instance or cell asynchronous
                                     # mode. (string, optional)
-dynamic_switch_event <string>       # Specifies switch pattern with rise/fal
                                     # time instead of cycle. (string, optional)
-dynamic_switch_pattern <string>     # Specifies stimulus pattern on the pins
                                     # of an instance and cell. (string, optional)
-exclude_clock <string>              # Excludes clock networks when specifying
                                     # a scale factor or power specification
                                     # for the whole design. clocks to
                                     # exclude|all (string, optional)
-exclude_ddv_modes <string>          # DDV modes excluded (string, optional)
-fanout_limit <string>               # fanout_limit defined by the user for
                                     # slew/cap/power assignments
                                     # (string, optional)
-force                               # Specifies to apply the set_power command
                                     # even if there are Verilog mismatches.
                                     # (bool, optional)
-include_ddv_modes <string>          # DDV modes included (string, optional)
-instance <string>                   # Specifies the instance name. If the cell
                                     # or instance name is not specified, the
                                     # power will be distributed to all rails.
                                     # (string, optional)
-internal                            # Specifies the target internal power of
                                     # the design, cell, or instance.
                                     # (bool, optional)
-leakage                             # Specifies the target leakage power of
                                     # the design, cell, instance, or power
                                     # net. (bool, optional)
-no_propagation                      # Support post state-propagation
                                     # user-defined dynamic switch pattern
                                     # (bool, optional)
-pg_net <string>                     # The specified power or pwl for the cell,
                                     # instance or design is applied to the
                                     # specified rail. (string, optional)
-pg_pin <string>                     # Specifies switch pattern to a specific
                                     # pg pin on instance. (string, optional)
-pin <string>                        # Specifies pin-wise power numbers for a
                                     # specific instance. (string, optional)
-pwl                                 # Specifies that power argument ( power |
                                     # pwl ) is a waveform rather than a power
                                     # number. (bool, optional)
-region <string>                     # Specifies region for power target.
                                     # (string, optional)
-repeat                              # Repeats dynamic switch pattern of all
                                     # the clock cycles in the simulation
                                     # period. (bool, optional)
-reset                               # Resets all specified options back to
                                     # default values. (bool, optional)
-scale_factor <string>               # Scales the power value by the specified
                                     # scale factor. (string, optional)
-signal_net <string>                 # Signal net name for power assignment to
                                     # connected instances (string, optional)
-slew <string>                       # Specifies slew to be used for instances
                                     # above fanout_limit (string, optional)
-static_mode <string>                # static MvMf mode (string, optional)
-sticky                              # Applies the simulation based PWL
                                     # waveform as is, to the specified
                                     # cell/instance for dynamic power
                                     # analysis. (bool, optional)
-switching                           # Specifies the target switching power of
                                     # the design, cell, or instance.
                                     # (bool, optional)
-trigger_time_adjustment <string>    # Specified trigger_time_adjustment will
                                     # be used to shift tool calculated trigger
                                     # time of a memory/macro (string, optional)