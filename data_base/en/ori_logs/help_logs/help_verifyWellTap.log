Usage: verifyWellTap [-help] [-area <box>] [-avoidAbutment] [-check <string>]
                     [-fromEdge] [-layer <layer_name>] [-powerDomain <string>]
                     [-report <string>] [-rule <float>] [-siteOffset <#>]
                     [-wellCutCell <string>] [-cell <string> ]

-help                     # Prints out the command usage
-area <box>               # Area in which well-taps are to be verified
                          # (box, optional)
-avoidAbutment            # Check no abutted tap cell in vertical and
                          # horizontal direction (bool, optional)
-cell <string>            # Specify the well-tap cells (string, optional)
-check <string>           # Check the latchup rule for pwell or nwell only
                          # (string, optional)
-fromEdge                 # Checks the rule distance from the right and left
                          # edges of the well-tap cells (bool, optional)
-layer <layer_name>       # Specify layer name to check rule check.
                          # (string, optional)
-powerDomain <string>     # Specify the power domain to check
                          # (string, optional)
-report <string>          # Specify the report name (string, optional)
-rule <float>             # Specify the maximum distance betwen two well-tap
                          # cells (float, optional)
-siteOffset <#>           # Check the offset value in number of sites that
                          # vertical taps need to be aware of
                          # (int, optional, min=1, max=INT_MAX)
-wellCutCell <string>     # Specify the well cut cells (string, optional)