Usage: write_category_summary [-help] -report <string> [[-ascend  | -descend ] [-byTNS  | -byWNS ]] [-csv  | {-no_frame_fix_width  [-no_split ]}]

-help                # Prints out the command usage
-ascend              # Specifies that the  report in ascending order, should
                     # specify option -byTNS or -byWNS (bool, optional)
-byTNS               # The TNS value will be specified as the sorting key,
                     # should specify option -ascend or -descend (bool, optional)
-byWNS               # The WNS value will be specified as the sorting key,
                     # should specify option -ascend or -descend (bool, optional)
-csv                 # Reports entries in csv format. (bool, optional)
-descend             # Specifies that the report in descending order, should
                     # specify option -byTNS or -byWNS (bool, optional)
-no_frame_fix_width  # Specifies that the table columns have a fixed minimum
                     # width, but no maximum width (bool, optional)
-no_split            # Specifies that each column follows the preceding column
                     # without splitting to a new line,if the data in one
                     # column overruns the next colum  (bool, optional)
-report <string>     # Specifies the name of the category report file. Default
                     # : category.rpt. (string, required)