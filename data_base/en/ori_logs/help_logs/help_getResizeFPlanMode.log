Usage: getResizeFPlanMode [-help] [-congAware] [-honorHalo] [-ioFix]
                          [-ioMoveWithEdge] [-ioProportional]
                          [-maintainResourceRatioAfterResize] [-proportional]
                          [-shiftBased] [-shrinkFence] [-snapToTrack]
                          [-quiet] [-nonDefault]

-help                                    # Prints out the command usage
-congAware                               # resizes and shifts the floorplan
                                         # objects by estimating the congestion
                                         # for the floorplan and automatically
                                         # deciding where to draw a resize line
                                         # to avoid the congested area.
                                         # (bool, default=false)
-honorHalo                               # honors placement halo and preserves
                                         # the space between macros held by
                                         # halo after the floorplan resize.
                                         # (bool, default=true)
-ioFix                                   # fixes I/Os at current location.
                                         # (bool, default=false)
-ioMoveWithEdge                          # moves pins on the moved edge
                                         # orthogonally to edge direction so
                                         # pins stay on edge after movement.
                                         # (bool, default=false)
-ioProportional                          # resize the space among I/Os
                                         # proportionally. (bool, default=true)
-maintainResourceRatioAfterResize        # Enable to maintain the resource
                                         # ratio after resizeFloorplan in
                                         # shift-based mode. (bool, default=false)
-proportional                            # resizes the space among floorplan
                                         # objects proportionally.
                                         # (bool, default=false)
-shiftBased                              # shifts floorplan objects at
                                         # appropriate location(s) without
                                         # changing the proportional spacing.
                                         # (bool, default=true)
-shrinkFence                             # enables resized lines to go through
                                         # fences and regions in floorplan.
                                         # (bool, default=false)
-snapToTrack                             # snaps resize values (shrink/expand)
                                         # of the floorplan to a multiple
                                         # integer of the metal layer pitch.
                                         # (bool, default=true)
-quiet                                   # Displays the current settings in Tcl list format only
-nonDefault                              # Displays the current settings which are not default settings