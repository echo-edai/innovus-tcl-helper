Usage: readBumpLocation [-help] <fileName>
                        [-allow_overlap_control {keep_all keep_existing_bumps keep_new_bumps}]
                        [-die_box] [-ignore_route_blockages] {[-frontBump <frontBumpCellName>] [-backBump <backBumpCellName>] [-bump_cell_from_bump_file ] [-force_current_die ] [-checkAlignment ]} [{-backBump <backBumpCellName> | -bump_cell_from_bump_file } [-rotate_bump  -prefix <string>]] [{-frontBump <frontBumpCellName> | -bump_cell_from_bump_file } [-rotate_bump  -prefix <string>] [-stackViaUnderBump <string>]] [-prefix <string> | -bump_name_from_bump_file {true false}] [-checkAlignment ] [-nonFeedthru ] [-feedthru ] [-tsvViaName <string> [-feedthruSize {x y}] [-offset {x y}]]

-help                                      # Prints out the command usage
<fileName>                                 # Bump location file name
                                           # (string, required)
-allow_overlap_control {keep_all keep_existing_bumps keep_new_bumps}
                                           # It specifies the overlap control
                                           # type. (enum, optional)
-backBump <backBumpCellName>               # Create aligned bumps using
                                           # specified bump cell
                                           # (string, optional)
-bump_cell_from_bump_file                  # Create bumps with the same bump
                                           # cell defined in bump file.
                                           # (bool, optional)
-bump_name_from_bump_file {true false}     # Create bumps with the same bump
                                           # name defined in bump file.
                                           # (bool, optional)
-checkAlignment                            # Check and Validate alignment and
                                           # assignment (bool, optional)
-die_box                                   # draw the die bounding box based on
                                           # the DieBox value in the bump file
                                           # (bool, optional)
-feedthru                                  # handle feedthru bump only
                                           # (bool, optional)
-feedthruSize {x y}                        # x and y size  (point, optional)
-force_current_die                         # The specified bump file is
                                           # considered as current die bump
                                           # file. Skip to check if the
                                           # specified bump file is for current
                                           # die or adjacent die or a block.
                                           # (bool, optional)
-frontBump <frontBumpCellName>             # Create aligned bumps using
                                           # specified bump cell
                                           # (string, optional)
-ignore_route_blockages                    # Allows bumps to be created on
                                           # route blockages. When this option
                                           # is specified, the tool ignores
                                           # checking route blockages when
                                           # creating bumps. (bool, optional)
-nonFeedthru                               # handle non-feedthru bump only
                                           # (bool, optional)
-offset {x y}                              # offset between bump and TSV in x
                                           # and y direction (point, optional)
-prefix <string>                           # add prefix name for bump during
                                           # bump creation and bump mapping
                                           # (string, optional)
-rotate_bump                               # Rotate bumps during bump mapping
                                           # according to the chip and bump
                                           # orientation information of
                                           # adjacent die. (bool, optional)
-stackViaUnderBump <string>                # under front bump stack via name
                                           # (string, optional)
-tsvViaName <string>                       # TSV via master name
                                           # (string, optional)