Usage: setEcoMode [-help] [-reset] [-addPortAsNeeded {true|false}]
                  [-honorDontTouch {true|false}] [-honorDontUse {true|false}]
                  [-honorFixedNetWire {true|false}]
                  [-honorFixedStatus {true|false}]
                  [-honorPowerIntent {true|false}]
                  [-inheritNetAttr {true|false}] [-LEQCheck {true|false}]
                  [-modifyOnlyLayers <bottom-layer>:<top-layer>]
                  [-prefixName <prefix>] [-preserveModuleFunction {true|false}]
                  [-refinePlace {true|false}] [-spreadInverter {true|false}]
                  [-updateTiming {true|false}] [ -batchMode {true|false} ] [ -delayCalcEffort effort_level ]

-help                                  # Prints out the command usage
-reset                                 # Resets all or specified options to default value
-addPortAsNeeded {true|false}          # Determines whether to add hierarchical
                                       # module ports during buffering. It only
                                       # works for manual ECO commands.
                                       # (bool, default=true)
-batchMode {true|false}                # Enter/Exit batch mode
                                       # (bool, default=false)
-delayCalcEffort <effort_level>        # Delay calculation effort level { low |
                                       # medium | high } used in timing update
                                       # (string, default=high)
-honorDontTouch {true|false}           # Check dont_touch on instances, cells
                                       # and nets (bool, default=true)
-honorDontUse {true|false}             # Skip library cells marked dont_use
                                       # (bool, default=true)
-honorFixedNetWire {true|false}        # Honor fixed wires of nets
                                       # (bool, default=true)
-honorFixedStatus {true|false}         # Honor fixed (placement) instances
                                       # (bool, default=true)
-honorPowerIntent {true|false}         # Perform MSV checks during ECO: Do not
                                       # allow resize of regular cell with
                                       # always-on cell (and vice-versa), do
                                       # not change cells belonging to
                                       # different power domains, do not allow
                                       # adding buffer to a power domain it
                                       # doesn't belong to, do not buffer a
                                       # cross power domain net, do not allow
                                       # deletion of an always-on buffer, a
                                       # level-shifter, or a buffer which will
                                       # cause redundant isolation cell.
                                       # (bool, default=true)
-inheritNetAttr {true|false}           # New net inherits attributes of
                                       # buffered net (bool, default=true)
-LEQCheck {true|false}                 # Do logical-equivalence checking
                                       # (bool, default=true)
-modifyOnlyLayers <bottom-layer>:<top-layer>
                                       # Modify routes only on metal layers in
                                       # this range (both inclusive)
                                       # (string, default="")
-prefixName <prefix>                   # Prefix name to be used by ECO commands
                                       # (string, default=ECO)
-preserveModuleFunction {true|false}   # Determines whether to preserve logical
                                       # functions at hierarchical module
                                       # ports. It only works for manual ECO
                                       # commands. (bool, default=false)
-refinePlace {true|false}              # Refine placement after ECO
                                       # (bool, default=true)
-spreadInverter {true|false}           # Spread inverters on buffered net
                                       # (bool, default=true)
-updateTiming {true|false}             # Update timing results after ECO
                                       # (bool, default=true)