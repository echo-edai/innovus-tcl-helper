Usage: ecoAddRepeater [-help] { -net <netName> | -term {list of pins} } [ -hinstGuide <hinstName> | -spreadDist <distance> | -spreadCount <number> ] [ -name <instName> | -spreadDist <distance> | -spreadCount <number> ] [ -spreadDist <distance> | -spreadCount <number> ] [ -newNetName <netName> | -spreadDist <distance> | -spreadCount <number> ] [ -loc {xLoc yLoc} | { xLoc yLoc inv_xLoc inv_yLoc} | -offLoadAtLoc {xLoc yLoc} | { xLoc yLoc inv_xLoc inv_yLoc} | -offLoadSlack <slack> | -spreadDist <distance> | -spreadCount <number> ] [ -radius <radius> | -logicalChangeOnly | -spreadDist <distance> | -spreadCount <number> ] [ -offLoadAtLoc {xLoc yLoc} | { xLoc yLoc inv_xLoc inv_yLoc} | -offLoadSlack <slack> | -spreadDist <distance> | -spreadCount <number> ] [ {[-loc {xLoc yLoc} | { xLoc yLoc inv_xLoc inv_yLoc}] [-relativeDistToSink <sinkWeight>] [-offLoadAtLoc {xLoc yLoc} | { xLoc yLoc inv_xLoc inv_yLoc}]} [ -radius <radius> ] ] [-loc {xLoc yLoc} | { xLoc yLoc inv_xLoc inv_yLoc} [-bufOrient {R0 | R90 | R180 | R270 | MX | MX90 | MY | MY90}]] [-net <netName> [-spreadDist <distance>]] [{-spreadDist <distance> | -spreadCount <number>} [-spreadPrefix <prefix>]] [-spreadDist <distance> [-firstSpreadDist <distance>]] [-cell {list of cells} ] [ -relativeDistToSink <sinkWeight> | -offLoadAtLoc {xLoc yLoc} | { xLoc yLoc inv_xLoc inv_yLoc} | -offLoadSlack <slack> | -spreadDist <distance> | -spreadCount <number> ] [ -loc {xLoc yLoc} | { xLoc yLoc inv_xLoc inv_yLoc} | -noPlace ]

-help                              # Prints out the command usage
-bufOrient {R0 | R90 | R180 | R270 | MX | MX90 | MY | MY90}
                                   # Specifies the legalized orientation for
                                   # the instance (string, optional)
-cell {list of cells}              # Specifies the name of the cell(s) which
                                   # is/are to be inserted as repeater(s).
                                   # (string, optional)
-firstSpreadDist <distance>        # Specifies the distance (from driver) after
                                   # which the first repeater is to be added
                                   # (float, optional, min=2.2250738585072e-308, max=1073741.823)
-hinstGuide <hinstName>            # Specifies the hierarchy in which inst was
                                   # inserted by ETS/3rd party tool
                                   # (string, optional)
-loc {xLoc yLoc} | { xLoc yLoc inv_xLoc inv_yLoc}
                                   # Specifies the legalized location(s) where
                                   # repeater (inverter-pair) will be placed
                                   # (point_list, optional)
-logicalChangeOnly                 # Specifies that buffer/inverter addition
                                   # should be done in logical-only mode
                                   # (bool, optional)
-name <instName>                   # Specifies the base name for the repeater
                                   # to be inserted (string, optional)
-net <netName>                     # Specifies the name of the net whose sinks
                                   # are to be buffered (string, optional)
-newNetName <netName>              # Specifies the base name for the new net
                                   # created for repeater insertion
                                   # (string, optional)
-noPlace                           # Specifies that the inserted cells should
                                   # not be placed. Only the logical change in
                                   # connectivity will be made. (bool, optional)
-offLoadAtLoc {xLoc yLoc} | { xLoc yLoc inv_xLoc inv_yLoc}
                                   # Specifies the location(s) at which buffer
                                   # (or inverter-pair) should be inserted to
                                   # drive the sinks downstream from the
                                   # location(s) (point_list, optional)
-offLoadSlack <slack>              # specifes the slack (in ns) threshold so
                                   # that repeaters will be inserted on paths
                                   # with slack less than threshold
                                   # (float, optional)
-radius <radius>                   # Specifies the radius (in um) in which the
                                   # added instances are free to move
                                   # (float, optional)
-relativeDistToSink <sinkWeight>   # Specifies the distance value for repeater
                                   # relative to sink pin
                                   # (float, optional, min=0, max=1)
-spreadCount <number>              # Specifies the number of repeaters to be
                                   # added for buffering
                                   # (int, optional, min=1, max=INT_MAX)
-spreadDist <distance>             # Specifies the distance after which
                                   # repeaters are to be added
                                   # (float, optional, min=2.2250738585072e-308, max=1073741.823)
-spreadPrefix <prefix>             # Specifies the prefix used for new
                                   # instances and nets added during spread
                                   # buffering (string, optional)
-term {list of pins}               # Specifies the sink terms to be buffered
                                   # (string, optional)