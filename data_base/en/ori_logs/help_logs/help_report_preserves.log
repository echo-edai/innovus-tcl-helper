Usage: report_preserves [-help] [-computed]
                        [-obj_type {design hinst module inst net hnet pin hpin base_cell}] [-dont_touch  | -dont_use ]

-help           # Prints out the command usage
-computed       # Include Include computed attributes that include inheritance
                # .dont_touch_effective, .dont_touch_sources,
                # .read_only_effective, and .dont_use_cells_effective
                # attributes in the report, unless filtered by -dont_touch or
                # -don't_use. This will cause all objects that inherit a
                # non-default value from a parent or the library to appear in
                # the report. (bool, optional)
-dont_touch     # Only report non-default attributes related to dont_touch:
                # .dont_touch*, .read_only*, is_ilm. (bool, optional)
-dont_use       # Only report non-default attributes related to dont_use:
                # .dont_use_cells*, .use_cells* (bool, optional)
-obj_type {design hinst module inst net hnet pin hpin base_cell}
                # Only report on specific object types. (enum, optional)