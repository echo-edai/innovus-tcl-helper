Usage: set_voltage_regulator_module [-help] {-reset  | {-name <string> -netlist <string> -input_pwr_pin_mapping <string> -output_pwr_pin_mapping <string> -ground_pin_mapping <string> -component_list <string> [-subckt_name <string>]}}

-help                               # Prints out the command usage
-component_list <string>            # vrm_component_list (string, optional)
-ground_pin_mapping <string>        # {spice_pin_name [DEF_net_name]}+
                                    # (string, optional)
-input_pwr_pin_mapping <string>     # {spice_pin_name [DEF_net_name]}+
                                    # (string, optional)
-name <string>                      # <vrm_name> (string, optional)
-netlist <string>                   # <vrm_spice_netlist_file_name>
                                    # (string, optional)
-output_pwr_pin_mapping <string>    # {spice_pin_name [DEF_net_name]}+
                                    # (string, optional)
-reset                              # reset all vrm options (bool, optional)
-subckt_name <string>               # vrm_subckt_name (string, optional)