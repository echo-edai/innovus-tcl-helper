Usage: set_package [-help] [-mapping_type <string>] {-reset  | [[-spice <string> [-mapping <string>] [-subckt <string>]] [-offset {x y}] [-rotate <float>] [-flip {true false}] [-scale <float>] ]} [-die_instance_name <string>]

-help                           # Prints out the command usage
-die_instance_name <string>     # <die instance name> (string, optional)
-flip {true false}              # <flip: true | false> (enum, optional)
-mapping <string>               # <Mapping file> (string, optional)
-mapping_type <string>          # <Mapping type: distributed | lumped>
                                # (string, optional)
-offset {x y}                   # <x y in microns> (point, optional)
-reset                          # <reset all previous set_package commands>
                                # (bool, optional)
-rotate <float>                 # <rotation angle in degrees> (float, optional)
-scale <float>                  # <scaling factor number> (float, optional)
-spice <string>                 # <Spice package model> (string, optional)
-subckt <string>                # <top level sub-circuit name>
                                # (string, optional)