-help                                     # Prints out the command usage
-reset                                    # Resets all or specified options to default value
-route_adjust_auto_via_weight {true|false}
                                          # adjust auto via weight for via
                                          # swapping (bool, default=true)
-route_allow_inst_overlaps {true|false}   # don't do instance overlap check
                                          # (bool, default=true)
-route_ignore_follow_pin_shapes {true|false}
                                          # Ignore follow pin via shapes (bool, default=false)
-route_process_node <value>               # Specify the process node
                                          # (string, default="")
-route_rc_extraction_corner <value>       # specific which RC extraction corner
                                          # to use in routing (string, default="")
-route_skip_analog {true|false}           # skip routing nets or pins marked +
                                          # USE ANALOG in the DEF file
                                          # (bool, default=false)
-route_via_weight <value>                 # set weight for vias
                                          # (string, default="")
-route_detail_add_passive_fill_only_on_layers <value>
                                          # specify layers where passive fill
                                          # will be added (string, default="")
-route_detail_allow_passive_fill_only_in_layers <value>
                                          # specify layers where do passive
                                          # fill only (string, default=false)
-route_detail_antenna_eco_list_file <value>
                                          # set file name for antenna eco list (string, default="")
-route_detail_auto_stop <value>           # control whether Nanoroute continues
                                          # routing if there are many
                                          # violations (string, default=true)
-route_detail_check_mar_on_cell_pin {true|false}
                                          # Enable mar checking on used cell
                                          # pins (bool, default=false)
-route_detail_end_iteration <value>       # specify the last iteration pass in
                                          # a detailed routing step
                                          # (string, default=auto)
-route_detail_fix_antenna <value>         # fix antenna violation by jumping
                                          # metal layers (ternary, default=auto)
-route_detail_fix_antenna_on_secondary_pg_nets {true|false}
                                          # fix antenna violation on sencondary
                                          # pg nets (bool, default=false)
-route_detail_fix_antenna_with_gate_array_filler_mode {true|false}
                                          # detect GA filler flow while doing
                                          # antenna violation fixing
                                          # (bool, default=false)
-route_detail_merge_abutting_cut {true|false}
                                          # merge two abutting cell cut shapes
                                          # into a new one (bool, default=true)
-route_detail_min_length_for_spread_wire <value>
                                          # specify the min. length of a
                                          # spreaded wire (string, default=0)
-route_detail_min_length_for_widen_wire <value>
                                          # specify the min. length of a
                                          # widened wire (float, default=1)
-route_detail_min_slack_for_opt_wire <value>
                                          # specify the min slack for a net
                                          # wire optimization (float, default=0)
-route_detail_no_taper_in_layers <value>
                                          # Specifies the range of the layer
                                          # where taper is not allowed
                                          # (string, default="")
-route_detail_no_taper_on_output_pin <value>
                                          # forbid wire tapering at output pin (ternary, default=false)
-route_detail_on_grid_only <value>        # route on grid only
                                          # (string, default=none)
-route_detail_post_route_litho_repair {true|false}
                                          # litho hotspot repair in post route
                                          # stage (bool, default=false)
-route_detail_post_route_spread_wire <value>
                                          # spread wire in post route stage (string, default=auto)
-route_detail_post_route_swap_via <value>
                                          # to enforce post route via swapping
                                          # mode in detail route command.
                                          # (string, default=false)
-route_detail_postroute_via_priority <value>
                                          # Set net priority for via swapping
                                          # based on timing (string, default=auto)
-route_detail_post_route_via_pillar_effort <value>
                                          # Set opt effort/range for
                                          # opportunistic via pillar
                                          # (string, default=high)
-route_detail_post_route_wire_widen <value>
                                          # widen wire in post route stage (string, default=none)
-route_detail_post_route_wire_widen_rule <value>
                                          # specify the rule used to widen wire (string, default="")
-route_detail_search_and_repair {true|false}
                                          # run search-and-repair step after
                                          # the initial detailed routing
                                          # (bool, default=true)
-route_detail_signoff_effort <value>      # specify when to give up on
                                          # irresolvable violations
                                          # (string, default=high)
-route_detail_stub_routing_in_first_layer <value>
                                          # to use Minimum routing in the first
                                          # routing layer defined in the LEF
                                          # (string, default=false)
-route_detail_use_multi_cut_via_effort <value>
                                          # specify the effort to use multi-cut
                                          # via during routing
                                          # (string, default=low)
-route_number_fail_limit <value>          # set limit for number of fails
                                          # (int, default=0)
-route_number_thread <value>              # set the number of processors to be
                                          # used in one workstation for
                                          # multi-threading (int, default=1)
-route_number_warning_limit <value>       # set limit for number of warnings
                                          # (int, default=0)
-route_third_party_data {true|false}      # Allow third party data as input
                                          # (bool, default=false)
-extract_keep_fill_wires {true|false}     # Keep metal fill wires for
                                          # extraction (bool, default=false)
-route_high_freq_constraint_groups <value>
                                          # only route specified constraint
                                          # groups, legal values are {net match
                                          # bus pair shield}, add "order" in
                                          # front to control route order
                                          # (string, default="")
-route_high_freq_match_report_file <value>
                                          # specify match report file name (string, default="")
-route_high_freq_num_reserved_layers <value>
                                          # number of layers reserved for
                                          # standard cell pin access
                                          # (int, default=1)
-route_high_freq_remove_floating_shield {true|false}
                                          # remove floating shield segments for
                                          # high frequency nets
                                          # (bool, default=false)
-route_high_freq_search_repair <value>    # run search and repair to remove
                                          # violations, legal value is one of
                                          # {auto false true only}
                                          # (string, default=auto)
-route_high_freq_shield_trim_length <value>
                                          # specify minimum length of shielding
                                          # wire to be kept (float, default=0)
-route_interposer_allow_diagonal_trunk <value>
                                          # allow_diagonal_trunk (string, default="")
-route_interposer_control_options <value>
                                          # control options (string, default="")
-route_interposer_interlayer_shielding_layers <value>
                                          # interlayer shielding layers (string, default="")
-route_interposer_interlayer_shielding_nets <value>
                                          # interlayer shielding nets (string, default="")
-route_interposer_interlayer_shielding_offsets <value>
                                          # interlayer shielding offsets (string, default="")
-route_interposer_interlayer_shielding_widths <value>
                                          # interlayer shielding widths (string, default="")
-route_interposer_same_layer_shielding_net <value>
                                          # same_layer_shielding_net (string, default="")
-route_interposer_same_layer_shielding_width_spacing <value>
                                          # same_layer_shielding_width_spacing (string, default="")
-route_interposer_trunk_routing_layers <value>
                                          # trunk_routing_layers (string, default="")
-route_interposer_trunk_routing_width_spacing <value>
                                          # trunk_routing_width_spacing (string, default="")
-route_add_antenna_inst_prefix <value>    # prefix for the diode insts added to
                                          # fix antenna (string, default="")
-route_allow_pin_as_feedthru <value>      # allow pin as feedthrough
                                          # (string, default=true)
-route_antenna_cell_name <value>          # specify the antenna diode cell
                                          # names for antenna fixing
                                          # (string, default="")
-route_concurrent_minimize_via_count_effort <value>
                                          # specify the effort of concurrent
                                          # via minimization
                                          # (string, default=medium)
-route_connect_to_bumps {true|false}      # connect to bumps in native
                                          # NanoRoute in Innovus
                                          # (bool, default=false)
-route_fix_clock_nets {true|false}        # set clock nets routing status to
                                          # fixed or routed (bool, default=false)
-route_route_clock_nets_first {true|false}
                                          # route clock nets first (bool, default=true)
-route_disable_route_rule_on_via_pillar_to_special_net_wire <value>
                                          # Disable non-default rules on via
                                          # pillar to special net wire
                                          # (string, default=false)
-route_eco_ignore_existing_route <value>
                                          # Ignore existing route in eco, mode:
                                          # {all | signal} (string, default="")
-route_enable_route_rule_si_limit_length <value>
                                          # use MAR wire length as NDR PRL
                                          # requirement for metal spacing check
                                          # (string, default=false)
-route_enforce_route_rule_on_special_net_wire <value>
                                          # enforce ndr rule on all special
                                          # wire segments of specified nets
                                          # (string, default=false)
-route_extra_via_enclosure <value>        # specify an extra via enclosure to
                                          # use when connecting to block pins
                                          # and special net wires
                                          # (float, default=0)
-route_honor_exclusive_region {true|false}
                                          # honor exclusive region routing (bool, default=true)
-route_honor_power_domain {true|false}    # honor power domain routing
                                          # (bool, default=false)
-route_ignore_antenna_top_cell_pin {true|false}
                                          # ignore antenna check on block I/O
                                          # pins (bool, default=true)
-route_antenna_diode_insertion {true|false}
                                          # insert antenna diode to fix antenna
                                          # violation (bool, default=false)
-route_diode_insertion_for_clock_nets {true|false}
                                          # allow diode insertion on clock nets (bool, default=false)
-route_shield_tap_cell_insertion {true|false}
                                          # insert tap cell for shielding (bool, default=false)
-route_relaxed_route_rule_spacing_to_power_ground_nets <value>
                                          # relax the spacing requirement from
                                          # NDR spacing for the layers
                                          # (string, default=none)
-route_reserve_space_for_multi_cut {true|false}
                                          # Reserves space to insert multicut
                                          # vias in postroute stage. This
                                          # option has to be set before
                                          # routing. After routing with this
                                          # parameter specified, you can add
                                          # double-cut vias or larger overhang
                                          # vias by using the "routeDesign
                                          # -viaOpt" command. For examples, see
                                          # routeDesign. (bool, default=false)
-route_reverse_direction <value>          # reverse routing direction in area:
                                          # (lx ly ux uy [bot_lyr : top_lyr])
                                          # ... , top_lyr and bot_lyr could be
                                          # either layer name or layer routing
                                          # id (string, default="")
-route_selected_net_only {true|false}     # route selected net only
                                          # (bool, default=false)
-route_shield_crosstie_offset <value>     # Specifies the offset in terms of
                                          # number of tracks for adding
                                          # crossties. The default is 0 for all
                                          # layers. The syntax is
                                          # 'layer_name:numTrack1
                                          # layer_name2:numTrack2... '.
                                          # (string, default="")
-route_shield_length_threshold <value>    # min route segment length below
                                          # which there is no shielding needed
                                          # (float, default=-1)
-route_shield_report_skip_status {true|false}
                                          # generate report file on if a net is
                                          # skipped for shielding
                                          # (bool, default=false)
-route_shield_stripe_layer_range <value>
                                          # specify the target layer range of
                                          # stripes for tie net connection
                                          # (string, default="")
-route_shield_tap_cell_name <value>       # specify the tap cell names for
                                          # shielding (string, default="")
-route_strictly_honor_1d_routing <value>
                                          # Strictly honor 1d routing (string, default=false)
-route_strict_honor_route_rule <value>    # Strictly enforce non-default rules
                                          # (string, default=false)
-route_stripe_layer_range <value>         # specify the target layer range of
                                          # stripes for tie net connection
                                          # (string, default="")
-route_tieoff_to_shapes <value>           # specify the target special wire
                                          # shapes or target instance pin for
                                          # tie net connection: [auto stripe
                                          # ring powergroundpin]
                                          # (string, default=auto)
-route_trim_pull_back_distance_from_boundary <value>
                                          # route_trim_pull_back_distance_from_boundary
                                          # {<layer>:<value> ...}
                                          # (string, default="")
-route_trunk_with_cluster_target_size <value>
                                          # global control of trunk routing
                                          # pattern for nets with TRUNK pattern
                                          # attribute. 0: nets with TRUNK
                                          # pattern will be routed as Steiner
                                          # tree; 1: default, nets will be
                                          # routed as traditional trunk
                                          # pattern, i.e., each pin directly
                                          # connects to SNET trunk separately;
                                          # >1: define a proximate max cluster
                                          # size (in number of pins), and nets
                                          # will be routed as fishbone style,
                                          # i.e., several pins in a column are
                                          # clustered together, and then
                                          # connects to SNET trunk.
                                          # (int, default=1)
-route_use_auto_via <value>               # allow to use internal generated
                                          # vias (string, default=auto)
-route_with_eco {true|false}              # enable eco routing
                                          # (bool, default=false)
-route_with_litho_driven {true|false}     # enable the litho-driven routing
                                          # (bool, default=false)
-route_with_si_driven {true|false}        # enable si driven routing
                                          # (bool, default=false)
-route_with_timing_driven {true|false}    # enable timing driven routing
                                          # (bool, default=false)
-route_with_trim_metal <value>            # set cut metal dgrid for short pin
                                          # extension generated
                                          # (string, default="")
-route_with_via_in_pin <value>            # enclose via in pin shape
                                          # (string, default=false)
-route_with_via_only_for_block_cell_pin <value>
                                          # enclose via in pin shape for macro
                                          # cell pins (string, default=false)
-route_with_via_only_for_stdcell_pin <value>
                                          # disable planar access to standard
                                          # cell pins (string, default=false)