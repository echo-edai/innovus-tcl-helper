Usage: analyze_resistance [-help] [-cell <string>] [-die_mode {3dic}]
                          [-domain <string>] [-domain_threshold <float>]
                          [-exclude_list_file <string>]
                          [-force_reextraction {true false}]
                          [-instance_list {string1 string2 ...}]
                          [-instance_list_file <string>]
                          [-instance_pair_list {string1 string2 ...}]
                          [-instance_pair_list_file <string>] [-net <string>]
                          [-net_threshold {string1 string2 ...}]
                          [-node_list {string1 string2 ...}]
                          [-node_list_file <string>]
                          [-node_pair_list {string1 string2 ...}]
                          [-node_pair_list_file <string>] [-output <string>]
                          [-output_dir <string>] [-print_cell_name]
                          [-region <string>] [-report_limit <integer>]
                          [-threshold <float>]

-help                                     # Prints out the command usage
-cell <string>                            # master cell name or name list
                                          # (string, optional)
-die_mode {3dic}                          # <die model> (enum, optional)
-domain <string>                          # domain name (string, optional)
-domain_threshold <float>                 # domain threshold (float, optional)
-exclude_list_file <string>               # exclude cell/instance file
                                          # (string, optional)
-force_reextraction {true false}          # force reextraction (enum, optional)
-instance_list {string1 string2 ...}      # instance list {{INST1 [PIN1]}
                                          # {INST2 [PIN2]}+} (list, optional)
-instance_list_file <string>              # instance list file
                                          # (string, optional)
-instance_pair_list {string1 string2 ...}
                                          # instance pair list {{INST1 INST2
                                          # [PIN1 PIN2]}+} (list, optional)
-instance_pair_list_file <string>         # instance pair list file
                                          # (string, optional)
-net <string>                             # net name (string, optional)
-net_threshold {string1 string2 ...}      # net threshold {{netname
                                          # threshold}+} (list, optional)
-node_list {string1 string2 ...}          # node list {{x y layer [label]}+}
                                          # (list, optional)
-node_list_file <string>                  # node list file (string, optional)
-node_pair_list {string1 string2 ...}     # node pair list {{x1 y1 layer1 x2 y2
                                          # layer2 [label]}+} (list, optional)
-node_pair_list_file <string>             # node list file (string, optional)
-output <string>                          # output file (string, optional)
-output_dir <string>                      # output directory (string, optional)
-print_cell_name                          # print cell names in the effective
                                          # resistance report (bool, optional)
-region <string>                          # analysis region {x1 y1 x2 y2 layer
                                          # [num_nodes] [region_name]}
                                          # (string, optional)
-report_limit <integer>                   # limit number on how many effective
                                          # resistance to report (int, optional)
-threshold <float>                        # threshold (float, optional)