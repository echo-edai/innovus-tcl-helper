Usage: report_annotated_delay [-help] [<pin_port_list>]
                              [-ignore_tied_low_high_net_arcs] [-list_annotated]
                              [-list_non_annotated] [-max_line <number>]
                              [-tcl_list] [-view <viewName>]
                              [> <file_name[.gz]>] [>> <file_name[.gz]>]

-help                              # Prints out the command usage
<pin_port_list>                    # Specifies the pin/port list for which
                                   # annotated delay is to be reported
                                   # (string, optional)
-ignore_tied_low_high_net_arcs     # Ignores timing arcs of power and ground
                                   # nets (bool, optional)
-list_annotated                    # Specifies the annotated arcs are to be
                                   # reported (bool, optional)
-list_non_annotated                # Specifies the non annotated arcs are to be
                                   # reported (bool, optional)
-max_line <number>                 # Upper bound for the number of lines to be
                                   # reported for each type of delay arcs.
                                   # (int, optional)
-tcl_list                          # Specifies the output to be in tcl list
                                   # format (bool, optional)
-view <viewName>                   # View for which slack is to be reported.
                                   # Default is worst of all views
                                   # (string, optional)
> <file_name[.gz]>                 # Redirect output to file
                                   # (redirect_operator, optional)
>> <file_name[.gz]>                # Redirect output to file
                                   # (redirect_operator, optional)