Usage: set_pg_nets [-help] [-die_instance_name <string>] [-force]
                   [-pkg_net_name <string>] [-vu_limit <float>] -reset  | {-net <string> -voltage <float> [-lib_binding_voltage <float>] [-threshold <float>] [-tolerance <float>] }

-help                                   # Prints out the command usage
-die_instance_name <string>             # <die instance name>
                                        # (string, optional)
-force                                  # <skip validity checking>
                                        # (bool, optional)
-lib_binding_voltage <float>            # <voltage for lib binding>
                                        # (float, optional)
-net <string>                           # <net name> (string, required)
-pkg_net_name <string>                  # <specify net name on the package
                                        # side> (string, optional)
-reset                                  # <reset all pg data> (bool, optional)
-threshold <float>                      # <net threshold> (float, optional)
-tolerance <float>                      # <net tolerance> (float, optional)
-voltage <float>                        # <net voltage> (float, required)
-vu_limit <float>                       # <vu limit> (float, optional)