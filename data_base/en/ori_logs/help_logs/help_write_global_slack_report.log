Usage: write_global_slack_report [-help] [<pin_port_list>] [-early] [-fall]
                                 [-include_ports] [-late] [-max_slack <val>]
                                 [-min_slack <val>] [-rise] [-view <view_name>]
                                 [> <file_name[.gz]>] [>> <file_name[.gz]>]

-help                                    # Prints out the command usage
<pin_port_list>                          # Specifies the pin/port list
                                         # (string, optional)
-early                                   # Specifies the mode for which slack
                                         # is to be reported. (bool, optional)
-fall                                    # Specifies the transition for which
                                         # slack is to be reported.
                                         # (bool, optional)
-include_ports                           # Report the slack for ports.
                                         # (bool, optional)
-late                                    # Specifies the mode for which slack
                                         # is to be reported. (bool, optional)
-max_slack <val>                         # Upper bound for the slack to be
                                         # reported. (float, optional)
-min_slack <val>                         # lower bound for the slack to be
                                         # reported. (float, optional)
-rise                                    # Specifies the transition for which
                                         # slack is to be reported.
                                         # (bool, optional)
-view <view_name>                        # View for which slack is to be
                                         # reported. Default is worst of all
                                         # views (string, optional)
> <file_name[.gz]>                       # Redirect output to file
                                         # (redirect_operator, optional)
>> <file_name[.gz]>                      # Redirect output to file
                                         # (redirect_operator, optional)