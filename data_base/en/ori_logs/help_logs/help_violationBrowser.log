Usage: violationBrowser [-help] [-aclimit] [-all] [-append]
                        [-area {x1 y1 x2 y2}] [-connectivity] [-density]
                        [-displayByLayer] [-geometry]
                        [-max_error_per_type <integer>] [-no_display_false]
                        [-overlap] [-process_antenna] [-search_desc] [-short] [-filter_query <LO formula> | {-filter <filterString> -filter_mode {AND|OR|NOT}}]

-help                             # Prints out the command usage
-aclimit                          # Displays AC limit violations.
                                  # (bool, optional)
-all                              # Displays all the violations that are
                                  # present in the design. (bool, optional)
-append                           # Search new markers but not clear existing
                                  # markers in violation browser (bool, optional)
-area {x1 y1 x2 y2}               # Specifies the coordinates of the area whose
                                  # violations to display. (string, optional)
-connectivity                     # Displays connectivity violations.
                                  # (bool, optional)
-density                          # Displays metal density violations.
                                  # (bool, optional)
-displayByLayer                   # Display By Layer not Route Type.
                                  # (bool, optional)
-filter <filterString>            # Specifies a text string in the violation
                                  # message. Violation Browser searches the
                                  # message of each violation and displays only
                                  # the violations whose messages match the
                                  # search conditions. (string, optional)
-filter_mode {AND|OR|NOT}         # Specifies the condition for searching
                                  # multiple strings in the violation browser.
                                  # You cannot filter complex expressions
                                  # because the AND, OR, and NOT parameters are
                                  # mutually exclusive. (string, optional)
-filter_query <LO formula>        # Specify a complex LO format to filter out
                                  # the error markers. The option is excluded
                                  # with -filter and -filter_mode.
                                  # (string, optional)
-geometry                         # Displays geometry violations.
                                  # (bool, optional)
-max_error_per_type <integer>     # Specify the error marker number limit for
                                  # each type. (int, optional)
-no_display_false                 # Prevents the EDI System software from
                                  # displaying false violations. (bool, optional)
-overlap                          # Displays overlaps in the design.
                                  # (bool, optional)
-process_antenna                  # Displays process antenna violations.
                                  # (bool, optional)
-search_desc                      # Searches for text in the violation message
                                  # and the violation description.
                                  # (bool, optional)
-short                            # Displays short violations. (bool, optional)