Usage: write_lef_abstract [-help] <out_file> [-add_obs_layers <layer_list>]
                          [-cutObsMinSpacing] [-excludeObsLayers <layer_list>]
                          [-excludePinLayers <layer_list>] [-extractBlockObs]
                          [-extractBlockPGPinLayers <layer_list>]
                          [-extractBlockSignalPinLayers <layer_list>]
                          [-ignoreBumpOnPin {all pg signal}] [-ioPadPin]
                          [-noCutObs] [-property] [-stripePin [-selected ]] [-stripePin [-portForEachStripePin ]] [-stripePin [-PGPinLayers <layer_list>]] [-stripePin [-PGNets <net>+]] [-specifyTopLayer <layer> [-obs_above_top_layer <layer>+]] [-specifyTopLayer <layer> ] [-obs_above_top_layer <layer>+ ] [-extractWellLayerObs <well_layer_list> [-extractWellObsByRow <margin>]] [-extractWellLayerObs <well_layer_list> [-mergeConnectedWellOnly ]] [-obsSpacing <value_layer_pair_list> [-obsSpacingPerLayer ]]  [ -5.6 | -5.7 | -5.8 | -6.0 ] [-design_boundary <point_list> | -extractRoutingObs <microns>] [-cutObsToExposeRouting <microns> | -extractRoutingObs <microns>]

-help                                     # Prints out the command usage
<out_file>                                # LEF output file name
                                          # (string, required)
-5.6                                      # write out LEF version 5.6
                                          # (bool, optional)
-5.7                                      # write out LEF version 5.7
                                          # (bool, optional)
-5.8                                      # write out LEF version 5.8
                                          # (bool, optional)
-6.0                                      # write out LEF version 6.0
                                          # (bool, optional)
-PGNets <net>+                            # Write out PG stripes only on these
                                          # pg nets ((net)+, optional)
-PGPinLayers <layer_list>                 # Write out PG stripes on these
                                          # layers ((layer)+, optional)
-add_obs_layers <layer_list>              # Shapes on these layers will be
                                          # written as OBS shapes in the LEF.
                                          # Cannot be routing or cut layers.
                                          # (string, optional)
-cutObsMinSpacing                         # Cut OBS around pin shapes by
                                          # min-spacing (bool, optional)
-cutObsToExposeRouting <microns>          # Cut OBS from the boundary by
                                          # <microns> to expose routing.
                                          # (float, optional)
-design_boundary <point_list>             # Write out SIZE and OBS based on the
                                          # design boundary (string, optional)
-excludeObsLayers <layer_list>            # Do not create OBS shapes on these
                                          # layers ((layer)+, optional)
-excludePinLayers <layer_list>            # Do not create PIN shapes on these
                                          # layers ((layer)+, optional)
-extractBlockObs                          # Extract OBS from BLOCK, RING, PAD
                                          # macro above top layer, and write to
                                          # the LEF file (bool, optional)
-extractBlockPGPinLayers <layer_list>     # Extract PG pins from BLOCK, RING,
                                          # PAD, COVER macros on these layers
                                          # ((layer)+, optional)
-extractBlockSignalPinLayers <layer_list>
                                          # Extract signal pins (connected to
                                          # design term) from BLOCK, RING, PAD,
                                          # COVER macros on these layers
                                          # ((layer)+, optional)
-extractRoutingObs <microns>              # Extract regular routing and the
                                          # shiled wire as OBS from the
                                          # boundary by <microns>
                                          # (float, optional)
-extractWellLayerObs <well_layer_list>    # Extract OBS from instances on
                                          # specified well layers by merging
                                          # all shapes into one bounding box
                                          # ((layer)+, optional)
-extractWellObsByRow <margin>             # Extract OBS from the bounding box
                                          # of rows plus the margin on
                                          # specified well layers
                                          # (float, optional)
-ignoreBumpOnPin {all pg signal}          # Do not dump bump shapes on pins
                                          # (enum, optional)
-ioPadPin                                 # Write out IO pads that are
                                          # connected to design pins as LEF pin
                                          # shapes (bool, optional)
-mergeConnectedWellOnly                   # Merge connected well shapes only,
                                          # instead to merge all shapes into
                                          # one bounding box (bool, optional)
-noCutObs                                 # Do not cut OBS shapes around pins
                                          # (bool, optional)
-obsSpacing <value_layer_pair_list>       # Write out LEF58_OBSSPACING property
                                          # in OBS section (string, optional)
-obsSpacingPerLayer                       # Write out the spacing for each
                                          # layer under layer definition
                                          # (bool, optional)
-obs_above_top_layer <layer>+             # Write out OBS shapes rather than
                                          # one large abstract OBS shape for
                                          # each special wire and via on these
                                          # layers that are not PIN shapes.
                                          # ((layer)+, optional)
-portForEachStripePin                     # A separate LEF port will be created
                                          # for each pin shape created by
                                          # -stripePin (bool, optional)
-property                                 # Write out all user defined design
                                          # properties (bool, optional)
-selected                                 # Write out only selected PG stripes
                                          # as LEF pin shapes (bool, optional)
-specifyTopLayer <layer>                  # Create OBS up to this layer
                                          # ((layer), optional)
-stripePin                                # Write out PG stripes on top metal
                                          # layer as LEF pin shapes
                                          # (bool, optional)