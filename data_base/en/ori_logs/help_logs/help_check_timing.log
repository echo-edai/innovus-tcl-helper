Usage: check_timing [-help] [-check_only <warning_list>]
                    [-clock_crossing_output_format {summary csv}]
                    [-exclude_warning <warning_list>]
                    [-include_warning <warning_list>] [-tcl_list]
                    [-type <type_list>] [-verbose] [-view <view_name>]
                    [> <file_name[.gz]>] [>> <file_name[.gz]>] [ <port_or_pin_list>]

-help                               # Prints out the command usage
<port_or_pin_list>                  # Lists pins or ports (string, optional)
-check_only <warning_list>          # Allows you to specify warning types.
                                    # Valid entries in warning_list are:
                                    # clock_expected, clock_not_propagated, 
                                    # no_gen_clock_source,
                                    # master_clk_edge_not_reaching,
                                    # multiple_clock,
                                    # data_check_multiple_reference_signal,
                                    # data_check_no_reference_signal,
                                    # clock_gating_no_data,
                                    # clock_gating_controlling_edge_unknown,
                                    # clock_missing_at_sequential_output,
                                    # pulse_non-pulse_clock_merge,
                                    # invalid_pll_configuration,
                                    # clocks_masked_by_another_clock,
                                    # uncons_endpoint,
                                    # max_delay_constrained_internal_endpoint,
                                    # no_arr, async_arr, missing_arr,
                                    # specific_async_arr, no_drive, loop,
                                    # ideal_clock_waveform, clock_crossing,
                                    # clock_clipping_gate, clock_clipping_freq,
                                    # const_collision, signal_level
                                    # ,missing_drive,missing_clock_groups and
                                    # unexpandable_clock (string, optional)
-clock_crossing_output_format {summary csv}
                                    # Specifies format of clock crossing report
                                    # to be generated (enum, optional)
-exclude_warning <warning_list>     # Excludes the specified warning types when
                                    # generating the report (string, optional)
-include_warning <warning_list>     # Includes the specified warning types when
                                    # generating the report (string, optional)
-tcl_list                           # Produces the report in Tcl list format
                                    # instead of a tabular format (bool, optional)
-type <type_list>                   # Limits the checks to the specified type
                                    # (string, optional)
-verbose                            # Gives detailed information about the
                                    # warnings (bool, optional)
-view <view_name>                   # Reports warning(s) that belong to the
                                    # specified view (string, optional)
> <file_name[.gz]>                  # Output file name
                                    # (redirect_operator, optional)
>> <file_name[.gz]>                 # Output file name
                                    # (redirect_operator, optional)