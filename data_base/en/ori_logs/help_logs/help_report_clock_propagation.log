Usage: report_clock_propagation [-help] -clock <clock_list>
                                [-max_paths <number of paths>]
                                -to <pin_port_list> [-verbose]
                                [-view <viewName>] [> <filename[.gz]>]
                                [>> <filename[.gz]>]

-help                            # Prints out the command usage
-clock <clock_list>              # List or collection of clocks for which
                                 # reachability is desired. (string, required)
-max_paths <number of paths>     # Specifies to report number of maximum clock
                                 # paths per clock (int, optional)
-to <pin_port_list>              # Specifies the pin/port list
                                 # (string, required)
-verbose                         # Generates a verbose report for clock
                                 # propagation stop reason (bool, optional)
-view <viewName>                 # Generates a report for specified analysis
                                 # view (string, optional)
> <filename[.gz]>                # Redirects output to specified file
                                 # (redirect_operator, optional)
>> <filename[.gz]>               # Redirects output to specified file
                                 # (redirect_operator, optional)