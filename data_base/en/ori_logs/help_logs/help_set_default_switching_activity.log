Usage: set_default_switching_activity [-help] [-black_box_density <string>]
                                      [-black_box_duty <string>]
                                      [-block <string>]
                                      [-clip_activity_to_domain_freq <string>]
                                      [-clock_gates_enable <string>]
                                      [-clock_gates_output <string>]
                                      [-clock_gates_output_ratio <string>]
                                      [-comb_clockgate_ratio <string>]
                                      [-duty <string>]
                                      [-global_activity <string>]
                                      [-hier <string>] [-icg_ratio <string>]
                                      [-input_activity <string>]
                                      [-macro_activity <string>]
                                      [-name <string>] [-period <string>]
                                      [-reset] [-reset_type <string>]
                                      [-seq_activity <string>]

-help                                  # Prints out the command usage
-black_box_density <string>            # set default tdensity on all blackbox's
                                       # output pin (string, optional)
-black_box_duty <string>               # set default duty on all blackbox's
                                       # output pin (string, optional)
-block <string>                        # Specify master cell name for activity
                                       # setting (string, optional)
-clip_activity_to_domain_freq <string> # domain-based activity clipping
                                       # (string, optional)
-clock_gates_enable <string>           # set clock gates enable activity
                                       # (string, optional)
-clock_gates_output <string>           # set clock gates output activity
                                       # (string, optional)
-clock_gates_output_ratio <string>     # set clock gates output ratio
                                       # (string, optional)
-comb_clockgate_ratio <string>         # set propagation ratio for
                                       # combinational clock gate cell outputs
                                       # (string, optional)
-duty <string>                         # Specifies the duty cycle, which is the
                                       # probability that the signal is a
                                       # logical 1. Default : 0.5,
                                       # (string, optional)
-global_activity <string>              # Specifies the average number of times
                                       # that all unset nodes switch in a clock
                                       # cycle. (string, optional)
-hier <string>                         # set hierarchy name (string, optional)
-icg_ratio <string>                    # set propagation ratio for integrated
                                       # clock gate cell outputs
                                       # (string, optional)
-input_activity <string>               # Specifies the average number of times
                                       # that a primary input switches in a
                                       # clock cycle. (string, optional)
-macro_activity <string>               # set macro activity (string, optional)
-name <string>                         # set jitter activity name
                                       # (string, optional)
-period <string>                       # Specifies the default operating period
                                       # (1/frequency). (string, optional)
-reset                                 # reset all options (bool, optional)
-reset_type <string>                   # reset the following type
                                       # (string, optional)
-seq_activity <string>                 # Specifies the activity of outputs of
                                       # sequential logic. (string, optional)