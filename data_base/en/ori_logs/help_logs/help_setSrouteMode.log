Usage: setSrouteMode [-help] [-reset] [-allowWrongWayRoute {true|false}]
                     [-avoidOverCoreRowLayer <layerName>]
                     [-blockPinConnectRingPinCorners {true|false}]
                     [-blockPinRouteWithPinWidth {true|false}]
                     [-connectBrokenCorePin {true|false}]
                     [-corePinIgnoreObs {none|placement_blockage|overlap_obs|block_halo}]
                     [-corePinJoinLimit <value>] [-corePinLength <value>]
                     [-corePinLengthAsInstance {true|false}]
                     [-corePinMaxViaScale <widthPct heightPct>]
                     [-corePinReferenceMacro <macro>]
                     [-corePinReferToFollowPin {true|false}]
                     [-corePinSiteRailWidth {site name layer and width}]
                     [-corePinSnapTo {M1_pin|opt_routing_track|grid|half_grid}]
                     [-corePinStopRoute {RowEnd|CellPinEnd}]
                     [-extendNearestTarget {true|false}]
                     [-jogThresholdRatio <value>]
                     [-layerNormalCost {layer1 cost1 layer2 cost2 ...}]
                     [-layerWrongWayCost {layer1 cost1 layer2 cost2 ...}]
                     [-padPinMinViaSize <percentage>]
                     [-padPinSplit <width spacing>]
                     [-padRingLefConvention {true|false}]
                     [-secondaryPinMaxGap <value>]
                     [-secondaryPinRailWidth <value>]
                     [-signalPinAsPG {true|false}]
                     [-splitLongVia {threshold step offset height}]
                     [-srpgAonCellPin {cellName:pinName}]
                     [-targetNumber <value>] [-targetSearchDistance <dist>]
                     [-timeLimit <value>] [-treatEndcapAsCore {true|false}]
                     [-treatWelltapAsEndcap <list of cells>]
                     [-viaConnectToShape {padring|ring|stripe|blockring|blockpin|coverpin|noshape|blockwire|corewire|followpin|iowire}]
                     [-viaThruToClosestRing {true|false}]

-help                                     # Prints out the command usage
-reset                                    # Resets all or specified options to default value
-allowWrongWayRoute {true|false}          # allow wrong way route
                                          # (bool, default=false)
-avoidOverCoreRowLayer <layerName>        # specify number of layers to avoid
                                          # routing over core row area
                                          # (string, default=max layer of standard cell pin)
-blockPinConnectRingPinCorners {true|false}
                                          # Extend the ring pins at the corners (bool, default=false)
-blockPinRouteWithPinWidth {true|false}   # Connect using pin width only
                                          # (bool, default=false)
-connectBrokenCorePin {true|false}        # Break followpin for standard cell
                                          # pin or obs (bool, default=false)
-corePinIgnoreObs {none|placement_blockage|overlap_obs|block_halo}
                                          # ignore specified blockage when
                                          # connecting follow pin
                                          # (enums={none placement_blockage overlap_obs block_halo}_list, default=none)
-corePinJoinLimit <value>                 # gaps smaller than this variable
                                          # cause followpin rails to be joined
                                          # (float, default=0, min=0, max=10000000000)
-corePinLength <value>                    # connect core pins of at least
                                          # specified length
                                          # (float, default=0, min=0, max=10000000000)
-corePinLengthAsInstance {true|false}     # connect core pins if their lengths
                                          # are the same as the instances
                                          # (bool, default=false)
-corePinMaxViaScale <widthPct heightPct>
                                          # Maximum via width and height at
                                          # stripe crossover for standcell pins
                                          # (%) (string, default="")
-corePinReferenceMacro <macro>            # use specified macro as reference
                                          # for followpin creation
                                          # (string, default="")
-corePinReferToFollowPin {true|false}     # M2 followpin generation uses follow
                                          # pin wire (bool, default=false)
-corePinSiteRailWidth {site name layer and width}
                                          # follow pin width at layer for
                                          # specified site (string, default="")
-corePinSnapTo {M1_pin|opt_routing_track|grid|half_grid}
                                          # snap M2 followpin referred to M1
                                          # pin to position
                                          # (enums={M1_pin opt_routing_track grid half_grid}_list, default=M1_pin)
-corePinStopRoute {RowEnd|CellPinEnd}     # (enums={RowEnd CellPinEnd}, default=RowEnd)
-extendNearestTarget {true|false}         # extend nearest target so that it
                                          # can be connected (bool, default=false)
-jogThresholdRatio <value>                # distance ratio between a jogging
                                          # target and a straight target
                                          # (float, default=10, min=1, max=100000)
-layerNormalCost {layer1 cost1 layer2 cost2 ...}
                                          # layer cost of preferred direction (string, default="")
-layerWrongWayCost {layer1 cost1 layer2 cost2 ...}
                                          # layer cost of non-preferred
                                          # direction (string, default="")
-padPinMinViaSize <percentage>            # Minimum via width percent between
                                          # pad and ring.
                                          # (float, default=20, min=1, max=100)
-padPinSplit <width spacing>              # Split width and spacing for wide
                                          # pad pins (string, default="")
-padRingLefConvention {true|false}        # Keep user LEF input for pad rings
                                          # (bool, default=true)
-secondaryPinMaxGap <value>               # gaps bigger than this variable
                                          # cause level shifter rail to break
                                          # for them
                                          # (float, default=0, min=0, max=10000000000)
-secondaryPinRailWidth <value>            # width of followpin rail
                                          # (float, default=0, min=0, max=10000000000)
-signalPinAsPG {true|false}               # signal pins as PG pins
                                          # (bool, default=false)
-splitLongVia {threshold step offset height}
                                          # Split vias longer than <threshold>
                                          # into smaller vias with specified
                                          # <step> and bottom/left end <offset>
                                          # and vertical/horizontal <height>
                                          # (string, default=0 0 -1 -1)
-srpgAonCellPin {cellName:pinName}        # List of cell/pin information NOT
                                          # extract from CPF (string, default="")
-targetNumber <value>                     # number of target to connect
                                          # (int, default=0, min=0, max=100000)
-targetSearchDistance <dist>              # target search distance
                                          # (float, default=0)
-timeLimit <value>                        # time limit (in seconds) that the
                                          # router is allowed in routing each
                                          # port
                                          # (float, default=0, min=0.001, max=100)
-treatEndcapAsCore {true|false}           # sroute treat Endcap macro as Core
                                          # macro (bool, default=false)
-treatWelltapAsEndcap <list of cells>     # sroute treat Welltap macro as
                                          # Endcap macro (string, default="")
-viaConnectToShape {padring|ring|stripe|blockring|blockpin|coverpin|noshape|blockwire|corewire|followpin|iowire}
                                          # Make via connection to specified
                                          # shapes
                                          # (enums={padring ring stripe blockring blockpin coverpin noshape blockwire corewire followpin iowire}_list, default=padring ring stripe blockring blockpin coverpin noshape blockwire corewire followpin iowire)
-viaThruToClosestRing {true|false}        # A via should connect only to
                                          # closest ring layer when multiple
                                          # rings overlap (bool, default=false)