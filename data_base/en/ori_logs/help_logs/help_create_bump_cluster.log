Usage: create_bump_cluster [-help] [-area {x1 y1 x2 y2}] [-enclosure {x y}]
                           -layer <name> -pitch {x y} -size {n m} [[-type {signal | power | ground}] | [-nets {net+}]]

-help                           # Prints out the command usage
-area {x1 y1 x2 y2}             # Specify area to group bump cluster. The
                                # default area is the entire floorplan area.
                                # (box, optional)
-enclosure {x y}                # Specify distance from bump-array-edge to
                                # cluster-metal-edge is a in x-direction and b
                                # in y-direction. a and b are unified in all HB
                                # cluster groups. (point, optional)
-layer <name>                   # Specify metal layer of the cluster.
                                # (string, required)
-nets {net+}                    # Specify nets of bump of the cluster. One
                                # cluster should have the same net.
                                # ((net)+, optional)
-pitch {x y}                    # Specify x pitch and y pitch for bumps in the
                                # cluster. (point, required)
-size {n m}                     # Specify n*m size of clusters. There are n*m
                                # bumps in one cluster. (string, required)
-type {signal power ground}     # Specify bump type of the cluster.
                                # (enum, optional)