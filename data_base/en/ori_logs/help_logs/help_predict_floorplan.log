Usage: predict_floorplan [-help] [-allow_illegal_macro] [-enable_cpg] [-reshape [[-post_reshape_tcl <string>]]] [{-reshape | -skip_generate_fence }]

-help                                # Prints out the command usage
-allow_illegal_macro                 # Allow the tool to continue even when
                                     # macros are not legally placed. Default
                                     # value: false (bool, optional)
-enable_cpg                          # Enable CPG for a design which already
                                     # has a floorplan with macro locations.
                                     # (bool, optional)
-post_reshape_tcl <string>           # Allow tool to load user specified
                                     # floorplan objects after reshape
                                     # floorplan. Such as track. It must be
                                     # used with option -reshape at the same
                                     # time. (string, optional)
-reshape                             # Allow tool to enlarge floorplan in order
                                     # to fit all instances. (bool, optional)
-skip_generate_fence                 # Skip the auto-fence generation.
                                     # (bool, optional)