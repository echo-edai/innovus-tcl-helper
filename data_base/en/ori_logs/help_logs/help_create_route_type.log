Usage: create_route_type [-help] [-em_ndr_dist <float>]
                         [-em_ndr_rule <rule_name>] [-min_stack_layer <layer>]
                         -name <string>
                         [-one_side_spacing_range <bottomLayerNum:topLayerNum]
                         [-prefer_multi_cut_via]
                         [-shield_side {one_side both_side}]
                         [-shield_tap_instance_insertion_effort {none standard high}]
                         [-stack_distance <float>] [[[-non_default_rule <ndr_name>] [-shield_net <net_name>] [-bottom_shield_layer <layer>] [-top_preferred_layer <layer>] [-bottom_preferred_layer <layer>] [-preferred_routing_layer_effort {low medium high}]] ] [-mask <mask_number> [-layer_mask_range <bottomLayerNum:topLayerNum>]]

-help                                 # Prints out the command usage
-bottom_preferred_layer <layer>       # bottom preferred layer
                                      # ((layer), optional)
-bottom_shield_layer <layer>          # bottom shield layer ((layer), optional)
-em_ndr_dist <float>                  # EM ndr rule source to sink distance
                                      # (float, optional)
-em_ndr_rule <rule_name>              # EM non default rule name
                                      # (string, optional)
-layer_mask_range <bottomLayerNum:topLayerNum>
                                      # Specify the layer range that the mask
                                      # constrain should be applied on. For
                                      # example, 3:4 means that the constrain
                                      # should be applied on M3 & M4.
                                      # (string, optional)
-mask <mask_number>                   # mask constraint number in allowed range
                                      # (0-3) (int, optional, min=0, max=3)
-min_stack_layer <layer>              # Specify that output pins of the net
                                      # should use stacked vias from the pin to
                                      # the given layer in min_stack_layer, and
                                      # the rest of the connections should
                                      # start from that given layer.
                                      # ((layer), optional)
-name <string>                        # name of route type (string, required)
-non_default_rule <ndr_name>          # non default rule (string, optional)
-one_side_spacing_range <bottomLayerNum:topLayerNum
                                      # Specify the layer range that one side
                                      # spacing constrain should be applied on.
                                      # (string, optional)
-prefer_multi_cut_via                 # Specify whether or not to use multi-cut
                                      # vias for connections at net driver pins
                                      # (bool, optional)
-preferred_routing_layer_effort {low medium high}
                                      # preferred routing layer effort (enum, optional)
-shield_net <net_name>                # shield net (string, optional)
-shield_side {one_side both_side}     # shield side (enum, optional)
-shield_tap_instance_insertion_effort {none standard high}
                                      # Specifies clock route type for clock
                                      # shielding, including high
                                      # frequency(high) and low
                                      # frequency(standard) that main
                                      # difference is what ground tie cell
                                      # instance/via used to achieve shield
                                      # segments electrical connection.
                                      # (enum, optional)
-stack_distance <float>               # Specify that the cut distance of cuts
                                      # on adjacent layers in the stacked vias
                                      # defined in option min_stack_layer
                                      # should be less than or equal to the
                                      # given value. (float, optional)
-top_preferred_layer <layer>          # top preferred layer ((layer), optional)