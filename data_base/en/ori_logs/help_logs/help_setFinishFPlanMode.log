Usage: setFinishFPlanMode [-help] [-reset]
                          [-abuttedEdgeAsNonRowArea {true|false}]
                          [-activeObj {macro|macroHalo|core|iopad|iocell|fence|hardblkg|softblkg|partialblkg|routeblkg|row|die}]
                          [-direction {x|y|xy}]
                          [-drcRegionObj {macro|macroHalo|hardBlkg|minGap|coreSpacing|nonRowArea|row}]
                          [-fillOption {channel|boundary}]
                          [-override {true|false}]

-help                                     # Prints out the command usage
-reset                                    # Resets all or specified options to default value
-abuttedEdgeAsNonRowArea {true|false}     # Specify whether the abutted edge of
                                          # power domain should be nonRowArea
                                          # (bool, default=true)
-activeObj {macro|macroHalo|core|iopad|iocell|fence|hardblkg|softblkg|partialblkg|routeblkg|row|die}
                                          # activeObj list (enums={macro macroHalo core iopad iocell fence hardblkg softblkg partialblkg routeblkg row die}_list, default=macro macroHalo core)
-direction {x|y|xy}                       # direction
                                          # (enums={x y xy}, default=xy)
-drcRegionObj {macro|macroHalo|hardBlkg|minGap|coreSpacing|nonRowArea|row}
                                          # drcRegion object list (enums={macro macroHalo hardBlkg minGap coreSpacing nonRowArea row}_list, default=macro macroHalo hardBlkg minGap coreSpacing row)
-fillOption {channel|boundary}            # fill option
                                          # (enums={channel boundary}_list, default=channel)
-override {true|false}                    # override or not
                                          # (bool, default=false)