Usage: set_message [-help] [-id <list_of_msgIDs>] [-severity {warn error info reset} | -limit <number> | -no_limit  | -suppress  | -unsuppress  | -on_error {msg_only exit stop_script} | -stop_script_limit <number>]

-help                                 # Prints out the command usage
-id <list_of_msgIDs>                  # Specifies the list of msgIDs to be
                                      # processed. (string, optional)
-limit <number>                       # Sets the message limit for the selected
                                      # messages. The limit must be
                                      # non-negative.Limit zero will suppresses
                                      # the message (int, optional)
-no_limit                             # Removes any existing limit on the
                                      # selected messages. (Suppressed messages
                                      # will not be un-suppressed.)
                                      # (bool, optional)
-on_error {msg_only exit stop_script} # Take the extra action for error message
                                      # in -id <id_list>. Without -id option,
                                      # the extra action applies to all error
                                      # messages. Exit = exit immediately;
                                      # stop_script = wait for command to
                                      # finish and return to the Tcl prompt;
                                      # msg_only = just print error message.
                                      # (enum, optional)
-severity {warn error info reset}     # Specifies the new sverity for the
                                      # messages being processed. (enum, optional)
-stop_script_limit <number>           # Sets the message limit per every public
                                      # command. If you set -stop_script_limit
                                      # 10, at the 10th time the message being
                                      # triggered for one command, the tool
                                      # will wait for current Tcl command to
                                      # finish, then stop executing any Tcl
                                      # script, and return to the interactive
                                      # Tcl prompt. The default value is -1,
                                      # which is unlimited. (int, optional)
-suppress                             # Suppresses the message.
                                      # (bool, optional)
-unsuppress                           # Unsuppresses the message.
                                      # (bool, optional)