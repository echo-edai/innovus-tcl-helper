Usage: addIoInstance [-help] [-cell {name list}] -inst {name list}
                     [-orientation <string>] [-spacing <val>] [-spread] {{-refInst <inst_name> [-ccw ]} | {-selected  [-ccw ]} | {-repeat <num> [-skip <num>] [-inSelected  | {[-side <string>] [-ioRing <num>]} | -ioRow <name>]} | -loc {x y}}

-help                 # Prints out the command usage
-ccw                  # where to place new IO instance, default is in
                      # counterclocksise direction of reference instance.
                      # (bool, optional)
-cell {name list}     # cell name list for new IO instances (string, optional)
-inSelected           # to repeatedly insert new IO instances in selected cells
                      # (bool, required)
-inst {name list}     # instance name prefix for new IO, must match the number
                      # of cells (string, required)
-ioRing <num>         # add new IO instance on IO ring 'num' (int, optional)
-ioRow <name>         # row name on which new IO instance is added
                      # (string, optional)
-loc {x y}            # location of new IO instance (point, required)
-orientation <string> # Orientation: R0 R90 R180 R270 MX90 MY90 MX MY
                      # (string, optional)
-refInst <inst_name>  # reference instance for new IO instance
                      # (string, optional)
-repeat <num>         # repeatedly adding IO instances for every 'num' cells
                      # (int, required)
-selected             # selected instances as references where new inst is
                      # added. (bool, required)
-side <string>        # specify which side to add new IO (string, optional)
-skip <num>           # skip 'num' of cell to add first IO inst, effective when
                      # -repeat is specified (int, optional)
-spacing <val>        # distance of new IO instance from referenced inst.
                      # (float, optional)
-spread               # when specified, all IO cells on the row where new IO is
                      # added will be evenly replaced. (bool, optional)