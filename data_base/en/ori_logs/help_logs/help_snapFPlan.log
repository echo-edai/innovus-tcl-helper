Usage: snapFPlan [-help] { {-all } | {-selected } | {[-guide ][-block ][-stdCell ][-ioPad ][-areaIo ][-ptnCore ][-pinGuide ][-routeBlk ][-placeBlk ][-macroPin ][-pin ][-pinBlk ]}}

-help                   # Prints out the command usage
-all                    # all supported objects (bool, required)
-areaIo                 # I/O cells (bool, optional)
-block                  # block cells (bool, optional)
-guide                  # guide constraints (bool, optional)
-ioPad                  # I/O cells (bool, optional)
-macroPin               # snap macro according to relationship between pin
                        # location and DPT tracks. (bool, optional)
-pin                    # I/O pins (bool, optional)
-pinBlk                 # pin blockages (bool, optional)
-pinGuide               # pin guides (bool, optional)
-placeBlk               # placement blockages (bool, optional)
-ptnCore                # Partition (bool, optional)
-routeBlk               # routing blockages (bool, optional)
-selected               # selected objects (bool, required)
-stdCell                # std. cells (bool, optional)