Usage: read_path_descriptions [-help] <filename> [-hpin]
                              [-path_type {end summary full full_clock end_slack_only summary_slack_only}]
                              [-retime {aocv ssta path_slew_propagation aocv_path_slew_propagation waveform_propagation}]

-help                 # Prints out the command usage
<filename>            # Input File (string, required)
-hpin                 # Prints all hierarchical crossings of an arc under hpin
                      # column in report_timing table (bool, optional)
-path_type {end summary full full_clock end_slack_only summary_slack_only}
                      # The path_type option lets you choose the format of the
                      # report by path type (enum, optional)
-retime {aocv ssta path_slew_propagation aocv_path_slew_propagation waveform_propagation}
                      # Reanalyzes the specified set of paths using the
                      # specified method (enum, optional)