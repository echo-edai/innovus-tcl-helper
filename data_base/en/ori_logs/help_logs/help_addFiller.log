Usage: addFiller [-help] [-area <areaBoxList>] [-cell <cellList>]
                 [-check_signal_drc {true|false}] [-diffCellViol {true|false}]
                 [-ecoMode {true|false}] [-fitGap] [-fixDRC]
                 [-fix_horizontal_max_length_violation]
                 [-fix_vertical_max_length_violation]
                 [-honorPrerouteAsObs {true|false}] [-markFixed]
                 [-merge {true|false}] [-minHole {true|false}]
                 [-powerDomain <powerDomainName>] [-prefix <prefixName>]
                 [-prevent_vertical_stack_max_length_violation]
                 [-util <targetUtilization>] [-viaEnclosure {true|false}] [-createRows {true|false} ]

-help                                    # Prints out the command usage
-area <areaBoxList>                      # List of area in which fillers are to
                                         # be inserted (string, optional)
-cell <cellList>                         # List of filler cells
                                         # (string, optional)
-check_signal_drc {true|false}           # DRC checking after filler insertion
                                         # (bool, optional)
-createRows {true|false}                 # Create rows for filler cell
                                         # techSites which do not have rows in
                                         # the floor plan (bool, optional)
-diffCellViol {true|false}               # Check violations between different
                                         # cell types (bool, optional)
-ecoMode {true|false}                    # Fillers inserted in ecoFlow
                                         # (bool, optional)
-fitGap                                  # Chooses combinations of filler cells
                                         # avoiding creating single-width gaps
                                         # (bool, optional)
-fixDRC                                  # Corrects DRC violations on fillers
                                         # reported by verifyGeometry
                                         # (bool, optional)
-fix_horizontal_max_length_violation     # fix horizontal max length violation
                                         # (bool, optional)
-fix_vertical_max_length_violation       # fix vertical stack max length
                                         # violation (bool, optional)
-honorPrerouteAsObs {true|false}         # Filler command honors
                                         # setPrerouteAsObs value (bool, optional)
-markFixed                               # Mark inserted fillers as pre-placed
                                         # (bool, optional)
-merge {true|false}                      # DRC checking with -merge option
                                         # passed to verifyGeometry
                                         # (bool, optional)
-minHole {true|false}                    # DRC checking with -minHole option
                                         # passed to verifyGeometry
                                         # (bool, optional)
-powerDomain <powerDomainName>           # Power domain for which fillers are
                                         # to be inserted (string, optional)
-prefix <prefixName>                     # Prefix of fillers to inserted
                                         # (string, optional)
-prevent_vertical_stack_max_length_violation
                                         # add repair filler to cut vertical
                                         # stack to prevent its max length
                                         # violation (bool, optional)
-util <targetUtilization>                # Utilization factor
                                         # (float, optional, min=0, max=1)
-viaEnclosure {true|false}               # DRC checking with -viaEnclosure
                                         # option passed to verifyGeometry
                                         # (bool, optional)