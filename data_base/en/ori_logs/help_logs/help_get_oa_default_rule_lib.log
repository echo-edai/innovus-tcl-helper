Usage: get_oa_default_rule_lib [-help] [-rule <rule_name>] [-libs <lib_list> ] [-verbose  ]

-help                 # Prints out the command usage
-libs <lib_list>      # List of library names to search through. If not
                      # specified, all libraries will be searched.
                      # (string, optional)
-rule <rule_name>     # Name of the rule to find. If not specified, the
                      # init_oa_default_rule variable will be used and if the
                      # variable has an empty string value, the standard lookup
                      # (LEFDefaultRouteSpec by type, then by name) will be
                      # used. (string, optional)
-verbose              # Echo details of library name where the rule was found
                      # (including descending through technology references
                      # from libraries specified in the lib_list) (bool, optional)