Usage: get_macro_place_constraint [-help] [-cell <string>]
                                  [-macro_corner_keepout]
                                  [-power_domain_as_core] [[-array <string>] | [-inst <string> -orientation ] | [-cell_obs ] | [-track_adjustment ] | [-max_io_pin_group_keep_out ] | [-forbidden_space_to_core ] | [-forbidden_space_to_macro ] | [-min_space_to_core ] | [-min_space_to_macro ] | [-parallel_run_length ] | [-horizontal_stacking ] | [-vertical_stacking ] | [-honor_strict_spacing_constraint ] | [-avoid_abut_macro_edge_with_pins ] | [-same_length_site ] | [-pg_resource_model ] | [-non_default ] | [-halo_sharing ] | [-parallel_run_length_for_stacking ] ]

-help                                # Prints out the command usage
-array <string>                      # return the macro array name
                                     # (string, optional)
-avoid_abut_macro_edge_with_pins     # return if avoid to abut the macro edges
                                     # with pins (bool, optional)
-cell <string>                       # return the cell which will be set
                                     # cell_obs (string, optional)
-cell_obs                            # return the cell obs value
                                     # (bool, optional)
-forbidden_space_to_core             # return the forbidden space to core value
                                     # (bool, optional)
-forbidden_space_to_macro            # return the fobidden space to macro value
                                     # (bool, optional)
-halo_sharing                        # return the halo sharing mode
                                     # (bool, optional)
-honor_strict_spacing_constraint     # return the spacing mode (bool, optional)
-horizontal_stacking                 # return the horizontal stacking
                                     # constraint (bool, optional)
-inst <string>                       # return the macro which will be set the
                                     # orientation constraints (string, optional)
-macro_corner_keepout                # return the macro corner keepout value
                                     # (bool, optional)
-max_io_pin_group_keep_out           # return the max height and (optionally)
                                     # side extension of IO pins blockages
                                     # (bool, optional)
-min_space_to_core                   # return the minimum space to core value
                                     # (bool, optional)
-min_space_to_macro                  # return the minimum space to macro value
                                     # (bool, optional)
-non_default                         # Displays the current settings which are
                                     # not default settings (bool, optional)
-orientation                         # return the valid orientations
                                     # (bool, optional)
-parallel_run_length                 # return the parallel run length value
                                     # (bool, optional)
-parallel_run_length_for_stacking    # return the stacking parallel run length
                                     # value (bool, optional)
-pg_resource_model                   # return the pg resource model
                                     # (bool, optional)
-power_domain_as_core                # return the power domain as core mode
                                     # (bool, optional)
-same_length_site                    # return the same length site number
                                     # (bool, optional)
-track_adjustment                    # return the track adjustment value
                                     # (bool, optional)
-vertical_stacking                   # return the vertical stacking constraint
                                     # (bool, optional)