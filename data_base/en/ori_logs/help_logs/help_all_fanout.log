Usage: all_fanout [-help] [-hpin] [-only_cells]
                  [-trace_through {case_disable|user_disable|all|clocks|loop_snipped|latches}]
                  [-view <view_name>] [-levels <value> | -pin_levels <value>] {-from {collection | object_list} } [-endpoints_only ] [ > | >> ]

-help                              # Prints out the command usage
-endpoints_only                    # Returns a collection only of valid end
                                   # points in the fanout cone (bool, optional)
-from {collection | object_list}   # Specifies 'from' objects for the
                                   # collections to be returned (string, optional)
-hpin                              # Returns hierarchical pins along with flat
                                   # pins (bool, optional)
-levels <value>                    # number of gate levels to go forward from a
                                   # specific pin object to create the
                                   # collection (int, optional)
-only_cells                        # Returns a collection only of the cells in
                                   # the fanout cone (bool, optional)
-pin_levels <value>                # number delay arcs to go forward from a
                                   # specific pin object to create the
                                   # collection (int, optional)
-trace_through {case_disable|user_disable|all|clocks|loop_snipped|latches}
                                   # Option to select tracing through disabled
                                   # arcs (string, optional)
-view <view_name>                  # Specifies view name for which fan cone
                                   # traversal is to be performed
                                   # (string, optional)
> <filename>                       # output to file
                                   # (redirect_operator, optional)
>> <filename>                      # output to file
                                   # (redirect_operator, optional)