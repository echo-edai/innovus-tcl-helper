Usage: trim_pg [-help] [-keep_dangling_via] -net {list_of_nets} { {-layer {<layer_name1> [<layer_name2>]} -pattern <trimming_pattern> -type {stripe via}} | -candidate_file <file_name> } [ -exclude_local_grid {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...} | -candidate_file <file_name> ] [ -exclude {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...} | -candidate_file <file_name> ] [ -threshold <float> | -candidate_file <file_name> ] [ -area {x1, y1, x2, y2} | -candidate_file <file_name> ]

-help                                      # Prints out the command usage
-area {x1, y1, x2, y2}                     # trimming area (box, optional)
-candidate_file <file_name>                # candidate file name
                                           # (string, optional)
-exclude {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...}
                                           # Exclude areas in which the part of
                                           # stripes is not trimming
                                           # (box_list, optional)
-exclude_local_grid {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...}
                                           # Exclude areas in which the whole
                                           # stripes are skipped for trimming
                                           # (box_list, optional)
-keep_dangling_via                         # Keep dangling VIAs when trimming
                                           # stripe (bool, optional)
-layer {<layer_name1> [<layer_name2>]}     # One layer name for stripe trimming
                                           # and two layer names for VIA
                                           # trimming (string, optional)
-net {list_of_nets}                        # Specify the net names to be
                                           # trimmed ((net)+, required)
-pattern <trimming_pattern>                # trimming pattern
                                           # (string, optional)
-threshold <float>                         # Threshold for stripe merging
                                           # (float, optional)
-type {stripe via}                         # Trim type, to trim stripe on one
                                           # layer or stack via vetween two
                                           # layers (enum, optional)