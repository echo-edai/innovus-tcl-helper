Usage: debug_irdrop [-help] [-eco_report] [-enable_xp {true false}]
                    [-non_violating_instslimit <float>]
                    [-nworst_instances <integer>] [-output_directory <string>]
                    -state_directory <string> [-summary_only] [ -net <string> | -domain <string> ] [ -net_threshold <float> | -domain_threshold <float> ] [ -region {x1 y1 x2 y2} | -nregion <integer> ] [ -tile_row_col {x y} | -tile_size {x y} ]

-help                                 # Prints out the command usage
-domain <string>                      # domain name (string, required)
-domain_threshold <float>             # domain threshold (float, optional)
-eco_report                           # create eco report (bool, optional)
-enable_xp {true false}               # <use full distributed partition
                                      # Voltus-XP invocation.> (enum, optional)
-net <string>                         # net name (string, required)
-net_threshold <float>                # net threshold (float, optional)
-non_violating_instslimit <float>     # report non-violating instances that are
                                      # close to threshold (float, optional)
-nregion <integer>                    # number of regions (int, optional)
-nworst_instances <integer>           # number of worst instances
                                      # (int, optional)
-output_directory <string>            # output directory (string, optional)
-region {x1 y1 x2 y2}                 # region (box, optional)
-state_directory <string>             # state directory (string, required)
-summary_only                         # only do summary report (bool, optional)
-tile_row_col {x y}                   # number of tiles in x and y direction
                                      # (point, optional)
-tile_size {x y}                      # size of each tile in x and y direction
                                      # (point, optional)