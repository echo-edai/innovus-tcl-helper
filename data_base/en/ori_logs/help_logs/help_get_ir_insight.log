Usage: get_ir_insight [-help] [-cap_lower_limit <float>]
                      [-cap_upper_limit <float>] [-domain <string>]
                      [-domain_threshold <float>] [-eco_list <string>]
                      [-eco_mode <string>] [-ir_drop_histogram_bin_size <float>]
                      [-ir_drop_histogram_lower_limit <float>]
                      [-ir_drop_histogram_upper_limit <float>] [-mode <string>]
                      [-nregion <integer>] [-nworst_aggressors <integer>]
                      [-nworst_instances <integer>] [-output_directory <string>]
                      [-pdn_model <string>] [-reset_predict]
                      [-scenario <string>] [-state_directory <string>]
                      [-watch_box <string>] [-watch_inst <string>]

-help                                   # Prints out the command usage
-cap_lower_limit <float>                # lower limit for aggr capacitance in
                                        # eco_report mode (float, optional)
-cap_upper_limit <float>                # upper limit for aggr capacitance in
                                        # eco_report mode (float, optional)
-domain <string>                        # domain name (string, optional)
-domain_threshold <float>               # domain_threshold (float, optional)
-eco_list <string>                      # Provide the eco list for prediction
                                        # (string, optional)
-eco_mode <string>                      # dump
                                        # violation||aggressor||both||load_split
                                        # for eco report (string, optional)
-ir_drop_histogram_bin_size <float>     # bin size for IR histogram
                                        # (float, optional)
-ir_drop_histogram_lower_limit <float>  # lower limit for IR histogram in
                                        # summary only mode (float, optional)
-ir_drop_histogram_upper_limit <float>  # upper limit for IR histogram in
                                        # summary only mode (float, optional)
-mode <string>                          # different modes
                                        # summary_only|report_by_region|report_aggressor|eco_report|predict_ir|skip|compare|pdn_check (string, optional)
-nregion <integer>                      # number of regions (int, optional)
-nworst_aggressors <integer>            # How many aggressor per violation to
                                        # report (int, optional)
-nworst_instances <integer>             # number of worst instances
                                        # (int, optional)
-output_directory <string>              # output_directory (string, optional)
-pdn_model <string>                     # Assign the power deliver network
                                        # model for aggressor-based features
                                        # (string, optional)
-reset_predict                          # reset the previous rounds of eco
                                        # (bool, optional)
-scenario <string>                      # scenario list (string, optional)
-state_directory <string>               # state_directory (string, optional)
-watch_box <string>                     # instances inside the box will be
                                        # watched for prediction
                                        # (string, optional)
-watch_inst <string>                    # instances who be watched for
                                        # prediction (string, optional)