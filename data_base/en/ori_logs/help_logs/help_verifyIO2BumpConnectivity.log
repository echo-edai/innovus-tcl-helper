Usage: verifyIO2BumpConnectivity [-help] [-error <integer>] [-report <string>]
                                 [-subclass <string>] [-warning <integer>]
                                 [-bump_connect_target | -class_bump]
                                 [-bumps <string> | -class_bump]
                                 [-bumps <string> | -nets <string>]

-help                    # Prints out the command usage
-bump_connect_target     # Checks only if routing matches connection specified
                         # by bump_connect_target properties (io:pin:port)
                         # regardless the class of the port. (bool, optional)
-bumps <string>          # The name of bumps that will be checked
                         # (string, optional)
-class_bump              # Checks only if ports of CLASS BUMP are routed to the
                         # bumps regardless the bump_connect_target properties.
                         # (bool, optional)
-error <integer>         # Specifies the maximum number of errors to report
                         # (int, optional)
-nets <string>           # The name of nets that will be checked
                         # (string, optional)
-report <string>         # Specifies the report file for
                         # verifyIO2BumpConnectivity violations data
                         # (string, optional)
-subclass <string>       # The name of subclasses of which the wires and vias
                         # will be checked (string, optional)
-warning <integer>       # Specifies the maximum number of warnings to report
                         # (int, optional)