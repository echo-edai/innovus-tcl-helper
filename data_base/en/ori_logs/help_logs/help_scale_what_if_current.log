Usage: scale_what_if_current [-help] [-net <string>] [-reset]
                             [-scale_clock_network]
                             [-scale <string> | -current <string>]
                             [-global | -region <string> | -hierarchy <string> | -inst_list <string>]

-help                           # Prints out the command usage
-current <string>               # current value in mA (string, optional)
-global                         # global (bool, optional)
-hierarchy <string>             # hierarchy name (string, optional)
-inst_list <string>             # instance list (string, optional)
-net <string>                   # net name (string, optional)
-region <string>                # region (string, optional)
-reset                          # reset scale current options (bool, optional)
-scale <string>                 # scale value (string, optional)
-scale_clock_network            # scale clock network? (bool, optional)