Usage: get_wire_variation_mode [-help] [-corner_sigma_multiplier]
                               [-correlation_type]
                               [-disable_positive_slack_shift]
                               [-enable_seperate_wire_var_sigma_multiplier]
                               [-layer_avg_rpt] [-rc_correlation_factor]
                               [-reset] [-use_nsigma_coupling_capacitance]
                               [-use_nsigma_slew_for_timing_check]
                               [-wire_cell_variation_correlation]
                               [-wire_var_reporting_sigma_multiplier]
                               [-quiet] [-nonDefault]

-help                                      # Prints out the command usage
-corner_sigma_multiplier                   # Provide scaling multiplier for
                                           # corner scaling (string, default="")
-correlation_type                          # How to handle inter-layer
                                           # correlation. accepted values
                                           # statistical|binomial|corner
                                           # (enums={statistical correlated binomial corner}, default=statistical)
-disable_positive_slack_shift              # disable positive slack shift
                                           # caused by BEOL variation.
                                           # (bool, default=false)
-enable_seperate_wire_var_sigma_multiplier
                                           # Allow seperate reporting sigma
                                           # multplier for wire variations. To
                                           # be used along with option
                                           # -wire_var_reporting_sigma_multiplier
                                           # (bool, default=false)
-layer_avg_rpt                             # Enable layer averaging reporting(
                                           # true/false ) (bool, default=false)
-rc_correlation_factor                     # same layer R&C correlation.
                                           # accepted values ( 1 | -1 )
                                           # (int, default=1)
-reset                                     # reset wire variation modes to
                                           # default value (bool, default=false)
-use_nsigma_coupling_capacitance           # Use mean+nSigma coupling caps(
                                           # true/false ) (bool, default=false)
-use_nsigma_slew_for_timing_check          # Use Wire Var aware slews for
                                           # timing check lookup( true/false )
                                           # (bool, default=false)
-wire_cell_variation_correlation           # Whether to RSS or add the
                                           # random-cell variation and  wire
                                           # variation for arrivals and slack(
                                           # true/false ) (bool, default=false)
-wire_var_reporting_sigma_multiplier       # Deterministic sigma multiplier for
                                           # reporting beol variations
                                           # (float, default=0)
-quiet                                     # Displays the current settings in Tcl list format only
-nonDefault                                # Displays the current settings which are not default settings