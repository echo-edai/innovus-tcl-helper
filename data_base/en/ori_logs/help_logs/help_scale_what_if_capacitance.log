Usage: scale_what_if_capacitance [-help] [-add] [-layer <string>]
                                 [-net <string>] -reset  | {{-global  | -region <string> | -cell <string> | -instance <string> | -file <string>} [-intrinsic_cap <string>] [-loading_cap <string>] [-grid_cap <string>]}

-help                               # Prints out the command usage
-add                                # add cap instaed of scaling, all scaling
                                    # values are assumed to be in absoulte in
                                    # farad(F) unit (bool, optional)
-cell <string>                      # cell name (string, optional)
-file <string>                      # file name (string, required)
-global                             # is global (bool, required)
-grid_cap <string>                  # grid capacitance scale factor
                                    # (string, optional)
-instance <string>                  # instance name (string, optional)
-intrinsic_cap <string>             # intrinsic capacitance scale factor
                                    # (string, optional)
-layer <string>                     # lef layer for added capacitance
                                    # (string, optional)
-loading_cap <string>               # loading capacitance scale factor
                                    # (string, optional)
-net <string>                       # net name (string, optional)
-region <string>                    # region <x1 y1 x2 y2> (um)
                                    # (string, required)
-reset                              # reset all scale capacitance options
                                    # (bool, optional)