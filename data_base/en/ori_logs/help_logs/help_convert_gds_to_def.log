Usage: convert_gds_to_def [-help] [-black_box_cell_file <string>]
                          [-esd_cell_bbox_file <string>]
                          [-esd_marker_layer_file <string>]
                          [-extract_signal_net_logic_info_only]
                          [-gds_file <string>] [-gds_layermap <string>]
                          [-ignore_gds_inst_name] [-inst_name_file <string>]
                          [-inst_name_prefix <string>]
                          [-net_location_file <string>]
                          [-output_components {ALL CONN NONE}]
                          [-output_def_file <string>]
                          [-output_lef_macros <string>]
                          [-power_grid_library <string>]
                          [-print_complete_short_path] [-spef_file <string>]
                          [-tech_gds_layermap <string>] [-top_cell <string>]
                          [-use_gds_label <string>] [-verilog_file <string>]
                          [-zero_pin_size]

-help                                   # Prints out the command usage
-black_box_cell_file <string>           # <black box cell file>
                                        # (string, optional)
-esd_cell_bbox_file <string>            # <esd cell bbox file>
                                        # (string, optional)
-esd_marker_layer_file <string>         # <esd marker layer file>
                                        # (string, optional)
-extract_signal_net_logic_info_only     # output only logical connectivity for
                                        # signal net in NET section, no routing
                                        # shapes (bool, optional)
-gds_file <string>                      # <input gds file> (string, optional)
-gds_layermap <string>                  # <layer mapping file>
                                        # (string, optional)
-ignore_gds_inst_name                   # ignore instance names read from gds
                                        # file (bool, optional)
-inst_name_file <string>                # <instance name file>
                                        # (string, optional)
-inst_name_prefix <string>              # <instance name prefix>
                                        # (string, optional)
-net_location_file <string>             # <net location file>
                                        # (string, optional)
-output_components {ALL CONN NONE}      # <format: ALL | CONN | NONE>
                                        # (enum, optional)
-output_def_file <string>               # <output def file name>
                                        # (string, optional)
-output_lef_macros <string>             # <output lef macro list file>
                                        # (string, optional)
-power_grid_library <string>            # <power grid libraries>
                                        # (string, optional)
-print_complete_short_path              # print complete short path when
                                        # shorted (bool, optional)
-spef_file <string>                     # <input spef file name>
                                        # (string, optional)
-tech_gds_layermap <string>             # <def/lef layer mapping file
                                        # (string, optional)
-top_cell <string>                      # <top cell name> (string, optional)
-use_gds_label <string>                 # <format: ALL | TOP | <tech layer
                                        # name> | <cellname>:<tech layer name>
                                        # | <cellname>:ALL> (string, optional)
-verilog_file <string>                  # <output verilog file name>
                                        # (string, optional)
-zero_pin_size                          # set pin size to zero in the output
                                        # def file (bool, optional)