Usage: report_wire_load [-help]
                        [-inst <name_or_collection_of_hierarchical_instances>]
                        [-ports <list_or_collection_of_ports>]
                        [> <filename>[.gz]] [>> <filename>[.gz]] [-late  | -early ]

-help                                   # Prints out the command usage
-early                                  # Reports wireload model information
                                        # for the best case condition
                                        # (bool, optional)
-inst <name_or_collection_of_hierarchical_instances>
                                        # Reports wireload model information
                                        # for the specified hierarchical
                                        # instance(s) only (string, optional)
-late                                   # Reports wireload model information in
                                        # worst-case condition (bool, optional)
-ports <list_or_collection_of_ports>    # Reports wireload model information
                                        # for the specified ports
                                        # (string, optional)
> <filename>[.gz]                       # writes the report to the specified
                                        # file name. If the file already
                                        # exists, the software overwrites it
                                        # (redirect_operator, optional)
>> <filename>[.gz]                      # writes the report to the specified
                                        # file name. If the file already
                                        # exists,the software concatenates the
                                        # report to the end of the file
                                        # (redirect_operator, optional)