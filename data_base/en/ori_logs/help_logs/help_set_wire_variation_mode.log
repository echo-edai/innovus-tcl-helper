Usage: set_wire_variation_mode [-help] [-reset]
                               [-corner_sigma_multiplier <std::string>]
                               [-correlation_type {statistical|correlated|binomial|corner}]
                               [-disable_positive_slack_shift {true|false}]
                               [-enable_seperate_wire_var_sigma_multiplier {true|false}]
                               [-layer_avg_rpt {true|false}]
                               [-rc_correlation_factor <int>]
                               [-reset {true|false}]
                               [-use_nsigma_coupling_capacitance {true|false}]
                               [-use_nsigma_slew_for_timing_check {true|false}]
                               [-wire_cell_variation_correlation {true|false}]
                               [-wire_var_reporting_sigma_multiplier <double>]

-help                                      # Prints out the command usage
-reset                                     # Resets all or specified options to default value
-corner_sigma_multiplier <std::string>     # Provide scaling multiplier for
                                           # corner scaling (string, default="")
-correlation_type {statistical|correlated|binomial|corner}
                                           # How to handle inter-layer
                                           # correlation. accepted values
                                           # statistical|binomial|corner
                                           # (enums={statistical correlated binomial corner}, default=statistical)
-disable_positive_slack_shift {true|false}
                                           # disable positive slack shift
                                           # caused by BEOL variation.
                                           # (bool, default=false)
-enable_seperate_wire_var_sigma_multiplier {true|false}
                                           # Allow seperate reporting sigma
                                           # multplier for wire variations. To
                                           # be used along with option
                                           # -wire_var_reporting_sigma_multiplier
                                           # (bool, default=false)
-layer_avg_rpt {true|false}                # Enable layer averaging reporting(
                                           # true/false ) (bool, default=false)
-rc_correlation_factor <int>               # same layer R&C correlation.
                                           # accepted values ( 1 | -1 )
                                           # (int, default=1)
-reset {true|false}                        # reset wire variation modes to
                                           # default value (bool, default=false)
-use_nsigma_coupling_capacitance {true|false}
                                           # Use mean+nSigma coupling caps(
                                           # true/false ) (bool, default=false)
-use_nsigma_slew_for_timing_check {true|false}
                                           # Use Wire Var aware slews for
                                           # timing check lookup( true/false )
                                           # (bool, default=false)
-wire_cell_variation_correlation {true|false}
                                           # Whether to RSS or add the
                                           # random-cell variation and  wire
                                           # variation for arrivals and slack(
                                           # true/false ) (bool, default=false)
-wire_var_reporting_sigma_multiplier <double>
                                           # Deterministic sigma multiplier for
                                           # reporting beol variations
                                           # (float, default=0)