Usage: setTieHiLoMode [-help] [-reset]
                      [-cell {{tieCellList1} {tieCellList2} ...}]
                      [-createHierPort {true|false}]
                      [-honorDontTouch {true|false}]
                      [-honorDontUse {true|false}]
                      [-maxDistance <dist-in-microns>] [-maxFanout <nr-pins>]
                      [-modulePrevention {true|false}] [-prefix <tie-prefix>]
                      [-reportHierPort {true|false}]

-help                                   # Prints out the command usage
-reset                                  # Resets all or specified options to default value
-cell {{tieCellList1} {tieCellList2} ...}
                                        # Set tie cell lists for setTieHiLoMode
                                        # command (string, default="")
-createHierPort {true|false}            # Add tie-cells in different hierarchy
                                        # than tie-off pins when possible
                                        # (bool, default=false)
-honorDontTouch {true|false}            # honor dont_touch attribute on nets,
                                        # insts, cells and modules
                                        # (bool, default=false)
-honorDontUse {true|false}              # honor dont_use attribute on cells.
                                        # (bool, default=false)
-maxDistance <dist-in-microns>          # distance between tie-cell and
                                        # tie-pins should be less than given
                                        # value (float, default=0)
-maxFanout <nr-pins>                    # the number of tie-pins a tie-net can
                                        # drive. A '0' means no-limit
                                        # (int, default=0)
-modulePrevention {true|false}          # add tie cell for module instantiation
                                        # port (bool, default=false)
-prefix <tie-prefix>                    # Prefix of tie cell instances
                                        # (string, default="")
-reportHierPort {true|false}            # Report created ports when
                                        # createHierPort is set
                                        # (bool, default=false)