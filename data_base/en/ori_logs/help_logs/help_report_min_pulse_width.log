Usage: report_min_pulse_width [-help] [-clock <object_list>] [-net]
                              [-path_type {summary short full_clock}]
                              [-pins <object_list>] [-tcl_list] [-verbose]
                              [-view <view_name>] [-violation_only]
                              [-waveform_aware_type {regular waveform_aware both}]
                              [> <filename[.gz]>] [>> <filename[.gz]>]

-help                                     # Prints out the command usage
-clock <object_list>                      # Specifies a set of clocks to report
                                          # min_pulse_width (string, optional)
-net                                      # Adds a row for the net arc
                                          # (bool, optional)
-path_type {summary short full_clock}     # Specifies the type of report to
                                          # generate (enum, optional)
-pins <object_list>                       # Specifies a set of ports and pins
                                          # on the clock network
                                          # (string, optional)
-tcl_list                                 # Produces the report in Tcl list
                                          # format instead of a tabular format
                                          # (bool, optional)
-verbose                                  # Detailed information about minimum
                                          # pulse width calculations
                                          # (bool, optional)
-view <view_name>                         # Specifies analysis view
                                          # (string, optional)
-violation_only                           # Reports only violating checks
                                          # (bool, optional)
-waveform_aware_type {regular waveform_aware both}
                                          # waveform aware pulse width check to
                                          # be reported (enum, optional)
> <filename[.gz]>                         # Redirects output to the specified
                                          # file (redirect_operator, optional)
>> <filename[.gz]>                        # Redirects output to the specified
                                          # file (redirect_operator, optional)