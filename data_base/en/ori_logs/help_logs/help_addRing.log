Usage: addRing [-help]
               [-around {each_block each_reef power_domain default_power_domain selected cluster shared_cluster user_defined}]
               [-center <0|1>] [-exclude_selected <0|1>]
               [-extend_corner [tl tr bl br lt lb rt rb]] [-follow {core io}]
               [-jog_distance <real_value>] -nets <name-or-value>
               [-offset_adjustment {automatic fixed}] [-rectangle <0|1>]
               [-skip_side {top bottom left right}]
               [-snap_wire_center_to_grid {None Grid Half_Grid Either}]
               [-threshold {value|auto}] [-type {core_rings block_rings}]
               [-uda <subclass_string>] [-use_interleaving_wire_group <0|1>]
               [-use_wire_group <0|1>] [-use_wire_group_bits <value>]
               [-use_wire_group_reinforcement <0|1>]
               [-use_wire_group_reinforcement_group_via <0|1>]
               [-use_wire_group_reinforcement_spacing_width {spacing width}]
               [-user_defined_region <x1 y1 x2 y2 ...>] {-layer {layer | {top top_layer bottom bottom_layer left left_layer right right_layer}} } {-width {value | {top top_width bottom bottom_width left left_width right right_width}} } {-spacing {value | {top top_spacing bottom bottom_spacing left left_spacing right right_spacing}} } [-offset {value | {top top_offset bottom bottom_offset left left_offset right right_offset}} ]

-help                                      # Prints out the command usage
-around {each_block each_reef power_domain default_power_domain selected cluster shared_cluster user_defined}
                                           # around the objects to create rings (enum, optional)
-center <0|1>                              # the center the core rings between
                                           # the I/O pads and core boundaries
                                           # (bool, optional)
-exclude_selected <0|1>                    # exclude seleted objects
                                           # (bool, optional)
-extend_corner [tl tr bl br lt lb rt rb]
                                           # extends the specified segment of
                                           # the ring to specified dirction
                                           # (enum_list, optional)
-follow {core io}                          # core rings are placed along the
                                           # core boundary or the I/O boundary
                                           # (enum, optional)
-jog_distance <real_value>                 # minimum jog distance
                                           # (string, optional)
-layer {layer | {top top_layer bottom bottom_layer left left_layer right right_layer}}
                                           # layer name (string, required)
-nets <name-or-value>                      # net name list (string, required)
-offset {value | {top top_offset bottom bottom_offset left left_offset right right_offset}}
                                           # offset value (string, optional)
-offset_adjustment {automatic fixed}       # offset adjustment (enum, optional)
-rectangle <0|1>                           # rectangle rings only
                                           # (bool, optional)
-skip_side {top bottom left right}         # specify which side will be skipped
                                           # from creating ring
                                           # (enum_list, optional)
-snap_wire_center_to_grid {None Grid Half_Grid Either}
                                           # snap wire center to routing grid (enum, optional)
-spacing {value | {top top_spacing bottom bottom_spacing left left_spacing right right_spacing}}
                                           # spacing value (string, optional)
-threshold {value|auto}                    # merge with pre-routed rings if
                                           # within spacing threshold
                                           # (string, optional)
-type {core_rings block_rings}             # the ring type (enum, optional)
-uda <subclass_string>                     # user defined attribute subclass
                                           # (string, optional)
-use_interleaving_wire_group <0|1>         # interleaving (bool, optional)
-use_wire_group <0|1>                      # connects multiple wires from the
                                           # same net together (bool, optional)
-use_wire_group_bits <value>               # the net number of the wire group
                                           # (int, optional)
-use_wire_group_reinforcement <0|1>        # reinforcement stripes
                                           # (bool, optional)
-use_wire_group_reinforcement_group_via <0|1>
                                           # make group vias at ring corner (bool, optional)
-use_wire_group_reinforcement_spacing_width {spacing width}
                                           # specify spacing and width (string, optional)
-user_defined_region <x1 y1 x2 y2 ...>     # the coordinates for a rectilinear
                                           # region (string, optional)
-width {value | {top top_width bottom bottom_width left left_width right right_width}}
                                           # width value (string, required)