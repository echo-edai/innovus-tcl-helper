Usage: getMsvMode [-help] [-allowNestedDefaultDomain]
                  [-allowPowerDomainMinGapZero] [-checkAllNetsForDomainCrossing]
                  [-handleBackToBackIsolation] [-handlePD] [-handlePDComplex]
                  [-honorCpfGlobalConnectionSpecForAoBuffer]
                  [-honorCpfGlobalConnectionSpecForShifter]
                  [-honorDotLibRelatedPGPin]
                  [-honorEffectiveDomainForIsoLsInsertion]
                  [-markIsoEnablePinAsAlwaysOn]
                  [-notUseTopFTermDomainForVoltage]
                  [-shareWellAOBufferingSupport]
                  [-upf_allow_shifter_voltage_mismatch]
                  [-upf_insert_on_floating_pins] [-quiet] [-nonDefault]

-help                                      # Prints out the command usage
-allowNestedDefaultDomain                  # Allows a non-default power domain
                                           # member to be logically nested in a
                                           # default power domain
                                           # (bool, default=true)
-allowPowerDomainMinGapZero                # (bool, default=true)
-checkAllNetsForDomainCrossing             # Checks all the nets for domain
                                           # crossings (bool, default=true)
-handleBackToBackIsolation                 # Supports back-to-back isolation
                                           # insertion along cross-domain net
                                           # based on power intent ISO rule
                                           # (bool, default=false)
-handlePD                                  # To route intra-power domain nets
                                           # only within their power domains
                                           # (bool, default=true)
-handlePDComplex                           # to handle nets belong to multiple
                                           # power domains (bool, default=true)
-honorCpfGlobalConnectionSpecForAoBuffer
                                           # Honors connection specs for AO
                                           # buffer based on the power intent
                                           # rules (bool, default=false)
-honorCpfGlobalConnectionSpecForShifter    # Honors connection specs for
                                           # shifters based on the CPF rules
                                           # (bool, default=false)
-honorDotLibRelatedPGPin                   # Honors timing library related PG
                                           # pins (bool, default=true)
-honorEffectiveDomainForIsoLsInsertion     # Honors effective domains for
                                           # ISO/LS insertions
                                           # (bool, default=true)
-markIsoEnablePinAsAlwaysOn                # To mark all Isolation cell's
                                           # enable pin as always on
                                           # (bool, default=true)
-notUseTopFTermDomainForVoltage            # Controls voltage using top fterm
                                           # domain for IO pin voltage
                                           # (bool, default=false)
-shareWellAOBufferingSupport               # (bool, default=true)
-upf_allow_shifter_voltage_mismatch        # (bool, default=true)
-upf_insert_on_floating_pins               # (bool, default=true)
-quiet                                     # Displays the current settings in Tcl list format only
-nonDefault                                # Displays the current settings which are not default settings