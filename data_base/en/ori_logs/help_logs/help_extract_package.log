Usage: extract_package [-help] [-output <string>] [-spd_file <string>] { [<domain> [-workspace <string>] [-reference_net <string>] [-pkg_die_name <string>] [-pkg_bga_name <string>] ]}

-help                          # Prints out the command usage
<domain>                       # <rail analysis domain name> (string, required)
-output <string>               # <output directory of package model>
                               # (string, optional)
-pkg_bga_name <string>         # <specify bga circuit> (string, optional)
-pkg_die_name <string>         # <specify die circuit> (string, optional)
-reference_net <string>        # <def net name> (string, optional)
-spd_file <string>             # <package extraction spd file>
                               # (string, optional)
-workspace <string>            # <package extraction workspace .ximx>
                               # (string, optional)