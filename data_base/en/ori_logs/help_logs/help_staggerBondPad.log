Usage: staggerBondPad [-help] [-pad <position padName position padName...>]
                      [-pinName <pinName>] {-pattern <pattern_string> | -startStaggerPosition {I M O}} {{-startIoInstName <instName> [-endIoInstName <instName>]} | {[-side {e w n s}] [-ring <number>]} | -all }

-help                           # Prints out the command usage
-all                            # specifies that bond pads will be placed on
                                # all I/O instances (bool, optional)
-endIoInstName <instName>       # specifies the name of the last I/O instance
                                # (string, optional)
-pad <position padName position padName...>
                                # specifies which bond pad and position to use (string, optional)
-pattern <pattern_string>       # specifies the stagger pattern of the bond
                                # pads (string, optional)
-pinName <pinName>              # specifies the name of the pin inside the
                                # instance (string, optional)
-ring <number>                  # specifies which ring to operate on
                                # (int, optional)
-side {e w n s}                 # specifies the geographical side of the die
                                # (enum, optional)
-startIoInstName <instName>     # specifies the name of the first I/O instance
                                # (string, optional)
-startStaggerPosition {I M O}   # specifies the starting stagger position of
                                # the specified bond pad (enum, optional)