Usage: setMaxCapPerFreqTran [-help]
                            -cap {{cap11 cap12 ...} {cap21 cap22 ..} ..}
                            [-force] -freq {freq1 freq2 ...}
                            [-inputpin <inputpin>] [-lib <libName>]
                            -pins {cell outputpin} -tran {freq1 freq2 ...}

-help                                  # Prints out the command usage
-cap {{cap11 cap12 ...} {cap21 cap22 ..} ..}
                                       # specify a Nfreq x Ntran table of
                                       # capacitance values (list, required)
-force                                 # Compute maxCap from interpolated
                                       # -freq, -tran and -cap values
                                       # (bool, optional)
-freq {freq1 freq2 ...}                # specify a list of at least two
                                       # frequency values (list, required)
-inputpin <inputpin>                   # specify an input pin name for the
                                       # input transition in -tran
                                       # (string, optional)
-lib <libName>                         # specify library name
                                       # (string, optional)
-pins {cell outputpin}                 # Add new capacitance constraints to the
                                       # specified set of cells and pins
                                       # (list, required)
-tran {freq1 freq2 ...}                # specify a list of at least two
                                       # transition values (list, required)