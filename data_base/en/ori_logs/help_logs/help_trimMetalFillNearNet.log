Usage: trimMetalFillNearNet [-help] [-area {x1 y1 x2 y2}] [-clock]
                            [-createFillBlockage <string>] [-layer <string>]
                            [-minTrimDensity {<percent1> <layer_list1> [{<percent2> <layer_list2>}]…}]
                            [-minTrimUnionDensityToAboveLayer {<percent1> <layer_list1> [{<percent2> <layer_list2>}]…}]
                            [-net <string>] [-recomputeDensity] [-remove]
                            [-slackThreshold <float>] [-spacing <float>]
                            [-spacingAbove <float>] [-spacingBelow <float>]

-help                            # Prints out the command usage
-area {x1 y1 x2 y2}              # Specifies a set of coordinates within which
                                 # to trim metal fill (box, optional)
-clock                           # Specifies whether trim around all clock 
                                 # (bool, optional)
-createFillBlockage <string>     # Create fill blockage with the specified
                                 # name, so later fill steps will not re-fill
                                 # the trimmed area (string, optional)
-layer <string>                  # Only trim fill on list of layer names
                                 # (string, optional)
-minTrimDensity {<percent1> <layer_list1> [{<percent2> <layer_list2>}]…}
                                 # Only trim until meet the given percent
                                 # window density. { <percent1> <layer_list1> [
                                 # {<percent2> <layer_list2>} ]…}
                                 # (string, optional)
-minTrimUnionDensityToAboveLayer {<percent1> <layer_list1> [{<percent2> <layer_list2>}]…}
                                 # Only trim until meet the given percent
                                 # window density. { <percent1> <layer_list1> [
                                 # {<percent2> <layer_list2>} ]…}
                                 # (string, optional)
-net <string>                    # Specifies a list of critical net names or
                                 # pointers which are surrounded by metal fill
                                 # (string, optional)
-recomputeDensity                # Force a call to verifyMetalDensity to
                                 # re-compute window densities, rather than use
                                 # stored densities in the DB (bool, optional)
-remove                          # If set, metal-fill shapes overlapping the
                                 # critical-net halo area are removed entirely
                                 # rather than trimming (bool, optional)
-slackThreshold <float>          # Trimming around nets with slack less than
                                 # slack_in_ns (float, optional)
-spacing <float>                 # Trim fill on same layer by dist_in_um around
                                 # critical net routes (float, optional)
-spacingAbove <float>            # Trim fill on above layer by dist_in_um
                                 # around critical net routes (float, optional)
-spacingBelow <float>            # Trim fill on below layer by dist_in_um
                                 # around critical net routes (float, optional)