Usage: report_ccopt_pin_insertion_delays [-help] [-bin_size <string>]
                                         [-clock_trees {string1 string2 ...}]
                                         [-file <name>]
                                         [-sources {string1 string2 ...}] [ -skew_groups {string1 string2 ...} | -include_reporting_only_skew_groups ] [ -delay_corner <delay_corner> ] [ -check_type <type> ] [ -delay_type <type> ]

-help                                  # Prints out the command usage
-bin_size <string>                     # Specify a bin (bucket) size for the
                                       # report histograms. (string, optional)
-check_type {setup hold}               # Report in the specified check type
                                       # (enum, optional)
-clock_trees {string1 string2 ...}     # Restricts the report to the specified
                                       # clock trees. (list, optional)
-delay_corner <delay_corner>           # Report in the specified delay corner
                                       # ((delay_corner), optional)
-delay_type {early late}               # Report in this delay type
                                       # (enum, optional)
-file <name>                           # Save a copy of the contents of the
                                       # report to the specified file name
                                       # (string, optional)
-include_reporting_only_skew_groups    # Additionally include the
                                       # reporting-only skew groups in the
                                       # report. (bool, optional)
-skew_groups {string1 string2 ...}     # Restricts the report to the specified
                                       # skew groups. By default all
                                       # delay-constraining skew groups are
                                       # included. (list, optional)
-sources {string1 string2 ...}         # Restricts the report to skew group
                                       # sink pins that have a pin insertion
                                       # delay value from one of the listed
                                       # sources. (list, optional)