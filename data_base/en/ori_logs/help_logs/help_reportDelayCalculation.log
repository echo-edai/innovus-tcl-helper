Usage: reportDelayCalculation [-help] [-active_arcs] -from <string> [-max]
                              [-min] [-mis] [-outfile <string>]
                              [-physical_context] [-show_all_attackers] [-si]
                              [-thresholds] -to <string> [-view <string>]
                              [-voltage] [-waveform]

-help                       # Prints out the command usage
-active_arcs                # show active arcs only (bool, optional)
-from <string>              # Specifies the name of the -from port or pin.
                            # (string, required)
-max                        # Report worst-case in min-max mode.
                            # (bool, optional)
-min                        # Report best-case in min-max mode.
                            # (bool, optional)
-mis                        # Report AMIS related information (bool, optional)
-outfile <string>           # Specifies the output file name.
                            # (string, optional)
-physical_context           # report lle details (bool, optional)
-show_all_attackers         # Include small attackers in report
                            # (bool, optional)
-si                         # Report SI related information (bool, optional)
-thresholds                 # Report the threshold values. (bool, optional)
-to <string>                # Specifies the name of the -to port or pin.
                            # (string, required)
-view <string>              # Specifies the view name. (string, optional)
-voltage                    # Report the voltage of the cell or net timing arc.
                            # (bool, optional)
-waveform                   # Report the waveforms of the pins.
                            # (bool, optional)