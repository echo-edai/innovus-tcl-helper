Description:
create a metric table beneath a heading

Usage: create_metric_table [-help]
                           [-auto_hide] [-collapsible_key]
                           [-format {html excel text}] -heading <string>
                           [-hide_footers] [-hide_graph_footers]
                           [-hierarchy_separator <string>] [-id <string>]
                           [-key <string>] [-per_snapshot]
                           [-show_label_every <integer>]
                           -type {horizontal vertical cpu dict histogram imageplot}

-help                             # Prints out the command usage
-auto_hide                        # whether to auto hide the table
                                  # (bool, optional)
-collapsible_key                  # collapse key columns with option to expand
                                  # them (bool, optional)
-format {html excel text}         # config for specified report_metric format
                                  # (enum, optional)
-heading <string>                 # id of heading to append (string, required)
-hide_footers                     # hide the min, average and max rows from the
                                  # bottom of the table. Graph buttons are
                                  # still shown (bool, optional)
-hide_graph_footers               # hide the graph buttons from the bottom of
                                  # the table (bool, optional)
-hierarchy_separator <string>     # show the metric names with hierarchy using
                                  # the provided separator (string, optional)
-id <string>                      # id for new table (string, optional)
-key <string>                     # key for any regexp (string, optional)
-per_snapshot                     # expand the table per snapshot
                                  # (bool, optional)
-show_label_every <integer>       # frequency of X axis labels in the histogram
                                  # (int, optional)
-type {horizontal vertical cpu dict histogram imageplot}
                                  # type
                                  # (horizontal|vertical|cpu|dict|histogram|imageplot)
                                  # of table (enum, required)