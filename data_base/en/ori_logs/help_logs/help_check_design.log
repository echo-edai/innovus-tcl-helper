Usage: check_design [-help] [-id <string>] [-out_file <string>] {[{-type {library netlist synthesis power_intent timing hierarchical pin_assign budget assign_statements extract_rc place opt cts route signoff all} | -type_3d {db tech_lib netlist power_intent timing place floorplan route all}} [-format {table detail}]] [-no_check ]}

-help                  # Prints out the command usage
-format {table detail} # table: to print the results in table format.
                       # detail : to print the results from check_design using
                       # the old style of log file. Basically, this is just a
                       # way to let user (if necessary) go back to the old
                       # style of log file for check_design. (enum, optional)
-id <string>           # Check violation list (e.g. 'CHKPLC-100')
                       # (string, optional)
-no_check              # Just echo out all the messages that would be checked,
                       # don't do any checks (bool, required)
-out_file <string>     # Specifies output report file, contents dumped to this
                       # file is Tcl formatted (string, optional)
-type {library netlist synthesis power_intent timing hierarchical pin_assign budget assign_statements extract_rc place opt cts route signoff all}
                       # List of categories to check, accepts single & multiple
                       # values (one or more categories) (enum_list, required)
-type_3d {db tech_lib netlist power_intent timing place floorplan route all}
                       # List of 3DIC design categories to check, accepts
                       # single & multiple values (one or more categories)
                       # (enum_list, required)