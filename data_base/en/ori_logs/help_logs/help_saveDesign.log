Usage: saveDesign [-help] [-current_top_cell_only] [-noFill] [-no_pvs_fill]
                  [-skip_file {metric cmd}] {{fileName } | {{{-cellview <string> | -view <string>} [ -saveRestoreFile <string>] [-oaUsedLibsOnly | -oaLibs ]} }} [-timingGraph [-noConstraint ]] [[-user_path [-keep_input_path ]] ] [-tcon ] [-rc ] [-libs ] [-lib2ldb ] [-def ] [-verilog ] [-tgz ] [-no_wait <string> ] [-addTiming | -mmmc2 ] [-addTiming ]

-help                                      # Prints out the command usage
<fileName>                                 # Save restore script to this file.
                                           # <filename>.dat will be the saved
                                           # directory (string, required)
-addTiming                                 # Copy the old timing data when
                                           # loaded in physical-only mode
                                           # (bool, optional)
-cellview <string>                         # Save to this OA cellview
                                           # {<libname> <cellname> <viewname>}
                                           # (string, required)
-current_top_cell_only                     # Only write current design module
                                           # and its submodules in the netlist.
                                           # By default, all the modules from
                                           # the input netlist will be saved
                                           # even if they don't belong to
                                           # current design. (bool, optional)
-def                                       # Save a DEF file also
                                           # (bool, optional)
-keep_input_path                           # Save the path same as the path in
                                           # the input file. (bool, optional)
-lib2ldb                                   # Convert .lib to .ldb for better
                                           # restore performance (bool, optional)
-libs                                      # Resolve symlinks of timing lib
                                           # files and side files (bool, optional)
-mmmc2                                     # Saves the complete design database
                                           # in MMMC2 format (bool, optional)
-noConstraint                              # Save the timing graph data doesn't
                                           # have sdc constraints data
                                           # (bool, optional)
-noFill                                    # Do not save any fill shapes
                                           # (bool, optional)
-no_pvs_fill                               # Tool not to save pvs fill data
                                           # file (bool, optional)
-no_wait <string>                          # Saves the design in a separate
                                           # process according setMultiCpuUsage
                                           # setting, so users can continue
                                           # executing new commands
                                           # simultaneously while the design is
                                           # being saved. (string, optional)
-oaLibs                                    # Saves all OA libraries specified
                                           # in cds.lib under directory
                                           # libname/cellname/viewname/libs/oa/.
                                           # (bool, optional)
-oaUsedLibsOnly                            # Saves only the libraries listed in
                                           # the init_oa_tech_lib,
                                           # init_oa_ref_lib, and
                                           # init_oa_search_lib, which are
                                           # referenced through the on-demand
                                           # processing. On specifying this
                                           # parameter, a new cds.lib file is
                                           # created with only the specified
                                           # libraries. The libraries are saved
                                           # under directory
                                           # libname/cellname/viewname/libs/oa/.
                                           # (bool, optional)
-rc                                        # Save the RC parasitic data
                                           # (bool, optional)
-saveRestoreFile <string>                  # Specifies the file name that can
                                           # be sourced to read back the
                                           # OpenAccess Design (string, optional)
-skip_file {metric cmd}                    # Remove db files have user
                                           # information (enum_list, optional)
-tcon                                      # Save the timing constraint file
                                           # even if not changed (bool, optional)
-tgz                                       # Make design data a tar ball
                                           # (bool, optional)
-timingGraph                               # Save the timing graph data
                                           # (bool, optional)
-user_path                                 # By default all external file
                                           # references (e.g. library files)
                                           # are stored as absolute paths
                                           # without any symbolic-links so the
                                           # DB directory is portable anywhere
                                           # on the same network.  This option
                                           # means external file references are
                                           # stored exactly as the user entered
                                           # it (e.g. full paths like /x/y, or
                                           # relative paths like ../x/y, 
                                           # ./x/y), and any symlinks used
                                           # inside the path names are also
                                           # kept (bool, optional)
-verilog                                   # Save ASCII Verilog file also
                                           # (bool, optional)
-view <string>                             # Save the OA data to this OA
                                           # viewname (string, required)