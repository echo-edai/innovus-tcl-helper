Usage: add_tap_walls [-help] [-bottom] -cell <cellName> [-layer <layer_name>]
                     [-left] [-orientation {R0 MX MY R180}] [-pitch <float>]
                     [-prefix <prefix>] [-range <lx ux>|<ly uy>] [-right] [-top]
                     [-y_flip_side {left right both}]

-help                            # Prints out the command usage
-bottom                          # Specifies add tap-wall cell on bottom side
                                 # (bool, optional)
-cell <cellName>                 # Specify cell to insert. (string, required)
-layer <layer_name>              # Specify layer name to check rule check.
                                 # (string, optional)
-left                            # Specifies add tap-wall cell on left side
                                 # (bool, optional)
-orientation {R0 MX MY R180}     # Specify orientation of added tap-wall cells
                                 # (enum, optional)
-pitch <float>                   # Distance from the center of one tap-wall
                                 # cell to the center of the following wall-tap
                                 # cell (unit:um) (float, optional)
-prefix <prefix>                 # Prefix of tap-wall cells to inserted.
                                 # (string, optional)
-range <lx ux>|<ly uy>           # Specify {lx, lx} or {ly uy} as the start/end
                                 # point at the user given side (point, optional)
-right                           # Specifies add tap-wall cell on right side
                                 # (bool, optional)
-top                             # Specifies add tap-wall cell on top side
                                 # (bool, optional)
-y_flip_side {left right both}   # Specify orientation of added tap-wall cells
                                 # (enum, optional)