Usage: set_power_rail_layers_nets [-help] [-design_opacity <value>]
                                  [-disable_switch_nets {names}]
                                  [-enable_switch_nets {names}]
                                  [-instance_voltage_method {Worst Best Avg WorstAvg WorstSlidingAvg BestSlidingAvg}]
                                  [-instance_voltage_window <1|0>]
                                  [-rail_analysis_opacity <value>]
                                  [-show_layer_net_setting_list]
                                  [-via_size <value>] [ -enable_visible_layers <all|layer_names> | -disable_visible_layers <all|layer_names> | -layers {{name report0/1 visible0/1}{...}} ] [ -enable_visible_sem_layers <all|layer_names> | -disable_visible_sem_layers <all|layer_names> ] [ -enable_report_layers <all|layer_names> | -disable_report_layers <all|layer_names> | -layers {{name report0/1 visible0/1}{...}} ] [ -nets {{all_power 0/1}{all_ground 0/1}} | -enable_nets {names} | -disable_nets {names} ]

-help                              # Prints out the command usage
-design_opacity <value>            # Design opacity (float, optional)
-disable_nets {names}              # Disable nets (string, optional)
-disable_report_layers <all|layer_names>
                                   # Disable report layers: all, layer names (string, optional)
-disable_switch_nets {names}       # Disable switch nets (string, optional)
-disable_visible_layers <all|layer_names>
                                   # Disable layers: all,layer names (string, optional)
-disable_visible_sem_layers <all|layer_names>
                                   # Disable lef layers: all,layer names (string, optional)
-enable_nets {names}               # Enable nets (string, optional)
-enable_report_layers <all|layer_names>    # Enable report layers: all,layer
                                           # names (string, optional)
-enable_switch_nets {names}        # Enable switch nets (string, optional)
-enable_visible_layers <all|layer_names>
                                   # Enable visible layers: all,layer names (string, optional)
-enable_visible_sem_layers <all|layer_names>
                                   # Enable visible lef layers : all,layer
                                   # names (string, optional)
-instance_voltage_method {Worst Best Avg WorstAvg WorstSlidingAvg BestSlidingAvg}
                                   # IV Method Type. (enum, optional)
-instance_voltage_window <1|0>     # IV window.timing/switching whole
                                   # (bool, optional)
-layers {{name report0/1 visible0/1}{...}}
                                   # Set report/visible layers on/off (string, optional)
-nets {{all_power 0/1}{all_ground 0/1}}    # Set all power or ground nets
                                           # on/off (string, optional)
-rail_analysis_opacity <value>     # Rail Analysis Opacity (float, optional)
-show_layer_net_setting_list       # Show the current status of layer/net
                                   # setting (bool, optional)
-via_size <value>                  # Via Size (float, optional)