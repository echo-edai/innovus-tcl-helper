Usage: pinAlignment [-help] [-ignore_ref_pin_shape] [-markFixed]
                    [-moveFixedPin] [-noSnap] [-refType {partition_pin hinst}]
                    [-verbose] [-keepLayer | -newLayer <layer>] [-legalizePin ] [-refObj <refObjName> ] [-ptnInst <ptnName> ] [-pinNames <pinList> ]

-help                                     # Prints out the command usage
-ignore_ref_pin_shape                     # Specifies that the aligned pin will
                                          # ignore matching of shape with the
                                          # reference pin. (bool, optional)
-keepLayer                                # Specifies whether to keep the
                                          # current pin layer. (bool, optional)
-legalizePin                              # Specifies that the aligned pin will
                                          # be tried for nearby legalized
                                          # location while placing the pin.
                                          # (bool, optional)
-markFixed                                # Specifies that the pins that are
                                          # moved by this command will have a
                                          # Fixed status. (bool, optional)
-moveFixedPin                             # Specifies that the pins with a
                                          # Fixed status can also be moved.
                                          # (bool, optional)
-newLayer <layer>                         # Specify a new pin layer.
                                          # (string, optional)
-noSnap                                   # Disables pins from being snapped to
                                          # the routing grid. (bool, optional)
-pinNames <pinList>                       # Specifies the pin(s) of partition
                                          # to be aligned between the facing
                                          # edges with the reference block. You
                                          # can use wildcards (*?) with this
                                          # parameter. (string, optional)
-ptnInst <ptnName>                        # Specifies the target partition inst
                                          # or hinst name (including top) whose
                                          # pins will be aligned to the pins of
                                          # the specified (or inferred)
                                          # instance (or partition).
                                          # (string, optional)
-refObj <refObjName>                      # Specifies the reference object
                                          # where the specified pins of the
                                          # target block will be aligned to the
                                          # pins of the reference object.
                                          # (string, optional)
-refType {partition_pin hinst}            # Refers to type of refObj to be
                                          # considered with wildcard
                                          # (enum, optional)
-verbose                                  # To generate intermediate messages.
                                          # (bool, optional)