Usage: setOaxMode [-help] [-reset] [-allowAnalysisOnly {true|false}]
                  [-allowBitConnection {true|false}]
                  [-allowTechUpdate {true|false}] [-bindkeyFile <fileName>]
                  [-compressLevel <value>] [-convertTo {polygon|defaultStyle}]
                  [-cutRows {true|false}] [-displayDrfFile <pathName>]
                  [-displayDrfInLibrary {true|false}]
                  [-drcFillPurpose {gap_fill|drawing}]
                  [-encloseQuickAbstractPins {true|false}]
                  [-fullLayerList {true|false}] [-fullPath {true|false}]
                  [-hybridRows {true|false}] [-instPlacedIfUnknown {true|false}]
                  [-libCreateMode {none|attach|copy|reference}]
                  [-locking {false|true|errorIfLocked}]
                  [-logicOnlyImport {true|false}] [-merge_trim {true|false}]
                  [-nonRectilinearShapes {bbox|approximate}]
                  [-pinPurpose {true|false}] [-pushPinConstraint {true|false}]
                  [-quickAbstractForCustomCells {pcells|stdcells|all|off}]
                  [-readSystemReservedLayers {all|text|off}]
                  [-saveCdsFixedVias {new_vias_only|off}]
                  [-saveMaskDataLocked {true|false}]
                  [-saveNetVoltage {true|false}]
                  [-saveRelativePath {true|false}]
                  [-silently_ignore_unsupported_vias {true|false}]
                  [-textPurpose <purpose_name>]
                  [-tieNet {tieHighNetName tieLowNetName}]
                  [-updateMode {false|true|auto}]
                  [-useVirtuosoBindkey {true|false}]
                  [-useVirtuosoColor {true|false}] [-viewSubType {VCE|VXL|none}] [ -saveRestoreFile {false|true}]

-help                                      # Prints out the command usage
-reset                                     # Resets all or specified options to default value
-allowAnalysisOnly {true|false}            # Allow analysis only flow
                                           # (bool, default=false)
-allowBitConnection {true|false}           # Whether to create instance
                                           # terminal creations bitwise, if bus
                                           # not found in OA.
                                           # (bool, default=false)
-allowTechUpdate {true|false}              # Whether to allow the tech.db to be
                                           # updated or not. (bool, default=true)
-bindkeyFile <fileName>                    # Virtuoso bind key file
                                           # (string, default="")
-compressLevel <value>                     # OA Database compression level
                                           # (int, default=1, min=0, max=9)
-convertTo {polygon|defaultStyle}          # Whether to convert non-conforming
                                           # pathsegs/paths to polygon or
                                           # convert the endStyle to truncate
                                           # on orthogonal and to custom on
                                           # diagonal pathsegs
                                           # (enums={polygon defaultStyle}, default=polygon)
-cutRows {true|false}                      # Whether to use cutRows or not 
                                           # (bool, default=false)
-displayDrfFile <pathName>                 # Display resource file
                                           # (string, default="")
-displayDrfInLibrary {true|false}          # Whether to use display resource
                                           # file in the tech library
                                           # (bool, default=false)
-drcFillPurpose {gap_fill|drawing}         # Whether to save drcFill shapes to
                                           # gap_fill or drawing purpose. By
                                           # default DEF routes with + SHAPE
                                           # DRCFILL are mapped to the OA
                                           # 'gapFill' purpose. Some OA
                                           # techfiles do not have this purpose
                                           # defined, and require these shapes
                                           # be mapped to 'drawing' purpose. In
                                           # that case, they get an additional
                                           # internal attribute so they can
                                           # round-trip back to DRCFILL shapes
                                           # properly.
                                           # (enums={gap_fill drawing}, default=gap_fill)
-encloseQuickAbstractPins {true|false}     # Include shapes that enclose layout
                                           # pin shapes (bool, default=true)
-fullLayerList {true|false}                # Whether to support full list of
                                           # layer import  (bool, default=true)
-fullPath {true|false}                     # Whether to use full path or not 
                                           # (bool, default=false)
-hybridRows {true|false}                   # Read hybrid rows from PDK 
                                           # (bool, default=false)
-instPlacedIfUnknown {true|false}          # Whether to map OA Placement status
                                           # oacNonePlacementStatus of an
                                           # instance to Placed(true)/
                                           # Unplaced(false). 
                                           # (bool, default=true)
-libCreateMode {none|attach|copy|reference}
                                           # Library creation method during
                                           # saveDesign for newly created
                                           # libraries
                                           # (enums={none attach copy reference}, default=reference)
-locking {false|true|errorIfLocked}        # Whether to lock the OA database
                                           # during restoreDesign
                                           # (enums={false true errorIfLocked}, default=false)
-logicOnlyImport {true|false}              # Whether to run oaIn after
                                           # init_design or not
                                           # (bool, default=false)
-merge_trim {true|false}                   # Merge the trim metal shapes during
                                           # save when the trim metal gap less
                                           # than or equal to the max_gap in
                                           # micron. (bool, default=true)
-nonRectilinearShapes {bbox|approximate}
                                           # Translates non-rectilinear shapes
                                           # to rectilinear shapes.
                                           # (enums={bbox approximate}, default=bbox)
-pinPurpose {true|false}                   # Whether to set Pin Purpose as Pin
                                           # or not (bool, default=false)
-pushPinConstraint {true|false}            # whether saveDesign to push
                                           # interoperable pin constraint into
                                           # its corresponding blackbox
                                           # abstract cellview.
                                           # Note: Interoperable pin constraint
                                           # means pin constraints that are
                                           # understood by Innovus, Virtuoso
                                           # and PVS. (bool, default=false)
-quickAbstractForCustomCells {pcells|stdcells|all|off}
                                           # Trim design shapes of Custom Cells (enums={pcells stdcells all off}, default=all)
-readSystemReservedLayers {all|text|off}
                                           # Read system reserved layers from
                                           # PDK
                                           # (enums={ all text off }, default=all)
-saveCdsFixedVias {new_vias_only|off}      # Save fixed via 
                                           # (enums={new_vias_only off}, default=new_vias_only)
-saveMaskDataLocked {true|false}           # Whether to save colored shapes
                                           # with locked attribute
                                           # (bool, default=false)
-saveNetVoltage {true|false}               # Whether to allow saveDesign to
                                           # write voltage information to the
                                           # oaBitNet's voltage attribute
                                           # (bool, default=false)
-saveRelativePath {true|false}             # Whether to save relative path in
                                           # config file.  (bool, default=true)
-saveRestoreFile {true|false}              # Whether to save the view.inn file
                                           # (bool, default=false)
-silently_ignore_unsupported_vias {true|false}
                                           # Whether restoreDesign should issue
                                           # messages about vias that are not
                                           # supported in Innovus.
                                           # (bool, default=false)
-textPurpose <purpose_name>                # Specify the purpose name that will
                                           # be used when text labels
                                           # (add_text) are written.
                                           # (string, default=drawing)
-tieNet {tieHighNetName tieLowNetName}     # tieHigh tieLow net names
                                           # (string, default="")
-updateMode {false|true|auto}              # Whether to use
                                           # (save/restore)OaDesign in update
                                           # mode or not  (ternary, default=false)
-useVirtuosoBindkey {true|false}           # Whether to use Virtuoso bind keys
                                           # (bool, default=false)
-useVirtuosoColor {true|false}             # Whether to use Virtuoso color and
                                           # stipple (bool, default=false)
-viewSubType {VCE|VXL|none}                # Subtype of view of the OA design
                                           # (enums={VCE VXL none}, default=VXL)