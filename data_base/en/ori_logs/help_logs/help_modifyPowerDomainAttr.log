Usage: modifyPowerDomainAttr [-help] <pd> [-addBlockBox {block ...}]
                             [-core2Bot <float>] [-core2Left <float>]
                             [-core2Right <float>] [-core2Top <float>]
                             [-defaultTechSite <string>]
                             [-disjointHInstBoxList {...}]
                             [-extraRowPattern {site ...}]
                             [-firstRowSiteIndex <integer>]
                             [-lastRowSiteIndex <integer>]
                             [-rowFlip {first second noflip auto}]
                             [-rowPatternSite <site_name>]
                             [-rowSpaceType {0 1 2}] [-rowSpacing <float>] [-minGaps {Top Bottom Left Right} | -gapEdges {value ...}] [-rsExts {Top Bottom Left Right} | -extEdges {value ...}]

-help                                # Prints out the command usage
<pd>                                 # power domain name ((pd), required)
-addBlockBox {block ...}             # list of block boxes to add
                                     # (string, optional)
-core2Bot <float>                    # core to bottom (micron)
                                     # (float, optional)
-core2Left <float>                   # core to left (micron) (float, optional)
-core2Right <float>                  # core to right (micron) (float, optional)
-core2Top <float>                    # core to top (micron) (float, optional)
-defaultTechSite <string>            # set default techsite (string, optional)
-disjointHInstBoxList {...}          # list of disjoint HInst boxes
                                     # (string, optional)
-extEdges {value ...}                # {ext. search distances per edge}
                                     # (string, optional)
-extraRowPattern {site ...}          # site name for extra row pattern
                                     # (string, optional)
-firstRowSiteIndex <integer>         # first Row Site Index (int, optional)
-gapEdges {value ...}                # gap values per edge (string, optional)
-lastRowSiteIndex <integer>          # last Row Site Index (int, optional)
-minGaps {Top Bottom Left Right}     # min gap values for 4 sides
                                     # (float, optional)
-rowFlip {first second noflip auto}  # row flip (enum, optional)
-rowPatternSite <site_name>          # site name for row pattern
                                     # (string, optional)
-rowSpaceType {0 1 2}                # row space type (enum, optional)
-rowSpacing <float>                  # row spacing (float, optional)
-rsExts {Top Bottom Left Right}      # rsExt values for 4 sides
                                     # (float, optional)