Usage: createPinGuide [-help] {[ -area {x1 y1 x2 y2} | [-edge <integer> [[-offset_start <float>] [-offset_end <float>]]] ] [ -layer {layeridList} [-layerPriority ]]} [-pin <string> | -pinGroup <string> | -net <string> | -netGroup <string> | -name <string> ] [-edge <integer> | -net <string> | -netGroup <string>] [-cell <string> | -net <string> | -netGroup <string>]

-help                   # Prints out the command usage
-area {x1 y1 x2 y2}     # Specifies the coordinates of the pin guide area.
                        # (box, optional)
-cell <string>          # Specifies name of the cell. (string, optional)
-edge <integer>         # Specifies the integer value where edge numbering
                        # starts from lower-left corner of a partition
                        # clock-wise. (int, optional)
-layer {layeridList}    # Specifies the metal layer(s) for the pin guide. 
                        # (string, optional)
-layerPriority          # Specifies that pins should be assigned based on the
                        # layer order. (bool, optional)
-name <string>          # Specifies the name of the partition pin guide object.
                        # (string, optional)
-net <string>           # For nets, specifies the name of the net. For buses,
                        # specifies the name of the bus or the bus radix.
                        # (string, optional)
-netGroup <string>      # Specifies the name of the net group.
                        # (string, optional)
-offset_end <float>     # specify a distance in microns from ending corner of
                        # the edge. (float, optional, min=0, max=65535)
-offset_start <float>   # specify a distance in microns from starting corner of
                        # the edge. (float, optional, min=0, max=65535)
-pin <string>           # Specifies the name of the pin. (string, optional)
-pinGroup <string>      # Specifies the name of the pin group.
                        # (string, optional)