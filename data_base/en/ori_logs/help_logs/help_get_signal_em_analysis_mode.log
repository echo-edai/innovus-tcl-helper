Usage: get_signal_em_analysis_mode [-help]
                                   [-additional_individual_violation_report]
                                   [-avgRecovery] [-check_thermal_aware_em]
                                   [-current_scale_factor]
                                   [-current_scale_table]
                                   [-default_freq_for_unconstrained_nets]
                                   [-delta_T] [-delta_T_layer_list] [-detailed]
                                   [-effort_level] [-em_cdf_percentage]
                                   [-em_limit_scale_factor]
                                   [-em_limit_scale_table] [-em_res_width]
                                   [-em_temperature]
                                   [-em_temperature_layer_list] [-em_threshold]
                                   [-enable_seb] [-env_temperature] [-error]
                                   [-extraction_tech_file] [-forceHoldView]
                                   [-handle_pin_obs_via] [-ict_em_models]
                                   [-Ipeak_Td_method] [-ircx_models] [-lifetime]
                                   [-method] [-min_net_freq_file]
                                   [-minPeakDutyRatio] [-minPeakFreq] [-net]
                                   [-net_file] [-net_freq_file]
                                   [-read_detail_delta_temperature_file]
                                   [-report] [-report_db] [-seb_lifetime]
                                   [-seb_table] [-seb_temperature] [-selected]
                                   [-set_current_file] [-simulation_net]
                                   [-simulation_net_file] [-skip_category_mode]
                                   [-skip_net] [-skip_net_file] [-toggle]
                                   [-use_rms_delta_t] [-useQrcTech] [-view]
                                   [-quiet] [-nonDefault]

-help                                     # Prints out the command usage
-additional_individual_violation_report   # Report calculated duty ratio in
                                          # addition with applied duty ratio in
                                          # report file. (bool, default=false)
-avgRecovery                              # override QRC tech em_recover factor
                                          # for all layers used in Iavg limits.
                                          # (float, default=1, min=-1, max=1)
-check_thermal_aware_em                   # check thermal aware EM
                                          # (bool, default=false)
-current_scale_factor                     # Scale Signal EM current, syntax:
                                          # -current_scale_factor { [rms
                                          # <rms_value>] [peak <peak_value>]
                                          # [avg <avg_value>] }
                                          # (string, default="")
-current_scale_table                      # Specifies the layer-based scale
                                          # table for current (string, default="")
-default_freq_for_unconstrained_nets      # Specifies the frequency for EM
                                          # calculation when a net has no
                                          # defined frequency or a defined
                                          # frequency of 0Hz in the design.
                                          # Unit: Hz. (float, default=1000000)
-delta_T                                  # maximum change in temperature
                                          # allowed in units of Celsius.  Used
                                          # in the QRC tech for RMS limits.
                                          # Default=5. (float, default=5)
-delta_T_layer_list                       # Specifies layer based delta
                                          # temperature for EM RMS currnet
                                          # limit analysis (string, default="")
-detailed                                 # Generates a detailed report
                                          # containing information for all
                                          # signal nets, including those
                                          # without violations
                                          # (bool, default=false)
-effort_level                             # Enum_list legal values are: low,
                                          # medium, high. Default: low.
                                          # (enums={low  medium high}, default=low)
-em_cdf_percentage                        # Specify em cumulative distribution
                                          # factor (cdf) percentage.
                                          # (float, default=1e-09)
-em_limit_scale_factor                    # Scale Signal EM limit, syntax:
                                          # -em_limit_scale_factor { [rms
                                          # <rms_value>] [peak <peak_value>]
                                          # [avg <avg_value>] }
                                          # (string, default="")
-em_limit_scale_table                     # Specifies the layer-based scale
                                          # table for em_limit
                                          # (string, default="")
-em_res_width                             # Specifies width used to get EM
                                          # limit. enum_list legal values are:
                                          # drawn, silicon. Default: drawn.
                                          # (enums={drawn silicon}, default=drawn)
-em_temperature                           # Specifies the temperature used to
                                          # lookup the temperature scaling
                                          # factor. By default, no scaling is
                                          # done. Unit: Celsius.
                                          # (float, default=-1)
-em_temperature_layer_list                # Specifies layer based EM
                                          # temperature for EM AVG current
                                          # limit analysis (string, default="")
-em_threshold                             # The value is the ratio of signal
                                          # current (avg/peak/rms) to the
                                          # respective EM limit. Default: 1.0.
                                          # (float, default=1)
-enable_seb                               # Enable SEB calculation
                                          # (bool, default=false)
-env_temperature                          # environment temperature. Unit:
                                          # Celsius. (float, default=-1)
-error                                    # Specifies the maximam number of
                                          # errors to report. (int, default=10000)
-extraction_tech_file                     # Specify qrcTechFile name.
                                          # (string, default="")
-forceHoldView                            # Turn this on to force hold view.
                                          # (bool, default=false)
-handle_pin_obs_via                       # Turn on to handle pin obs via.
                                          # (bool, default=false)
-ict_em_models                            # Specify ict EM file to provide EM
                                          # rule if EM rule not exists in
                                          # qrcTechFile. (string, default="")
-Ipeak_Td_method                          # Specifies Td calculation method for
                                          # Ipeak check. enum_list legal values
                                          # are:
                                          # effective_width_from_integration,
                                          # effective_half_peak_width,
                                          # max_equivalent_dc_peak,
                                          # sum_half_peak_width. Default:
                                          # effective_width_from_integration.
                                          # (enums={effective_width_from_integration effective_half_peak_width max_equivalent_dc_peak sum_half_peak_width}, default=effective_width_from_integration)
-ircx_models                              # Specify ircx model file.
                                          # (string, default="")
-lifetime                                 # Specifies the hours of operation
                                          # used to lookup the lifetime scaling
                                          # factor. By default, no scaling is
                                          # done. Unit: hour.
                                          # (float, default=87600)
-method                                   # Specifies the current waveform
                                          # calculation method, check one or
                                          # more of Irms, Ipeak, and Iavg
                                          # limits. enum_list legal values are:
                                          # rms, peak, avg. Default: rms.
                                          # (string, default="")
-min_net_freq_file                        # Specify minimum net freq file for
                                          # user input net frequency by regular
                                          # expression. (string, default="")
-minPeakDutyRatio                         # Do not check Ipeak for nets with
                                          # duty ratio below <duty_ratio>.
                                          # default = 0.05, range 0.0 to 1.0.
                                          # (float, default=-1, min=0, max=1)
-minPeakFreq                              # Do not check Ipeak for nets with
                                          # frequency below <freq> in units of
                                          # hertz. default = 1e6. Unit: Hz.
                                          # (float, default=1000000)
-net                                      # Specifies whether to check named or
                                          # selected nets (string, default="")
-net_file                                 # Specifies from file the net to
                                          # check in signalEM analysis
                                          # (string, default="")
-net_freq_file                            # Specify net freq file for user
                                          # input net frequency.
                                          # (string, default="")
-read_detail_delta_temperature_file       # Specify detail delta temperature
                                          # file for thermal aware checking.
                                          # (string, default="")
-report                                   # Specifies the report file for the
                                          # violation data (string, default="")
-report_db                                # Enable writing a db file to store
                                          # data for GUI display.
                                          # (bool, default=false)
-seb_lifetime                             # Specifies the hours of operation.
                                          # By default, it's 5 years. Unit :
                                          # hour. (float, default=43800)
-seb_table                                # Specify seb table file.
                                          # (string, default="")
-seb_temperature                          # Specifies the temperature of
                                          # operation. By default, it's 110c.
                                          # Unit: Celsius. (float, default=-273)
-selected                                 # Specifies whether to check named or
                                          # selected nets (bool, default=false)
-set_current_file                         # Specify current file to provide
                                          # currents for cell/instance's pin.
                                          # (string, default="")
-simulation_net                           # Specifies a list of nets to use
                                          # simulation mode (string, default="")
-simulation_net_file                      # Specifies a file contained a list
                                          # of nets to use simulation mode
                                          # (string, default="")
-skip_category_mode                       # Specify the mode that under which
                                          # condition a net should be skipped
                                          # and which category a skipped net
                                          # belongs to. (int, default=1)
-skip_net                                 # Specifies the net to be skipped in
                                          # signalEM analysis (string, default="")
-skip_net_file                            # Specifies the net to be skipped in
                                          # signalEM analysis (string, default="")
-toggle                                   # Specifies the toggle rate for
                                          # signal nets
                                          # (float, default=1, min=0, max=1)
-use_rms_delta_t                          # Turn on to use rms delta
                                          # temperature. (bool, default=false)
-useQrcTech                               # Turn this on to force Irms checks
                                          # to use the QRC tech file rather
                                          # than the LEF tech.  If either Ipeak
                                          # or Iavg is also checked, then all
                                          # checks will use the QRC tech file,
                                          # including Irms. (bool, default=true)
-view                                     # Specifies the name of the view
                                          # (string, default="")
-quiet                                    # Displays the current settings in Tcl list format only
-nonDefault                               # Displays the current settings which are not default settings