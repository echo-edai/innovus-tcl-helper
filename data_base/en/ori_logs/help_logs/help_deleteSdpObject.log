Usage: deleteSdpObject [-help] {[-object {objName(s)} [-keepCellPlacement ]] | -obstruct {sdpGroupName(s)} | [-emptyRow <instName> [-numRow <val>]]}

-help                                  # Prints out the command usage
-emptyRow <instName>                   # Empty row(s) will be deleted
                                       # before/after specified instance based
                                       # on the group justifyBy constraint
                                       # (string, optional)
-keepCellPlacement                     # Keep cell placement when deleting sdp
                                       # object (bool, optional)
-numRow <val>                          # number of row to be deleted
                                       # (int, optional)
-object {objName(s)}                   # Name of sdp object to be deleted
                                       # (string, optional)
-obstruct {sdpGroupName(s)}            # Name of sdp group obstruction to be
                                       # deleted (string, optional)