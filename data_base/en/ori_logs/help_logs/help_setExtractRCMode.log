Usage: setExtractRCMode [-help] [-reset] [-assumeMetFill <scalevalue>]
                        [-capFilterMode {relOnly|relAndCoup|relOrCoup}]
                        [-cerebrus_license_only {true|false}]
                        [-compressOptMemRCDB {true|false}]
                        [-coupled {true|false}] [-coupling_c_th <value>]
                        [-defViaCap {true|false}]
                        [-effortLevel {low|medium|high|signoff}]
                        [-engine {preRoute|postRoute}] [-extraCmdFile <file>]
                        [-extract_rc_quantus_executable <file_path>]
                        [-extract_rc_signoff_stream_layer_map_ccl <file_name>]
                        [-extractionFillStreamMapFile <file>]
                        [-hardBlockObs {true|false}] [-incremental {true|false}]
                        [-iquantus_cap_high_accuracy_mode {true|false}]
                        [-layerIndependent {0|1}] [-lefTechFileMap <file_name>]
                        [-localCpu <number>] [-pvs_fill {true|false}]
                        [-qrcCmdFile <file_name>]
                        [-qrcCmdType {auto|partial|custom}]
                        [-qrcOutputMode {spef|rcdb}]
                        [-qrcRunMode {concurrent|sequential}]
                        [-relative_c_th <value>]
                        [-signoff_stream_layer_map <file_name>]
                        [-total_c_th <value>] [-tQuantusModelFile <file_name>]
                        [-tsvSubcktFile <file_name>]
                        [-turboReduce {true|false|auto}]
                        [-useQrcOAInterface {true|false}]
                        [-useShieldingInDetailMode {true|false}]
                        [-viaCap {true|false}]
                        [-writeDefOptionsForSignoffExtract <def_options>]

-help                                      # Prints out the command usage
-reset                                     # Resets all or specified options to default value
-assumeMetFill <scalevalue>                # Assume metal fill
                                           # (float, default=0, min=0, max=1)
-capFilterMode {relOnly|relAndCoup|relOrCoup}
                                           # Coupling Capacitance Filtering
                                           # Mode
                                           # (enums={relOnly relAndCoup relOrCoup}, default=relOnly)
-cerebrus_license_only {true|false}        # Fall back to the regular QTS
                                           # license(s) when Cerebrus is not
                                           # available (bool, default=false)
-compressOptMemRCDB {true|false}           # Create compressed RCDB
                                           # (bool, default=false)
-coupled {true|false}                      # Extract coupling cap
                                           # (bool, default=false)
-coupling_c_th <value>                     # Coupling C threshold value
                                           # (float, default=3)
-defViaCap {true|false}                    # Consider via caps for extraction
                                           # (bool, default=false)
-effortLevel {low|medium|high|signoff}     # Specifies the effort level of the
                                           # post-route extraction engine
                                           # (enums={low medium high signoff}, default=undefined)
-engine {preRoute|postRoute}               # Extraction engine
                                           # (enums={preRoute postRoute}, default=preRoute)
-extraCmdFile <file>                       # Extra command file for Quantus QRC
                                           # (string, default="")
-extract_rc_quantus_executable <file_path>
                                           # QRC Executable file path (string, default="")
-extract_rc_signoff_stream_layer_map_ccl <file_name>
                                           # QRC stream  map file in CCL format (string, default="")
-extractionFillStreamMapFile <file>        # Quantus stream/oasis file
                                           # (string, default="")
-hardBlockObs {true|false}                 # Makes obstructions and
                                           # power/ground pin shapes visible to
                                           # the extractor for hard blocks only
                                           # (bool, default=false)
-incremental {true|false}                  # Use incremental signoff mode
                                           # (bool, default=true)
-iquantus_cap_high_accuracy_mode {true|false}
                                           # Use for iquantus capacitance high
                                           # accuracy mode  (bool, default=false)
-layerIndependent {0|1}                    # Enable layer independent
                                           # extraction
                                           # (int, default=1, min=0, max=1)
-lefTechFileMap <file_name>                # LEF-QRCTechfile layer map file
                                           # (string, default="")
-localCpu <number>                         # (int, default=0)
-pvs_fill {true|false}                     # Use to send the PVS fill data
                                           # attached to the Innovus DB (see
                                           # set_pvs_fill) to Quantus
                                           # (bool, default=false)
-qrcCmdFile <file_name>                    # Quantus QRC user command file name
                                           # (string, default="")
-qrcCmdType {auto|partial|custom}          # Quantus QRC command input type
                                           # (enums={auto partial custom}, default=auto)
-qrcOutputMode {spef|rcdb}                 # Quantus QRC output mode
                                           # (enums={spef rcdb}, default=spef)
-qrcRunMode {concurrent|sequential}        # Quantus QRC MMMC run mode
                                           # (enums={concurrent sequential}, default=concurrent)
-relative_c_th <value>                     # Relative C threshold value
                                           # (float, default=0.03)
-signoff_stream_layer_map <file_name>      # QRC stream  map file
                                           # (string, default="")
-total_c_th <value>                        # Total C threshold value
                                           # (float, default=5)
-tQuantusModelFile <file_name>             # TQuantus model file name
                                           # (string, default="")
-tsvSubcktFile <file_name>                 # TSV subckt file name
                                           # (string, default="")
-turboReduce {true|false|auto}             # Reduce XCap (IQuantus)
                                           # (enums={true false auto}, default=auto)
-useQrcOAInterface {true|false}            # Use OA interface for invoking
                                           # Quantus QRC extraction
                                           # (bool, default=false)
-useShieldingInDetailMode {true|false}     # Considers shielding for a wire
                                           # segment (bool, default=false)
-viaCap {true|false}                       # Consider via caps for extraction
                                           # (bool, default=true)
-writeDefOptionsForSignoffExtract <def_options>
                                           # write_def options (string, default="")