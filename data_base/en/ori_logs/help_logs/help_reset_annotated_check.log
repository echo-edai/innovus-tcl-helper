Usage: reset_annotated_check [-help] [<object_list>] [-clock {rise fall}]
                             [-cond <sdf_condtion>] [-fall] [-rise] [-setup | -recovery ] [-hold | -removal ] [-nochange_high | -nochange_low ] [ [[-from <from_pins>][-to <to_pins>]] | -all ]

-help                  # Prints out the command usage
<object_list>          # Resets the annotated checks on specified list or
                       # collection of cell instances (string, optional)
-all                   # Resets all annotated timing check values in the design
                       # (bool, optional)
-clock {rise fall}     # Direction of the related pin of the check to reset
                       # (enum, optional)
-cond <sdf_condtion>   # Option specified is -cond (string, optional)
-fall                  # Restricts the reset to only affect the falling edge of
                       # the constrained pins (bool, optional)
-from <from_pins>      # Beginning instance pin of the timing arcs for which
                       # the annotated check is reset (string, optional)
-hold                  # Resets annotations on the hold check type
                       # (bool, optional)
-nochange_high         # Resets the annotations on the high timing check type
                       # (bool, optional)
-nochange_low          # Resets the annotations on the low timing check type
                       # (bool, optional)
-recovery              # Resets annotations on the recovery check type
                       # (bool, optional)
-removal               # Resets annotations on the removal check type
                       # (bool, optional)
-rise                  # Restricts the reset to only affect the rising edge of
                       # the constrained pins (bool, optional)
-setup                 # Resets annotations on the setup check type
                       # (bool, optional)
-to <to_pins>          # Terminating instance pin of the timing arcs for which
                       # the annotated check is reset (string, optional)