Usage: checkPlace [-help] [<violationReportFileName>] [-clearMarker]
                  [-honorPrerouteForFiller] [-ignoreFillerInUtil]
                  [-ignoreOutOfCore] [-inst <string>] [-ioPinBlockage]
                  [-macroBlockage] [-noCheckPinAccess] [-noHalo] [-noHardFence]
                  [-noPreplaced] [-selectedOnly]

-help                                   # Prints out the command usage
<violationReportFileName>               # Specifies the report file
                                        # (string, optional)
-clearMarker                            # Removes the violation markers from a
                                        # previous checkPlace run, without
                                        # rerunning checkPlace (bool, optional)
-honorPrerouteForFiller                 # Checks for placement blockage
                                        # violations on physical instances
                                        # placed under preroutes or specified
                                        # by setPrerouteAsObs (bool, optional)
-ignoreFillerInUtil                     # Ignore filler cells in calculating
                                        # utilization (bool, optional)
-ignoreOutOfCore                        # Skips instances outside the core
                                        # design area (bool, optional)
-inst <string>                          # the list of instances to check
                                        # (string, optional)
-ioPinBlockage                          # Instructs legalization routines to
                                        # treat top-level I/O pins as fixed
                                        # metal obstructions while placing
                                        # standard cell instances at the block
                                        # level (bool, optional)
-macroBlockage                          # Checks if a block-cell is overlapping
                                        # any macro-specifc blockages in design
                                        # (bool, optional)
-noCheckPinAccess                       # Specifies to not check for pin access
                                        # violations (bool, optional)
-noHalo                                 # Skips block halos (bool, optional)
-noHardFence                            # Ignores fence and region placement
                                        # constraints (bool, optional)
-noPreplaced                            # Does not check fixed instances
                                        # (bool, optional)
-selectedOnly                           # Only selected instances are checked
                                        # for legality (bool, optional)