Usage: set_self_heat_analysis_mode [-help] [-alpha_parameters <string>]
                                   [-beta_parameters <string>]
                                   [-cell_thermal_resistance_file <string>]
                                   [-detail_delta_temperature_file <string>]
                                   [-detail_delta_temperature_region <string>]
                                   [-die_instance_input_signal_em <string>]
                                   [-die_instance_name <string>]
                                   [-instance_power_file <string>]
                                   [-report_conn_pin_wire <string>]
                                   [-scale_rms_limit <float>] [-tiles <string>] [ -tile_delta_temperature_file <string> ] [ -instance_delta_temperature_file <string> ]

-help                                     # Prints out the command usage
-alpha_parameters <string>                # self heat alpha layer parameters
                                          # (string, optional)
-beta_parameters <string>                 # self heat beta parameters
                                          # (string, optional)
-cell_thermal_resistance_file <string>    # <input: cell's equivalent thermal
                                          # resistance file> (string, optional)
-detail_delta_temperature_file <string>   # detailed delta temperature file
                                          # (string, optional)
-detail_delta_temperature_region <string>
                                          # detailed delta temperature region (string, optional)
-die_instance_input_signal_em <string>    # input signal self-heat related
                                          # setting per die (string, optional)
-die_instance_name <string>               # <die instance name
                                          # (string, optional)
-instance_delta_temperature_file <string>
                                          # instance delta temperature file (string, optional)
-instance_power_file <string>             # instance power file
                                          # (string, optional)
-report_conn_pin_wire <string>            # report results on wires connecting
                                          # to cell pins (string, optional)
-scale_rms_limit <float>                  # <RMS EM limit scale factor>
                                          # (float, optional)
-tile_delta_temperature_file <string>     # tile delta temperature file
                                          # (string, optional)
-tiles <string>                           # number of map tiles <num_x num_y>
                                          # (string, optional)