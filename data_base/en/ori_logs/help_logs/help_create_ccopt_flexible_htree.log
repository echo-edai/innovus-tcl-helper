Usage: create_ccopt_flexible_htree [-help]
                                   [-adjust_sink_grid_for_aspect_ratio <string>]
                                   [-auto_sinks_sink_area <string>]
                                   [-final_cell <libCell/ptnCell>]
                                   [-image_directory <string>] -name <string>
                                   [-partition_boundary_polarity {non_inverting inverting ignore}]
                                   -pin <instTerm|term|hInstTerm>+
                                   [-sink_grid_box <string>]
                                   [-sink_grid_exclusion_zones {string1 string2 ...}]
                                   [-sink_grid_sink_area <string>] {[-sinks {string1 string2 ...}] [-sink_grid <string>] [-auto_sinks <string>]} [ -layer_density <float> ] [ -hv_balance <string> ] [ -inverting ] [ -omit_symmetry <string> ] [ -power_weight <float> ] [ -stop_at_sdc_clock_roots ] [ -sinks {string1 string2 ...} ] [ -max_driver_distance <string> [ -max_root_distance <string> ]] [ -partition_groups <string> ]  [ -sink_instance_prefix <string> ] [ -mode <string> ] [-trunk_cell <libCell/ptnCell> ] [-sinks {string1 string2 ...} | -auto_sinks <string>] [ -sink_grid <string> | -auto_sinks <string>] [-hv_balance <string> ]

-help                                      # Prints out the command usage
-adjust_sink_grid_for_aspect_ratio <string>
                                           # If true adjust the sink grid for
                                           # the aspect ratio of the sink grid
                                           # box (if specified) or floorplan
                                           # (string, optional)
-auto_sinks <string>                       # Specifies the number of sink
                                           # rectangles per partition hinst and
                                           # top-level. (string, optional)
-auto_sinks_sink_area <string>             # Approximate size of the rectangle
                                           # describing the initial width and
                                           # height of automatically computed
                                           # sink rectangles {width height}
                                           # (string, optional)
-final_cell <libCell/ptnCell>              # Library cell to use for the H-tree
                                           # sinks (must be buffer or inverter)
                                           # ((libCell/ptnCell), optional)
-hv_balance <string>                       # Specifies whether horizontal and
                                           # vertical wires can only be
                                           # balanced against other wires of
                                           # the same orientation (true,
                                           # default), or whether any wire can
                                           # be balanced against any other wire
                                           # (false) (string, optional)
-image_directory <string>                  # Name of the directory to which
                                           # images are written (string, optional)
-inverting                                 # Specifies whether the tree will
                                           # invert its input (bool, optional)
-layer_density <float>                     # In DRV mode, the assumed layer
                                           # density used to compute the
                                           # parasitics for timing estimates of
                                           # H-tree nets during H-tree
                                           # synthesis based on the non default
                                           # rule for top nets (default 1.0)
                                           # (float, optional, min=0, max=1)
-max_driver_distance <string>              # In distance mode, the maximum
                                           # length of the nets connecting
                                           # H-tree drivers. (string, optional)
-max_root_distance <string>                # In distance mode, maximum length
                                           # of the net connecting the root and
                                           # the first driver of the H-tree.
                                           # (string, optional)
-mode <string>                             # Specifies the driver insertion
                                           # mode (default 'drv')
                                           # (string, optional)
-name <string>                             # Name of the flexible H-tree
                                           # (string, required)
-omit_symmetry <string>                    # Omit the creation of symmetry
                                           # drivers and/or branches to balance
                                           # the H-tree (string, optional)
-partition_boundary_polarity {non_inverting inverting ignore}
                                           # The polarity of the clock signal
                                           # with regard to the source when
                                           # entering partitions (enum, optional)
-partition_groups <string>                 # The groups in which partition are
                                           # clustered in channelless designs.
                                           # Nested lists imply allowed
                                           # crossings between groups.
                                           # (string, optional)
-pin <instTerm|term|hInstTerm>+            # Output pin or port under which the
                                           # H-tree is created
                                           # ((instTerm|term|hInstTerm)+, required)
-power_weight <float>                      # Specifies the power weight
                                           # (default 1.0)
                                           # (float, optional, min=0, max=1)
-sink_grid <string>                        # Specifies the columns and rows of
                                           # a grid of H-tree sinks {columns
                                           # rows}, where the columns and rows
                                           # may be swapped if
                                           # -adjust_sink_grid_for_aspect_ratio
                                           # is true. (string, optional)
-sink_grid_box <string>                    # Box describing the area that the
                                           # grid of H-tree sinks should cover
                                           # {xmin ymin xmax ymax}
                                           # (string, optional)
-sink_grid_exclusion_zones {string1 string2 ...}
                                           # Boxes describing zones that should
                                           # not be covered by the grid of
                                           # H-tree sinks. list {xmin ymin xmax
                                           # ymax} (list, optional)
-sink_grid_sink_area <string>              # Approximate size of the rectangle
                                           # describing valid locations for
                                           # final cells (given by -final_cell)
                                           # per H-tree sink in the grid {width
                                           # height} (string, optional)
-sink_instance_prefix <string>             # Prefix used for inst names of
                                           # final cells (given by -final_cell)
                                           # of H-tree sinks (string, optional)
-sinks {string1 string2 ...}               # Specifies H-tree sinks as
                                           # approximate rectangular areas for
                                           # locations of final cells (given by
                                           # -final_cell), or pins to wire to.
                                           # Nested lists imply clustering
                                           # relationships. list of {pin |
                                           # {xmin ymin xmax ymax}}
                                           # (list, optional)
-stop_at_sdc_clock_roots                   # Stop searching for parts of the
                                           # clock tree through SDC clock roots
                                           # when defining generated clock
                                           # trees for H-tree sinks
                                           # (bool, optional)
-trunk_cell <libCell/ptnCell>              # Library cell to use inside the
                                           # H-tree (must be buffer or
                                           # inverter)
                                           # ((libCell/ptnCell), optional)