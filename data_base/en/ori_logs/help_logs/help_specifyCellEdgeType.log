Usage: specifyCellEdgeType [-help] [-cellRow <integer>] {-left <string> | -right <string> | -top <string> | -bottom <string> | -reset } [{-left <string> | -right <string>} [-half {top | bottom}]] [{-top <string> | -bottom <string>} [-range {x y}]] [{-cell <string>} [-reset ]]

-help                   # Prints out the command usage
-bottom <string>        # specify an edge type on the bottom side
                        # (string, optional)
-cell <string>          # specify cell to which to add edge constraint
                        # (string, required)
-cellRow <integer>      # specify the row number for horizontal edge type
                        # (int, optional)
-half {top bottom}      # half row of the specified cell row (enum, optional)
-left <string>          # specify an edge type on the left side
                        # (string, optional)
-range {x y}            # specify the range for vertical edge type
                        # (point, optional)
-reset                  # reset the specified cell constraint to lef status
                        # (bool, optional)
-right <string>         # specify an edge type on the right side
                        # (string, optional)
-top <string>           # specify an edge type on the top side
                        # (string, optional)