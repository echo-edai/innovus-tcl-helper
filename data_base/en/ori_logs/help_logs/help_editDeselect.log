Usage: editDeselect [-help] [-area {x1 y1 x2 y2}] [-direction {H V 45 135}]
                    [-floating_via] [-layer <string>] [-nets <net>*]
                    [-physical_pin_only] [-regular_wire_with_drc]
                    [-shape {RING STRIPE FOLLOWPIN IOWIRE COREWIRE BLOCKWIRE PADRING BLOCKRING FILLWIRE FILLWIREOPC DRCFILL None}]
                    [-shield] [-shield_only]
                    [-status {COVER FIXED NOSHIELD ROUTED SHIELD UNKNOWN}]
                    [-subclass <string>] [-type {Regular Special Patch}]
                    [-use {CLOCK POWER SIGNAL}] [-via_cell <string>]
                    [-with_edit_flag {0 1}] [-object_type {Wire Via} ] [-from_pin <string> -to_pin <string>]

-help                             # Prints out the command usage
-area {x1 y1 x2 y2}               # Specifies the coordinates for the area from
                                  # which to deselect the wires. (box, optional)
-direction {H V 45 135}           # Specifies the orientation of the wires to
                                  # deselect. (enum, optional)
-floating_via                     # Specifies only select floating vias
                                  # (bool, optional)
-from_pin <string>                # Specify the start pin name for deselect
                                  # wire. (string, optional)
-layer <string>                   # Specifies the layers from which to deselect
                                  # wires or vias. (string, optional)
-nets <net>*                      # Specifies the net names from which to
                                  # deselect wires or vias. ((net)*, optional)
-object_type {Wire Via}           # Specified whether to select wires or vias
                                  # (enum_list, optional)
-physical_pin_only                # Specifies whether to deselect physical
                                  # pins. (bool, optional)
-regular_wire_with_drc            # Specifies whether to select regular wires
                                  # with violation markers. (bool, optional)
-shape {RING STRIPE FOLLOWPIN IOWIRE COREWIRE BLOCKWIRE PADRING BLOCKRING FILLWIRE FILLWIREOPC DRCFILL None}
                                  # Specifies the shapes of the wires or vias
                                  # to deselect. (enum_list, optional)
-shield                           # Specifies whether to deselect the wires and
                                  # vias of nets specified by -nets and the
                                  # wires and vias shielding the nets specified
                                  # by the -nets parameter. (bool, optional)
-shield_only                      # Specifies whether to deselect the wires and
                                  # vias shielding the nets specified by the
                                  # -nets parameter. (bool, optional)
-status {COVER FIXED NOSHIELD ROUTED SHIELD UNKNOWN}
                                  # Specifies the status of wires to deselect. (enum_list, optional)
-subclass <string>                # Specifies the subclass name of the wires to
                                  # be deselected. (string, optional)
-to_pin <string>                  # Specify the end pin name for deselect wire.
                                  # (string, optional)
-type {Regular Special Patch}     # Specifies whether to deselect regular wires
                                  # or special wires or patch wires.
                                  # (enum, optional)
-use {CLOCK POWER SIGNAL}         # Specifies that only CLOCK wires will be
                                  # deselected. (enum, optional)
-via_cell <string>                # Specifies the via cells of vias to be
                                  # selected (string, optional)
-with_edit_flag {0 1}             # Specifies whether to deselect the wires
                                  # with specified value of property "isEdit"
                                  # on the net (enum, optional)