Usage: set_proto_model [-help] [-create_extra_macro <string>] -model <string>
                       [-planDesign_target_util <float>] [-reset]
                       [-type {full flex_module flex_instgroup}] [[-create_total_area <float>] | [-create_gate_area <float>] | [-create_gate_count <integer> -create_area_per_gate <float>]]

-help                               # Prints out the command usage
-create_area_per_gate <float>       # Specifies area per gate in square micron.
                                    # (float, optional, min=0, max=1.79769313486232e+308)
-create_extra_macro <string>        # Specifies the additional macros to be
                                    # added to the original netlist.
                                    # (string, optional)
-create_gate_area <float>           # Specifies total area of gates. This value
                                    # does not include macro area.
                                    # (float, optional, min=0, max=1.79769313486232e+308)
-create_gate_count <integer>        # Specifies number of gates.
                                    # (int, optional)
-create_total_area <float>          # Specifies the model area that includes
                                    # standard cell area and macro area.
                                    # (float, optional, min=0, max=1.79769313486232e+308)
-model <string>                     # Specifies a model name.
                                    # (string, required)
-planDesign_target_util <float>     # Specifies target utilization value will
                                    # be used by planDesign to derive initial
                                    # size of the model.
                                    # (float, optional, min=0, max=1.79769313486232e+308)
-reset                              # Resets parameters to their default
                                    # values. If you specify -reset by itself,
                                    # the software resets all set_proto_model
                                    # parameters to their default values. If
                                    # you specify parameters after -reset, the
                                    # software resets only those parameters to
                                    # their default values. (bool, optional)
-type {full flex_module flex_instgroup}    # Specifies the model type.
                                           # (enum, optional)