Usage: set_io_thresholds [-help] { [-slew_lower_threshold_pct <pctValue>]  [-slew_upper_threshold_pct <pctValue>]  [-input_threshold_pct <pctValue>]  [-output_threshold_pct <pctValue>] } | { [-slew_lower_threshold_pct_rise <pctValue>]  [-slew_lower_threshold_pct_fall <pctValue>]  [-slew_upper_threshold_pct_rise <pctValue>]  [-slew_upper_threshold_pct_fall <pctValue>]  [-input_threshold_pct_rise <pctValue>]  [-input_threshold_pct_fall <pctValue>]  [-output_threshold_pct_rise <pctValue>]  [-output_threshold_pct_fall <pctValue>] }

-help                                    # Prints out the command usage
-input_threshold_pct <pctValue>          # specifies the slew input threshold
                                         # value (int, optional)
-input_threshold_pct_fall <pctValue>     # specifies the slew input fall
                                         # threshold value (int, optional)
-input_threshold_pct_rise <pctValue>     # specifies the slew input rise
                                         # threshold value (int, optional)
-output_threshold_pct <pctValue>         # specifies the slew output threshold
                                         # value (int, optional)
-output_threshold_pct_fall <pctValue>    # specifies the slew output fall
                                         # threshold value (int, optional)
-output_threshold_pct_rise <pctValue>    # specifies the slew output rise
                                         # threshold value (int, optional)
-slew_lower_threshold_pct <pctValue>     # specifies the slew lower threshold
                                         # value (int, optional)
-slew_lower_threshold_pct_fall <pctValue>
                                         # specifies the slew lower fall
                                         # threshold value (int, optional)
-slew_lower_threshold_pct_rise <pctValue>
                                         # specifies the slew lower rise
                                         # threshold value (int, optional)
-slew_upper_threshold_pct <pctValue>     # specifies the slew upper threshold
                                         # value (int, optional)
-slew_upper_threshold_pct_fall <pctValue>
                                         # specifies the slew upper fall
                                         # threshold value (int, optional)
-slew_upper_threshold_pct_rise <pctValue>
                                         # specifies the slew upper rise
                                         # threshold value (int, optional)