Usage: check_library [-help] [-place [-cell <cells> | -all_lib_cell ] [-legal_frequency ] [-file <name>] ]

-help                                      # Prints out the command usage
-all_lib_cell                              # check all lib cells
                                           # (bool, optional)
-cell <cells>                              # specify cells to check
                                           # ((libCell/ptnCell)+, optional)
-file <name>                               # output file name
                                           # (string, optional)
-legal_frequency                           # check multi-height cell legal
                                           # frequency (bool, optional)
-place                                     # do library checking for placement
                                           # (bool, optional)