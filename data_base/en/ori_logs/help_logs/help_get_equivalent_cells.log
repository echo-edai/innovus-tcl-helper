Usage: get_equivalent_cells [-help] -cell <string> [ [ [ { { -delay_corner <string> [-early_only | -late_only ] } | -max | -min } [-power_domain <string>] ] | -library <string> ] ]

-help                      # Prints out the command usage
-cell <string>             # Cell Name for which equivalent cells need to be
                           # fetched (string, required)
-delay_corner <string>     # to fetch equivalent cells from libraries of a
                           # specific delay corner only (string, optional)
-early_only                # to fetch cells only from early libraries of the
                           # specified delay corner (bool, optional)
-late_only                 # to fetch cells only from late libraries of the
                           # specified delay corner (bool, optional)
-library <string>          # to fetch cells only for the given library 
                           # (string, optional)
-max                       # to fetch equivalent cells from max libraries only
                           # (bool, optional)
-min                       # to fetch equivalent cells from min libraries only
                           # (bool, optional)
-power_domain <string>     # to fetch cells only for the libraries of a
                           # specific power domain (string, optional)