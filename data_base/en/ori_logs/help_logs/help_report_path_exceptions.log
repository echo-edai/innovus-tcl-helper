Usage: report_path_exceptions [-help] [-all] [-ignored] [-tcl_list]
                              [> <filename[.gz]>] [>> <filename[.gz]>] [-view <view_name> ] [-early | -late ]

-help                        # Prints out the command usage
-all                         # Reports all applied and ignored path exceptions
                             # (bool, optional)
-early                       # Generates the path exception report for early
                             # reports (bool, optional)
-ignored                     # Reports only the path exceptions that have been
                             # ignored by timing analysis (bool, optional)
-late                        # Generates the path exception report for late
                             # reports (bool, optional)
-tcl_list                    # Produces the report in Tcl list format instead
                             # of a tabular format (bool, optional)
-view <view_name>            # Generates a timing check report for the
                             # specified analysis view only. By default all
                             # active views are reported (string, optional)
> <filename[.gz]>            # Redirects output to specified file
                             # (redirect_operator, optional)
>> <filename[.gz]>           # Redirects output to specified file
                             # (redirect_operator, optional)