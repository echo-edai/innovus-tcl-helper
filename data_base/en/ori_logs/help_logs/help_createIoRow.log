Usage: createIoRow [-help] {-site <site_name> [{ {-side <string> [-rowMargin <val>] [-beginOffset <val>] [-endOffset <val> | -length <len> | -nrSites <nr>]} |{-corner <string> [-xOffset <val>] [-yOffset <val>]} }] [-orientation <string>] [-name <row_name>]}| {-deriveByCells } | {-deriveBySelection }

-help                      # Prints out the command usage
-beginOffset <val>         # distance from die edge (float, optional)
-corner <string>           # for corner cell row, always one site row BL BR TR
                           # TL (string, optional)
-deriveByCells             # create io row for all io cells in design.
                           # (bool, required)
-deriveBySelection         # create IO row from selected cells (bool, required)
-endOffset <val>           # distance from die edge for end of IO row
                           # (float, optional)
-length <len>              # row lenght starting from die edge or -beginOffset
                           # val. (float, optional)
-name <row_name>           # name for new IO row (string, optional)
-nrSites <nr>              # row length in number of site. (int, optional)
-orientation <string>      # row orientation, can be one of R0, R90, R180, R270
                           # (string, optional)
-rowMargin <val>           # distance from row edge to die edge.
                           # (float, optional)
-side <string>             # if no side is specified, 1 row on each side
                           # (S,E,N,and W) will be created. (string, optional)
-site <site_name>          # IO cell site name (string, required)
-xOffset <val>             # distance of left or right edge of corner row to
                           # die edge. (float, optional)
-yOffset <val>             # distance of top or bottom edge of corner row to
                           # die edge. (float, optional)