Usage: get_add_target_pg_mode [-help] [-allow_weak_connect]
                              [-max_extension_distance] [-pins]
                              [-pins_group_distance] [-respect_routes]
                              [-share_resource] [-quiet] [-nonDefault]

-help                            # Prints out the command usage
-allow_weak_connect              # Decreate specified pillar number to avoid
                                 # drc (bool, default=false)
-max_extension_distance          # Specify the max distance that target PG pin
                                 # can extend to target layer
                                 # (float, default=2147483647)
-pins                            # Specify the cell pins to be connected
                                 # (string, default="")
-pins_group_distance             # Specify the side_to_side distance of pins to
                                 # be treated as a group during connecting
                                 # target PG pins (string, default=auto)
-respect_routes                  # Specifies whether to honor pre-existing
                                 # routes check during stripe generation
                                 # (enums={none | fixed | fixed_and_clock | all}, default=fixed_and_clock)
-share_resource                  # New added PG connect to the existing PG at
                                 # middle layer (bool, default=true)
-quiet                           # Displays the current settings in Tcl list format only
-nonDefault                      # Displays the current settings which are not default settings