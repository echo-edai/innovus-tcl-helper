#################################################################################
# Design Stage: PreRoute
# Design Mode: 90nm
# Analysis Mode: Non-MMMC Non-OCV 
# Parasitics Mode: No SPEF/RCDB 
# Signoff Settings: SI Off 
#################################################################################

Usage: ecoAddBacksideConstraint [-help] -embeddedFtvCells {list of cells}
                                -net <netName>
                                -topPreferredLayer <top-layer-name> [-groupTerms {{..} {..}} | -minimumFtvs ] [-loc {xLoc yLoc} | { xLoc yLoc inv_xLoc inv_yLoc} [-bufOrient {R0 | R90 | R180 | R270 | MX | MX90 | MY | MY90}]]

-help                                 # Prints out the command usage
-bufOrient {R0 | R90 | R180 | R270 | MX | MX90 | MY | MY90}
                                      # Specifies orientation(s) for FTV
                                      # instance(s) (string, optional)
-embeddedFtvCells {list of cells}     # Specifies names of FTVO and FTVI cells
                                      # (one each) (string, required)
-groupTerms {{..} {..}}               # Specifies groups of terms with common
                                      # FTV cell (string, optional)
-loc {xLoc yLoc} | { xLoc yLoc inv_xLoc inv_yLoc}
                                      # Specifies location(s) where FTV
                                      # instance(s) will be placed
                                      # (point_list, optional)
-minimumFtvs                          # Add one FTVO cell at driver term and
                                      # one FTVI cell to drive all the sinks
                                      # (bool, optional)
-net <netName>                        # Specifies name of the net on which FTV
                                      # cells are to be added (string, required)
-topPreferredLayer <top-layer-name>   # Specifies name of the preferred top
                                      # back-side layer (string, required)