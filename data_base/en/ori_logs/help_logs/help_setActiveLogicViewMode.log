Usage: setActiveLogicViewMode [-help] [-reset] [-keepAsync {true|false}]
                              [-keepHighFanoutPorts {true|false}]
                              [-keepInstInSdc {true|false}]
                              [-keepLoopBack {true|false}]

-help                                 # Prints out the command usage
-reset                                # Resets all or specified options to default value
-keepAsync {true|false}               # Keep paths from asynchronous input
                                      # ports (bool, default=false)
-keepHighFanoutPorts {true|false}     # Keep high fanout input port paths
                                      # (bool, default=true)
-keepInstInSdc {true|false}           # Keep instances which have constraints
                                      # on it (bool, default=false)
-keepLoopBack {true|false}            # Keep loop back paths
                                      # (bool, default=false)