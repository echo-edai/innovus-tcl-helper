Usage: generate_xpgv [-help] -cell <string> [-inst_list <string>]
                     [-libgen_include <string>] [-output_dir <string>]
                     [-rail_include <string>]
                     [-reuse_block_state_directory <string>]
                     {-state_directory <string> | -mvmf_config <string>}

-help                                     # Prints out the command usage
-cell <string>                            # (string, required)
-inst_list <string>                       # (string, optional)
-libgen_include <string>                  # (string, optional)
-mvmf_config <string>                     # (string, required)
-output_dir <string>                      # ./ (string, optional)
-rail_include <string>                    # (string, optional)
-reuse_block_state_directory <string>     # (string, optional)
-state_directory <string>                 # (string, required)