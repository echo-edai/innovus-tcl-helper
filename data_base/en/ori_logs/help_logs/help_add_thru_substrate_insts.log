add_thru_substrate_insts -net net [-driver_thru_substrate_cell cell1] -load_thru_substrate_cell cell2 [-shared_load_thru_substrate_cell] [-selected] [-redraw]

-help                                # Prints out the command usage
-driver_thru_substrate_cell <libCell/ptnCell>
                                     # Thru-substrate cell for driver ((libCell/ptnCell), optional)
-load_thru_substrate_cell <libCell/ptnCell>
                                     # Thru-substrate cell for load(s) ((libCell/ptnCell), required)
-net <net>                           # Net to add thru-substrate instances
                                     # ((net), required)
-redraw                              # Redraw the graphics window
                                     # (bool, optional)
-selected                            # Only selected loads are routed through
                                     # the backside (bool, optional)
-shared_load_thru_substrate_cell     # Loads share one thru-substrate instance
                                     # (one thru-substrate instance for each
                                     # load if not specified) (bool, optional)