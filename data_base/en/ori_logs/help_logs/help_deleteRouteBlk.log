Usage: deleteRouteBlk [-help] [-cutLayer <list of layerName | layerZ | all>]
                      [-drcRegionLayer <list of layerName | layerZ | all>]
                      [-layer <list of layerName | layerZ | all>]
                      [-trimMetalLayer <list of layerName | layerZ | all>]
                      [-type {all routes fills slots partial}] [-box {x1 y1 x2 y2} | -name <blk> | -all ]

-help                                      # Prints out the command usage
-all                                       # delete all routing blockages
                                           # (bool, required)
-box {x1 y1 x2 y2}                         # llx, lly, urx, ury (box, required)
-cutLayer <list of layerName | layerZ | all>
                                           # specify cut layers (list, optional)
-drcRegionLayer <list of layerName | layerZ | all>
                                           # specify region layers (list, optional)
-layer <list of layerName | layerZ | all>
                                           # specify metal layers (list, optional)
-name <blk>                                # blockage names need be deleted,
                                           # wild char support. (list, required)
-trimMetalLayer <list of layerName | layerZ | all>
                                           # specify trimMetal layers (list, optional)
-type {all routes fills slots partial}     # only delete this type of
                                           # blockage,default all (enum, optional)