Usage: streamOut [-help] <fileName> [-attachNetProp <string>]
                 [-dieAreaAsBoundary] [-extraMapFile <string>]
                 [-ignoreSubtype {NETTYPE SHAPE}] [-libName <string>]
                 [-mapFile <string>] [-mergeViaCellMapFile <string>]
                 [-mode {ALL FILLONLY NOFILL NOINSTANCES}] [-noStructureName]
                 [-offset {x y}] [-outputCriticalNetColorFromFileOnly <string>]
                 [-outputMacros] [-probe_pin_label <string>]
                 [-reportFile <string>] [-signoff_fill]
                 [-structureName <string>] [-units <integer>] [-merge <string> [-noTSV <tsv_name_list>] [-uniquifyCellNames ]] [{-area {x1 y1 x2 y2} } [-strict ] [-enclosed_instances_only ]] [-format {stream oasis} [-outputInstanceName <string>] [-outputNetName <string>]] [-attachInstanceName <integer> | -outputInstanceName <string>] [-attachNetName <integer> | -outputNetName <string>]

-help                             # Prints out the command usage
<fileName>                        # <fileName> (list, required)
-area {x1 y1 x2 y2}               # -area x1 y1 x2 y2 (box, optional)
-attachInstanceName <integer>     # -attachInstanceName <attrNumber>
                                  # (int, optional)
-attachNetName <integer>          # -attachNetName <attrNumber> (int, optional)
-attachNetProp <string>           # -attachNetProp { {<prop_name> <attr_num>}
                                  # ... } (string, optional)
-dieAreaAsBoundary                # output die area as boundary
                                  # (bool, optional)
-enclosed_instances_only          # Only stream out the instances whose shapes
                                  # are fully enclosed by specified area.
                                  # (bool, optional)
-extraMapFile <string>            # specify extra map file. (string, optional)
-format {stream oasis}            # Specify tape out file format
                                  # (enum, optional)
-ignoreSubtype {NETTYPE SHAPE}    # Ignore the map file line with subtype
                                  # keywords (enum_list, optional)
-libName <string>                 # -libName libraryName (string, optional)
-mapFile <string>                 # -mapFile mapFile (string, optional)
-merge <string>                   # -merge {list of external Stream files}
                                  # (string, optional)
-mergeViaCellMapFile <string>     # Specify the cell list which need merge via
                                  # cell from external file. (string, optional)
-mode {ALL FILLONLY NOFILL NOINSTANCES}    # output mode type (enum, optional)
-noStructureName                  # merge GDSII file withOut loading design
                                  # (bool, optional)
-noTSV <tsv_name_list>            # A list of TSV via names that should be from
                                  # merge file not be written out from design.
                                  # (string, optional)
-offset {x y}                     # -offset x y (point, optional)
-outputCriticalNetColorFromFileOnly <string>
                                  # Specify the net list and layer range which
                                  # need output color to gds file.
                                  # (string, optional)
-outputInstanceName <string>      # Write the instance name string to oasis
                                  # file. (string, optional)
-outputMacros                     # output macros (bool, optional)
-outputNetName <string>           # Write the net name string to oasis file.
                                  # (string, optional)
-probe_pin_label <string>         # User specify probe label string, default
                                  # PROBE_PIN (string, optional)
-reportFile <string>              # -reportFile fileName (string, optional)
-signoff_fill                     # Merge the signoff fill data attached to the
                                  # current DB into the output gds file.
                                  # (bool, optional)
-strict                           # Truncate the object outside the area
                                  # (bool, optional)
-structureName <string>           # top structure name (string, optional)
-uniquifyCellNames                # uniquify conflict cell name in merge file
                                  # (bool, optional)
-units <integer>                  # -units
                                  # {100|200|400|800|1000|2000|4000|8000|10000|20000} (int, optional)