Usage: reset_input_delay [-help] <port_or_pin_list> [-clock <clock_name>]
                         [-clock_fall] [-fall] [-level_sensitive] [-max] [-min]
                         [-rise]

-help                   # Prints out the command usage
<port_or_pin_list>      # Specifies a single or multiple pins or ports for
                        # which the input delay is reset (string, required)
-clock <clock_name>     # Name of the clock (string, optional)
-clock_fall             # Removes the assertions for the delay that is relative
                        # to the falling edge of the clock (bool, optional)
-fall                   # Resets the input delay for the falling edge at the
                        # input port (bool, optional)
-level_sensitive        # Resets input delay that is launched by a positive
                        # level sensitive latch (bool, optional)
-max                    # Removes the delay assertions that refer to the setup
                        # analysis (bool, optional)
-min                    # Removes the delay assertions that refer to the hold
                        # analysis (bool, optional)
-rise                   # Resets the input delay for the rising edge at the
                        # input port (bool, optional)