Usage: defOut [-help] <fileName> [-addHalfWireExtensionOnPin] [-allLayers]
              [-bumpAsPin] [-cutRow] [-cut_pg_rail] [-earlyGlobalRoute]
              [-flatten_via_pillar] [-floorplan] [-ioRow] [-netlist]
              [-noCoreCells] [-noPrintWildCard] [-noStdCells] [-noTracks]
              [-no_covered_wire_patch] [-no_virtual_trim]
              [-outputMaskLayers <string>] [-scanChain] [-selected]
              [-skip_trimmetal_layers] [-specialRouteUserClass <string>]
              [-trimmetal_gap_fill] [-unit <unit_per_micron>] [-unplaced]
              [-useEEQCellWithLibertyInfo] [-usedVia]
              [-verilog_from_def_netlist_flow] [-withShield] [-routing [-routing_to_specialnet | -wrongway_routing_as_specialroute ]] [ -noSpecialNet ]

-help                              # Prints out the command usage
<fileName>                         # Output DEF file name (string, required)
-addHalfWireExtensionOnPin         # Forces the zero-extension on pins to the
                                   # default half-width extension (bool, optional)
-allLayers                         # Writes out any wires and shapes on
                                   # non-routing layers to SPECIALNETS section
                                   # (bool, optional)
-bumpAsPin                         # Writes bump cells as top-level pins in the
                                   # PINS section (bool, optional)
-cutRow                            # Cuts rows against placement obstructions,
                                   # block halos, or power domain fence minimum
                                   # gaps (bool, optional)
-cut_pg_rail                       # Cut the pg rails (bool, optional)
-earlyGlobalRoute                  # Writes information about the wires
                                   # generated by Early Global Router to the
                                   # NETS section of the DEF file (bool, optional)
-flatten_via_pillar                # Via pillars are flattened into separate
                                   # individual vias. (bool, optional)
-floorplan                         # Writes the floorplan data to the DEF file
                                   # (bool, optional)
-ioRow                             # Generates I/O rows based on I/O pad
                                   # placement, and writes the I/O row
                                   # information to the DEF file (bool, optional)
-netlist                           # Writes the netlist to the DEF file
                                   # (bool, optional)
-noCoreCells                       # Excludes core cell information from the
                                   # DEF file to reduce the data size for
                                   # import into APD (bool, optional)
-noPrintWildCard                   # Suppresses the use of the wildcard format
                                   # to represent special net connectivity
                                   # (bool, optional)
-noSpecialNet                      # Excludes special net information from the
                                   # DEF file (bool, optional)
-noStdCells                        # Excludes placed and unplaced standard cell
                                   # information from the DEF file
                                   # (bool, optional)
-noTracks                          # Excludes output track and gcell statements
                                   # to the DEF file (bool, optional)
-no_covered_wire_patch             # Don't write out wire patch that is covered
                                   # by a routing (bool, optional)
-no_virtual_trim                   # Don't write out virtual trims
                                   # (bool, optional)
-outputMaskLayers <string>         # Output MASK data on specified layers only
                                   # (string, optional)
-routing                           # Writes the routing information to the NETS
                                   # section of the DEF file (bool, optional)
-routing_to_specialnet             # Write all regular NETS routing to the
                                   # SPECIALNETS section (bool, optional)
-scanChain                         # Writes scan chain information to the DEF
                                   # file (bool, optional)
-selected                          # Writes only the DEF header, selected
                                   # instances in COMPONENTS section and
                                   # routing on selected nets in
                                   # SPECIALNETS/NETS section if -routing is
                                   # also specified (bool, optional)
-skip_trimmetal_layers             # not write trimmetal shapes in FILLS
                                   # section (bool, optional)
-specialRouteUserClass <string>    # User Class for special route
                                   # (string, optional)
-trimmetal_gap_fill                # write trimmetal gap fills to a dummy net
                                   # _TRIMMETAL_FILLS_RESERVERD in SPECIALNETS
                                   # section (bool, optional)
-unit <unit_per_micron>            # Unit per micron for the DEF file
                                   # (int, optional)
-unplaced                          # Writes information about unplaced standard
                                   # cells to the DEF file (bool, optional)
-useEEQCellWithLibertyInfo         # use EEQ cell with timing library info as
                                   # the master cell of a leaf instance
                                   # (bool, optional)
-usedVia                           # Writes out used vias only to DEF file
                                   # (bool, optional)
-verilog_from_def_netlist_flow     # Reconciles the names in the DEF and
                                   # Verilog files generated by the loadDefFile
                                   # command (bool, optional)
-withShield                        # Writes out shield information to DEF file
                                   # (bool, optional)
-wrongway_routing_as_specialroute  # Write wrong way routing in the SPECIALNETS
                                   # section (bool, optional)