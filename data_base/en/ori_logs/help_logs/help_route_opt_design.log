Usage: route_opt_design [-help] [-drv] [-hold] [-ideal_clock] [-incremental]
                        [-num_paths <string>] [-opt] [-out_dir <string>]
                        [-prefix <string>] [-route] [-setup]
                        [-timing_debug_report]

-help                       # Prints out the command usage
-drv                        # DRV fixing only (bool, optional)
-hold                       # Hold fixing (bool, optional)
-ideal_clock                # Ideal Clock option (bool, optional)
-incremental                # PostRoute incremental optimization
                            # (bool, optional)
-num_paths <string>         # Specify number of timing paths generated in
                            # timing report (string, optional)
-opt                        # PostRoute Optimization only (bool, optional)
-out_dir <string>           # Specify dir for reports (string, optional)
-prefix <string>            # Specify prefix for reports (string, optional)
-route                      # Do route only (bool, optional)
-setup                      # Setup and DRV fixing (bool, optional)
-timing_debug_report        # Generate machine readable timing report
                            # (bool, optional)