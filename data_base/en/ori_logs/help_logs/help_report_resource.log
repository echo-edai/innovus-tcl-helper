Usage: report_resource [-help] [-peak] [-verbose] [-start <string> | [-end <string> [-session_cpu ] [-diff_memory ]]] [-check_MemCpu {true false} [-period <integer>] [-memory_threshold <float>]]

-help                          # Prints out the command usage
-check_MemCpu {true false}     # Checks the machine's physical memory and CPU
                               # resources. When specified, the software
                               # enables memory/CPU checking and reports a
                               # warning if the free memory is below 5 percent
                               # of the total memory or if the average CPU load
                               # large. (enum, optional)
-diff_memory                   # output different peak memory and current
                               # memory between step start and step end 
                               # (bool, optional)
-end <string>                  # Specifies the end point to measure the peak
                               # memory attained during a specific command
                               # (string, optional)
-memory_threshold <float>      # Specifies the threshold as ratio of total
                               # machine/LSF memory. Warning is to be flagged
                               # if available memory goes below this threshold
                               # (float, optional, min=0, max=1)
-peak                          # Reports current peak memory till a given point
                               # in a flow (bool, optional)
-period <integer>              # Period of checking the physical memory and CPU
                               # usage, default 1800s
                               # (int, optional, min=1, max=INT_MAX)
-session_cpu                   # report current cpu and real time after report
                               # last step status (bool, optional)
-start <string>                # Specifies the start point to measure the peak
                               # memory attained during a specific command
                               # (string, optional)
-verbose                       # report detailed memory information
                               # (bool, optional)