Usage: spaceObject [-help]
                   -fixSide {left right center top bottom middle distHorizontal distVertical}
                   [-honorHalo] [-space <float> [-isSpaceMeanLLtoLL ] ]

-help                                  # Prints out the command usage
-fixSide {left right center top bottom middle distHorizontal distVertical}
                                       # fixed side for spacing (enum, required)
-honorHalo                             # halo to instance boundary
                                       # (bool, optional)
-isSpaceMeanLLtoLL                     # is the space inputted means distance
                                       # from objectA's lower left to objectB's
                                       # lower left? default is false, which
                                       # means the space is the distance
                                       # between their bounding box
                                       # (bool, optional)
-space <float>                         # space value (float, optional)