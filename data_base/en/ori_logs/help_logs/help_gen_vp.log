Usage: gen_vp [-help] [-allow_finger_outside_cell {0 1}]
              [-dont_gen_list <string>] [-em_config_file <string>]
              [-finger_pitch <string>] [-gen_list <string>]
              [-match_pattern <string>] [-max_cell_extension <string>]
              [-max_finger_quantity <string>] -output_association_file <string>
              -output_rule_lef_file <string> [-prefix <string>]
              [-process_node {N7 N7Plus N6 N5 N4 N3 N2 S5 S3 P1278 P1280}]
              [-specify_cut_class <string>] [-top_num_limit <string>]
              [-vp_bottom_layer <string>] [-vp_top_layers <string>]
              [-write_cut_class {0 1}]

-help                                 # Prints out the command usage
-allow_finger_outside_cell {0 1}      # Allow 1 finger outside cell when not
                                      # able to create multiple fingers inside
                                      # cell boundary. Default: 0 (enum, optional)
-dont_gen_list <string>               # Cell list that dont generate via
                                      # pillars. (string, optional)
-em_config_file <string>              # Provide EM config file. EM config file
                                      # must follow EM syntax/format.
                                      # (string, optional)
-finger_pitch <string>                # The pitch of each layer's finger.
                                      # Default: M2 and M3 are 3 and others are
                                      # 2. (string, optional)
-gen_list <string>                    # Cell list that generate via pillars.
                                      # (string, optional)
-match_pattern <string>               # Customized library cell match pattern
                                      # to catch footprint and driving strength
                                      # (string, optional)
-max_cell_extension <string>          # The maximum extension pitch outside
                                      # cell boundary for via pillar fingers
                                      # creation. Specify the value by layer.
                                      # Default is 1 for all layers
                                      # (string, optional)
-max_finger_quantity <string>         # The maximum finger quantity by layer.
                                      # The value MUST be larger or equal to 2.
                                      # Default: M2/M4 is 3, M3 is 16, and M5
                                      # above is 2. (string, optional)
-output_association_file <string>     # Generate standard mode via pillar
                                      # association file. (string, required)
-output_rule_lef_file <string>        # Generate standard/rich mode combined
                                      # via pillar rule LEF. (string, required)
-prefix <string>                      # Prefix name of via pillars.
                                      # (string, optional)
-process_node {N7 N7Plus N6 N5 N4 N3 N2 S5 S3 P1278 P1280}
                                      # The library process node. The default
                                      # finger pitch is corresponding to
                                      # process node. User still can change the
                                      # finger pitch by "-finger_pitch".
                                      # (enum, optional)
-specify_cut_class <string>           # The cut class of each cut layer. For
                                      # example, specify VIA1's cut class as
                                      # SINGLECUT_A, apply -specify_cut_class
                                      # {VIA1 SINGLECUT_A}. (string, optional)
-top_num_limit <string>               # Write out only the top N largest rules
                                      # for each cell pin. Default: No limit.
                                      # (string, optional)
-vp_bottom_layer <string>             # The bottom layer of created via pillars
                                      # if pins are available on the specified
                                      # layer. Default: M1 (string, optional)
-vp_top_layers <string>               # The top layers of created via pillars.
                                      # Default: {M4 M5} (string, optional)
-write_cut_class {0 1}                # Write out cut class in vp file. Default
                                      # : 0 (enum, optional)