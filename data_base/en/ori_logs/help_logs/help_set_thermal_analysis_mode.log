Usage: set_thermal_analysis_mode [-help] [-boundary_condition_file <string>]
                                 [-power_map_file <string>]
                                 [-temperature_map_file <string>]
                                 [-thermal_output_dir <string>]
                                 [-tool_path <string>]

-help                                 # Prints out the command usage
-boundary_condition_file <string>     # <die boundary condition file>
                                      # (string, optional)
-power_map_file <string>              # <power map files> (string, optional)
-temperature_map_file <string>        # <temperature map file>
                                      # (string, optional)
-thermal_output_dir <string>          # <output directory> (string, optional)
-tool_path <string>                   # <bin folder of thermal tool>
                                      # (string, optional)