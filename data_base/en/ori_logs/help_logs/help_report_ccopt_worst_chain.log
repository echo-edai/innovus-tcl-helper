Usage: report_ccopt_worst_chain [-help] [-file <filename>]
                                [-view <analysis_view>] [ -check_type <type> ] [ -through <pin> | -through_file <filename> ]

-help                        # Prints out the command usage
-check_type {setup hold}     # the check type to query (enum, optional)
-file <filename>             # write report to this file (string, optional)
-through <pin>               # worst chain through this pin
                             # ((instTerm|term), optional)
-through_file <filename>     # create a worst chain report for each pin in this
                             # file (string, optional)
-view <analysis_view>        # the view for which the worst chain is reported
                             # ((analysis_view), optional)