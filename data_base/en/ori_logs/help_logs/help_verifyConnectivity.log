Usage: verifyConnectivity [-help] [-allPGPinPort] [-append] [-dividePowerNet]
                          [-error <integer>] [-ignorePGPin <string>]
                          [-markerOnHighestLayer] [-noAntenna] [-noFill]
                          [-noFloatingMetal] [-noOpen] [-noSoftPGConnect]
                          [-noUnConnPin] [-noUnroutedNet] [-noWeakConnect]
                          [-rawViolsMark] [-removeOldOpenVio] [-tsv <string>]
                          [-type {all regular special}] [-useNewOpenVio]
                          [-useVirtualConnection] [-warning <integer>] [-net <string> | -selected ] [-connLoop | -geomLoop ] [-centerLineConnect ] [-report <string> ] [-net <string> [-honorGroundLayerRange ]] [-preferredTopLayer <integer> | -honorGroundLayerRange ]

-help                           # Prints out the command usage
-allPGPinPort                   # Verify all PG ports connection.
                                # (bool, optional)
-append                         # Displays incremental results in the Violation
                                # Browser (bool, optional)
-centerLineConnect              # Uses a center-line model instead of the
                                # geometrical model to check regular nets
                                # (bool, optional)
-connLoop                       # Checks for connectivity loops in regular
                                # wires (bool, optional)
-dividePowerNet                 # Divides power nets into four subareas for
                                # connectivity verification (bool, optional)
-error <integer>                # Specifies the maximum number of errors to
                                # report (int, optional)
-geomLoop                       # Checks for loop violations of regular nets
                                # using a geometrical model (bool, optional)
-honorGroundLayerRange          # hornor GROUNDCONNECTIVITYLAYERS in
                                # connectivity check (bool, optional)
-ignorePGPin <string>           # Specifies the cell containing the pg pin that
                                # can be ignored in connectivity check
                                # (string, optional)
-markerOnHighestLayer           # Marker on the highest layer (bool, optional)
-net <string>                   # Specifies whether to check named nets
                                # (string, optional)
-noAntenna                      # Ignores violations due to unconnected wires
                                # (bool, optional)
-noFill                         # Specifies that metal fill should also be
                                # checked (bool, optional)
-noFloatingMetal                # Ignore floating metals that do not connected
                                # to any pin shapes (bool, optional)
-noOpen                         # Ignores open violations (bool, optional)
-noSoftPGConnect                # Disables utilizing masterslice layers in
                                # connectivity check (bool, optional)
-noUnConnPin                    # Ignores unconnected-pin violations
                                # (bool, optional)
-noUnroutedNet                  # Ignores nets that are not routed
                                # (bool, optional)
-noWeakConnect                  # Disables checking for routing to more than
                                # one port of the weakly connected pin ports
                                # (bool, optional)
-preferredTopLayer <integer>    # Specifies the preferred top layer to check
                                # (int, optional)
-rawViolsMark                   # Displays violation markers for opens as the
                                # bounding box of the island (bool, optional)
-removeOldOpenVio               # remove old open violation (bool, optional)
-report <string>                # Specifies the report file for connectivity
                                # violation data (string, optional)
-selected                       # Specifies whether to check selected nets or
                                # nets connected to the pins of selected
                                # instances/macros (bool, optional)
-tsv <string>                   # Specifies the TSV abstract die files to
                                # verify connectivity between the current die
                                # and the adjacent dies (string, optional)
-type {all regular special}     # Specifies the type of wires to verify
                                # (enum, optional)
-useNewOpenVio                  # Use an open violation marker to show
                                # unconnected objects (bool, optional)
-useVirtualConnection           # Implies a virtual connection for all bumps
                                # and external I/O pins of the same net
                                # (bool, optional)
-warning <integer>              # Specifies the maximum number of warnings to
                                # report (int, optional)