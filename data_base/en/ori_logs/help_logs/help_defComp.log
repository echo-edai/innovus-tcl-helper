Usage: defComp [-help] <fileName> [-bump] [-defAsGolden]
               [-ignoreLayerFrom <layer>] [-ignoreLayerTo <layer>]
               [-ignoreLogicChange] [-metalShapeDiff] [-placeBlockage]
               [-reportFile <reportFile>] [-row] [-snetPin]
               [-unit <unit_per_micron>] [-ignoreCellPlace <lef_macro_classes_list> [-checkCellPrefix <prefix_list>]]

-help                              # Prints out the command usage
<fileName>                         # Specifies the name of the DEF file you
                                   # want to compare with (string, required)
-bump                              # Compares bump placement, routing, and net
                                   # assignment (bool, optional)
-checkCellPrefix <prefix_list>     # Checks instances whose instance name
                                   # begins with the specified prefix
                                   # (string, optional)
-defAsGolden                       # Treats the DEF file as the golden
                                   # (bool, optional)
-ignoreCellPlace <lef_macro_classes_list>
                                   # Ignores the specified cell classes (string, optional)
-ignoreLayerFrom <layer>           # Ignores the specified metal or cut layer,
                                   # and all metal and cut layers above
                                   # ((layer), optional)
-ignoreLayerTo <layer>             # Ignores the specified metal or cut layer,
                                   # and all metal and cut layers below
                                   # ((layer), optional)
-ignoreLogicChange                 # Ignores logic changes when comparing a DEF
                                   # file (bool, optional)
-metalShapeDiff                    # Post-processes the original report file to
                                   # provide only differences on metal layers
                                   # (bool, optional)
-placeBlockage                     # Compares placement blockage and block halo
                                   # equivalence (bool, optional)
-reportFile <reportFile>           # Specifies the name of the report
                                   # containing the results (string, optional)
-row                               # Compares row and site equivalence, name,
                                   # location, and orientation (bool, optional)
-snetPin                           # Compares snet pins (bool, optional)
-unit <unit_per_micron>            # Uses the specified UNITS value (typically,
                                   # the UNITS value in the DEF file) to scale
                                   # all (string, optional)