Usage: setResizeFPlanMode [-help] [-reset] [-honorHalo {true|false}]
                          [-maintainResourceRatioAfterResize {true|false}]
                          [-shrinkFence {true|false}]
                          [-snapToTrack {true|false}] [-shiftBased {true|false} | -proportional {true|false} | -congAware {true|false}] [-ioProportional {true|false} | -ioMoveWithEdge {true|false} | -ioFix {true|false}]

-help                                    # Prints out the command usage
-reset                                   # Resets all or specified options to default value
-congAware {true|false}                  # resizes and shifts the floorplan
                                         # objects by estimating the congestion
                                         # for the floorplan and automatically
                                         # deciding where to draw a resize line
                                         # to avoid the congested area.
                                         # (bool, default=false)
-honorHalo {true|false}                  # honors placement halo and preserves
                                         # the space between macros held by
                                         # halo after the floorplan resize.
                                         # (bool, default=true)
-ioFix {true|false}                      # fixes I/Os at current location.
                                         # (bool, default=false)
-ioMoveWithEdge {true|false}             # moves pins on the moved edge
                                         # orthogonally to edge direction so
                                         # pins stay on edge after movement.
                                         # (bool, default=false)
-ioProportional {true|false}             # resize the space among I/Os
                                         # proportionally. (bool, default=true)
-maintainResourceRatioAfterResize {true|false}
                                         # Enable to maintain the resource
                                         # ratio after resizeFloorplan in
                                         # shift-based mode. (bool, default=false)
-proportional {true|false}               # resizes the space among floorplan
                                         # objects proportionally.
                                         # (bool, default=false)
-shiftBased {true|false}                 # shifts floorplan objects at
                                         # appropriate location(s) without
                                         # changing the proportional spacing.
                                         # (bool, default=true)
-shrinkFence {true|false}                # enables resized lines to go through
                                         # fences and regions in floorplan.
                                         # (bool, default=false)
-snapToTrack {true|false}                # snaps resize values (shrink/expand)
                                         # of the floorplan to a multiple
                                         # integer of the metal layer pitch.
                                         # (bool, default=true)