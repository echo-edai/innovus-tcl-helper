Usage: fixACLimitViolation [-help] [-excludeIO <true | false>]
                           [-excludeNetFile <filename>]
                           [-fixNetCategory {dataOnly clockOnly clockAndData}]
                           [-fixingMethod {route_rule down_size buffer size_or_buffer route_size_or_buffer}]
                           [-postCTS] [-selectNetFile <filename>]
                           [-useReportFile <filename>]
                           [-useSegmentBasedNDR <true | false>]

-help                                     # Prints out the command usage
-excludeIO <true | false>                 # Exclude nets connected to I/O pins
                                          # (bool, optional)
-excludeNetFile <filename>                # File with list of nets to be
                                          # excluded (string, optional)
-fixNetCategory {dataOnly clockOnly clockAndData}
                                          # Specify fixing type (enum, optional)
-fixingMethod {route_rule down_size buffer size_or_buffer route_size_or_buffer}
                                          # Specify fixing method (enum, optional)
-postCTS                                  # Enable fix in postCTS stage, valid
                                          # only for single iteration of NDR
                                          # (bool, optional)
-selectNetFile <filename>                 # File with list of nets to be fixed
                                          # (string, optional)
-useReportFile <filename>                 # verifyACLimit report file name
                                          # (string, optional)
-useSegmentBasedNDR <true | false>        # Enable/disable segment-based NDR
                                          # (bool, optional)