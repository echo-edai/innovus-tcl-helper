Usage: reportTwoPinChain [-help] [-reset  | [ [-output <string>] [-through <string>] [-noOverwrite ] [-showAll ] [-strict ] [-tolerance <float>] ]]

-help                # Prints out the command usage
-noOverwrite         # continue to display the previous 2-pin-chains also.
                     # Default: false (bool, optional)
-output <string>     # 2-pin nets will be traced and dumped in this file.
                     # Default: stdout (string, optional)
-reset               # just remove all gui markers and gui objects, created
                     # during previous invocations. No two pin chain reporting.
                     # Default: false (bool, optional)
-showAll             # display the intermediate instances of the chain also.
                     # Default: false (bool, optional)
-strict              # strictly two pin chain even at module port connections.
                     # Default: false (bool, optional)
-through <string>    # specify list of names of net, instterms, hinstterms for
                     # which 2-pin chains is to be traced and dumped
                     # (string, optional)
-tolerance <float>   # treat this much difference in ordinates as still
                     # aligned.Default: 1.0 (microns) (float, optional)