Usage: all_fanin [-help] [-hpin] [-only_cells] -to {collection | object_list}
                 [-trace_through {case_disable|user_disable|all|clocks|loop_snipped|latches}]
                 [-view <view_name>] [-levels <value> | -pin_levels <value>] [-startpoints_only ] [ > | >> ]

-help                                # Prints out the command usage
-hpin                                # Returns hierarchical pins along with
                                     # flat pins (bool, optional)
-levels <value>                      # number of gate levels to go back from a
                                     # specific pin object to create the
                                     # collection (int, optional)
-only_cells                          # Returns a collection only of the cells
                                     # in the fanin cone (bool, optional)
-pin_levels <value>                  # number delay arcs to go back from a
                                     # specific pin object to create the
                                     # collection (int, optional)
-startpoints_only                    # Returns a collection only of valid start
                                     # points in the fanin cone (bool, optional)
-to {collection | object_list}       # Specifies 'to' objects for the
                                     # collections to be returned
                                     # (string, required)
-trace_through {case_disable|user_disable|all|clocks|loop_snipped|latches}
                                     # Option to select tracing through
                                     # disabled arcs (string, optional)
-view <view_name>                    # Specifies view name for which fan cone
                                     # traversal is to be performed
                                     # (string, optional)
> <filename>                         # output to file
                                     # (redirect_operator, optional)
>> <filename>                        # output to file
                                     # (redirect_operator, optional)