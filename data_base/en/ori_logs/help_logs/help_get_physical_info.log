Usage: get_physical_info [-help] [-highlight]
                         [-shapes {RING STRIPE FOLLOWPIN IOWIRE COREWIRE BLOCKWIRE PADRING BLOCKRING FILLWIRE FILLWIREOPC DRCFILL None}]
                         [-subclass {subclass_name_list}]
                         [-type {connection routing_path}] {-object <string> | -selected }

-help                               # Prints out the command usage
-highlight                          # Highlight the routing path
                                    # (bool, optional)
-object <string>                    # Specifies the object from which to get
                                    # the physical information. For bump, it's
                                    # required to input the whole bump name and
                                    # for IO instance, it can input inst_name,
                                    # inst_name:pin_name or
                                    # inst_name:pin_name:port_number.
                                    # (string, optional)
-selected                           # Get the physical information for the
                                    # selected object (bool, optional)
-shapes {RING STRIPE FOLLOWPIN IOWIRE COREWIRE BLOCKWIRE PADRING BLOCKRING FILLWIRE FILLWIREOPC DRCFILL None}
                                    # Specifies the shapes of the wires and
                                    # vias to be checked. The default value is
                                    # IOWIRE. (enum_list, optional)
-subclass {subclass_name_list}      # Specifies the subclass name of the wires
                                    # and vias to be checked (string, optional)
-type {connection routing_path}     # Specifies the type of physical
                                    # information to return. The default value
                                    # is connection. (enum, optional)