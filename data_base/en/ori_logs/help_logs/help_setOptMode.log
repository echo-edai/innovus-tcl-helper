-opt_post_route_hold_recovery <ENUM>       # (ternary, default=auto)
-opt_post_route_setup_recovery <ENUM>      # Enables postRoute SI setup timing
                                           # recovery in GigaOpt.
                                           # (ternary, default=auto)
-opt_power_effort {none|low|high}          # Effort level for power aware mode
