-help                                      # Prints out the command usage
-reset                                     # Resets all or specified options to default value
-opt_activity_refresh_args <LIST>          # Specify the list of setStim
                                           # options to be passed for Joules
                                           # Xreplay. Call "setOptMode
                                           # -activity_refresh_args  help" to
                                           # get detailed usage.
                                           # (string, default="")
-opt_add_always_on_feed_through_buffers {true|false}
                                           # Activates adding Always On Feed
                                           # Thru buffers (bool, default=false)
-opt_add_insts {true|false}                # Enables adding of new instances
                                           # (bool, default=true)
-opt_new_inst_prefix <PREFIX>              # Prefix string for name of new
                                           # instances (string, default="")
-opt_new_net_prefix <PREFIX>               # Prefix string for name of new nets
                                           # (string, default="")
-opt_add_ports {true|false}                # Enables adding ports for optimal
                                           # buffering (bool, default=true)
-opt_all_end_points {true|false}           # Enables the all end points
                                           # optimization mode
                                           # (bool, default=false)
-opt_allow_multi_bit_on_flop_with_sdc {true|false|mergeOnly|splitOnly}
                                           # allow merge or split works on
                                           # flops which have SDC
                                           # (enums={true false mergeOnly splitOnly}, default=true)
-opt_allow_only_cell_swapping {true|false}
                                           # Forces the post route optimization
                                           # to perform only same-size Vth
                                           # swapping for timing improvements
                                           # (bool, default=false)
-opt_multi_bit_flop_merge_bank_label_inference {true|false}
                                           # Enables soft merging of flops with
                                           # the same bank label
                                           # (bool, default=false)
-opt_consider_routing_congestion {auto|false|true}
                                           # Enables routing congestion check
                                           # at the postRoute stage during
                                           # optimization of setup, hold, drv,
                                           # & glitch. It also impacts postCTS
                                           # hold fixing.
                                           # (enums={auto false true}, default=auto)
-opt_clone_insts_list <insts_list>         # list of instance list
                                           # (string, default="")
-opt_delete_insts {true|false}             # Enables instance deletion on all
                                           # paths (bool, default=true)
-opt_add_repeater_report_failure_reason {true|false}
                                           # To enable printing detailed
                                           # failure reason report file for
                                           # addRepeaterByRule
                                           # (bool, default=false)
-opt_detail_drv_failure_reason {true|false}
                                           # To enable printing detailed drv
                                           # failure reason report file
                                           # (bool, default=false)
-opt_detail_drv_failure_reason_max_num_nets <value>
                                           # Specify how many violating nets
                                           # printed
                                           # (int, default=50, min=1, max=9999)
-opt_down_size_insts {true|false}          # Enables instance downsizing
                                           # (bool, default=true)
-opt_drv_margin <DOUBLE>                   # Used for scaling maxCap/maxTran
                                           # constraints (float, default=0)
-opt_early_hold_fixing {none|ideal|propagated}
                                           # set the ideal or propagaged clock
                                           # mode for hold fixing in preCTS
                                           # (enums={none ideal propagated}, default=none)
-opt_enable_clock_pulse_width_checks {true|false}
                                           # Fix and honor pulse width check
                                           # violations (bool, default=false)
-opt_enable_data_to_data_checks {true|false}
                                           # (enums={true false}, default=false)
-opt_enable_podv2_clock_opt_flow {true|false}
                                           # enable PodV2 and clock_opt_design
                                           # flow (bool, default=true)
-opt_enable_targeted_synthesis {true|false}
                                           # Enable targeted synthesis mode (bool, default=false)
-opt_drv_with_miller_cap {true|false}      # (bool, default=false)
-opt_post_route_fix_clock_drv {true|false}
                                           # enables DRV fixing on clock net (bool, default=true)
-opt_drv {true|false}                      # Enables fixing maxCap/maxTran
                                           # violations on constrained nets
                                           # (bool, default=true)
-opt_fix_fanout_load {true|false}          # Enables fixing fanOut load
                                           # violations (bool, default=false)
-opt_post_route_fix_glitch {true|false}    # Enables glitch fixing in AAE flow
                                           # (bool, default=true)
-opt_hold_allow_overlap {auto|false|true}
                                           # Enables hold optimization to
                                           # insert cells with overlaps when
                                           # inadequate free space is
                                           # available. The placement will then
                                           # be legalized before ECO routing.
                                           # (enums={auto false true}, default=auto)
-opt_hold_allow_resize {false|true}        # Enables the resizing capability
                                           # inside hold optimization.
                                           # (enums={false true}, default=true)
-opt_hold_allow_setup_tns_degradation {true|false}
                                           # Allows setup total negative slack
                                           # to degrade during hold
                                           # optimization. (bool, default=true)
-opt_hold_on_excluded_clock_nets {true|false}
                                           # Do hold fixing on the excluded
                                           # clock nets (bool, default=false)
-opt_post_route_fix_si_transitions {true|false}
                                           # Enables sislew fixing in AAE flow (bool, default=false)
-opt_high_effort_cells <LIST>              # Provide a list of cells to be used
                                           # for high effort optimization.
                                           # Dont-use and Dont-touch
                                           # constraints for these cells will
                                           # be ignored for high effort
                                           # optimization. (string, default="")
-opt_hold_cells <LIST>                     # Provide a list of buffer & delay
                                           # cells to be used for hold
                                           # buffering. The dont_use
                                           # constraints for these cells will
                                           # be ignored. (string, default="")
-opt_hold_slack_threshold <SLACK>          # Specifies slack threshold value
                                           # beyond which the hold timing
                                           # violations will not be fixed
                                           # (float, default=-1000)
-opt_hold_target_slack <SLACK>             # Specifies target slack value (in
                                           # nano secs) for hold timing
                                           # optimization (float, default=0)
-opt_honor_density_screen {true|false}     # Control density screen
                                           # (bool, default=false)
-opt_honor_fences {true|false}             # Specifies that the timing
                                           # optimization takes fences
                                           # constraints into account.
                                           # Placement of cells will be
                                           # legalized within each fence.
                                           # (bool, default=false)
-opt_hold_ignore_path_groups <INST>        # Specifies path groups to be
                                           # excluded in hold timing
                                           # optimization (string, default="")
-opt_leakage_to_dynamic_ratio <ratio>      # relative effort for leakage and
                                           # dynamic power optimization in the
                                           # range [0.0 - 1.0] (float, default=1)
-opt_max_density <DENSITY>                 # Specifies maximum area utilization
                                           # (float, default=0.95)
-opt_max_length <value>                    # Enables max length constraints in
                                           # optDesign
                                           # (float, default=-1, min=-1, max=2147483647)
-opt_multi_bit_flop_merge_timing_effort {low|medium|high}
                                           # Timing effort level for MBFF
                                           # merging
                                           # (enums={low medium high}, default=medium)
-opt_multi_bit_flop_split_timing_effort {low|medium|high}
                                           # Timing effort level for MBFF
                                           # splitting
                                           # (enums={low medium high}, default=low)
-opt_move_insts {true|false}               # Enables moving instances while
                                           # fixing setup violations
                                           # (bool, default=true)
-opt_multi_bit_combinational_merge_timing_effort {low|medium|high}
                                           # Specifies the timing effort level
                                           # for multibit combinational merging
                                           # (enums={low medium high}, default=medium)
-opt_multi_bit_combinational_mode {auto|power|area}
                                           # Enables the user specific multi
                                           # bit combination cell merge and
                                           # split based on area and power
                                           # (enums={auto power area}, default=auto)
-opt_multi_bit_combinational_opt {false|true|mergeOnly|splitOnly}
                                           # enables or disables the multi-bit
                                           # combinational optimization flow
                                           # (enums={false true mergeOnly splitOnly}, default=splitOnly)
-opt_multi_bit_combinational_split_timing_effort {low|medium|high}
                                           # Specifies the timing effort level
                                           # for multibit combinational
                                           # splitting
                                           # (enums={low medium high}, default=low)
-opt_multi_bit_flop_name_prefix <LIST>     # User to specify multi bit flop
                                           # name prefix
                                           # (string, default=CDN_MBIT_)
-opt_multi_bit_flop_name_separator <LIST>
                                           # User to specify flop merge and
                                           # split name separator
                                           # (string, default=_MB_)
-opt_multi_bit_flop_name_suffix <LIST>     # User to specify multi bit flop
                                           # name suffix, For example: _FF
                                           # (string, default="")
-opt_multi_bit_flop_opt {false|true|mergeOnly|splitOnly}
                                           # specifies multi bit flop
                                           # merge/split opt
                                           # (enums={false true mergeOnly splitOnly}, default=splitOnly)
-opt_multi_bit_flop_reorder_bits {false|true|timing|power}
                                           # Enable Swap MBFF bits to take
                                           # advantage of mixed-drving stength
                                           # cells. false: Disable; true:
                                           # enable for timing and power
                                           # optimization; timing: enable for
                                           # timing optimization; power: enable
                                           # for power optimization.
                                           # (enums={false true timing power}, default=false)
-opt_multi_bit_unused_bit_count <INT>      # specifies how many maximum unused
                                           # bits to be allowed in each
                                           # multibit cell
                                           # (int, default=1, min=1, max=32)
-opt_multi_bit_unused_bits {false|true|prePlace|preCTS}
                                           # specifies whether a mapped
                                           # multibit instance can have one or
                                           # more unused bits
                                           # (enums={false true prePlace preCTS}, default=prePlace)
-opt_pre_route_ndr_aware <LIST>            # Provide a list of NDR names that
                                           # will be used NDR-based
                                           # optimization (string, default="")
-opt_one_pass_lec {true|false}             # Set options one pass lec opt
                                           # support (bool, default=false)
-opt_duplicate_cte_constrained_hport {true|false}
                                           # allow buffering to duplicate
                                           # hterms/hports with CTE
                                           # constraints. (bool, default=true)
-opt_icg_enable_pin_rebuffering {true|auto|false}
                                           # Rebuffer nets to enable pin of ICG
