Usage: signoffOptDesign [-help] [-all] [-area] [-drv] [-dynamic] [-hold]
                        [-leakage] [-noEcoRoute] [-outDir <string>] [-power]
                        [-prefix <string>] [-reportFullClockPath] [-setup]

-help                                # Prints out the command usage
-all                                 # Performs DRV, Setup, Hold and Power
                                     # optimization in PBA mode (bool, optional)
-area                                # Reclaims area on the netlist with a
                                     # target of not causing any DRV/Setup/Hold
                                     # degradation. (bool, optional)
-drv                                 # Optimizes DRV violations. DRV
                                     # optimization fixes violations in the
                                     # order (glitch, drv, xtalk delta delay).
                                     # (bool, optional)
-dynamic                             # Reclaims dynamic power on the netlist
                                     # with a target of not causing any
                                     # DRV/Setup/Hold degradation.
                                     # (bool, optional)
-hold                                # Optimizes hold timing violations on the
                                     # netlist with a target of not causing any
                                     # DRV/Setup degradation. (bool, optional)
-leakage                             # Reclaims leakage power on the netlist
                                     # with a target of not causing any
                                     # DRV/Setup/Hold degradation.
                                     # (bool, optional)
-noEcoRoute                          # No ECO-routing after optimization
                                     # (bool, optional)
-outDir <string>                     # Timing reports would be saved in this
                                     # directory (string, optional)
-power                               # Reclaims total power on the netlist with
                                     # a target of not causing any
                                     # DRV/Setup/Hold degradation.
                                     # (bool, optional)
-prefix <string>                     # Prefix for timing report file names
                                     # (string, optional)
-reportFullClockPath                 # Enable full clock path in detailed
                                     # report (bool, optional)
-setup                               # Optimizes setup timing violations on the
                                     # netlist with a target of not causing any
                                     # DRV/Hold degradation. (bool, optional)