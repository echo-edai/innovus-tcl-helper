Usage: compare_power_intent [-help] [-domain_attr]
                            [-domain_boundary_port_constr]
                            [-domain_map_file <string>] [-file_prefix <string>]
                            -golden1801 <string> -hier1801 <string>
                            [-pin_effective_domain] [-power_domains <string>]
                            [-verbose]

-help                                 # Prints out the command usage
-domain_attr                          # (bool, optional)
-domain_boundary_port_constr          # (bool, optional)
-domain_map_file <string>             # (string, optional)
-file_prefix <string>                 # (string, optional)
-golden1801 <string>                  # (string, required)
-hier1801 <string>                    # (string, required)
-pin_effective_domain                 # (bool, optional)
-power_domains <string>               # (string, optional)
-verbose                              # (bool, optional)