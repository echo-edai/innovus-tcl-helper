Usage: getTieHiLoMode [-help] [-cell] [-createHierPort] [-honorDontTouch]
                      [-honorDontUse] [-maxDistance] [-maxFanout]
                      [-modulePrevention] [-prefix] [-reportHierPort]
                      [-quiet] [-nonDefault]

-help                                   # Prints out the command usage
-cell                                   # Set tie cell lists for setTieHiLoMode
                                        # command (string, default="")
-createHierPort                         # Add tie-cells in different hierarchy
                                        # than tie-off pins when possible
                                        # (bool, default=false)
-honorDontTouch                         # honor dont_touch attribute on nets,
                                        # insts, cells and modules
                                        # (bool, default=false)
-honorDontUse                           # honor dont_use attribute on cells.
                                        # (bool, default=false)
-maxDistance                            # distance between tie-cell and
                                        # tie-pins should be less than given
                                        # value (float, default=0)
-maxFanout                              # the number of tie-pins a tie-net can
                                        # drive. A '0' means no-limit
                                        # (int, default=0)
-modulePrevention                       # add tie cell for module instantiation
                                        # port (bool, default=false)
-prefix                                 # Prefix of tie cell instances
                                        # (string, default="")
-reportHierPort                         # Report created ports when
                                        # createHierPort is set
                                        # (bool, default=false)
-quiet                                  # Displays the current settings in Tcl list format only
-nonDefault                             # Displays the current settings which are not default settings