Usage: route_pg [-help] [-check_psdl_only] [-connect_floating_net <string>]
                [-delete_floating] [-fast] [-post_cut_color]
                [-psdl_file <file_name>] [-skip_block_pin]
                [-skip_partial_overlap_via] [-skip_physical_pin] [-skip_via]
                [-stop_on_error] [-use_full_pattern] [-use_namespace]
                [-write_psdl <string>]

-help                              # Prints out the command usage
-check_psdl_only                   # Perform sanity check on PSDL input file
                                   # only (bool, optional)
-connect_floating_net <string>     # Connect floating wires of specified net
                                   # name (string, optional)
-delete_floating                   # Remove floating wires (bool, optional)
-fast                              # Generate PG in fast mode (bool, optional)
-post_cut_color                    # Enable post cut color (bool, optional)
-psdl_file <file_name>             # PSDL input file (string, optional)
-skip_block_pin                    # Skip connection to block pins
                                   # (bool, optional)
-skip_partial_overlap_via          # Skip building via on partial overlap
                                   # intersection (bool, optional)
-skip_physical_pin                 # Skip creating physical pin on the design
                                   # boundary (bool, optional)
-skip_via                          # Skip building via object (bool, optional)
-stop_on_error                     # Stop pgroute process if there is any error
                                   # in PSDL file (bool, optional)
-use_full_pattern                  # Only allow full PATTERN (bool, optional)
-use_namespace                     # Use namespace for METAL id
                                   # (bool, optional)
-write_psdl <string>               # Write a PSDL file for checking
                                   # (string, optional)