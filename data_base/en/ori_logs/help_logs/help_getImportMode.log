Usage: getImportMode [-help] [-discardFloatingVNets] [-keepEmptyModule]
                     [-minDBUPerMicron] [-syncRelativePath] [-timerMode]
                     [-quiet] [-nonDefault]

-help                                      # Prints out the command usage
-discardFloatingVNets                      # If true, an hnet (Verilog wire
                                           # statement) that has nothing
                                           # connected to it, is deleted from
                                           # the netlist. The default value is
                                           # false in Innovus to allow for
                                           # netlist repair, but true in Tempus
                                           # to delete non-timed nets and
                                           # reduce memory. (bool, default=false)
-keepEmptyModule                           # By default, usage of an empty
                                           # Verilog module that has no
                                           # matching library cell name becomes
                                           # an empty hinst.  If this value is
                                           # false, a dummy library cell is
                                           # created, and usage of it becomes
                                           # an inst.  You should then use
                                           # other commands to 'fix' the dummy
                                           # library cell before proceeding in
                                           # the flow. (bool, default=true)
-minDBUPerMicron                           # Minimum DBU per micron
                                           # (uint, default=0)
-syncRelativePath                          # Synchronize Relative paths
                                           # (bool, default=false)
-timerMode                                 # Timer Mode (bool, default=false)
-quiet                                     # Displays the current settings in Tcl list format only
-nonDefault                                # Displays the current settings which are not default settings