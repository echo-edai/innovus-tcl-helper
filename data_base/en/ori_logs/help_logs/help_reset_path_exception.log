Usage: reset_path_exception [-help] [-exact] [-fall]
                            [-fall_through <through_list>] [-rise]
                            [-rise_through <through_list>]
                            [-through <through_list>]
                            [-type <exception_type_list>] [-all  | [ [-from <from_list> | -rise_from <from_list> | -fall_from <from_list>] [-to <to_list> | -rise_to <to_list> | -fall_to <to_list>] ] ] [-setup  | -hold ]

-help                           # Prints out the command usage
-all                            # Removes all path exceptions. This option
                                # cannot be used with the -from, -through and
                                # -to options (bool, optional)
-exact                          # Resets matching exceptions with same number
                                # of from|through|to options as specified here
                                # (bool, optional)
-fall                           # Apply the assertion at the falling edge of
                                # the signal on the path endpoints
                                # (bool, optional)
-fall_from <from_list>          # Resets the exceptions from the paths that
                                # have falling transition on specified objects
                                # (start pins and/or launching clocks)
                                # (string, optional)
-fall_through <through_list>    # Resets the exceptions from the paths that
                                # goes through falling transition of specified
                                # pins (string, optional)
-fall_to <to_list>              # Resets the exceptions from the paths that
                                # have falling transition on specified objects
                                # (endpoint pins and/or capturing clocks)
                                # (string, optional)
-from <from_list>               # Resets the exceptions from the paths that
                                # have specified objects (start pins and/or
                                # launching clocks) (string, optional)
-hold                           # Resets only the hold exceptions
                                # (bool, optional)
-rise                           # Applies the assertion at the rising edge of
                                # the signal on the path endpoints
                                # (bool, optional)
-rise_from <from_list>          # Resets the exceptions from the paths that
                                # have rising transition on specified objects
                                # (start pins and/or launching clocks)
                                # (string, optional)
-rise_through <through_list>    # Resets the exceptions from the paths that
                                # goes through rising transition of specified
                                # pins (string, optional)
-rise_to <to_list>              # Resets the exceptions from the paths that
                                # have rising transition on specified objects
                                # (endpoint pins and/or capturing clocks)
                                # (string, optional)
-setup                          # Resets only the setup exceptions
                                # (bool, optional)
-through <through_list>         # Resets the exceptions from the paths that
                                # goes through specified pins (string, optional)
-to <to_list>                   # Resets the exceptions from the paths that
                                # have specified objects (endpoint pins and/or
                                # capturing clocks) (string, optional)
-type <exception_type_list>     # Removes only path exceptions of the specified
                                # type. Valid types are false_path, multicycle
                                # and path_delay (string, optional)