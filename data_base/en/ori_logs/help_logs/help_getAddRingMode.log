Usage: getAddRingMode [-help] [-avoid_short] [-break_core_ring_io_list]
                      [-continue_on_no_selection] [-detailed_log]
                      [-extend_blockring_search_distance]
                      [-extend_corering_search_distance]
                      [-extend_merge_with_prewires] [-extend_over_row]
                      [-extend_search_nets] [-extend_stripe_search_distance]
                      [-gap_width_without_io] [-ignore_rows] [-max_via_size]
                      [-orthogonal_only] [-ring_target] [-skip_crossing_trunks]
                      [-skip_via_on_pin] [-skip_via_on_wire_shape]
                      [-spacing_from_block] [-split_long_via]
                      [-stacked_via_bottom_layer] [-stacked_via_top_layer]
                      [-via_using_exact_crossover_size] [-wire_center_offset]
                      [-quiet] [-nonDefault]

-help                                      # Prints out the command usage
-avoid_short                               # Specifies whether to avoid short
                                           # violation (bool, default=false)
-break_core_ring_io_list                   # Specifies io instance names for
                                           # which core ring wires are broken
                                           # (string, default="")
-continue_on_no_selection                  # Continues w/o selection
                                           # (bool, default=false)
-detailed_log                              # Outputs detailed log file
                                           # addring.log (bool, default=false)
-extend_blockring_search_distance          # Specifies blockring extension
                                           # search distance (float, default=0)
-extend_corering_search_distance           # Specifies corering extension
                                           # search distance (float, default=0)
-extend_merge_with_prewires                # Specifies whether to merge with
                                           # prerouted wires (bool, default=true)
-extend_over_row                           # Specifies whether to extend over
                                           # row (bool, default=false)
-extend_search_nets                        # Specifies search net names
                                           # (string, default="")
-extend_stripe_search_distance             # Specifies stripe extension search
                                           # distance (float, default=0)
-gap_width_without_io                      # Specifies the max missing IO Pads
                                           # area width between IO Pads
                                           # (float, default=0)
-ignore_rows                               # Specifies whether to ignore all
                                           # rows (bool, default=false)
-max_via_size                              # the maximum size of a crossover
                                           # via (string, default="")
-orthogonal_only                           # vias connect to orthogonal targets
                                           # only (bool, default=true)
-ring_target                               # Specifies ring target
                                           # (enums={core_ring default first_ring pad_ring stripe}, default=default)
-skip_crossing_trunks                      # Specifies whether to skip crossing
                                           # trunks
                                           # (enums={horizontal vertical none}, default=none)
-skip_via_on_pin                           # prevent vias from being generated
                                           # on the specified type of pins
                                           # (enums={pad block cover standardcell physicalpin}_list, default=standardcell)
-skip_via_on_wire_shape                    # prevent vias from being generated
                                           # on the specified wire shapes
                                           # (enums={blockring stripe followpin corewire blockwire iowire padring ring fillwire noshape}_list, default=noshape)
-spacing_from_block                        # Specifies the spacing from block
                                           # (float, default=0)
-split_long_via                            # Split vias longer than <threshold>
                                           # into smaller vias with specified
                                           # <step> and bottom/left end
                                           # <offset> and vertical/horizontal
                                           # <length> (string, default=0 0 -1 -1)
-stacked_via_bottom_layer                  # lef layer name
                                           # (string, default=bottomLayer)
-stacked_via_top_layer                     # lef layer name
                                           # (string, default=topLayer)
-via_using_exact_crossover_size            # generate partial vias of the exact
                                           # crossover size (bool, default=true)
-wire_center_offset                        # offset value is from wire center
                                           # to domain/core boundary
                                           # (bool, default=false)
-quiet                                     # Displays the current settings in Tcl list format only
-nonDefault                                # Displays the current settings which are not default settings