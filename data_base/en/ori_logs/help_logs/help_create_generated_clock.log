Usage: create_generated_clock [-help] <target_pin_list> [-add]
                              [-comment <string>] [-duty_cycle <percent>]
                              [-edge_shift <edge_shift_list>] [-invert]
                              [-master_clock <source_clock_name>]
                              [-name <clock_name>] -source <source_pin>
                              [-source_invert] { [-multiply_by <factor>] [-divide_by <factor>] [-edges <edge_list>] [-combinational ] } [-multiply_by <factor> | -divide_by <factor>]

-help                             # Prints out the command usage
<target_pin_list>                 # List of pins where the generated clock
                                  # assertion is applied (string, required)
-add                              # Multiple clocks on the same source
                                  # (bool, optional)
-combinational                    # Consider only combinational paths for
                                  # latency (bool, optional)
-comment <string>                 # Not supported option (string, optional)
-divide_by <factor>               # Factor by which frequency of source clock
                                  # is divided for new frequency (int, optional)
-duty_cycle <percent>             # Sets the duty cycle (high pulse width or
                                  # clock period). The number ( percent )is
                                  # between 0 and 100  (float, optional)
                                  # (float, optional)
-edge_shift <edge_shift_list>     # Amount of shift for each edge in -edge_list
                                  # option (string, optional)
-edges <edge_list>                # List of edges from source clock that for
                                  # derived clock (string, optional)
-invert                           # Inverts the source clock (bool, optional)
-master_clock <source_clock_name> # Generates a target clock from the specified
                                  # clock name (string, optional)
-multiply_by <factor>             # Factor by which frequency of source clock
                                  # is multiplied for new frequency
                                  # (int, optional)
-name <clock_name>                # String name of the clock (string, optional)
-source <source_pin>              # Source pin from which clock shall be
                                  # derived (string, required)
-source_invert                    # Inverts the polarity of master clock at
                                  # specified source pin (bool, optional)