Usage: cloneMSVGate [-help] [-honorDontTouch] [-honorPrePlaced]
                    [-instances <string>] [-iso] [-maxCap <string>]
                    [-maxFanout <integer>] [-maxTran <string>] [-shifter]

-help                        # Prints out the command usage
-honorDontTouch              # do not clone dont touch instances / cells
                             # (bool, optional)
-honorPrePlaced              # do not clone preplaced (fixed) instances
                             # (bool, optional)
-instances <string>          # clone selected instances (string, optional)
-iso                         # clone isolation only (bool, optional)
-maxCap <string>             # max cap violation (string, optional)
-maxFanout <integer>         # max fanout violation (int, optional)
-maxTran <string>            # max transition violation (string, optional)
-shifter                     # clone level shifter only (bool, optional)