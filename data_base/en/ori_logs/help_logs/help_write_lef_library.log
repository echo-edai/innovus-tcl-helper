Usage: write_lef_library [-help] [<fileName>] [-lef_layer_order]
                         [-use_spacing_table_default] [-tech_only | -macro_only ] [-tech_only | -macro_list <string> ] [-macro_only [-no_property ] ] [-all_auto_generated_via | -macro_only ] [ -macro_only ] [ -all_auto_generated_via ]

-help                         # Prints out the command usage
<fileName>                    # output LEF filename (string, optional)
-all_auto_generated_via       # Writes auto generated vias from generateVias
                              # command (bool, optional)
-lef_layer_order              # Write layers specified in lefLayerOrder
                              # constraint only (bool, optional)
-macro_list <string>          # write macros specified in macro list
                              # (string, optional)
-macro_only                   # Writes macro only data to LEF file
                              # (bool, optional)
-no_property                  # Writes data in LEF file without any properties
                              # (bool, optional)
-tech_only                    # Writes tech only data to LEF file
                              # (bool, optional)
-use_spacing_table_default    # Writes DEFAULT value of SPACINGTABLE in LEF
                              # file (bool, optional)