Usage: report_inactive_arcs [-help] [<instance_or_port_list>]
                            [-exclude_type {const snipped disable library_disable global_disable conditional_disable Library_Mode power_mode_disable}]
                            [-include_net_arcs] [-include_when_cond]
                            [-type {const snipped disable library_disable global_disable conditional_disable Library_Mode power_mode_disable}]
                            [-view <view_name>] [> <filename[.gz]>]
                            [>> <filename[.gz]>] [-delay_arcs_only  | -check_arcs_only ]

-help                       # Prints out the command usage
<instance_or_port_list>     # Specifies list of instances or ports
                            # (string, optional)
-check_arcs_only            # Lists only disabled check arcs (bool, optional)
-delay_arcs_only            # lists only disabled timing delay arcs
                            # (bool, optional)
-exclude_type {const snipped disable library_disable global_disable conditional_disable Library_Mode power_mode_disable}
                            # Excludes the disabled arcs that belong to this
                            # category of disabled arcs (enum_list, optional)
-include_net_arcs           # Includes disabled net arcs in the report
                            # (bool, optional)
-include_when_cond          # When cond disabled condition is printed in
                            # detailed info (bool, optional)
-type {const snipped disable library_disable global_disable conditional_disable Library_Mode power_mode_disable}
                            # Lists only the disabled arcs that belong to this
                            # category of disabled arcs (enum_list, optional)
-view <view_name>           # Generates the report for the specified analysis
                            # view only (string, optional)
> <filename[.gz]>           # Redirects output to the specified file
                            # (redirect_operator, optional)
>> <filename[.gz]>          # Redirects output to the specified file
                            # (redirect_operator, optional)