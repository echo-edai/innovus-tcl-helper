Usage: fix_floorplan [-help] -file <string> -type {ufc tcic} [-selected ] [-report_file <string>] [-report_unplaced_block ] [-break_at_conflict ] [-honor_snap_block_grid ] [-selected_rules <string>]

-help                                      # Prints out the command usage
-break_at_conflict                         # Enable tool exit from fixing
                                           # violations when run into rules
                                           # conflict. User should fix conflict
                                           # rules then re-run fix_floorplan
                                           # (bool, optional)
-file <string>                             # Specify the rule or constraint
                                           # file name (string, required)
-honor_snap_block_grid                     # Specify to honor block snap grid
                                           # defined by setFPlanMode
                                           # -snapBlockGrid or set_db
                                           # floorplan_snap_block_grid
                                           # (bool, optional)
-report_file <string>                      # Specify the report file name to
                                           # save the report summary.
                                           # (string, optional)
-report_unplaced_block                     # Enable tool to show the number of
                                           # unplaced macros in summary
                                           # (bool, optional)
-selected                                  # Specify to fix violations by
                                           # moving only the selected objects.
                                           # Now only support to select macros.
                                           # (bool, optional)
-selected_rules <string>                   # selected rules only
                                           # (string, optional)
-type {ufc tcic}                           # Specify the type of input file.
                                           # Now only ufc and tcic files are
                                           # supported. (enum, required)