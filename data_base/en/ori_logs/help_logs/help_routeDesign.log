Usage: routeDesign [-help] [-backside] [-bump] [-fill_area {x1 y1 x2 y2}]
                   [-highFrequency] [-selected] [-viaPillarOpt] [[[-clockEco ] [-globalDetail ] [-placementCheck | -noPlacementCheck ] [[ -trackOpt ] [-idealClock ]] [-viaOpt ] [-wireOpt ]] | [-passiveFill ]]

-help                        # Prints out the command usage
-backside                    # Route back side layer only (bool, optional)
-bump                        # Do bump route (bool, optional)
-clockEco                    # Do clock eco routing (bool, optional)
-fill_area {x1 y1 x2 y2}     # Do passive fill for a specific area
                             # (box, optional)
-globalDetail                # Do global detail route (bool, optional)
-highFrequency               # Do high frequency route (bool, optional)
-idealClock                  # Use ideal clocks for optimization
                             # (bool, optional)
-noPlacementCheck            # Do not check placement (bool, optional)
-passiveFill                 # Do passive fill (bool, optional)
-placementCheck              # Do check placement, abort if error
                             # (bool, optional)
-selected                    # Route selected nets only (bool, optional)
-trackOpt                    # Do timing  optimization after track assignment
                             # (bool, optional)
-viaOpt                      # Do via optimization (bool, optional)
-viaPillarOpt                # Do opportunistic via pillars (bool, optional)
-wireOpt                     # Do wire optimization (bool, optional)