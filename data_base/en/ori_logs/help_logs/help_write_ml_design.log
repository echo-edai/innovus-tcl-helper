Usage: write_ml_design [-help] [-no_power] [-objects <object_list>]
                       -prefix <string> [-verbose] [-views <view_list>]

-help                      # Prints out the command usage
-no_power                  # don't dump power attributes (bool, optional)
-objects <object_list>     # List of db object(s) to dump, one or more of {
                           # analysis_view arc base_cell base_pin blockage
                           # cell_density clock congestion constraint_mode
                           # delay_corner design gcell_grid hinst hnet hpin
                           # hport inst layer marker net netlist opcond option
                           # p2p partition patch_wire pg_base_pin pg_pin pin
                           # pin_shape port rc_corner route_rule row site
                           # skew_group special_net timing_condition
                           # track_pattern unit_parasitic via_def }
                           # (tcl_obj, optional)
-prefix <string>           # Prefix for output files (string, required)
-verbose                   # display more message (bool, optional)
-views <view_list>         # Dump data for the specified analysis view(s).
                           # (tcl_obj, optional)