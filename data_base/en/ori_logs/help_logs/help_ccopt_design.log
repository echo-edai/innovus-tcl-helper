Usage: ccopt_design [-help] [-check_prerequisites] [-ckSpec] [-cts]
                    [-expandedViews] [-num_paths <string>] [-outDir <string>]
                    [-prefix <string>] [-timing_debug_report]

-help                               # Prints out the command usage
-check_prerequisites                # Only check prerequisites, with no changes
                                    # made to the design (bool, optional)
-ckSpec                             # run design using edi cts spec
                                    # (bool, optional)
-cts                                # run design using icts (bool, optional)
-expandedViews                      # expandedViews option (bool, optional)
-num_paths <string>                 # Specify the number of paths generated in
                                    # timing reports (string, optional)
-outDir <string>                    # output directory (string, optional)
-prefix <string>                    # File Name Prefix option (native only)
                                    # (string, optional)
-timing_debug_report                # Generate timing debug report
                                    # (bool, optional)