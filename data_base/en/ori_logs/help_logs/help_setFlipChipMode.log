Usage: setFlipChipMode [-help] [-reset] [-allow_layer_change {true|false}]
                       [-auto_pairing_file <fileName>]
                       [-bump_use_oct_shape {true|false}]
                       [-check_bump_access_directions {true|false}]
                       [-compaction {true|false}]
                       [-connectPowerCellToBump {true|false}]
                       [-constraintFile <fileName>]
                       [-drop_via_on_all_geometries {true|false}]
                       [-drop_via_on_power_mesh <layerName>]
                       [-extraConfig <fileName>] [-finger_direction {N|E|S|W}]
                       [-finger_max_width <real>] [-finger_min_width <real>]
                       [-finger_target_mesh_layer_range {topLayer [bottomLayer]}]
                       [-honor_bump_connect_target_constraint {true|false}]
                       [-ignore_pad_type_check {true|false}]
                       [-layerChangeBotLayer <layerName>]
                       [-layerChangeTopLayer <layerName>]
                       [-lower_layer_prevent_45_routing {true|false}]
                       [-lower_layer_route_width <real>]
                       [-merge_nearby_pin {true|false}]
                       [-multi_pad_routing_style {default|serial|star}]
                       [-multipleConnection {multiPadsToBump|multiBumpsToPad|default}]
                       [-pg_mesh_direction {default|horizontal|vertical}]
                       [-pg_mesh_main_width <real>] [-pg_mesh_max_width <real>]
                       [-pg_mesh_width <value>]
                       [-prevent_diagonal_wire_access_bumps {true|false}]
                       [-prevent_via_under_bump {true|false}]
                       [-prevent_via_under_bump_extension <real>]
                       [-route_bump_cluster {true|false}]
                       [-route_pg_style {none|finger|mesh}]
                       [-route_style {manhattan|45DegreeRoute}]
                       [-routeWidth <real>] [-via_abut_bump {true|false}]
                       [-wire_to_pad_honor_min_spacing <value>]

-help                                      # Prints out the command usage
-reset                                     # Resets all or specified options to default value
-allow_layer_change {true|false}           # Specifies if turning on layer
                                           # change feature (bool, default=false)
-auto_pairing_file <fileName>              # Specifies the output file name to
                                           # dump out fcroute auto pairing
                                           # information for bump to I/O
                                           # connection (string, default="")
-bump_use_oct_shape {true|false}           # fcroute use circumferential
                                           # octagon to replace the complex pin
                                           # shape (bool, default=false)
-check_bump_access_directions {true|false}
                                           # Specifies whether check the
                                           # special bump access directions
                                           # (bool, default=false)
-compaction {true|false}                   # Specifies if turning on compaction
                                           # routing (bool, default=false)
-connectPowerCellToBump {true|false}       # Connects all power bumps to the
                                           # I/O cell pin. It does not connect
                                           # to a power or ground stripe or
                                           # ring (bool, default=false)
-constraintFile <fileName>                 # Specifies the file that contains
                                           # constraints for flip chip routing
                                           # (string, default="")
-drop_via_on_all_geometries {true|false}
                                           # fcroute drop via on all geometries (bool, default=false)
-drop_via_on_power_mesh <layerName>        # Specifies the metal layer by layer
                                           # number or layer name that the
                                           # software can use to drop via
                                           # (string, default="")
-extraConfig <fileName>                    # Specifies the name of an extra
                                           # configuration file for flip chip
                                           # routing (string, default="")
-finger_direction {N|E|S|W}                # Specifies main expansion direction
                                           # for finger routing
                                           # (enums={N E S W}, default=N)
-finger_max_width <real>                   # Specifies the max routing width
                                           # for one wire segment
                                           # (float, default=0)
-finger_min_width <real>                   # Specifies the min routing width
                                           # for one wire segment
                                           # (float, default=0)
-finger_target_mesh_layer_range {topLayer [bottomLayer]}
                                           # Target mesh layer range for finger
                                           # routing (string, default="")
-honor_bump_connect_target_constraint {true|false}
                                           # Specifies if enabling port
                                           # numbering routing
                                           # (bool, default=false)
-ignore_pad_type_check {true|false}        # Specifies if supporting CLASS PAD
                                           # cells in flipchip flow
                                           # (bool, default=true)
-layerChangeBotLayer <layerName>           # Specifies the bottom-most metal
                                           # layer by layer number or layer
                                           # name that the software can use
                                           # when routing bumps
                                           # (string, default="")
-layerChangeTopLayer <layerName>           # Specifies the top-most metal layer
                                           # by layer number or layer name that
                                           # the software can use when routing
                                           # bumps (string, default="")
-lower_layer_prevent_45_routing {true|false}
                                           # Specifies if preventing 45-degree
                                           # routing for lower layer
                                           # (bool, default=false)
-lower_layer_route_width <real>            # Specifies the different value for
                                           # lower routing layer
                                           # (float, default=0, min=0, max=10000000000)
-merge_nearby_pin {true|false}             # Merge pins which are close but not
                                           # touched (bool, default=false)
-multi_pad_routing_style {default|serial|star}
                                           # Specifies the routing style for
                                           # multi-pads routing
                                           # (enums={default serial star}, default=default)
-multipleConnection {multiPadsToBump|multiBumpsToPad|default}
                                           # Specifies routing connections
                                           # between multiple pads and bumps.
                                           # Default is no multiple connection
                                           # (enums={multiPadsToBump multiBumpsToPad default}, default=default)
-pg_mesh_direction {default|horizontal|vertical}
                                           # Specifies the main routing
                                           # direction of PG mesh
                                           # (enums={default horizontal vertical}, default=default)
-pg_mesh_main_width <real>                 # Specifies the main width of PG
                                           # mesh
                                           # (float, default=0, min=0, max=10000000000)
-pg_mesh_max_width <real>                  # Specifies the max width of PG mesh
                                           # (float, default=0, min=0, max=10000000000)
-pg_mesh_width <value>                     # Specify the exact width of PG
                                           # mesh. One value for both
                                           # horizontal and vertical width. And
                                           # with two values, the first value
                                           # for horizontal width and the
                                           # second value for vertical width
                                           # (string, default="")
-prevent_diagonal_wire_access_bumps {true|false}
                                           # Specifies whether use diagonal
                                           # wire to access bump or not
                                           # (bool, default=false)
-prevent_via_under_bump {true|false}       # Specifies if generating vias
                                           # directly under the bump
                                           # (bool, default=false)
-prevent_via_under_bump_extension <real>
                                           # specifies the spacing value around
                                           # bump to avoid dropping vias
                                           # (float, default=-1, min=-2, max=DBL_MAX)
-route_bump_cluster {true|false}           # Route bump cluster after bump
                                           # grouped (bool, default=false)
-route_pg_style {none|finger|mesh}         # Specifies the routing pattern for
                                           # fcroute power routing
                                           # (enums={none finger mesh}, default=none)
-route_style {manhattan|45DegreeRoute}     # Specifies routing style
                                           # (enums={manhattan 45DegreeRoute}, default=45DegreeRoute)
-routeWidth <real>                         # Specifies routing width
                                           # (float, default=0)
-via_abut_bump {true|false}                # via abut bump only if it is
                                           # success (bool, default=false)
-wire_to_pad_honor_min_spacing <value>     # Specifies the min spacing between
                                           # bump/pad with wire (float, default=0)