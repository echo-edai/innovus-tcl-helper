Usage: editPin [-help] [-end {x y}] [-fixedPin] [-global_location]
               [-include_rectilinear_edge] [-masterCloneAware]
               [-offsetEnd <float>] [-offsetStart <float>] [-pinDepth <float>]
               [-pinWidth <float>] [-quiet] [-skipWrappingPins]
               [-snap {TRACK USERGRID MGRID}]
               [-spreadDirection {clockwise counterclockwise both}]
               [-start { x y}] [-use <string>] [ { -layer {layerId | layerIdList} | {[-layerH <layerId>] [-layerV <layerId>]} } [-layer_priority ] [-assign {x y} | -pattern {fill_track fill_layer fill_optimised fill_diagonal fill_sinusoidal fill_checkerboard}]] [ -side <string> | -edge <integer> ] [ -cell <string> | {-hinst <hinstName> [-refMaster ]} ] [ -fixOverlap [ -honorConstraint ]] [ -pattern {fill_track fill_layer fill_optimised fill_diagonal fill_sinusoidal fill_checkerboard} [ -reverse_alternate ]] [ -spacing <string> [ -unit {MICRON TRACK} ]] [ -assign {x y} | -spreadType {START CENTER SIDE EDGE RANGE} | -pattern {fill_track fill_layer fill_optimised fill_diagonal fill_sinusoidal fill_checkerboard}] [ -pin {pinName | pinNameList} ]

-help                            # Prints out the command usage
-assign {x y}                    # Preassigns a pin at the specified location. 
                                 # (point, optional)
-cell <string>                   # Specifies the name of the module.
                                 # (string, optional)
-edge <integer>                  # For rectilinear partitions, specifies the
                                 # edge along which the pins will be placed.
                                 # (int, optional)
-end {x y}                       # For pin spreading along a range, specifies
                                 # the coordinates where pins should end.
                                 # (point, optional)
-fixOverlap                      # Bool value true|1 specifies that the pins
                                 # should be moved to the closest acceptable
                                 # position such that pins do not overlap and
                                 # value false|0 will not remove any overlap.
                                 # (bool, optional)
-fixedPin                        # A value of true|1 sets the pin status to
                                 # Fixed. (bool, optional)
-global_location                 # Specifies that all the loc are global
                                 # (bool, optional)
-hinst <hinstName>               # Specifies the hinst name, including black
                                 # box or committed partition and top.
                                 # (string, optional)
-honorConstraint                 # Specifies whether user-defined pin
                                 # constraints should be honored. (bool, optional)
-include_rectilinear_edge        # Include all edges coming in solution space.
                                 # (bool, optional)
-layer {layerId | layerIdList}   # Specifies the layer on which the pins will
                                 # be assigned. (string, optional)
-layerH <layerId>                # Specifies the preferred horizontal layer on
                                 # which the pins will be assigned.
                                 # (string, optional)
-layerV <layerId>                # Specifies the preferred vertical layer on
                                 # which the pins will be assigned.
                                 # (string, optional)
-layer_priority                  # Specifies that the input layer is given
                                 # based on its priority. (bool, optional)
-masterCloneAware                # To enable master-clone-context aware for
                                 # feasibility checking (bool, optional)
-offsetEnd <float>               # Sets the offset from the end of edge or side
                                 # (in microns) to be considered as end point
                                 # for placing the pin. (float, optional)
-offsetStart <float>             # Sets the offset from the start of edge or
                                 # side (in microns) to be considered as start
                                 # point for placing the pin. (float, optional)
-pattern {fill_track fill_layer fill_optimised fill_diagonal fill_sinusoidal fill_checkerboard}
                                 # Specifies the multi-layer-spread-pattern to
                                 # be followed by the set of selected pins.
                                 # (enum, optional)
-pin {pinName | pinNameList}     # Specifies the pins, or the list of pins of
                                 # the specified module on which the command
                                 # will run. (string, required)
-pinDepth <float>                # Sets the depth of the pin in microns.
                                 # (float, optional)
-pinWidth <float>                # Sets the width of the pin in microns.
                                 # (float, optional)
-quiet                           # To suppress messages (bool, optional)
-refMaster                       # Specifies that edge, spreadDirection, offset
                                 # are with respect to master (bool, optional)
-reverse_alternate               # Reverse of specified
                                 # multi-layer-spread-pattern. (bool, optional)
-side <string>                   # For rectangular partitions, specifies the
                                 # side on which the pins will be placed.
                                 # (string, optional)
-skipWrappingPins                # For skipping pin wrapping on adjacent edge
                                 # or same edge from other side (bool, optional)
-snap {TRACK USERGRID MGRID}     # Specifies how the pins will be snapped.
                                 # (enum, optional)
-spacing <string>                # Displays the spacing between pins for
                                 # multi-pin editing. (string, optional)
-spreadDirection {clockwise counterclockwise both}
                                 # Specifies the direction of pin placement
                                 # from the start location along the partition
                                 # fence. (enum, optional)
-spreadType {START CENTER SIDE EDGE RANGE}
                                 # Specifies how to spread pins along a block's
                                 # edge. (enum, optional)
-start { x y}                    # For pin spreading along a range, specifies
                                 # the coordinates where pins should start.
                                 # (point, optional)
-unit {MICRON TRACK}             # Specifies the unit in microns or in tracks.
                                 # (enum, optional)
-use <string>                    # Specifies the +USE property of the partition
                                 # pin. (string, optional)