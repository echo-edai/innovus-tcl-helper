Usage: addSpareInstance [-help] [-async <netName>] [-clock <netName>]
                        -file <fname> [-fix_placed_insts {TRUE|FALSE}]
                        [-prefix <prefix>] [-tie <0|1>] [-hier <module> | -powerDomain <domain> [-submodule <name>]]

-help                              # Prints out the command usage
-async <netName>                   # async net information (string, optional)
-clock <netName>                   # name of clock net (string, optional)
-file <fname>                      # file of cell names and numbers
                                   # (string, required)
-fix_placed_insts {TRUE|FALSE}     # do not move existing placed instances to
                                   # find location for newly spare insts
                                   # (bool, optional)
-hier <module>                     # module in which to add spares
                                   # (string, optional)
-powerDomain <domain>              # power domain in which to add spares
                                   # (string, optional)
-prefix <prefix>                   # prefix for spare instances
                                   # (string, optional)
-submodule <name>                  # module created for spares
                                   # (string, optional)
-tie <0|1>                         # tie net for spare instances
                                   # (int, optional)