Usage: write_name_mapping [-help] [-bbox_pins] [-hierarchical]
                          [-map_pins {input output all}] [-pin_polarity]
                          [-skip_clock_gate] [-updated_only] {<out_file> | [[-output <string>] -prefix <string>]} [-enable_one_to_one_mapping  | -report_power_format ] [-hdl  | -initial  | [-input_mapping_file <string> [-print_deleted ] [-include_new_iterms ]]]

-help                            # Prints out the command usage
<out_file>                       # Name of output name mapping file
                                 # (string, optional)
-bbox_pins                       # If true, writes out bbox pins, if false,
                                 # write out bbox (bool, optional)
-enable_one_to_one_mapping       # If true, only one of the clone will be
                                 # printed in the mapping file. (bool, optional)
-hdl                             # Enable the generation of name mapping from
                                 # current names to names defined by 'hdl_name'
                                 # attribute. (bool, optional)
-hierarchical                    # Specify if write out other post boundary
                                 # optimizations mapping. (bool, optional)
-include_new_iterms              # When the value is set as true, the output
                                 # mapping file will write out the updated
                                 # items as well as "new added iterms" that
                                 # exists in innovus but not in input mapping
                                 # file. (bool, optional)
-initial                         # Enable the generation of name mapping from
                                 # current names to names defined by
                                 # 'initial_name' attribute. (bool, optional)
-input_mapping_file <string>     # When provided Tool will read existing
                                 # mapping file and write out updated mapping
                                 # file. (string, optional)
-map_pins {input output all}     # Specify type of sequential pins to write
                                 # out, defaut is input. (enum, optional)
-output <string>                 # Specify output directory (string, optional)
-pin_polarity                    # Specify if write out polarity information.
                                 # (bool, optional)
-prefix <string>                 # Used for file name prefix (string, optional)
-print_deleted                   # If user specifies the option or provide
                                 # value as true then mapping file will also
                                 # print deleted instances. Default False
                                 # (bool, optional)
-report_power_format             # Specify if write out power replay format, if
                                 # false, write out default format with 'add
                                 # mapped point'. (bool, optional)
-skip_clock_gate                 # Filter out ICGs which are not in RTL,
                                 # default true. (bool, optional)
-updated_only                    # It skips printing any pin which does not
                                 # have any change/update during
                                 # optimizations/flow. (bool, optional)