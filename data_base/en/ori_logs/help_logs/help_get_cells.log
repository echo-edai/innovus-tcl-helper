Usage: get_cells [-help] [-filter <expr>] [-hierarchical] [-hsc <char>] [-leaf]
                 [-nocase] [-quiet] [-regexp] [ <patterns> | -of_objects <object_list> ]

-help                         # Prints out the command usage
<patterns>                    # Patterns for instance names (string, optional)
-filter <expr>                # Filters the collection with the specified
                              # expression (string, optional)
-hierarchical                 # Patterns should be matched hierarchically
                              # (bool, optional)
-hsc <char>                   # Hierarchical delimiter for patterns
                              # (string, optional)
-leaf                         # Return leaf cells only (bool, optional)
-nocase                       # Pattern matching is not case sensitive
                              # (bool, optional)
-of_objects <object_list>     # Creates a collection of all cells associated
                              # with the specified pins or nets (string, optional)
-quiet                        # Suppresses all error and warning messages
                              # generated when the get_cells command is run
                              # (bool, optional)
-regexp                       # Treats the specified patterns as a regular
                              # expression patterns (bool, optional)