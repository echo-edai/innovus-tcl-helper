Usage: reset_data_check [-help] [-clock <clock_object>] [-hold] [-setup] {-from <pin_or_port_list> | -rise_from <pin_or_port_list> | -fall_from <pin_or_port_list>} {-to <pin_or_port_list> | -rise_to <pin_or_port_list> | -fall_to <pin_or_port_list>}

-help                             # Prints out the command usage
-clock <clock_object>             # Removes the data check with a related
                                  # (-from) pin event that is triggered by the
                                  # specified clock (string, optional)
-fall_from <pin_or_port_list>     # Removes checks at the falling edge of the
                                  # signal on the from pins (string, optional)
-fall_to <pin_or_port_list>       # Removes the falling edge of the signal on
                                  # the to pins (string, optional)
-from <pin_or_port_list>          # Removes checks for both the rising and the
                                  # falling edges (string, optional)
-hold                             # Data check to be removed is for hold check
                                  # (bool, optional)
-rise_from <pin_or_port_list>     # Removes checks at the rising edge of the
                                  # signal on the from pins (string, optional)
-rise_to <pin_or_port_list>       # Removes the rising edge of the signal on
                                  # the from pins (string, optional)
-setup                            # Data check to be removed is for setup check
                                  # (bool, optional)
-to <pin_or_port_list>            # Removes both the rising and the falling
                                  # edges (string, optional)