Usage: create_what_if_shape [-help] [-area {x1 y1 x2 y2}]
                            [-direction {hor ver}] [-display]
                            [-format {text def}] [-layer <string>]
                            [-nets <string>] [-objects {selected all}]
                            [-offset {x y}] [-pitch <float>] [-spacing <string>]
                            [-type {wire via}] [-add  -method {auto exact}] [-add  | -select  | -deselect  | -delete  | -list  | -save <string> | -load <string> | -remove_existing_wires ] [-add  -width <string>] [-save <string> -append ]

-help                   # Prints out the command usage
-add                    # add what-if wires/vias (bool, optional)
-append                 # append all wires/vias into existing file
                        # (bool, optional)
-area {x1 y1 x2 y2}     # <llx> <lly> <urx> <ury> bounding box coordinates of a
                        # region (box, optional)
-delete                 # delete what if wires/via in conjunction with -objects
                        # <all/selected> (bool, optional)
-deselect               # deselect what-if shapes either by “area” in
                        # conjunction with –area {llx lly urx ury} for
                        # overlap check or standalone for all shapes
                        # (bool, optional)
-direction {hor ver}    # specify the direction in which wire is to be added
                        # (enum, optional)
-display                # works in -win mode. Will zoom the selected wires/vias
                        # (bool, optional)
-format {text def}      # specify output file format (enum, optional)
-layer <string>         # <layerName>layer on which what if wire is to be added
                        # (string, optional)
-list                   # list all the what-if wires/via added in conjuction
                        # with -objects <all/selected> (bool, optional)
-load <string>          # <filename> load whatif file (string, optional)
-method {auto exact}    # vias to be added automatically or exact
                        # (enum, optional)
-nets <string>          # net on which what if wire needs to be added
                        # (string, optional)
-objects {selected all} # selected or all objects in conjunction with list or
                        # delete (enum, optional)
-offset {x y}           # {x_offset y_offset} the offset in x and y direction
                        # (point, optional)
-pitch <float>          # the interval after which the what if wires will be
                        # added  for each specified net (float, optional)
-remove_existing_wires  # delete existing wires (bool, optional)
-save <string>          # <filename>save to what_if_file (string, optional)
-select                 # select what-if shapes either by “area” in
                        # conjunction with –area {llx lly urx ury} for
                        # overlap check or standalone for all shapes
                        # (bool, optional)
-spacing <string>       # the interval after which the what if wires will be
                        # added  for each specified net (string, optional)
-type {wire via}        # specify what-if wire or what-if via (enum, optional)
-width <string>         # the interval after which the what if wires will be
                        # added  for each specified net (string, optional)