Usage: ecoPlace [-help] [-fixPlacedInsts {true|false}]
                [-place_detail_use_GA_filler_groups {true|false}]
                [-reportSpareCells <value>] [-saveODInfoOnly {true|false}]
                [-timing_driven {true|false}] [-useGACells <techSiteName>]
                [-useGAFillerCells <fillerCellList>]
                [-useSpareCells {true|false}]

-help                                  # Prints out the command usage
-fixPlacedInsts {true|false}           # do not move existing placed instances
                                       # to find location for newly placed
                                       # insts (bool, default=false)
-place_detail_use_GA_filler_groups {true|false}
                                       # filler cell insts will only be
                                       # replaced by logic insts that belong to
                                       # same GA groups. (bool, default=false)
-reportSpareCells <value>              # report spare instances which are
                                       # selected to map unplaced logical
                                       # instances (string, default="")
-saveODInfoOnly {true|false}           # save the snapshot of the site OD
                                       # information to DB (bool, default=false)
-timing_driven {true|false}            # turn on SKP for ecoPlace
                                       # (bool, default=false)
-useGACells <techSiteName>             # place new cells on GA grid, at
                                       # locations where given techSite is
                                       # available (string, default="")
-useGAFillerCells <fillerCellList>     # replace given filler cell insts with
                                       # new logic insts, assuming GA pattern
                                       # will match, if orient is same
                                       # (string, default="")
-useSpareCells {true|false}            # convert the spare closest to optimal
                                       # location of new inst
                                       # (bool, default=false)