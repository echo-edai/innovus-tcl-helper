Usage: scanTrace [-help] [-verbose {true|false}] [-lockup | -nolockup]
                 [-compLogic | -noCompLogic]

-help                     # Prints out the command usage
-compLogic {true|false}   # trace through multiple input logic gate
                          # (bool, optional)
-lockup {true|false}      # specifies that the tracing detects lockup latches
                          # automatically (bool, optional)
-noCompLogic              # do not trace through multiple input logic gate
                          # (bool, optional)
-nolockup                 # specifies that the tracing will not detect lockup
                          # elements (bool, optional)
-verbose {true|false}     # print out more message (bool, optional)