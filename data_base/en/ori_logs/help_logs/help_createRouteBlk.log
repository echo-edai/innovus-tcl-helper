Usage: createRouteBlk [-help] [-cutLayer <layerId|{layerId list}|all>]
                      [-drcRegionLayer <layerId|{layerId list}|all>]
                      [-inst <name>] [-layer <layerId|{layerId list}|all>]
                      [-mask <integer>] [-noWrongWay] [-pushdown]
                      [-trimMetalLayer <layerZ|{layerZ list}|all>] {-box {x1 y1 x2 y2} | -cover | -polygon {{x1 y1} {x2 y2}...} | -boxList {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...} } [-exceptpgnet | -pgnetonly | -partial <integer>] [-spacing <float> | -designRuleWidth <float>] [-fills | -exceptFill ] [-name <blk> | -prefixOn ]

-help                                   # Prints out the command usage
-box {x1 y1 x2 y2}                      # llx, lly, urx, ury (box, required)
-boxList {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...}
                                        # a list of boxes that defines a list
                                        # of one or more rectangles.
                                        # (box_list, required)
-cover                                  # use instance box (bool, required)
-cutLayer <layerId|{layerId list}|all>  # specify cut layers (list, optional)
-designRuleWidth <float>                # distance from design edge
                                        # (float, optional)
-drcRegionLayer <layerId|{layerId list}|all>
                                        # specify drc region layers (list, optional)
-exceptFill                             # set 'exceptFill' attribute. Specifies
                                        # that the routing blockage is to be
                                        # applied to other all net routings but
                                        # not on metal fills (bool, optional)
-exceptpgnet                            # set 'exceptpgnet' attribute
                                        # (bool, optional)
-fills                                  # set 'fill' attribute (bool, optional)
-inst <name>                            # instance name to be covered
                                        # (string, optional)
-layer <layerId|{layerId list}|all>     # specify metal layers (list, optional)
-mask <integer>                         # specify the mask which will only be
                                        # blocked. (int, optional)
-name <blk>                             # blockage name (string, optional)
-noWrongWay                             # set 'noWrongWay' attribute. Only real
                                        # routing wires will honor it and do
                                        # not have jogs in this region.
                                        # (bool, optional)
-partial <integer>                      # create partial routing blockage with
                                        # routing specified density
                                        # (int, optional, min=0, max=100)
-pgnetonly                              # set 'pgnetonly' attribute. Only PG
                                        # nets will honor the created routing
                                        # blockage. (bool, optional)
-polygon {{x1 y1} {x2 y2}...}           # coordination of each vertex of the
                                        # shape. (point_list, required)
-prefixOn                               # name blockage with prefix
                                        # (bool, optional)
-pushdown                               # set 'pushdown' attribute. Specify the
                                        # blockage is pushed down into the
                                        # block from the top level of the
                                        # design (bool, optional)
-spacing <float>                        # minimum spacing between layers
                                        # (float, optional)
-trimMetalLayer <layerZ|{layerZ list}|all>
                                        # specify trim metal layers (list, optional)