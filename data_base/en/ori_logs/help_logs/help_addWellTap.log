Usage: addWellTap [-help] [-area <box>] [-avoidAbutment] [-cell <string>]
                  [-cellInterval <float>] [-channel_offset <float>]
                  [-checkerBoard] [-fixedGap] [-inRowOffset <float>]
                  [-powerDomain <name>] [-prefix <prefix>]
                  [-siteOffset <siteNums>] [-skipRow <integer>]
                  [-startRowNum <integer>] [{ -block_boundary_only flag }] [{{-termination_cell <cell_list> | {-top_termination_cell <cell_list> -bottom_termination_cell <cell_list>}} -column_cell <cell_list>} [-block_boundary_only flag]] [{-wellCutCell <string>} [-fixCutCell flag]] [-pitch <float> [-pitchOffset <float>]] [{-check_channel | -vertical_boundary_spacing <float> | -incremental <string>}] [{-insert_cells <string> | -incremental <string>}] [-safety_tmr [-safety_tmr_insts <instance_list>]]

-help                                    # Prints out the command usage
-area <box>                              # Area in which welltaps are to be
                                         # inserted (box, optional)
-avoidAbutment                           # Specifies wether inserting avoids
                                         # abutment in vertical and horizontal
                                         # direction (bool, optional)
-block_boundary_only <flag>              # Specifies whether inserting
                                         # termination cells on the core
                                         # boundary (bool, optional)
-bottom_termination_cell <cell_list>     # Specifies the list of termination
                                         # cells to be used at bottom
                                         # (string, optional)
-cell <string>                           # Cell to be used as welltap
                                         # (string, optional)
-cellInterval <float>                    # Distance from the center of one
                                         # well-tap cell to the center of the
                                         # following well-tap cell in the same
                                         # row (float, optional)
-channel_offset <float>                  # Specifies the offset value between
                                         # taps and blockage in channel
                                         # (float, optional, min=0, max=1.79769313486232e+308)
-check_channel                           # insert well taps inside channel
                                         # (bool, optional)
-checkerBoard                            # Places welltaps in a checker-board
                                         # fashion (bool, optional)
-column_cell <cell_list>                 # Specifies the list of cells which
                                         # can be replaced by termination cell
                                         # (string, optional)
-fixCutCell <flag>                       # Fix all the instances which belong
                                         # to wellCutCell list (bool, optional)
-fixedGap                                # Ensures that the specified gap is
                                         # always maintained (bool, optional)
-inRowOffset <float>                     # Specifies the distance between the
                                         # first wellTap in a row and the start
                                         # of the row (float, optional)
-incremental <string>                    # Checks whether any instances of the
                                         # cells specified in the list_of_cells
                                         # are within 0.45 times the -maxGap or
                                         # -cellGap from the next well-tap cell
                                         # in the same row. If so, does not add
                                         # well-tap cells at that location.
                                         # (string, optional)
-insert_cells <string>                   # Insert mixed well-taps, support LUP
                                         # layer and boundary rule
                                         # (string, optional)
-pitch <float>                           # Specifies where welltaps could be
                                         # placed if a wellTap cannot be
                                         # inserted at cellInterval or maxGap
                                         # (float, optional)
-pitchOffset <float>                     # Specifies the offset value used for
                                         # pitch calculation (float, optional)
-powerDomain <name>                      # Power domain for which welltaps are
                                         # to be inserted (string, optional)
-prefix <prefix>                         # Prefix of welltaps to inserted
                                         # (string, optional)
-safety_tmr                              # Places welltaps adjacent to the left
                                         # & right edges of every tmr flop
                                         # (bool, optional)
-safety_tmr_insts <instance_list>        # Specifies the list of instances
                                         # required to place welltaps
                                         # adjacently (string, optional)
-siteOffset <siteNums>                   # Specifies an offset value in number
                                         # of sites so that the vertical taps
                                         # need to be aware of (uint, optional)
-skipRow <integer>                       # Specifies the number of rows to skip
                                         # between two rows of an identical
                                         # pattern. (int, optional)
-startRowNum <integer>                   # Specifies the row number starting
                                         # from the from bottom or left side of
                                         # the design on which the well-tap
                                         # cells must be placed. (int, optional)
-termination_cell <cell_list>            # Specifies the list of termination
                                         # cells to be used (string, optional)
-top_termination_cell <cell_list>        # Specifies the list of termination
                                         # cells to be used at top
                                         # (string, optional)
-vertical_boundary_spacing <float>       # Specifies vertical boundary spacing
                                         # with well tap
                                         # (float, optional, min=-1, max=1.79769313486232e+308)
-wellCutCell <string>                    # Specifies the list of cells with the
                                         # well cuts (string, optional)