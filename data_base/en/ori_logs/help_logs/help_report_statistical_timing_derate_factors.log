**WARN: (TCLCMD-1483):	The report_statistical_timing_derate_factors command is obsolete and will be removed from the software in a future release. The command will continue to work in the current release - but to ensure that your scripts will be compatible with future versions of the software - you should remove this command from your scripts.

Usage: report_statistical_timing_derate_factors [-help] [-derate_cell]
                                                [-derate_cell_check]
                                                [-derate_net]
                                                [-max_slack <float>]
                                                [-path_based_ssta]
                                                [-path_group <groupname_list>]
                                                [-ssta_view <ssta_view_name>]
                                                [-sta_view <sta_view_name>]
                                                [-type {arrival_time_based slack_time_based}] [-early  | -late ] [ -clock_factor  | -data_factor ] [ -max_paths <integer> | -max_points <integer>]

-help                            # Prints out the command usage
-clock_factor                    # Specifies if the user-defined factor value
                                 # is for clock (bool, optional)
-data_factor                     # Specifies if the user-defined factor value
                                 # is for data (bool, optional)
-derate_cell                     # Applies user-specified scaling factors on
                                 # cell delays (bool, optional)
-derate_cell_check               # Applies user-specified scaling factors on
                                 # timing checks. (bool, optional)
-derate_net                      # Applies user-specified scaling factors on
                                 # net delays. (bool, optional)
-early                           # Specifies the mode for which derate is to be
                                 # reported. (bool, optional)
-late                            # Specifies the mode for which derate is to be
                                 # reported. (bool, optional)
-max_paths <integer>             # Reports the specified number of worst paths
                                 # in the design, regardless of the endpoint
                                 # (int, optional)
-max_points <integer>            # Reports the worst path it finds to each
                                 # endpoint up to the number specified by the
                                 # -max_points option (int, optional)
-max_slack <float>               # Reports only those paths with slack equal to
                                 # or less than the value of float are reported
                                 # (float, optional)
-path_based_ssta                 # Enables generation of the statistical OCV
                                 # factor using path based SSTA analysis.
                                 # (bool, optional)
-path_group <groupname_list>     # Considers only the path contained in the
                                 # groups in the specified groupname_list for
                                 # computing the statistical timing derate
                                 # factor. (string, optional)
-ssta_view <ssta_view_name>      # Specifies view for SSTA run.
                                 # (string, optional)
-sta_view <sta_view_name>        # Specifies view for STA run.
                                 # (string, optional)
-type {arrival_time_based slack_time_based}
                                 # Specifies if the OCV factor needs to be
                                 # generated using the arrival time or slack
                                 # time approach. Default is arrival_time_based
                                 # (enum, optional)