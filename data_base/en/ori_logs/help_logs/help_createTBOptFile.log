Usage: createTBOptFile [-help] -bottleneckInstanceNumber <integer> [-early]
                       [-max_paths <integer>] [-max_slack <float>]
                       [-min_slack <float>] -outFile <string>
                       [-path_group <string>] [-timingFile <string>]

-help                                   # Prints out the command usage
-bottleneckInstanceNumber <integer>     # Number of instances to generate.
                                        # (int, required)
-early                                  # Generate tbOpt file for hold.
                                        # (bool, optional)
-max_paths <integer>                    # Considers the specified number of
                                        # worst paths, regardless of the
                                        # endpoint. (int, optional)
-max_slack <float>                      # Considers only the paths with slack
                                        # equal to or less than the specified
                                        # value. (float, optional)
-min_slack <float>                      # Considers only the paths with slack
                                        # greater than the specified value.
                                        # (float, optional)
-outFile <string>                       # Specifies output file name.
                                        # (string, required)
-path_group <string>                    # Considers only the paths from the
                                        # specified path group. (string, optional)
-timingFile <string>                    # Timing report file name.
                                        # (string, optional)