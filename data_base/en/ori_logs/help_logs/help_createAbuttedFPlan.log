Usage: createAbuttedFPlan [-help] [-cutToFixOverlap]
                          [-honorPlaceBlockage <string>]
                          [-ptnToCoreGap <micron>] [-ptnToPtnGap <micron>] {-hinsts <string> | -selected  | -all }

-help                                    # Prints out the command usage
-all                                     # grow all partitions in the design
                                         # (bool, optional)
-cutToFixOverlap                         # if this option is on, we will cut
                                         # overlapped partitions, otherwise, we
                                         # will shrink them instead of cutting.
                                         # (bool, optional)
-hinsts <string>                         # names of Hinsts of target partitions
                                         # to grow (string, optional)
-honorPlaceBlockage <string>             # default is not honor placement
                                         # blockage, user can set to all or
                                         # placement blockage names
                                         # (string, optional)
-ptnToCoreGap <micron>                   # distance between partitions and core
                                         # boundary after grow. (float, optional)
-ptnToPtnGap <micron>                    # distance between partitions after
                                         # grow. (float, optional)
-selected                                # grow selected partitions
                                         # (bool, optional)