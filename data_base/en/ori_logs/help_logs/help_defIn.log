Usage: defIn [-help] <fileName> [-add_blockage] [-add_power_switch]
             [-allWarning] [-components] [-deleteBump] [-deleteSpecialRoute]
             [-ignore_drcfill] [-ignore_pg_connectivity] [-nets]
             [-override_special_routing {pg signal logical physical all}]
             [-preserveShape] [-removeHalfWireExtensionOnPin]
             [-specialRouteUserClass <string>] [-specialnets]
             [-verilog_from_def_netlist_flow] [ -incremental_routing ]

-help                              # Prints out the command usage
<fileName>                         # Def filename (string, required)
-add_blockage                      # indicate it's a reduced netlist and
                                   # undefined instances are converted to
                                   # blockages (bool, optional)
-add_power_switch                  # Add power switch for missing DEF
                                   # components (bool, optional)
-allWarning                        # Lists all warning message (bool, optional)
-components                        # Read COMPONENTS (bool, optional)
-deleteBump                        # Delete bump (bool, optional)
-deleteSpecialRoute                # Delete special route (bool, optional)
-ignore_drcfill                    # Ignore the special routing with DRCFILL
                                   # shape attribute (bool, optional)
-ignore_pg_connectivity            # Ignore the pg connectivity in both
                                   # SPECIALNETS and NETS section (bool, optional)
-incremental_routing               # Incremental read nets (bool, optional)
-nets                              # Read NETS (bool, optional)
-override_special_routing {pg signal logical physical all}
                                   # Delete special routing in db on nets
                                   # specified in def file by net type
                                   # (enum, optional)
-preserveShape                     # preserveShape (bool, optional)
-removeHalfWireExtensionOnPin      # Truncates the half-width (bool, optional)
-specialRouteUserClass <string>    # User Class for special route
                                   # (string, optional)
-specialnets                       # Read SPECIALNETS (bool, optional)
-verilog_from_def_netlist_flow     # Reconciles name in DEF and Verilog
                                   # (bool, optional)