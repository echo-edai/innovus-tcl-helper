Usage: generateRCFactor [-help] [-outputFile <string>]
                        [-postroute {low medium}] [-preroute {true false}]
                        [-reference {low medium high signoff externalSpef}]
                        [-spefMapFile <string>] [-useSameRouting {true false}]
                        [-use_ostrich_filters <string>]

-help                            # Prints out the command usage
-outputFile <string>             # Specifies file name to save new RC factor
                                 # setting  (string, optional)
-postroute {low medium}          # Generates scale factor for postRoute
                                 # extraction  (enum, optional)
-preroute {true false}           # Generates scale factor for preRoute
                                 # extraction  (enum, optional)
-reference {low medium high signoff externalSpef}
                                 # Specifies engine/external spef for
                                 # comparison  (enum, optional)
-spefMapFile <string>            # Specifies spef map file for comparison in
                                 # MMMC designs  (string, optional)
-useSameRouting {true false}     # Specifies to use same routed db when
                                 # generating spefs  (enum, optional)
-use_ostrich_filters <string>    # Specifies file name containing ostrich data
                                 # filters (string, optional)