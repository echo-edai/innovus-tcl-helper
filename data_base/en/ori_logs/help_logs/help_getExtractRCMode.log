Usage: getExtractRCMode [-help] [-assumeMetFill] [-capFilterMode]
                        [-cerebrus_license_only] [-compressOptMemRCDB]
                        [-coupled] [-coupling_c_th] [-defViaCap] [-effortLevel]
                        [-engine] [-extraCmdFile]
                        [-extract_rc_quantus_executable]
                        [-extract_rc_signoff_stream_layer_map_ccl]
                        [-extractionFillStreamMapFile] [-hardBlockObs]
                        [-incremental] [-iquantus_cap_high_accuracy_mode]
                        [-layerIndependent] [-lefTechFileMap] [-localCpu]
                        [-pvs_fill] [-qrcCmdFile] [-qrcCmdType] [-qrcOutputMode]
                        [-qrcRunMode] [-relative_c_th]
                        [-signoff_stream_layer_map] [-total_c_th]
                        [-tQuantusModelFile] [-tsvSubcktFile] [-turboReduce]
                        [-useQrcOAInterface] [-useShieldingInDetailMode]
                        [-viaCap] [-writeDefOptionsForSignoffExtract]
                        [-quiet] [-nonDefault]

-help                                      # Prints out the command usage
-assumeMetFill                             # Assume metal fill
                                           # (float, default=0, min=0, max=1)
-capFilterMode                             # Coupling Capacitance Filtering
                                           # Mode
                                           # (enums={relOnly relAndCoup relOrCoup}, default=relOnly)
-cerebrus_license_only                     # Fall back to the regular QTS
                                           # license(s) when Cerebrus is not
                                           # available (bool, default=false)
-compressOptMemRCDB                        # Create compressed RCDB
                                           # (bool, default=false)
-coupled                                   # Extract coupling cap
                                           # (bool, default=false)
-coupling_c_th                             # Coupling C threshold value
                                           # (float, default=3)
-defViaCap                                 # Consider via caps for extraction
                                           # (bool, default=false)
-effortLevel                               # Specifies the effort level of the
                                           # post-route extraction engine
                                           # (enums={low medium high signoff}, default=undefined)
-engine                                    # Extraction engine
                                           # (enums={preRoute postRoute}, default=preRoute)
-extraCmdFile                              # Extra command file for Quantus QRC
                                           # (string, default="")
-extract_rc_quantus_executable             # QRC Executable file path
                                           # (string, default="")
-extract_rc_signoff_stream_layer_map_ccl
                                           # QRC stream  map file in CCL format (string, default="")
-extractionFillStreamMapFile               # Quantus stream/oasis file
                                           # (string, default="")
-hardBlockObs                              # Makes obstructions and
                                           # power/ground pin shapes visible to
                                           # the extractor for hard blocks only
                                           # (bool, default=false)
-incremental                               # Use incremental signoff mode
                                           # (bool, default=true)
-iquantus_cap_high_accuracy_mode           # Use for iquantus capacitance high
                                           # accuracy mode  (bool, default=false)
-layerIndependent                          # Enable layer independent
                                           # extraction
                                           # (int, default=1, min=0, max=1)
-lefTechFileMap                            # LEF-QRCTechfile layer map file
                                           # (string, default="")
-localCpu                                  # (int, default=0)
-pvs_fill                                  # Use to send the PVS fill data
                                           # attached to the Innovus DB (see
                                           # set_pvs_fill) to Quantus
                                           # (bool, default=false)
-qrcCmdFile                                # Quantus QRC user command file name
                                           # (string, default="")
-qrcCmdType                                # Quantus QRC command input type
                                           # (enums={auto partial custom}, default=auto)
-qrcOutputMode                             # Quantus QRC output mode
                                           # (enums={spef rcdb}, default=spef)
-qrcRunMode                                # Quantus QRC MMMC run mode
                                           # (enums={concurrent sequential}, default=concurrent)
-relative_c_th                             # Relative C threshold value
                                           # (float, default=0.03)
-signoff_stream_layer_map                  # QRC stream  map file
                                           # (string, default="")
-total_c_th                                # Total C threshold value
                                           # (float, default=5)
-tQuantusModelFile                         # TQuantus model file name
                                           # (string, default="")
-tsvSubcktFile                             # TSV subckt file name
                                           # (string, default="")
-turboReduce                               # Reduce XCap (IQuantus)
                                           # (enums={true false auto}, default=auto)
-useQrcOAInterface                         # Use OA interface for invoking
                                           # Quantus QRC extraction
                                           # (bool, default=false)
-useShieldingInDetailMode                  # Considers shielding for a wire
                                           # segment (bool, default=false)
-viaCap                                    # Consider via caps for extraction
                                           # (bool, default=true)
-writeDefOptionsForSignoffExtract          # write_def options
                                           # (string, default="")
-quiet                                     # Displays the current settings in Tcl list format only
-nonDefault                                # Displays the current settings which are not default settings