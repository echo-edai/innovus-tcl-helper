Usage: setAddStripeMode [-help] [-reset]
                        [-allow_jog {none|padcore_ring|block_ring}]
                        [-allow_nonpreferred_dir {none|blockring|corering|padring|stripe}]
                        [-area {<lx ly ux uy> | <x1 y1 x2 y2 x3 y3 ...>}]
                        [-break_at {none|block_ring|selected_block|unassigned_bump|overlap_ringpin|outer_ring|outside_ringmacro|blocks_without_same_net}]
                        [-color_balance {same_color|alternate_color|none}]
                        [-continue_on_no_selection {true|false}]
                        [-detailed_log {true|false}]
                        [-domain_offset_from_core {true|false}]
                        [-extend_to_closest_target {ring|stripe|same_dir_stripe|area_boundary|none}]
                        [-extend_to_first_ring {true|false}]
                        [-ignore_block_check {true|false}]
                        [-ignore_blockring_when_breaking {true|false}]
                        [-ignore_DRC {true|false}]
                        [-ignore_nondefault_domains {true|false}]
                        [-inside_cell_allow_shift {true|false}]
                        [-inside_cell_only {true|false}]
                        [-keep_pitch_after_snap {true|false}]
                        [-max_extension_distance <value>]
                        [-max_via_size {shape width% height% target_penetration%}]
                        [-merge_with_all_layers {true|false}]
                        [-mesh_via {true|false}]
                        [-offset_from_core {true|false}]
                        [-optimize_stripe_for_routing_track {shift|none}]
                        [-orthogonal_offset {edge1 offset_value ...}]
                        [-orthogonal_only {true|false}]
                        [-over_row_extension {true|false}]
                        [-partial_set_thru_domain {true|false}]
                        [-recommend_width <file_name>]
                        [-remove_floating_stapling {true|false}]
                        [-remove_floating_stripe_over_block {true|false}]
                        [-remove_stripe_under_ring {true|false}]
                        [-route_over_rows_only {true|false}]
                        [-rows_without_stripes_only {true|false}]
                        [-same_sized_stack_vias {true|false}]
                        [-skip_via_on_pin {pad|block|cover|standardcell|physicalpin}]
                        [-skip_via_on_wire_shape {blockring|stripe|followpin|corewire|blockwire|iowire|padring|ring|fillwire|noshape}]
                        [-spacing_from_block <value>]
                        [-spacing_type {edge_to_edge|center_to_center}]
                        [-split_long_via {threshold step offset length}]
                        [-split_vias {true|false}] [-split_wire_spacing <value>]
                        [-split_wire_weight <integer_0_to_10>]
                        [-split_wire_width <value>]
                        [-stacked_via_bottom_layer <layerName>]
                        [-stacked_via_top_layer <layerName>]
                        [-stapling_extend_to_minimum_spacing {true|false}]
                        [-stapling_nets_style {end_to_end|side_to_side|side_to_side_full_nets}]
                        [-stapling_shift {true|false}]
                        [-stop_at_closest_target {none|block_ring|core_ring|stripe}]
                        [-stop_at_last_wire_for_area {true|false}]
                        [-stripe_min_length <value>] [-stripe_min_width <value>]
                        [-switch_cellname <cellname>]
                        [-switch_layer_overlap_length <value>]
                        [-trim_antenna_back_to_shape {none|block_ring|core_ring|pad_ring|stripe}]
                        [-trim_antenna_max_distance <value>]
                        [-trim_stripe {none|design_boundary|core_boundary}]
                        [-use_exact_spacing {true|false}]
                        [-use_point2point_router {true|false}]
                        [-use_stripe_width {true|false}]
                        [-via_using_exact_crossover_size {true|false}] [-respect_routes {none||fixed||fixed_and_clock||all} ]

-help                                      # Prints out the command usage
-reset                                     # Resets all or specified options to default value
-allow_jog {none|padcore_ring|block_ring}
                                           # Specifies the allowed jog type. (enums={none padcore_ring block_ring}_list, default=padcore_ring block_ring)
-allow_nonpreferred_dir {none|blockring|corering|padring|stripe}
                                           # Specifies whether to allow
                                           # non-preferred direction to jog to
                                           # target
                                           # (enums={none blockring corering padring stripe}_list, default=padring)
-area {<lx ly ux uy> | <x1 y1 x2 y2 x3 y3 ...>}
                                           # Specify the rectangular areas or
                                           # rectilinear areas or a mix of
                                           # them, the correct value should be
                                           # {<lx ly ux uy> | <x1 y1 x2 y2 x3
                                           # y3 ...>} (string, default="")
-break_at {none|block_ring|selected_block|unassigned_bump|overlap_ringpin|outer_ring|outside_ringmacro|blocks_without_same_net}
                                           # Specifies the stripe break point. (enums={none block_ring selected_block unassigned_bump overlap_ringpin outer_ring outside_ringmacro blocks_without_same_net}_list, default=none)
-color_balance {same_color|alternate_color|none}
                                           # same_color would correspond to
                                           # interlace with groups and
                                           # alternate_color would correspond
                                           # to interlace within group
                                           # (enums={same_color alternate_color none}, default=none)
-continue_on_no_selection {true|false}     # Specifies whether to continue w/o
                                           # selection (bool, default=false)
-detailed_log {true|false}                 # Specifies whether to output
                                           # detailed log file addStripe.log
                                           # (bool, default=false)
-domain_offset_from_core {true|false}      # Specifies whether to use global
                                           # offset for power domain stripes
                                           # (bool, default=false)
-extend_to_closest_target {ring|stripe|same_dir_stripe|area_boundary|none}
                                           # Specifies the stripe to specified
                                           # target
                                           # (enums={ring stripe same_dir_stripe area_boundary none}_list, default=none)
-extend_to_first_ring {true|false}         # Specifies whether to extend stripe
                                           # antennas to closest ring
                                           # (bool, default=false)
-ignore_block_check {true|false}           # Specifies whether to ignore block
                                           # check (bool, default=false)
-ignore_blockring_when_breaking {true|false}
                                           # Specifies whether to break stripe
                                           # outside block (bool, default=false)
-ignore_DRC {true|false}                   # Specifies whether to ignore DRC
                                           # check during stripe generation, it
                                           # is always used for prototype flow
                                           # (bool, default=false)
-ignore_nondefault_domains {true|false}    # Specifies whether to break at
                                           # non-default domain
                                           # (bool, default=false)
-inside_cell_allow_shift {true|false}      # Specifies to allow the created
                                           # pillar inside cell can be shifted
                                           # when meeting DRC
                                           # (bool, default=false)
-inside_cell_only {true|false}             # Specifies whether to generate
                                           # stripes only inside selected or
                                           # specified cell (bool, default=false)
-keep_pitch_after_snap {true|false}        # (bool, default=false)
-max_extension_distance <value>            # Specifies maximum extension
                                           # distance(default=max integer) when
                                           # -extend_to_closest_target is
                                           # specified.
                                           # (float, default=2147483647)
-max_via_size {shape width% height% target_penetration%}
                                           # the maximum size of a crossover
                                           # via, the correct value should be
                                           # {shape width% height%
                                           # target_penetration%}
                                           # (string, default="")
-merge_with_all_layers {true|false}        # Specifies whether to merge a
                                           # stripe on all layers
                                           # (bool, default=false)
-mesh_via {true|false}                     # use mesh via to reduce memory
                                           # (bool, default=false)
-offset_from_core {true|false}             # Specifies whether to offset first
                                           # or last stripe from the core area
                                           # (bool, default=true)
-optimize_stripe_for_routing_track {shift|none}
                                           # move stripe location to preserve
                                           # routing resource
                                           # (enums={shift none}_list, default=none)
-orthogonal_offset {edge1 offset_value ...}
                                           # Specifies the offsets for edges
                                           # orthogonally, the correct value
                                           # should be {[{edge1
                                           # orthogonal_offset1} {edge2 edge3
                                           # orthogonal_offset2} {edge4 edge5
                                           # ... orthogonal_offset3} ...] |
                                           # [all orthogonal_offset]}
                                           # (string, default={none})
-orthogonal_only {true|false}              # vias connect to orthogonal targets
                                           # only (bool, default=true)
-over_row_extension {true|false}           # Specifies whether to extend the
                                           # stripe to cover followpin at the
                                           # row end (bool, default=false)
-partial_set_thru_domain {true|false}      # Specifies whether to go over power
                                           # domain if domain contains the
                                           # specified net (bool, default=false)
-recommend_width <file_name>               # Specify the values of recommended
                                           # width in the file name
                                           # (string, default="")
-remove_floating_stapling {true|false}     # remove floating stapling stripe if
                                           # there is no via connection
                                           # (bool, default=true)
-remove_floating_stripe_over_block {true|false}
                                           # Specifies whether to remove stripe
                                           # fragments start and end inside
                                           # same block or ring macro
                                           # (bool, default=true)
-remove_stripe_under_ring {true|false}     # Specifies whether to remove those
                                           # segments under rings.
                                           # (bool, default=false)
-respect_routes {none|||fixed|||fixed_and_clock|||all}
                                           # Specifies whether to honor
                                           # pre-existing routes check during
                                           # stripe generation
                                           # (enums={none | fixed | fixed_and_clock | all}, default=fixed_and_clock)
-route_over_rows_only {true|false}         # Specifies whether to  route stripe
                                           # over rows within the boundary
                                           # (bool, default=false)
-rows_without_stripes_only {true|false}    # Specifies whether to generate
                                           # stripes over rows w/o stripes
                                           # (bool, default=false)
-same_sized_stack_vias {true|false}        # generate same-sized stacked vias
                                           # (bool, default=false)
-skip_via_on_pin {pad|block|cover|standardcell|physicalpin}
                                           # prevent vias from being generated
                                           # on the specified type of pins
                                           # (enums={pad block cover standardcell physicalpin}_list, default=standardcell)
-skip_via_on_wire_shape {blockring|stripe|followpin|corewire|blockwire|iowire|padring|ring|fillwire|noshape}
                                           # prevent vias from being generated
                                           # on the specified wire shapes
                                           # (enums={blockring stripe followpin corewire blockwire iowire padring ring fillwire noshape}_list, default=noshape)
-spacing_from_block <value>                # Specifies the spacing from block
                                           # (float, default=0)
-spacing_type {edge_to_edge|center_to_center}
                                           # Specify the type of intra spacing
                                           # for addStripe -spacing
                                           # (enums={edge_to_edge center_to_center}, default=edge_to_edge)
-split_long_via {threshold step offset length}
                                           # Split vias longer than <threshold>
                                           # into smaller vias with specified
                                           # <step> and bottom/left end
                                           # <offset> and vertical/horizontal
                                           # <length>, the correct value should
                                           # be {threshold step offset length}
                                           # (string, default=0 0 -1 -1)
-split_vias {true|false}                   # create multiple partial vias
                                           # (bool, default=false)
-split_wire_spacing <value>                # Specifies the spacing between each
                                           # split wire (float, default=0)
-split_wire_weight <integer_0_to_10>       # Deletes fewest IO wires to
                                           # accommodate approximately n of 10
                                           # split stripe wires (float, default=0)
-split_wire_width <value>                  # Specifies the width of each split
                                           # wire (float, default=0)
-stacked_via_bottom_layer <layerName>      # lef layer name
                                           # (string, default=bottomLayer)
-stacked_via_top_layer <layerName>         # lef layer name
                                           # (string, default=topLayer)
-stapling_extend_to_minimum_spacing {true|false}
                                           # Specified to automatically extend
                                           # the adjacent stapling as long as
                                           # enough to satisfy the end-to-end
                                           # minimum spacing with DRC free
                                           # (bool, default=false)
-stapling_nets_style {end_to_end|side_to_side|side_to_side_full_nets}
                                           # Specify the stapling style if
                                           # multiple nets are specified
                                           # (enums={end_to_end side_to_side side_to_side_full_nets}, default=end_to_end)
-stapling_shift {true|false}               # shift stapling stripe to avoid the
                                           # drc automatically
                                           # (bool, default=true)
-stop_at_closest_target {none|block_ring|core_ring|stripe}
                                           # Specifies the stripe to specified
                                           # target when over_pins is enabled.
                                           # (enums={none block_ring core_ring stripe}_list, default=none)
-stop_at_last_wire_for_area {true|false}
                                           # Specifies whether to trim back
                                           # stripe antennas to the closest
                                           # wire or pin of the same net
                                           # (bool, default=false)
-stripe_min_length <value>                 # Specifies the minimum stripe
                                           # length (string, default=stripe_width)
-stripe_min_width <value>                  # Specifies the min width of
                                           # remaining stripe after being
                                           # trimmed (float, default=0)
-switch_cellname <cellname>                # Specifies the switch cells to be
                                           # treated as rings
                                           # (string, default=none)
-switch_layer_overlap_length <value>       # Specifies the overlap distance
                                           # used for the via between a stripe
                                           # layer and the layer being switched
                                           # to (float, default=0)
-trim_antenna_back_to_shape {none|block_ring|core_ring|pad_ring|stripe}
                                           # Specifies the distance between the
                                           # end of antenna and blocked target
                                           # (enums={none block_ring core_ring pad_ring stripe}_list, default=none)
-trim_antenna_max_distance <value>         # Specifies the distance between the
                                           # end of antenna and blocked target
                                           # (float, default=0)
-trim_stripe {none|design_boundary|core_boundary}
                                           # Specifies if stripe is trimmed by
                                           # the specified shape.
                                           # (enums={none design_boundary core_boundary}, default=none)
-use_exact_spacing {true|false}            # Specifies whether to use exact
                                           # spacing (bool, default=false)
-use_point2point_router {true|false}       # Specifies whether to use exact
                                           # spacing (bool, default=false)
-use_stripe_width {true|false}             # Specifies whether to use stripe
                                           # width (bool, default=true)
-via_using_exact_crossover_size {true|false}
                                           # generate partial vias of the exact
                                           # crossover size (bool, default=true)