Usage: set_reinforce_pg_mode [-help] [-reset]
                             [-auto_ir_fix_effort {low|medium|high}]
                             [-critical_path_slack <value>]
                             [-irdrop_hierarchical_block {block1 block2 ... | *}]
                             [-irdrop_hierarchical_top_rail_analysis_directory {directory}]
                             [-respect_defined_nets {file_name}]
                             [-respect_routes {none|fixed|fixed_and_clock|all}]
                             [-respect_stdcell_geometry {none|sequential|all}] [ -timing_aware_effort { none | low | medium | high }]

-help                                   # Prints out the command usage
-reset                                  # Resets all or specified options to default value
-auto_ir_fix_effort {low|medium|high}   # Specifies the IR fixing effort level
                                        # during stripe generation.
                                        # (enums={low medium high}, default=low)
-critical_path_slack <value>            # Specifies a slack threshold, in
                                        # nanoseconds, for critical nets during
                                        # timing-driven reinforce_pg.
                                        # (float, default=0)
-irdrop_hierarchical_block {block1 block2 ... | *}
                                        # Specifies hierarchical blocks to fix
                                        # irdrop. (string, default="")
-irdrop_hierarchical_top_rail_analysis_directory {directory}
                                        # Specifies the directory of rail
                                        # analysis information of full chip for
                                        # hierarchical blocks to fix irdrop.
                                        # (string, default="")
-respect_defined_nets {file_name}       # Specifies reinforce_pg to respect
                                        # user defined nets in file.
                                        # (string, default="")
-respect_routes {none|fixed|fixed_and_clock|all}
                                        # Specifies whether to honor
                                        # pre-existing routes check during
                                        # stripe generation
                                        # (enums={none fixed fixed_and_clock all}, default=fixed_and_clock)
-respect_stdcell_geometry {none|sequential|all}
                                        # Specifies the cell type to be
                                        # respected in via generation.
                                        # (enums={none sequential all}, default=all)
-timing_aware_effort {none|low|medium|high}
                                        # Specifies the timing effort level
                                        # during timing-driven reinforce_pg.
                                        # (enums={none low medium high}, default=none)