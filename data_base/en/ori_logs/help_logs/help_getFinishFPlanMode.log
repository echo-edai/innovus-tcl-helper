Usage: getFinishFPlanMode [-help] [-abuttedEdgeAsNonRowArea] [-activeObj]
                          [-direction] [-drcRegionObj] [-fillOption] [-override]
                          [-quiet] [-nonDefault]

-help                                     # Prints out the command usage
-abuttedEdgeAsNonRowArea                  # Specify whether the abutted edge of
                                          # power domain should be nonRowArea
                                          # (bool, default=true)
-activeObj                                # activeObj list
                                          # (enums={macro macroHalo core iopad iocell fence hardblkg softblkg partialblkg routeblkg row die}_list, default=macro macroHalo core)
-direction                                # direction
                                          # (enums={x y xy}, default=xy)
-drcRegionObj                             # drcRegion object list
                                          # (enums={macro macroHalo hardBlkg minGap coreSpacing nonRowArea row}_list, default=macro macroHalo hardBlkg minGap coreSpacing row)
-fillOption                               # fill option
                                          # (enums={channel boundary}_list, default=channel)
-override                                 # override or not
                                          # (bool, default=false)
-quiet                                    # Displays the current settings in Tcl list format only
-nonDefault                               # Displays the current settings which are not default settings