Usage: setScanReorderMode [-help] [-reset] [-addScanPortPrefix <value>]
                          [-clkAware {true|false}] [-compLogic {true|false}]
                          [-enable_for_partition {true|false}]
                          [-keepPDPorts {true|false}]
                          [-keepPort <keepPortHInstFile>]
                          [-preferH {true|false}] [-preferV {true|false}]
                          [-scanEffort {low|medium|high|auto}]
                          [-skipMode {skipNone|skipBuffer|skipFloatingBuffer}]
                          [-swapEffort {low|medium|high}]

-help                                     # Prints out the command usage
-reset                                    # Resets all or specified options to default value
-addScanPortPrefix <value>                # prefix of scan hport
                                          # (string, default="")
-clkAware {true|false}                    # Clock tree aware reorder
                                          # (bool, default=false)
-compLogic {true|false}                   # trace considering multiple input
                                          # logic (bool, default=false)
-enable_for_partition {true|false}        # enable scanReorder for design with
                                          # partition (bool, default=false)
-keepPDPorts {true|false}                 # Maintains hierarchical ports
                                          # without adding or deleting shifters
                                          # (bool, default=true)
-keepPort <keepPortHInstFile>             # Specifies filename which contains
                                          # HInsts (string, default="")
-preferH {true|false}                     # Makes horizontal scan chain
                                          # connections if possible
                                          # (bool, default=false)
-preferV {true|false}                     # Makes vertical scan chain
                                          # connections if possible
                                          # (bool, default=false)
-scanEffort {low|medium|high|auto}        # Specifies effort level for
                                          # scanReorder
                                          # (enums={low medium high auto}, default=auto)
-skipMode {skipNone|skipBuffer|skipFloatingBuffer}
                                          # Specifies method for handling
                                          # buffers and inverters
                                          # (enums={skipNone skipBuffer skipFloatingBuffer}, default=skipNone)
-swapEffort {low|medium|high}             # Specifies effort level for
                                          # scanReorder different chains
                                          # swapping
                                          # (enums={low medium high}, default=high)