Usage: addSplitPowerVia [-help] [-edgeLength {layer1 value1 layer2 value2 ...}]
                        [-forceCount] [-localCheckerBoard] [-master <cell_name>]
                        [-maxViaSize {x y}]
                        [-maxWireLength {layer1 value1 layer2 value2 ...}]
                        [-maxWireSpacing {layer1 value1 layer2 value2 ...}]
                        [-mergeCount {x y}] [-mergeDistance {x y}]
                        [-minEnclosure] [-minViaSize {x y}]
                        [-minWireLength {layer1 value1 layer2 value2 ...}]
                        [-minWireSpacing {layer1 value1 layer2 value2 ...}]
                        [-pinLayer {layer1 layer2 ...}]
                        [-prerouteAlign {none samelayer alllayer}]
                        [-snap_wire_center_to_grid {layer1 {none | grid | half_grid | either} layer2 {none | grid | half_grid | either} ...}]
                        [-stackedCheckerBoard] [-uda <userDefinedAttribute>]
                        [-wireCount {layer1 value1|auto layer2 value2|auto ...}]
                        [-wireOffset {layer1 value1 layer2 value2 ...}]
                        [-wireWidth {layer1 value1 layer2 value2 ...}]
                        [-delete | -wires_only]

-help                                  # Prints out the command usage
-delete                                # Deletes the via for selected
                                       # wires/objects (bool, optional)
-edgeLength {layer1 value1 layer2 value2 ...}
                                       # the extension length of the wires for
                                       # each layer in um (string, optional)
-forceCount                            # Forces the tool to generate the given
                                       # wirecount even if the wires extend
                                       # beyond the overlap area (bool, optional)
-localCheckerBoard                     # allow local checkerboard cut
                                       # generation rather than matching the
                                       # global checkerboard pattern
                                       # (bool, optional)
-master <cell_name>                    # add jenga wires and vias between
                                       # paralell wires, over the specified
                                       # stdcell (string, optional)
-maxViaSize {x y}                      # max via size (point, optional)
-maxWireLength {layer1 value1 layer2 value2 ...}
                                       # the max length of the wires for each
                                       # layer in um (string, optional)
-maxWireSpacing {layer1 value1 layer2 value2 ...}
                                       # the max wire spacing of wires for each
                                       # layer in um (string, optional)
-mergeCount {x y}                      # merge neighboring wire count
                                       # (integer, optional)
-mergeDistance {x y}                   # merging distance in x and y direction
                                       # (point, optional)
-minEnclosure                          # Create the shortest wires that meet
                                       # DRC rules rather than the default wire
                                       # length of the entire overlap area
                                       # (bool, optional)
-minViaSize {x y}                      # min via size (point, optional)
-minWireLength {layer1 value1 layer2 value2 ...}
                                       # the min length of the wires for each
                                       # layer in um (string, optional)
-minWireSpacing {layer1 value1 layer2 value2 ...}
                                       # the min wire spacing of wires for each
                                       # layer in um (string, optional)
-pinLayer {layer1 layer2 ...}          # list of pin layers in a macro used to
                                       # create via with crossover wire
                                       # (string, optional)
-prerouteAlign {none samelayer alllayer}
                                       # Defines the alignment of via wires
                                       # with preexisting wires on the same net
                                       # (enum, optional)
-snap_wire_center_to_grid {layer1 {none | grid | half_grid | either} layer2 {none | grid | half_grid | either} ...}
                                       # specifies the wire center alignment
                                       # style for middle layer jenga wires
                                       # (string, optional)
-stackedCheckerBoard                   # Create the stacked checker board vias
                                       # between intermediate layers
                                       # (bool, optional)
-uda <userDefinedAttribute>            # add the user defined attribute to the
                                       # to-be-built jenga wires and vias
                                       # (string, optional)
-wireCount {layer1 value1|auto layer2 value2|auto ...}
                                       # the count of wires for each layer in
                                       # integer (string, optional)
-wireOffset {layer1 value1 layer2 value2 ...}
                                       # wire offset away from the intersection
                                       # of selected wires (string, optional)
-wireWidth {layer1 value1 layer2 value2 ...}
                                       # the width of the wires for each layer
                                       # in um (string, optional)
-wires_only                            # only output jenga wires without
                                       # violations (bool, optional)