Usage: add_shape [-help] -layer {layerNameOrPointer} [-net {string}]
                 [-shape {None RING STRIPE FOLLOWPIN IOWIRE COREWIRE BLOCKWIRE FILLWIRE BLOCKAGEWIRE PADRING BLOCKRING DRCFILL FILLWIREOPC}]
                 [-shield_net {netNameOrPointer}]
                 [-status {ROUTED FIXED COVER SHIELD NOSHIELD}]
                 [-user_class <className>] {-rect {x1 y1 x2 y2} | -patch {x1 y1 x2 y2} | -polygon {x1 y1 x2 y2 ...xn yn} | [-pathSeg {x1 y1 x2 y2} -width <value> [-beginExt <value> -endExt <value>]]}

-help                               # Prints out the command usage
-beginExt <value>                   # The value in microns (float, optional)
-endExt <value>                     # The value in microns (float, optional)
-layer {layerNameOrPointer}         # Layer name or layer pointer
                                    # (string, required)
-net {string}                       # Net name (string, optional)
-patch {x1 y1 x2 y2}                # Coordinates of the lower-left and
                                    # upper-right points of the rectangle
                                    # (box, optional)
-pathSeg {x1 y1 x2 y2}              # the beginning and ending coordinates for
                                    # the path segment (box, optional)
-polygon {x1 y1 x2 y2 ...xn yn}     # point list of the polygon
                                    # (point_list, optional)
-rect {x1 y1 x2 y2}                 # Coordinates of the lower-left and
                                    # upper-right points of the rectangle
                                    # (box, optional)
-shape {None RING STRIPE FOLLOWPIN IOWIRE COREWIRE BLOCKWIRE FILLWIRE BLOCKAGEWIRE PADRING BLOCKRING DRCFILL FILLWIREOPC}
                                    # DEF Shape (enum, optional)
-shield_net {netNameOrPointer}      # Net name or net pointer
                                    # (string, optional)
-status {ROUTED FIXED COVER SHIELD NOSHIELD}
                                    # DEF status (enum, optional)
-user_class <className>             # User defined attribute class
                                    # (string, optional)
-width <value>                      # The width in microns (float, optional)