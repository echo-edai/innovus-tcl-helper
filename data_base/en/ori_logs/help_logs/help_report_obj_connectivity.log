Usage: report_obj_connectivity [-help] [-direction <string>] [-file <string>]
                               [-level <integer>] [-no_split]
                               [-through_registers] [-to_ports] [-insts <string>] | [-ports <string>] | [-selected ]

-help               # Prints out the command usage
-direction <string> # specify the pin direction of objects to be reported
                    # (in|out|all), default:all (string, optional)
-file <string>      # file to save report result, if not specified, a file
                    # <top_module_name>.tmcrpt will be saved (string, optional)
-insts <string>     # specify the macros to be reported (string, optional)
-level <integer>    # specify the report level (1 to 10), default:5
                    # (int, optional)
-no_split           # report one object in one line (bool, optional)
-ports <string>     # specify the IO ports to be reported (string, optional)
-selected           # report the selected macros or IO ports (bool, optional)
-through_registers  # include registers through by paths between selected
                    # objects in report (bool, optional)
-to_ports           # report connectivity from selected objects to IO ports
                    # (bool, optional)