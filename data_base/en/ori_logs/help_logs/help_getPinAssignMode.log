Usage: getPinAssignMode [-help] [-advanced_node_rule_support]
                        [-allow_unconnected_in_abutted_edge]
                        [-allowNonNdrNetPinsOnNdrTracks]
                        [-block_boundary_macro_distance]
                        [-force_abutment_with_fixed] [-insidePinSearchDistance]
                        [-max_distance_pairing] [-maxChannelWidthAsAbutted]
                        [-maxLayer] [-minLayer] [-pinEditInBatch]
                        [-pinOffStripe] [-pinToStripeDistance]
                        [-pinToViaDistanceNonPrefDirection]
                        [-pinToViaDistancePrefDirection]
                        [-promotedMacroMaxLayer] [-promotedMacroMinLayer]
                        [-restrict_boundary_macro_distance] [-strict_abutment]
                        [-useCommonColorEngineForIO] [-quiet] [-nonDefault]

-help                                  # Prints out the command usage
-advanced_node_rule_support            # If you use this parameter, all the pin
                                       # related command will use design object
                                       # shapes for deciding pin location which
                                       # will give accurate result but will
                                       # have larger runtime. (bool, default=true)
-allow_unconnected_in_abutted_edge     # If you use this parameter, unconnected
                                       # partition pin can be placed in abutted
                                       # edge (bool, default=true)
-allowNonNdrNetPinsOnNdrTracks         # A true value allows general pins to be
                                       # placed on ndr tracks if available.
                                       # Alternately, if the value is set to
                                       # false, the ndr-track rule is followed
                                       # strictly and the net's pins are placed
                                       # on matching ndr tracks only.
                                       # (bool, default=true)
-block_boundary_macro_distance         # This option blocks automatic pin
                                       # assignment, from putting pins on the
                                       # part of partition boundary facing
                                       # block on layers with OBS, in the
                                       # places where channel width between
                                       # partition boundary and block is less
                                       # than the value specified. For channel
                                       # width below specified value, block all
                                       # pins on boundary facing this channel
                                       # on layers with OBS.
                                       # (float, default=3, min=0, max=100)
-force_abutment_with_fixed             # For fixed abutted pins's connected
                                       # pin, ignore soft constraints checks
                                       # (bool, default=true)
-insidePinSearchDistance               # To control the search distance for
                                       # legalizing the internal pins
                                       # (int, default=10, min=1, max=100)
-max_distance_pairing                  # Ignores moving corresponding connected
                                       # pins of 2-pin-connection nets where
                                       # distance (in microns) between the pins
                                       # is equal or greater than distance
                                       # specified
                                       # (float, default=50, min=0, max=10000)
-maxChannelWidthAsAbutted              # If you set this parameter value then
                                       # all channel less than equal to
                                       # specified value will be considered as
                                       # abutted and abutment rules will be
                                       # applied
                                       # (float, default=3, min=0, max=400)
-maxLayer                              # Specifies the maximum metal layer name
                                       # for partition/block pin assignment
                                       # (string, default=31)
-minLayer                              # Specifies the minimum metal layer name
                                       # for partition/block pin assignment
                                       # (string, default=2)
-pinEditInBatch                        # To enable/disable pin-editing in batch
                                       # mode. (bool, default=false)
-pinOffStripe                          # Prevents the generation of pins on
                                       # metal layers with respect to the power
                                       # and ground stripe
                                       # (enums={below all none}, default=none)
-pinToStripeDistance                   # Layer specific, keep distance (in
                                       # microns) from pin to stripe
                                       # (string, default="")
-pinToViaDistanceNonPrefDirection      # Layer specific, keep distance (in
                                       # microns) from pin to via-stack
                                       # (string, default="")
-pinToViaDistancePrefDirection         # Layer specific, keep distance (in
                                       # microns) from pin to via-stack from
                                       # the partition fence boundary
                                       # (string, default="")
-promotedMacroMaxLayer                 # Specifies the maximum metal layer name
                                       # for promoting macro pins
                                       # (string, default=31)
-promotedMacroMinLayer                 # Specifies the minimum metal layer name
                                       # for promoting macro pins
                                       # (string, default=31)
-restrict_boundary_macro_distance      # This option blocks automatic pin
                                       # assignment, from putting pins on the
                                       # part of partition boundary facing
                                       # block on layers with OBS, in the
                                       # places where channel width between
                                       # partition boundary and block is less
                                       # than the value specified. For channel
                                       # width below specified value: OBS area
                                       # on the layer, channel length and
                                       # channel width considered to allow
                                       # suitable number of pins on boundary
                                       # facing this channel.
                                       # (float, default=30, min=0, max=100)
-strict_abutment                       # To relax abutment violations, for
                                       # placing multi partition pin of a net
                                       # and non neighbor pins of a net on
                                       # abutted edges (bool, default=true)
-useCommonColorEngineForIO             # assignIoPins command will use coloring
                                       # engine api to assign mask-color to
                                       # pins. (bool, default=false)
-quiet                                 # Displays the current settings in Tcl list format only
-nonDefault                            # Displays the current settings which are not default settings