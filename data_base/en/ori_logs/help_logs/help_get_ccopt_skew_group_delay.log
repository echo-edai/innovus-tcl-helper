Usage: get_ccopt_skew_group_delay [-help] [-edge {rise fall}]
                                  [-exclude_pin_insertion_delays]
                                  -skew_group <name> [ -skew | -longest | -shortest ] [ -path_length <distance_metric> | -summarize_stage_depth <cell_type_list> ] [ -all_active_sinks | -to <pin> | -from <pin> | -through <pin> ] [ -virtual_delays_only | -real_delays_only ] [ -wire_delays_only | -cell_delays_only ] [ -delay_corner <delay_corner> ] [ -check_type <type> ] [ -delay_type <type> ] [ -skew ] [ -summarize_stage_depth <cell_type_list> ] [ -path_length <distance_metric> ]

-help                                  # Prints out the command usage
-all_active_sinks                      # specifies that the result should be a
                                       # dict of sink and delays (bool, optional)
-cell_delays_only                      # specifies that cell delays only should
                                       # be queried (bool, optional)
-check_type {setup hold}               # the check type to query
                                       # (enum, optional)
-delay_corner <delay_corner>           # the delay corner to query
                                       # ((delay_corner), optional)
-delay_type {early late}               # the delay type to query
                                       # (enum, optional)
-edge {rise fall}                      # specifies the edge to query
                                       # (enum, optional)
-exclude_pin_insertion_delays          # specifies that the resultant delays
                                       # should exclude any pin insertion delay
                                       # (bool, optional)
-from <pin>                            # specifies the pin to query delays from
                                       # ((instTerm|term), optional)
-longest                               # specifies that the longest path delay
                                       # should be queried (bool, optional)
-path_length {half_perim pin_to_pin_steiner routed}
                                       # Report by the distance from the root
                                       # measured using the specified distance
                                       # metric. (enum, optional)
-real_delays_only                      # specifies that real delays only should
                                       # be queried (bool, optional)
-shortest                              # specifies that the shortest path delay
                                       # should be queried (bool, optional)
-skew                                  # specifies that skew should be queried
                                       # (bool, optional)
-skew_group <name>                     # the skew group to query
                                       # (string, required)
-summarize_stage_depth <cell_type_list>    # Report by the number of cells of
                                           # the given tcl list of cell types
                                           # rather than delay. Possible values
                                           # are buffer, inverter, logic,
                                           # clock_gate, generator or *.
                                           # (list, optional)
-through <pin>                         # specifies the pin to query delays
                                       # through ((instTerm|term), optional)
-to <pin>                              # specifies the pin to query delays to
                                       # ((instTerm|term), optional)
-virtual_delays_only                   # specifies that virtual delays only
                                       # should be queried (bool, optional)
-wire_delays_only                      # specifies that wire delays only should
                                       # be queried (bool, optional)