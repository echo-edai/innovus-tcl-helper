Usage: read_sdf [-help] <sdf_filename> [-continue_on_error] [-ilm_filter]
                [-increment] [-overwrite_incremental_delay]
                [-path <instanceName>] [-persistent] [-print_summary]
                [-scale <float>] [-strict_cond_matching] [-view <viewName>] [-sdf_field {min typ max} | [-early_sdf_field {min typ max}] [-late_sdf_field {min typ max}]]

-help                              # Prints out the command usage
<sdf_filename>                     # Specifies the name of the SDF file
                                   # (string, required)
-continue_on_error                 # Continues to read the file if an error
                                   # occurs (bool, optional)
-early_sdf_field {min typ max}     # Annotates the early delay from the
                                   # specified SDF field (enum, optional)
-ilm_filter                        # Ignores ILM-related errors
                                   # (bool, optional)
-increment                         # Increments the total delay without
                                   # affecting the detla delay (bool, optional)
-late_sdf_field {min typ max}      # Annotates the late delay from the
                                   # specified SDF field (enum, optional)
-overwrite_incremental_delay       # Replaces any pre-existing delta delays
                                   # with the new SDF values (bool, optional)
-path <instanceName>               # Specifies the instance in the design to
                                   # which the specified SDF file should be
                                   # applied (string, optional)
-persistent                        # Keeps the delays from certain SDF files
                                   # persistently in use during various steps
                                   # of the timing optimization flow
                                   # (bool, optional)
-print_summary                     # Outputs the summary information of
                                   # annotated delays (bool, optional)
-scale <float>                     # Overrides the automatic scaling of SDF
                                   # delays to the library units by the value
                                   # given (float, optional)
-sdf_field {min typ max}           # Annotates the delay from the specified SDF
                                   # field (enum, optional)
-strict_cond_matching              # Annotates only the conditions that are an
                                   # exact syntax-to-syntax match between the
                                   # SDF file and the .lib file (bool, optional)
-view <viewName>                   # Annotates the specified analysis view with
                                   # the delays from the SDF file
                                   # (string, optional)