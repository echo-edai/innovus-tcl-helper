Usage: report_message [-help] [[{-errors | -warnings | -all } [-count ]] | -suppressed ] [[-prefix <string> [-detail ] [-summary ]] ] [-detail | -count | -suppressed ] [-summary | -count | -suppressed ]

-help                # Prints out the command usage
-all                 # Return a list of all issued message IDs as a Tcl result.
                     # This does not include suppressed message IDs.
                     # (bool, optional)
-count               # Return count of every message when -errors, -warnings or
                     # -all is specified. (bool, optional)
-detail              # Return list of detail message of specified prefix.
                     # (bool, optional)
-errors              # Return a list of issued error message IDs as a Tcl
                     # result. (bool, optional)
-prefix <string>     # Return a list of issued error message IDs matched with
                     # -prefix specified as a Tcl result. (string, optional)
-summary             # Return message summary of specified prefix.
                     # (bool, optional)
-suppressed          # Return a list of suppressed message IDs as a Tcl result.
                     # (bool, optional)
-warnings            # Return a list of issued warning message IDs as a Tcl
                     # result. (bool, optional)