Usage: get_ccopt_skew_group_path [-help] [-show_generator_paths]
                                 -skew_group <skew_group>
                                 [-summarize_stage_depth <cell_type_list>] [ -longest | -shortest ] [ -virtual_delays_only | -real_delays_only ] [ -wire_delays_only | -cell_delays_only ] [ -sink <pin> | -below <pin> ] [ -delay_corner <delay_corner> ] [ -check_type <type> ] [ -delay_type <type> ]

-help                              # Prints out the command usage
-below <pin>                       # query path delays below this pin
                                   # ((instTerm|term), required)
-cell_delays_only                  # specifies that cell delays only should be
                                   # queried (bool, optional)
-check_type {setup hold}           # the check type to query (enum, optional)
-delay_corner <delay_corner>       # the delay corner to query
                                   # ((delay_corner), optional)
-delay_type {early late}           # the delay type to query (enum, optional)
-longest                           # specifies that the longest path delay
                                   # should be queried (bool, optional)
-real_delays_only                  # specifies that real delays only should be
                                   # queried (bool, optional)
-shortest                          # specifies that the shortest path delay
                                   # should be queried (bool, optional)
-show_generator_paths              # specifies that generator paths should be
                                   # shown (bool, optional)
-sink <pin>                        # query path delays above this pin
                                   # ((instTerm|term), required)
-skew_group <skew_group>           # the skew group to query
                                   # ((skew_group), required)
-summarize_stage_depth <cell_type_list>    # Report by the number of cells of
                                           # the given tcl list of cell types
                                           # rather than delay. Possible values
                                           # are buffer, inverter, logic,
                                           # clock_gate, generator or *.
                                           # (list, optional)
-virtual_delays_only               # specifies that virtual delays only should
                                   # be queried (bool, optional)
-wire_delays_only                  # specifies that wire delays only should be
                                   # queried (bool, optional)