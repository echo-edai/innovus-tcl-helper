Usage: getViaGenMode [-help] [-accuracy_effort] [-add_pin_to_pin_via]
                     [-align_merged_stack_via_metals] [-allow_via_expansion]
                     [-allow_wire_shape_change] [-area_only] [-bot_enclosure]
                     [-create_double_row_cut_via] [-create_max_row_cut_via]
                     [-cut_spacing] [-cutclass_preference]
                     [-disable_via_merging] [-extend_out_wire_end]
                     [-full_cut_via_only] [-genvia_naming_prefix]
                     [-hookup_contact_max] [-hookup_contact_pg_track]
                     [-hookup_preplace_fix] [-hookup_rail_pair]
                     [-hookup_via_distance] [-hookup_via_fixed_grid]
                     [-hookup_via_min_distance] [-hookup_via_style]
                     [-hookup_via_viarule] [-hookup_virtual_trim_grid]
                     [-ignore_design_boundary] [-ignore_DRC]
                     [-ignore_viarule_enclosure] [-inherit_wire_status]
                     [-invoke_verifyGeometry] [-keep_existing_via]
                     [-keep_fixed_via] [-mincut_preference]
                     [-optimize_cross_via] [-optimize_via_on_routing_track]
                     [-parameterized_via_only] [-partial_overlap_threshold]
                     [-preferred_vias_only] [-reference_boundary]
                     [-respect_signal_routes] [-respect_stdcell_geometry]
                     [-respect_wire_ndr] [-set_via_expansion_dir]
                     [-snap_via_center_to_grid] [-split_long_via_global_grid]
                     [-symmetrical_via_only] [-top_enclosure]
                     [-use_track_offset] [-use_trim_metal_enclosure]
                     [-viarule_preference] [-quiet] [-nonDefault]

-help                                     # Prints out the command usage
-accuracy_effort                          # Specifies viagen effort to generate
                                          # vias.
                                          # (enums={low medium high}, default=high)
-add_pin_to_pin_via                       # Inserts vias to connect pins
                                          # between cover macros
                                          # (bool, default=false)
-align_merged_stack_via_metals            # Aligns merged stack vias
                                          # (bool, default=false)
-allow_via_expansion                      # Allows via expansion to meet LEF
                                          # rules (bool, default=true)
-allow_wire_shape_change                  # Allows via to change the metal
                                          # shape of existing wire
                                          # (bool, default=true)
-area_only                                # adds via only within the specified
                                          # area (bool, default=false)
-bot_enclosure                            # Customize bot enclosure
                                          # (string, default="")
-create_double_row_cut_via                # Expands vias to have an additional
                                          # cut than original for one-row or
                                          # one-column vias if possible
                                          # (enums={0 1 2}, default=0)
-create_max_row_cut_via                   # Creates max rows of via cuts
                                          # (bool, default=false)
-cut_spacing                              # Customize cut spacing
                                          # (string, default="")
-cutclass_preference                      # Specifies via cut class preference
                                          # (string, default=default)
-disable_via_merging                      # Disables via merging
                                          # (bool, default=false)
-extend_out_wire_end                      # Extends via outside of existing
                                          # wires end (bool, default=true)
-full_cut_via_only                        # allows to create full cut via only
                                          # (bool, default=false)
-genvia_naming_prefix                     # Specifies prefix name for all vias
                                          # (string, default="")
-hookup_contact_max                       # Sets the max distance to create
                                          # hookup via from contact, and the
                                          # max distance between two hookup via
                                          # on a continuous M0 PG pin.
                                          # (string, default=0, 0)
-hookup_contact_pg_track                  # Sets start point and the pitch of
                                          # PG track used by hookup contact.
                                          # (string, default=0, 0)
-hookup_preplace_fix                      # Enhance hookup via generation
                                          # runtime (int, default=0)
-hookup_rail_pair                         # Create hookup vias over pairing
                                          # followpins (bool, default=false)
-hookup_via_distance                      # Sets via hookup distance and
                                          # boundary spacing
                                          # (string, default=4pitch 4pitch 0)
-hookup_via_fixed_grid                    # Specifies to add hookup via over
                                          # the fixed Grid. (bool, default=false)
-hookup_via_min_distance                  # min distance between two pg vias
                                          # (string, default=min)
-hookup_via_style                         # Sets via hookup style
                                          # (enums={none loose compact moderate}, default=none)
-hookup_via_viarule                       # Specifies the viarule used in
                                          # specified area (string, default="")
-hookup_virtual_trim_grid                 # Specifies the virtual trim grid for
                                          # pg hookup (string, default="")
-ignore_design_boundary                   # Allow vias to be on design boundary
                                          # (bool, default=false)
-ignore_DRC                               # Ignores DRC (bool, default=false)
-ignore_viarule_enclosure                 # Ignores enclosures defined in
                                          # VIARULE GENERATE (bool, default=true)
-inherit_wire_status                      # Inherits wire status
                                          # (bool, default=false)
-invoke_verifyGeometry                    # Invokes verify_drc
                                          # (bool, default=false)
-keep_existing_via                        # Keeps existing vias
                                          # (enums={0 1 2}, default=0)
-keep_fixed_via                           # Keeps fixed vias not modifiable
                                          # (bool, default=true)
-mincut_preference                        # Specifies min cut preference
                                          # (int, default=1)
-optimize_cross_via                       # Controls the creation of additional
                                          # via cuts (bool, default=false)
-optimize_via_on_routing_track            # Frees up via tracks
                                          # (bool, default=false)
-parameterized_via_only                   # generate parameterized vias only,
                                          # auto sets true for OA flow, false
                                          # for non-OA flow.
                                          # (enums={auto true false}, default=auto)
-partial_overlap_threshold                # Specifies ratio threshold of via
                                          # creation on partial overlap wires
                                          # (float, default=0)
-preferred_vias_only                      # Generate only vias set in
                                          # -viarule_preference
                                          # (enums={use_lef open keep}, default=use_lef)
-reference_boundary                       # Sets reference boundary
                                          # (enums={design core}, default=design)
-respect_signal_routes                    # Honors pre-existing signal routes
                                          # (enums={0 1 2}, default=0)
-respect_stdcell_geometry                 # Respects all standard cell patterns
                                          # (bool, default=false)
-respect_wire_ndr                         # Control whether viagen support ndr
                                          # rules (bool, default=false)
-set_via_expansion_dir                    # Sets via expansion direction
                                          # (enums={auto horizontal vertical}, default=auto)
-snap_via_center_to_grid                  # Specifies the via center alignment
                                          # style per routing layer
                                          # (string, default="")
-split_long_via_global_grid               # Controls global grids so vias on
                                          # them are in line
                                          # (string, default=0 0 0 0 0 0 0 0)
-symmetrical_via_only                     # adds symmetrical via only, auto
                                          # sets true for OA flow, false for
                                          # non-OA flow.
                                          # (enums={auto true false}, default=auto)
-top_enclosure                            # Customize top enclosure
                                          # (string, default="")
-use_track_offset                         # Uses track offset
                                          # (bool, default=false)
-use_trim_metal_enclosure                 # Force tool to use enclosures with
                                          # trim layer (bool, default=false)
-viarule_preference                       # Specifies via rule preference
                                          # (string, default=default)
-quiet                                    # Displays the current settings in Tcl list format only
-nonDefault                               # Displays the current settings which are not default settings