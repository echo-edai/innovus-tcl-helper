Usage: set_rail_analysis_domain [-help] [-gndnets <string>]
                                [-gndnets_list_file <string>] -name <string>
                                [-pwrnets <string>]
                                [-pwrnets_list_file <string>]
                                [-signets <string>]
                                [-signets_list_file <string>]
                                [-threshold <float>]

-help                           # Prints out the command usage
-gndnets <string>               # <ground nets> (string, optional)
-gndnets_list_file <string>     # <ground nets list file> (string, optional)
-name <string>                  # <domain name> (string, required)
-pwrnets <string>               # <power nets> (string, optional)
-pwrnets_list_file <string>     # <power nets list file> (string, optional)
-signets <string>               # <signal nets> (string, optional)
-signets_list_file <string>     # <signal nets list file> (string, optional)
-threshold <float>              # <net threshold>
                                # (float, optional, min=0, max=0.5)