Usage: setAddRingMode [-help] [-reset] [-avoid_short {true|false}]
                      [-break_core_ring_io_list <io_list>]
                      [-continue_on_no_selection {true|false}]
                      [-detailed_log {true|false}]
                      [-extend_blockring_search_distance <distance>]
                      [-extend_corering_search_distance <distance>]
                      [-extend_merge_with_prewires {true|false}]
                      [-extend_over_row {true|false}]
                      [-extend_search_nets <net_names>]
                      [-extend_stripe_search_distance <distance>]
                      [-gap_width_without_io <value>]
                      [-ignore_rows {true|false}]
                      [-max_via_size {shape width% height% target_penetration%}]
                      [-orthogonal_only {true|false}]
                      [-ring_target {core_ring|default|first_ring|pad_ring|stripe}]
                      [-skip_crossing_trunks {horizontal|vertical|none}]
                      [-skip_via_on_pin {pad|block|cover|standardcell|physicalpin}]
                      [-skip_via_on_wire_shape {blockring|stripe|followpin|corewire|blockwire|iowire|padring|ring|fillwire|noshape}]
                      [-spacing_from_block <value>]
                      [-split_long_via {threshold step offset length}]
                      [-stacked_via_bottom_layer <layerName>]
                      [-stacked_via_top_layer <layerName>]
                      [-via_using_exact_crossover_size {true|false}]
                      [-wire_center_offset {true|false}]

-help                                      # Prints out the command usage
-reset                                     # Resets all or specified options to default value
-avoid_short {true|false}                  # Specifies whether to avoid short
                                           # violation (bool, default=false)
-break_core_ring_io_list <io_list>         # Specifies io instance names for
                                           # which core ring wires are broken
                                           # (string, default="")
-continue_on_no_selection {true|false}     # Continues w/o selection
                                           # (bool, default=false)
-detailed_log {true|false}                 # Outputs detailed log file
                                           # addring.log (bool, default=false)
-extend_blockring_search_distance <distance>
                                           # Specifies blockring extension
                                           # search distance (float, default=0)
-extend_corering_search_distance <distance>
                                           # Specifies corering extension
                                           # search distance (float, default=0)
-extend_merge_with_prewires {true|false}
                                           # Specifies whether to merge with
                                           # prerouted wires (bool, default=true)
-extend_over_row {true|false}              # Specifies whether to extend over
                                           # row (bool, default=false)
-extend_search_nets <net_names>            # Specifies search net names
                                           # (string, default="")
-extend_stripe_search_distance <distance>
                                           # Specifies stripe extension search
                                           # distance (float, default=0)
-gap_width_without_io <value>              # Specifies the max missing IO Pads
                                           # area width between IO Pads
                                           # (float, default=0)
-ignore_rows {true|false}                  # Specifies whether to ignore all
                                           # rows (bool, default=false)
-max_via_size {shape width% height% target_penetration%}
                                           # the maximum size of a crossover
                                           # via (string, default="")
-orthogonal_only {true|false}              # vias connect to orthogonal targets
                                           # only (bool, default=true)
-ring_target {core_ring|default|first_ring|pad_ring|stripe}
                                           # Specifies ring target (enums={core_ring default first_ring pad_ring stripe}, default=default)
-skip_crossing_trunks {horizontal|vertical|none}
                                           # Specifies whether to skip crossing
                                           # trunks
                                           # (enums={horizontal vertical none}, default=none)
-skip_via_on_pin {pad|block|cover|standardcell|physicalpin}
                                           # prevent vias from being generated
                                           # on the specified type of pins
                                           # (enums={pad block cover standardcell physicalpin}_list, default=standardcell)
-skip_via_on_wire_shape {blockring|stripe|followpin|corewire|blockwire|iowire|padring|ring|fillwire|noshape}
                                           # prevent vias from being generated
                                           # on the specified wire shapes
                                           # (enums={blockring stripe followpin corewire blockwire iowire padring ring fillwire noshape}_list, default=noshape)
-spacing_from_block <value>                # Specifies the spacing from block
                                           # (float, default=0)
-split_long_via {threshold step offset length}
                                           # Split vias longer than <threshold>
                                           # into smaller vias with specified
                                           # <step> and bottom/left end
                                           # <offset> and vertical/horizontal
                                           # <length> (string, default=0 0 -1 -1)
-stacked_via_bottom_layer <layerName>      # lef layer name
                                           # (string, default=bottomLayer)
-stacked_via_top_layer <layerName>         # lef layer name
                                           # (string, default=topLayer)
-via_using_exact_crossover_size {true|false}
                                           # generate partial vias of the exact
                                           # crossover size (bool, default=true)
-wire_center_offset {true|false}           # offset value is from wire center
                                           # to domain/core boundary
                                           # (bool, default=false)