Usage: get_proto_mode [-help] [-allow_model_with_io]
                      [-allow_powerdomain_in_flexmodel] [-create_dir]
                      [-create_high_fanout_psPM] [-create_lib]
                      [-create_metal_fill_NDR] [-create_metal_fill_nominal]
                      [-create_multi_corner_psPM] [-create_NDR_psPM_model]
                      [-create_no_flex_filler] [-create_partition_as_flexmodel]
                      [-create_pipeline_flop] [-create_powerdomain_psPM]
                      [-create_timing_budget] [-identify_algorithm]
                      [-identify_estimated_flexmodel_number]
                      [-identify_exclude_module]
                      [-identify_exclude_module_and_parent]
                      [-identify_exclude_module_tree]
                      [-identify_honor_objects_hierarchy] [-identify_max_inst]
                      [-identify_min_inst] [-keep_inst_file_only]
                      [-keep_instance_defined_in_sdc] [-keep_slack_improve_NDR]
                      [-max_report_NDR_net] [-route_net_NDR]
                      [-timing_net_delay_model] [-timing_ps_per_micron]
                      [-verbose] [-quiet] [-nonDefault]

-help                                     # Prints out the command usage
-allow_model_with_io                      # Supports model with I/Os.
                                          # (bool, default=false)
-allow_powerdomain_in_flexmodel           # Allow powerdomain in flexmodel
                                          # (bool, default=false)
-create_dir                               # Specifies the directory to save
                                          # created models.
                                          # (string, default=proto_model)
-create_high_fanout_psPM                  # Create high fanout psPM models.
                                          # (bool, default=true)
-create_lib                               # Specifies the OA library to save
                                          # created models.
                                          # (string, default=proto_model_lib)
-create_metal_fill_NDR                    # Will be used by
                                          # create_ps_per_micron_model for
                                          # creating psPM model for  nets with
                                          # non default rules. (float, default=0)
-create_metal_fill_nominal                # Will be used by
                                          # create_ps_per_micron_model for
                                          # creating psPM model for normal 
                                          # nets. (float, default=0.5)
-create_multi_corner_psPM                 # Create multi corner psPM models.
                                          # (bool, default=false)
-create_NDR_psPM_model                    # Control whether
                                          # create_ps_per_micron_model should
                                          # generate psPM model for non default
                                          # rule or not
                                          # (enums={auto on off}, default=auto)
-create_no_flex_filler                    # Create proto model without adding
                                          # flex filler. (bool, default=false)
-create_partition_as_flexmodel            # Create partition specified as
                                          # flexmodel automatically.
                                          # (bool, default=false)
-create_pipeline_flop                     # Specifies a list of pipeline flop
                                          # instance patterns that are used in
                                          # the design. (string, default="")
-create_powerdomain_psPM                  # Create power domain psPM models.
                                          # (bool, default=false)
-create_timing_budget                     # Keep consistent setting of
                                          # deriveTimingBudget
                                          # (bool, default=false)
-identify_algorithm                       # identify_proto algorithm
                                          # <default=auto>
                                          # (enums={auto module_based instgroup_based}, default=auto)
-identify_estimated_flexmodel_number      # Specified the estimated flexModel
                                          # number to identify for the design
                                          # when using instance group based
                                          # identify_proto_model.
                                          # (int, default=20)
-identify_exclude_module                  # Excludes specified module(s) but
                                          # not its sub-modules for being
                                          # marked as models. (string, default="")
-identify_exclude_module_and_parent       # Excludes specified module(s) and
                                          # their parents for being marked as
                                          # models. (string, default="")
-identify_exclude_module_tree             # Excludes specified module(s) and
                                          # its sub-modules for being marked as
                                          # models. (string, default="")
-identify_honor_objects_hierarchy         # Specified the list of objects which
                                          # instance group based
                                          # identify_proto_model will honor its
                                          # hierarchy. (string, default="")
-identify_max_inst                        # Specifies the maximum instance
                                          # count threshold of a module to be
                                          # marked as model.(default=8% of
                                          # total instance count and no lower
                                          # than 300K instances) (int, default=-1)
-identify_min_inst                        # Specifies the minimum instance
                                          # count threshold of a module to be
                                          # marked as model. (int, default=1000)
-keep_inst_file_only                      # FlexModel only contains inst in
                                          # keep_inst_file. (bool, default=false)
-keep_instance_defined_in_sdc             # FlexModel will keep inst defined in
                                          # sdc file (bool, default=false)
-keep_slack_improve_NDR                   # Will be used by report_NDR_WNS_gain
                                          # to keep top critical nets as non
                                          # default rule nets .
                                          # (bool, default=false)
-max_report_NDR_net                       # Will be used by
                                          # create_ps_per_micron_model for
                                          # creating psPM model for  nets with
                                          # non default rules.
                                          # (float, default=0.05)
-route_net_NDR                            # Will be used by
                                          # create_ps_per_micron_model for
                                          # creating psPM model for  nets with
                                          # non default rules.
                                          # (string, default="")
-timing_net_delay_model                   # set mode of calculating wire delay
                                          # (enums={best_layer_no_detour best_layer_blockage_aware use_actual_wire}, default=best_layer_no_detour)
-timing_ps_per_micron                     # Specifies the estimated delay per
                                          # micron for each routing layer.
                                          # Layer range is from 1 to maximum
                                          # routing layers. (string, default="")
-verbose                                  # Output detailed information into
                                          # .log file. (bool, default=false)
-quiet                                    # Displays the current settings in Tcl list format only
-nonDefault                               # Displays the current settings which are not default settings