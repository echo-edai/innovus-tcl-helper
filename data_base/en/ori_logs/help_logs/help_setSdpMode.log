Usage: setSdpMode [-help] [-reset] [-clock_location <bottom|center>]
                  [-disable_extended_core {true|false}]
                  [-honor_dont_use {true|false}] [-honor_orient {true|false}]
                  [-legalization {NONE|SW|SE|NW|NE|AUTO}]
                  [-legalization_effort {low|medium|high}]
                  [-max_move_distance <DOUBLE>] [-num_column <INTVAL>]
                  [-place_report <STRVAL>]
                  [-pre_fixed_cells_blockage_direction {NONE|X|Y}]

-help                                  # Prints out the command usage
-reset                                 # Resets all or specified options to default value
-clock_location <bottom|center>        # ICG cell location
                                       # (string, default=center)
-disable_extended_core {true|false}    # disable the extended core flag
                                       # (bool, default=true)
-honor_dont_use {true|false}           # honor dont_use on base_cells during
                                       # EEQ swapping in SDP legalization
                                       # (bool, default=false)
-honor_orient {true|false}             # honor user specified orient during
                                       # legalization (bool, default=false)
-legalization {NONE|SW|SE|NW|NE|AUTO}  # Specify fixed corner of sdp box during
                                       # legalizing sdp instance
                                       # (enums={NONE SW SE NW NE AUTO}, default=NONE)
-legalization_effort {low|medium|high} # Specifies the legalization effort in
                                       # placing SDP groups
                                       # (enums={low medium high}, default=low)
-max_move_distance <DOUBLE>            # max sdp group move distance, default
                                       # is half perimeter of the core box
                                       # (float, default=0)
-num_column <INTVAL>                   # number of column for sdp group
                                       # (int, default=2)
-place_report <STRVAL>                 # Output a detailed sdp placement data.
                                       # Use empty string to reset to no output
                                       # (string, default="")
-pre_fixed_cells_blockage_direction {NONE|X|Y}
                                       # Specify the direction when covering
                                       # preplaced std cells using placement
                                       # blockages
                                       # (enums={NONE X Y}_list, default=NONE)