Usage: placeAIO [-help] [-assignBump] [-fast] [-hardFence]
                [-ignoreAIOByCellName {list}] [-ignoreAIOByName {list}]
                [-maxDistance <distance>] [-onlyAIO] [-packing]

-help                                  # Prints out the command usage
-assignBump                            # assigns bump after area I/O placement
                                       # (bool, optional)
-fast                                  # runs area I/O placement in the fast
                                       # mode (bool, optional)
-hardFence                             # restricts the area I/O placement to
                                       # the power domain fence (bool, optional)
-ignoreAIOByCellName {list}            # specifies the cell name of I/O
                                       # instances not to place (string, optional)
-ignoreAIOByName {list}                # specifies the I/O instance name not to
                                       # place (string, optional)
-maxDistance <distance>                # the maximum allowable distance
                                       # betweenthe I/O driver cells and the
                                       # bumps (int, optional)
-onlyAIO                               # places only area I/O instances
                                       # (bool, optional)
-packing                               # specifies the packing of I/O driver
                                       # cellswithin each cluster of rows
                                       # (bool, optional)