Usage: check_tcic [-help] [<files>] [-pre_opt] [-report_area]
                  [-report_file <string>] [-report_unplaced_block] [ -include_all_rules ] [-selected_rules <string> ]

-help                             # Prints out the command usage
<files>                           # Specify the tcic file (string, optional)
-include_all_rules                # report all the rules even if there is no
                                  # violation of that rule (bool, optional)
-pre_opt                          # Enable pre opt (bool, optional)
-report_area                      # Enable tool to report the object area data
                                  # in summary file (bool, optional)
-report_file <string>             # Specify the summary file name
                                  # (string, optional)
-report_unplaced_block            # Enable tool to show the number of unplaced
                                  # macros in summary (bool, optional)
-selected_rules <string>          # Specify the rule names (string, optional)