Usage: report_noise [-help] [-bumpy_waveform] [-cell_type <string>]
                    [-delay {max min}] [-double_clocking] [-double_switching]
                    [-exclude_failures] [-expand_virtual_attacker_bus]
                    [-failure] [-format <string>] [-gui_victim_nets_file]
                    [-histogram] [-level {vl vh vlu vho}]
                    [-max_threshold <float>] [-merge] [-merge_dir <string>]
                    [-nets <string>] [-output_file <string>]
                    [-output_format {single_line multiple_line single_line_multi_line_attacker}]
                    [-overshoot_undershoot] [-pins <string>]
                    [-precision <integer>] [-quiet_nets]
                    [-remove_status_row <string>]
                    [-report_virtual_attacker_constituents]
                    [-reverse_voltage_change_threshold <float>]
                    [-skip_nets_or_pins_in_header] [-slack <float>]
                    [-sort_by {noise receiver_peak slack cell_type incrDelay delay totDelay}]
                    [-style {default extended}] [-threshold <float>]
                    [-txtfile <string>] [-view <string>] [ [ > | >> ] ]

-help                                     # Prints out the command usage
-bumpy_waveform                           # generate report for bumpy nets
                                          # (bool, optional)
-cell_type <string>                       # generates glitch report for the
                                          # user specified cell-type
                                          # (string, optional)
-delay {max min}                          # specify the uncertainty type
                                          # (enum, optional)
-double_clocking                          # enable double clocking reporting
                                          # (bool, optional)
-double_switching                         # enable double switching reporting
                                          # (bool, optional)
-exclude_failures                         # Excludes all failing nets from the
                                          # glitch report. (bool, optional)
-expand_virtual_attacker_bus              # expand virtual attacker bus bits
                                          # (bool, optional)
-failure                                  # output glitch report for failure
                                          # net only (bool, optional)
-format <string>                          # output glitch report with the
                                          # specified fields (string, optional)
-gui_victim_nets_file                     # output glitch report with the
                                          # format for GUI interface
                                          # (bool, optional)
-histogram                                # generate glitch histogram
                                          # (bool, optional)
-level {vl vh vlu vho}                    # specifies level for which report
                                          # needs to be generated (enum, optional)
-max_threshold <float>                    # Specifies the maximum peak noise or
                                          # receiver peak thresholds to report
                                          # on. (float, optional)
-merge                                    # Generates merged report which
                                          # provide only worst glitch slack
                                          # report for each pin/level
                                          # combination across views
                                          # (bool, optional)
-merge_dir <string>                       # takes a directory name and
                                          # generates tool compatible database
                                          # (string, optional)
-nets <string>                            # name of nets to be reported
                                          # (list, optional)
-output_file <string>                     # output file (string, optional)
-output_format {single_line multiple_line single_line_multi_line_attacker}
                                          # Specifies if the output format
                                          # should be on a single line or on
                                          # multiple lines (enum, optional)
-overshoot_undershoot                     # Generates overshoot undershoot
                                          # glitch report (bool, optional)
-pins <string>                            # name of pins to be reported
                                          # (list, optional)
-precision <integer>                      # Specify precision value upto which
                                          # glitch data is to be printed.
                                          # Allowed values are 0, 1, 2 and 3.
                                          # (int, optional)
-quiet_nets                               # Generates quiet attackers report
                                          # (bool, optional)
-remove_status_row <string>               # Show only active attackers and
                                          # filter Sb, UF and LC from glitch
                                          # report (string, optional)
-report_virtual_attacker_constituents     # Show virtual attacker constituents
                                          # in report (bool, optional)
-reverse_voltage_change_threshold <float>
                                          # min reverse swing threshold (float, optional)
-skip_nets_or_pins_in_header              # Generates glitch report without
                                          # list of nets/pins in header
                                          # (bool, optional)
-slack <float>                            # generate report for bumpy nets
                                          # based on slack (float, optional)
-sort_by {noise receiver_peak slack cell_type incrDelay delay totDelay}
                                          # sorting type of the report,
                                          # <noise|receiver_peak|slack|cell_type>
                                          # for glitch report and
                                          # <incrDelay|delay|totDelay> for
                                          # delay report. (enum, optional)
-style {default extended}                 # style of the report format.
                                          # (enum, optional)
-threshold <float>                        # glitch (in mV) or uncertainty (in
                                          # ps) filter threshold (float, optional)
-txtfile <string>                         # output file (string, optional)
-view <string>                            # name of view to be reported
                                          # (string, optional)
> <filename>                              # Redirects output to the specified
                                          # file (redirect_operator, optional)
>> <filename>                             # Redirects output to the specified
                                          # file (redirect_operator, optional)