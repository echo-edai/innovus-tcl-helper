Usage: reset_macro_place_constraint [-help] [-array]
                                    [-avoid_abut_macro_edge_with_pins]
                                    [-cell_obs] [-cpg]
                                    [-forbidden_space_to_core]
                                    [-forbidden_space_to_macro]
                                    [-honor_strict_spacing_constraint]
                                    [-horizontal_stacking]
                                    [-instance_orientation]
                                    [-macro_corner_keepout]
                                    [-max_io_pin_group_keep_out]
                                    [-min_space_to_core] [-min_space_to_macro]
                                    [-parallel_run_length]
                                    [-parallel_run_length_for_stacking]
                                    [-pg_resource_model] [-power_domain_as_core]
                                    [-same_length_site] [-track_adjustment]
                                    [-vertical_stacking]

-help                                # Prints out the command usage
-array                               # delete all the array constraint
                                     # (bool, optional)
-avoid_abut_macro_edge_with_pins     # specify that not abut macro edges with
                                     # pins even macro distance is within
                                     # forbidden spacing setting (bool, optional)
-cell_obs                            # delete all the cell obs constraint
                                     # (bool, optional)
-cpg                                 # delete all the cpg constraint
                                     # (bool, optional)
-forbidden_space_to_core             # reset the forbidden space to core
                                     # (bool, optional)
-forbidden_space_to_macro            # reset the forbidden space to macro
                                     # (bool, optional)
-honor_strict_spacing_constraint     # specify that not honor forbidden spacing
                                     # and minimum spacing strictly
                                     # (bool, optional)
-horizontal_stacking                 # reset the max horizontal stack depth and
                                     # the minimum horizontal spacing
                                     # (bool, optional)
-instance_orientation                # delete all the instance orientations
                                     # (bool, optional)
-macro_corner_keepout                # reset macro corner keepout constraint
                                     # (bool, optional)
-max_io_pin_group_keep_out           # delete the macro-only blockages which
                                     # are automatically added to IO pins and
                                     # reset the max height or width of
                                     # macro-only blockages to 0 (bool, optional)
-min_space_to_core                   # reset the minimum space to core
                                     # (bool, optional)
-min_space_to_macro                  # reset the minimum space to macro
                                     # (bool, optional)
-parallel_run_length                 # reset the parallel run length to enable
                                     # space checking (bool, optional)
-parallel_run_length_for_stacking    # reset the stacking parallel run length
                                     # (bool, optional)
-pg_resource_model                   # delete the pg resource model
                                     # (bool, optional)
-power_domain_as_core                # reset the power domain as core
                                     # (bool, optional)
-same_length_site                    # reset the minimum difference site number
                                     # (bool, optional)
-track_adjustment                    # delete all the track adjustment
                                     # (bool, optional)
-vertical_stacking                   # reset the max vertical stack depth and
                                     # the minimum vertical spacing
                                     # (bool, optional)