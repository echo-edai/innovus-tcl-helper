Usage: addInst [-help] -cell <cellName> [-dontSnapToPlacementGrid]
               -inst <instName> [-loc {x y}] [-moduleBased <moduleName>]
               [-ori <orientation>] [-physical]
               [-place_status {fixed soft_fixed placed unplaced cover}]

-help                         # Prints out the command usage
-cell <cellName>              # Name of cell (string, required)
-dontSnapToPlacementGrid      # Don't snap location to placement grid for added
                              # instance, default is false (bool, optional)
-inst <instName>              # Name of instance (string, required)
-loc {x y}                    # location (point, optional)
-moduleBased <moduleName>     # Name of module (string, optional)
-ori <orientation>            # orientation, {R0 | R90 |R180 |R270 | MX | MX90
                              # | MY | MY90} (string, optional)
-physical                     # physical instance (bool, optional)
-place_status {fixed soft_fixed placed unplaced cover}
                              # Placement status;
                              # {fixed|soft_fixed|placed|unplaced|cover}
                              # (enum, optional)