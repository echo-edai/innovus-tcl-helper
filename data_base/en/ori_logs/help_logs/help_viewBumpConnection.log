Usage: viewBumpConnection [-help] [-honor_color] [-multiBumpsToPad]
                          [-multiPadsToBump] [-remove] [[[-net {net_list}] [-bump {bump_list}] [-io_inst {io_inst_list}] [-selected ]]|[[-bumpType {all power signal}] [-target {pad ring}]]]

-help                            # Prints out the command usage
-bump {bump_list}                # Specifies connecting bumps
                                 # (string, optional)
-bumpType {all power signal}     # Specifies connecting bump type
                                 # (enum, optional)
-honor_color                     # colorize flight line by the setting defined
                                 # by command ciopLoadBumpColorMapFile
                                 # (bool, optional)
-io_inst {io_inst_list}          # Specifies connecting IO instances
                                 # (string, optional)
-multiBumpsToPad                 # connect multiple bumps to one pad
                                 # (bool, optional)
-multiPadsToBump                 # connect multiple pads to one bump
                                 # (bool, optional)
-net {net_list}                  # Specifies connecting nets (string, optional)
-remove                          # remove bump connection (bool, optional)
-selected                        # connect selected bumps and IO instances
                                 # (bool, optional)
-target {pad ring}               # Specifies connecting target (enum, optional)