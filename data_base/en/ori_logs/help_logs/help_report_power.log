Usage: report_power [-help] [-block <string>] [-cap]
                    [-cap_unit {F mF uf nF pF fF}] [-cell <string>]
                    [-cell_list_file <string>] [-cell_type <string>]
                    [-clock_domain <string>] [-clock_gating_efficiency]
                    [-clock_network <string>] [-cluster_gating_efficiency]
                    [-comb_seq_power] [-compress <integer>]
                    [-count_seq_elements_in_clock_network]
                    [-die_instance_name <string>] [-distribute]
                    [-exclude_cells <string>] [-exclude_cells_file <string>]
                    [-exclude_instances <string>]
                    [-exclude_instances_file <string>]
                    [-float_precision <float>] [-format <string>]
                    [-group_type <string>] [-hierarchical_instances <string>]
                    [-hierarchy <string>] [-include_group_instance_count]
                    [-inst_list_file <string>] [-instances <string>] [-leakage]
                    [-net] [-no_wrap] [-nworst <string>] [-o <string>]
                    [-outfile <string>] [-output <string>] [-pg_net <string>]
                    [-pg_pin] [-power_db_directory <string>]
                    [-power_density_tiles <string>]
                    [-power_density_tiles_row_col <string>]
                    [-power_density_tiles_size <string>]
                    [-power_domain <string>] [-power_unit <string>]
                    [-print_memory_power] [-register_gating_efficiency]
                    [-report_prefix <string>] [-sort <string>] [-stat]
                    [-thermal_conductivity_inputs <string>]
                    [-thermal_leakage_temp <string>]
                    [-thermal_leakage_temperature_scale_table <string>]
                    [-thermal_leakage_temperature_scale_table_file <string>]
                    [-thermal_material_file <string>]
                    [-thermal_power_map_SI_unit <string>]
                    [-thermal_power_map_bottom_layer <string>]
                    [-thermal_power_map_densitytable_tile <string>]
                    [-thermal_power_map_file <string>]
                    [-thermal_power_map_format <string>]
                    [-thermal_power_map_format_version <string>]
                    [-thermal_power_map_header_include_file <string>]
                    [-thermal_power_map_powertable_tile <string>]
                    [-thermal_power_map_tile <string>]
                    [-thermal_power_map_top_layer <string>]
                    [-threshold <string>] [-threshold_voltage_group <string>]
                    [-time_based_report] [-time_unit <string>] [-toggle_rate]
                    [-use_geometry_cell_size <string>] [-view <string>]

-help                                    # Prints out the command usage
-block <string>                          # create power reports for block
                                         # <block_name> (string, optional)
-cap                                     # report net cap and pin cap
                                         # (bool, optional)
-cap_unit {F mF uf nF pF fF}             # capacitance unit. Default : pF
                                         # (picoFarads) (enum, optional)
-cell <string>                           # cells to report (string, optional)
-cell_list_file <string>                 # cell list in file to report
                                         # (string, optional)
-cell_type <string>                      # Specifies the cell type to include
                                         # in the power report. Default : all
                                         # (string, optional)
-clock_domain <string>                   # Specify clock domains in power
                                         # reports. (string, optional)
-clock_gating_efficiency                 # Generates a report that includes the
                                         # Clock Gating Efficiency (CGE) for
                                         # all clock gating instances as well
                                         # as different hierarchies in the
                                         # design. (bool, optional)
-clock_network <string>                  # Reports the power consumption of the
                                         # clock network, including the power
                                         # for generated clocks. Default : all.
                                         # (string, optional)
-cluster_gating_efficiency               # Specifies to generate the cluster
                                         # efficiency report in the RGE report.
                                         # (bool, optional)
-comb_seq_power                          # Specifies to generate a report that
                                         # gives the ratio of combinational
                                         # versus sequential power for all
                                         # modules of a given hierarchy.
                                         # (bool, optional)
-compress <integer>                      # compressed power report generation
                                         # (int, optional)
-count_seq_elements_in_clock_network     # include seqnential elements in clock
                                         # power (bool, optional)
-die_instance_name <string>              # specify die name (string, optional)
-distribute                              # create distributed power analysis
                                         # setup (bool, optional)
-exclude_cells <string>                  # -exclude_cells <cell_list>
                                         # (string, optional)
-exclude_cells_file <string>             # -exclude_cells_file <cell_list_file>
                                         # (string, optional)
-exclude_instances <string>              # -exclude_instances <inst_list>
                                         # (string, optional)
-exclude_instances_file <string>         # -exclude_instances_file
                                         # <instance_list_file> (string, optional)
-float_precision <float>                 # floating number precision control
                                         # (float, optional)
-format <string>                         # Specifies the type of report summary
                                         # required for static power reporting.
                                         # Valid Values are {simple |
                                         # detailed}, (string, optional)
-group_type <string>                     # user-defined cell group based power
                                         # summary (string, optional)
-hierarchical_instances <string>         # Specifies to report all the power
                                         # content for the specified
                                         # hierarchical instances/ blocks.
                                         # (string, optional)
-hierarchy <string>                      # Specifies the hierarchy level that
                                         # is included in the power report.
                                         # (string, optional)
-include_group_instance_count            # Report instance count for each
                                         # category in group power section
                                         # (bool, optional)
-inst_list_file <string>                 # instance list in file to report
                                         # (string, optional)
-instances <string>                      # Specifies the instances to include
                                         # in the power report. (string, optional)
-leakage                                 # Reports only leakage power of the
                                         # design. (bool, optional)
-net                                     # Reports the net switching power, as
                                         # well as the load capacitance, toggle
                                         # rate, and switching values for each
                                         # net in the design. (bool, optional)
-no_wrap                                 # no wrapping for long lines
                                         # (bool, optional)
-nworst <string>                         # Reports the number of nets with the
                                         # highest net switching power.
                                         # (string, optional)
-o <string>                              # Specifies the name of the power
                                         # analysis output directory that saves
                                         # the power reports. (string, optional)
-outfile <string>                        # Specifies the name of the report
                                         # file in which the top-level summary
                                         # of the power consumption information
                                         # is written. (string, optional)
-output <string>                         # Output Directory (string, optional)
-pg_net <string>                         # Reports the power consumed by each
                                         # instance that is connected to the
                                         # specified list of power nets.
                                         # Default : all. (string, optional)
-pg_pin                                  # include supply pin name in power
                                         # report (bool, optional)
-power_db_directory <string>             # power DB directory path
                                         # (string, optional)
-power_density_tiles <string>            # number of power density tiles
                                         # (string, optional)
-power_density_tiles_row_col <string>    # number of tiles in X/Y dimensions to
                                         # partition the specified region
                                         # (string, optional)
-power_density_tiles_size <string>       # tile size for partitioning the
                                         # specified region (string, optional)
-power_domain <string>                   # power domain list to report
                                         # (string, optional)
-power_unit <string>                     # power number unit (string, optional)
-print_memory_power                      # print memory power as seperate
                                         # category (bool, optional)
-register_gating_efficiency              # Generates a report that includes the
                                         # Register Gating Efficiency (RGE) and
                                         # Data Aware Gating Efficiency (DAGE)
                                         # for all sequential cell instances as
                                         # well as different hierarchies in the
                                         # design. (bool, optional)
-report_prefix <string>                  # Specifies a prefix for the report in
                                         # which the top-level summary of the
                                         # power consumption information is
                                         # written. (string, optional)
-sort <string>                           # Sorts the instance-based power
                                         # consumption data by internal ,
                                         # switching , leakage , or total
                                         # power. Default : total
                                         # (string, optional)
-stat                                    # report net statistics
                                         # (bool, optional)
-thermal_conductivity_inputs <string>    # Specifies a file containing the
                                         # thermal conductivity value for
                                         # layers. (string, optional)
-thermal_leakage_temp <string>           # Defines the temperature to calculate
                                         # leakage for the power map file.
                                         # (string, optional)
-thermal_leakage_temperature_scale_table <string>
                                         # Defines global leakage power scaling
                                         # factors on each temperature point.
                                         # (string, optional)
-thermal_leakage_temperature_scale_table_file <string>
                                         # Defines library/cell/instance based
                                         # leakage power scaling factors on
                                         # each temperature point.
                                         # (string, optional)
-thermal_material_file <string>          # Specifies a file to allow layer
                                         # thickness set by user.
                                         # (string, optional)
-thermal_power_map_SI_unit <string>      # use SI unit for Thermal Conductivity
                                         # (string, optional)
-thermal_power_map_bottom_layer <string>
                                         # report zero metal density lower than
                                         # this layer (string, optional)
-thermal_power_map_densitytable_tile <string>
                                         # Defines metal density table tile
                                         # number in the X and Y direction. By
                                         # default 10*10 will be used.
                                         # (string, optional)
-thermal_power_map_file <string>         # Generates the power map file with
                                         # the specified name in the output
                                         # directory. (string, optional)
-thermal_power_map_format <string>       # Generates a tile-based power map
                                         # file in the simple or stack format
                                         # to perform accurate thermal
                                         # analysis. (string, optional)
-thermal_power_map_format_version <string>
                                         # Version tag in power map file for
                                         # different format. (string, optional)
-thermal_power_map_header_include_file <string>
                                         # Specifies a file for adding extra
                                         # line in power map file header.
                                         # (string, optional)
-thermal_power_map_powertable_tile <string>
                                         # Defines power table tile number in
                                         # the X and Y direction. By default
                                         # 10*10 will be used. (string, optional)
-thermal_power_map_tile <string>         # Defines the tile number in the X and
                                         # Y direction. By default 10*10 will
                                         # be used. (string, optional)
-thermal_power_map_top_layer <string>    # report zero metal density higher
                                         # than this layer (string, optional)
-threshold <string>                      # Filters out the instances whose
                                         # total power dissipation is less than
                                         # the specified value. Default : 0.
                                         # (string, optional)
-threshold_voltage_group <string>        # Reports leakage by voltage threshold
                                         # group in the power report. Default :
                                         # all. (string, optional)
-time_based_report                       # write out detailed VCD profiling
                                         # report (bool, optional)
-time_unit <string>                      # time unit (string, optional)
-toggle_rate                             # Specifies to dump out instance-based
                                         # activity to the outfile. If multiple
                                         # clocks are reaching the instance,
                                         # then the fastest clock is used as a
                                         # reference. (bool, optional)
-use_geometry_cell_size <string>         # specify using gepmoetry or placement
                                         # for sclp PGV cell size
                                         # (string, optional)
-view <string>                           # Power analysis is performed for the
                                         # specified view. Default : Uses
                                         # current view in Tempus.
                                         # (string, optional)