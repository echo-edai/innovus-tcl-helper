Usage: set_aocv_thresholds [-help] [-min_stage_count_hold <int>]
                           [-min_stage_count_setup <int>] [-reset]
                           [-slack_pruning_threshold <float>]
                           -view <list_of_views>

-help                            # Prints out the command usage
-min_stage_count_hold <int>      # During Hold analysis, apply this AOCV stage
                                 # count floor so that all instance are
                                 # guaranteed to have a stage depth no less
                                 # than this value. A value of '0' will remove
                                 # the assertion. (int, optional)
-min_stage_count_setup <int>     # During Setup analysis, apply this AOCV stage
                                 # count floor so that all instance are
                                 # guaranteed to have a stage depth no less
                                 # than this value. A value of '0' will remove
                                 # the assertion. (int, optional)
-reset                           # Remove/set to default  all of the AOCV
                                 # threshold assertions for specified views.
                                 # (bool, optional)
-slack_pruning_threshold <float> # In two-pass/slack-based AOCV analysis mode,
                                 # this option can be set per view to control
                                 # the slack threshold at which paths are
                                 # removed from consideration for the next
                                 # phase of AOCV stage counting. (float, optional)
-view <list_of_views>            # Apply the specified thresholds to the list
                                 # of analysis views. (string, required)