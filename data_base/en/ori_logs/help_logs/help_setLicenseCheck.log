Usage: setLicenseCheck [-help] [-checkout <lic>] [-default] [-existOnServer]
                       [-optionList <"lic1 lic2 ...">] [-status] [-wait <t>]

-help                             # Prints out the command usage
-checkout <lic>                   # check out allowed optional license
                                  # (string, optional)
-default                          # restore system default (bool, optional)
-existOnServer                    # print out all licenses that exist on the
                                  # license server (bool, optional)
-optionList <"lic1 lic2 ...">     # ordered list to limit automatic optional
                                  # license check-out. Use -status to see legal
                                  # names (string, optional)
-status                           # current status of all licenses and
                                  # specified -wait <t> (bool, optional)
-wait <t>                         # wait for up to t minutes when checking-out
                                  # optional license
                                  # (int, optional, min=0, max=10000)