Usage: set_annotated_check [-help] <check_value> [-clock <clock_check>]
                           [-cond <sdf_condtion>] [-fall] -from <from_pins>
                           [-incremental] [-max] [-min] [-rise] -to <to_pins> { -setup | -hold | -recovery | -removal | -nochange_high | -nochange_low }

-help                    # Prints out the command usage
<check_value>            # The timing check value (float, required)
-clock <clock_check>     # Clock rising or falling (string, optional)
-cond <sdf_condtion>     # The condition only if the library has a condition
                         # attached to the specified timing check arc
                         # (string, optional)
-fall                    # Data fall transition for the timing check
                         # (bool, optional)
-from <from_pins>        # Start points of the timing arcs for which checks are
                         # annotated (string, required)
-hold                    # Sets timing check type to hold (bool, optional)
-incremental             # Set incremental checks (bool, optional)
-max                     # Maximum timing check for both data rise and data
                         # fall transitions (bool, optional)
-min                     # Minimum timing check for both data rise and data
                         # fall transitions (bool, optional)
-nochange_high           # Sets timing check type to nochange_high
                         # (bool, optional)
-nochange_low            # Sets timing check type to nochange_low
                         # (bool, optional)
-recovery                # Sets timing check type to recovery (bool, optional)
-removal                 # Sets timing check type to removal (bool, optional)
-rise                    # Data rise transition for the timing check
                         # (bool, optional)
-setup                   # Sets timing check type to setup (bool, optional)
-to <to_pins>            # Endpoints of the timing arcs for which checks are
                         # annotated (string, required)