Usage: set_clock_latency [-help] <latency> <pin_or_clock_list>
                         [-clock <clock_list>] [-clock_gate] [-fall] [-max]
                         [-min] [-rise] [-source  [-early ] [-late ] [-jitter <jitter_val>]]

-help                    # Prints out the command usage
<latency>                # Latency value (float, required)
<pin_or_clock_list>      # List of pins, ports or clocks to associate with the
                         # clock latency (string, required)
-clock <clock_list>      # Associates clock latency constraint with specific
                         # clock (string, optional)
-clock_gate              # Specifies local clock latency on pin or port objects
                         # (bool, optional)
-early                   # Specifies clock arrival time with respect to the
                         # early time of the clock signal (bool, optional)
-fall                    # Specifies the fall value of the waveform signal
                         # (bool, optional)
-jitter <jitter_val>     # Specifies dynamic portion of source clock latency
                         # value (float, optional)
-late                    # Specifies clock arrival time with respect to the
                         # late time of the clock signal (bool, optional)
-max                     # Specifies the clock latency for max operating corner
                         # (bool, optional)
-min                     # Specifies the clock latency for min operating corner
                         # (bool, optional)
-rise                    # Specifies the rise value of the waveform signal
                         # (bool, optional)
-source                  # Specifies source latency. If not specified, network
                         # latency is applied (bool, optional)