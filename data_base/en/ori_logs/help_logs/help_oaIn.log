Usage: oaIn [-help] <lib> <cell> <view>
            [-filter {block_insts blockages boundary fixed_core_insts floorplan pad_insts pin_shapes regions regular_routing special_routing bump_insts}]
            [-net { netnames }]

-help                       # Prints out the command usage
<lib>                       # Specifies the OpenAccess library name
                            # (string, required)
<cell>                      # Specifies the name of the top cell to import
                            # (string, required)
<view>                      # Specifies cell view name to import
                            # (string, required)
-filter {block_insts blockages boundary fixed_core_insts floorplan pad_insts pin_shapes regions regular_routing special_routing bump_insts}
                            # List if OpenAccess cellview information data to
                            # read. When not specified, all information is read
                            # from the OpenAccess cellview. When boundary is
                            # specified, the design boundary, rows and tracks
                            # are created from the new boundary. When
                            # pin_shapes is specified, existing pins are
                            # replaced by the ones being read from the
                            # cellview. (enum_list, optional)
-net { netnames }           # nets whose routing has to be read with -filter
                            # (string, optional)