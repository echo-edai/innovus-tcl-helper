Usage: write_codesign_die_abstract [-help] <DIEABSTRACTFILE>
                                   [-block_pin_layer_bottom <string>]
                                   [-block_pin_layer_top <string>]
                                   [-block_pin_minimum_size <float>]
                                   [-block_pin_name_includes <string>]
                                   [-bump_pin_layer_bottom <string>]
                                   [-bump_pin_layer_top <string>]
                                   [-constraints <string>]
                                   [-die_shrink_by <float>]
                                   [-die_thickness <float>]
                                   [-include_macro_obstructions]
                                   [-io_macros <string>]
                                   [-io_pin_layer_bottom <string>]
                                   [-io_pin_layer_top <string>]
                                   [-io_pin_minimum_size <float>]
                                   [-io_pin_name_includes <string>]
                                   [-layer_details]
                                   [-macro_obstructions_layer_bottom <string>]
                                   [-macro_obstructions_layer_top <string>]
                                   [-no_block_macros] [-no_blockages]
                                   [-no_rdl_routing] [-power_routing]
                                   [-power_routing_layer_bottom <string>]
                                   [-power_routing_layer_top <string>]
                                   [-rdl_routing_layer_bottom <string>]
                                   [-rdl_routing_layer_top <string>]
                                   [-scribe_all <float>] [-scribe_east <float>]
                                   [-scribe_north <float>]
                                   [-scribe_south <float>]
                                   [-scribe_west <float>]
                                   [-sealring_all <float>]
                                   [-sealring_east <float>]
                                   [-sealring_north <float>]
                                   [-sealring_south <float>]
                                   [-sealring_west <float>] [-version {4.0}]

-help                                    # Prints out the command usage
<DIEABSTRACTFILE>                        # name of die abstract file
                                         # (string, required)
-block_pin_layer_bottom <string>         # legal routing layers' name; used for
                                         # block macros.
                                         # If given, the layers below is not to
                                         # be output to the die abstract.
                                         # If not given, default value is the
                                         # next layer down from the top routing
                                         # layer (string, optional)
-block_pin_layer_top <string>            # legal routing layers' name; used for
                                         # block macros.
                                         # If given, the layers above is not to
                                         # be output to the die abstract
                                         # (string, optional)
-block_pin_minimum_size <float>          # This parameter defines the minimum
                                         # size of pin that will be output to
                                         # the die abstract.
                                         # The pin's x and y dimensions must be
                                         # at least this value (float, optional)
-block_pin_name_includes <string>        # This string indicates that only pins
                                         # that contain the string value will
                                         # be output (string, optional)
-bump_pin_layer_bottom <string>          # legal routing layers' name; used for
                                         # bump macros.
                                         # If given, the layers below is not to
                                         # be output to the die abstract
                                         # (string, optional)
-bump_pin_layer_top <string>             # legal routing layers' name; used for
                                         # bump macros.
                                         # If given, the layers above is not to
                                         # be output to the die abstract
                                         # (string, optional)
-constraints <string>                    # This indicates that there are
                                         # constraints in a file indicated by
                                         # <filename>. (string, optional)
-die_shrink_by <float>                   # This is the percentage by which the
                                         # die should be shrunk.
                                         # The default of 0 indicates no
                                         # shrink.
                                         # A typical shrink value is 10 (for a
                                         # 10.0% optical shrink).
                                         # (float, optional)
-die_thickness <float>                   # die thickness; default = 0
                                         # (float, optional)
-include_macro_obstructions              # when given, LEF macro OBS shapes
                                         # will be output to the die
                                         # abstract.
                                         # By default OBS obstructions are not
                                         # included (bool, optional)
-io_macros <string>                      # This parameter identifies what I/O
                                         # macros are to be written to the die
                                         # abstract.
                                         # none: it is only intended to do
                                         # co-design at the bump level.
                                         # design: only those I/O macros that
                                         # are referenced in the design will be
                                         # put in the die abstract. default is
                                         # design.
                                         # all: this abstract is going to be
                                         # sent to Orbit for early feasibility
                                         # planning (string, optional)
-io_pin_layer_bottom <string>            # legal routing layers' name; used for
                                         # I/O macros.
                                         # If given, the layers below is not to
                                         # be output to the die abstract
                                         # (string, optional)
-io_pin_layer_top <string>               # legal routing layers' name; used for
                                         # I/O macros.
                                         # If given, the layers above is not to
                                         # be output to the die abstract
                                         # (string, optional)
-io_pin_minimum_size <float>             # This parameter defines the minimum
                                         # size of pin that will be output to
                                         # the die abstract.
                                         # The pin's x and y dimensions must be
                                         # at least this value (float, optional)
-io_pin_name_includes <string>           # This string indicates that only pins
                                         # that contain the string value will
                                         # be output (string, optional)
-layer_details                           # when given, indicates that the layer
                                         # details is to be output to the die
                                         # abstract (bool, optional)
-macro_obstructions_layer_bottom <string>
                                         # If specified, identifies the bottom
                                         # layer for which OBS shapes are
                                         # exported to the die abstract.
                                         # The default value for this option is
                                         # the top metal layer (string, optional)
-macro_obstructions_layer_top <string>   # If specified, identifies the top
                                         # layer for which OBS shapes are
                                         # exported to the die abstract
                                         # (string, optional)
-no_block_macros                         # when given, indicates that the block
                                         # macros is not to be output to the
                                         # die abstract (bool, optional)
-no_blockages                            # when given, indicates that the
                                         # blockages is not to be output to the
                                         # die abstract (bool, optional)
-no_rdl_routing                          # when given, indicates that the rdl
                                         # routing is not to be output to the
                                         # die abstract (bool, optional)
-power_routing                           # when given, indicates that the power
                                         # routing is to be output to the die
                                         # abstract (bool, optional)
-power_routing_layer_bottom <string>     # legal routing layers' name; used for
                                         # power routing.
                                         # If given, the layers below is not to
                                         # be output to the die abstract
                                         # (string, optional)
-power_routing_layer_top <string>        # legal routing layers' name; used for
                                         # power routing.
                                         # If given, the layers above is not to
                                         # be output to the die abstract
                                         # (string, optional)
-rdl_routing_layer_bottom <string>       # legal routing layers' name; used for
                                         # rdl routing.
                                         # If given, the layers below is not to
                                         # be output to the die abstract
                                         # (string, optional)
-rdl_routing_layer_top <string>          # legal routing layers' name; used for
                                         # rdl routing.
                                         # If given, the layers above is not to
                                         # be output to the die abstract
                                         # (string, optional)
-scribe_all <float>                      # This define the distance in microns
                                         # from the die boundary to the edge of
                                         # the silicon after being cut from the
                                         # wafer.
                                         # All sides (float, optional)
-scribe_east <float>                     # This define the distance in microns
                                         # from the die boundary to the edge of
                                         # the silicon after being cut from the
                                         # wafer.
                                         # East side (float, optional)
-scribe_north <float>                    # This define the distance in microns
                                         # from the die boundary to the edge of
                                         # the silicon after being cut from the
                                         # wafer.
                                         # North side (float, optional)
-scribe_south <float>                    # This define the distance in microns
                                         # from the die boundary to the edge of
                                         # the silicon after being cut from the
                                         # wafer.
                                         # South side (float, optional)
-scribe_west <float>                     # This define the distance in microns
                                         # from the die boundary to the edge of
                                         # the silicon after being cut from the
                                         # wafer.
                                         # West side (float, optional)
-sealring_all <float>                    # Seal ring is a border around the die
                                         # boundary that is put in
                                         # pre-shrink.
                                         # All sides (float, optional)
-sealring_east <float>                   # Seal ring is a border around the die
                                         # boundary that is put in
                                         # pre-shrink.
                                         # East side (float, optional)
-sealring_north <float>                  # Seal ring is a border around the die
                                         # boundary that is put in
                                         # pre-shrink.
                                         # North side (float, optional)
-sealring_south <float>                  # Seal ring is a border around the die
                                         # boundary that is put in
