-help                                      # Prints out the command usage
-reset                                     # Resets all or specified options to default value
-accumulated_small_attacker_factor <double>
                                           # Specifies the multiplication
                                           # factor that controls the effect of
                                           # the cap mode accumulated small
                                           # attacker. (float, default=1)
-accumulated_small_attacker_mode {cap|current|zero_mean|numerical}
                                           # Specifies the multiplication
                                           # factor that controls the effect of
                                           # the cap mode accumulated small
                                           # attacker.
                                           # (enums={cap current zero_mean numerical}, default=dynamic setting)
-accumulated_small_attacker_threshold <double>
                                           # Specifies whether to use the
                                           # current-matching based method for
                                           # accumulated small attackers.
                                           # (float, default=10.01)
-attacker_alignment {path|path_overlap|timing_aware_edge|input_arrival}
                                           # Specifies the attacker alignment. (enums={path path_overlap timing_aware_edge input_arrival}, default=path)
-clock_delta_delay_threshold <double>      # Specifies the value above which
                                           # the clock delta delay should be
                                           # calculated. (float, default=-1)
-clocks {asynchronous|synchronous}         # Specifies the value above which
                                           # the clock delta delay should be
                                           # calculated.
                                           # (enums={asynchronous synchronous}, default=synchronous)
-constrained_input_threshold_failure_point {input|both}
                                           # (enums={input both}, default=input)
-delta_delay_annotation_mode {lumpedOnNet|arc}
                                           # Calculates the delay for each arc
                                           # (cell arc and net arc) in a path.
                                           # (enums={lumpedOnNet arc}, default=arc)
-delta_delay_threshold <double>            # delta delay analysis threshold
                                           # (float, default=-1)
-double_switching {none|clock|data_sequential|all}
                                           # Specifies type for which double
                                           # switching analysis will happen
                                           # (enums={none clock data_sequential all}, default=none)
-enable_bus_attacker_correlation {true|false}
                                           # (bool, default=false)
-enable_delay_report {true|false}          # Enables SI delay reports.
                                           # (bool, default=false)
-enable_double_clocking_check {true|false}
                                           # Enables double clocking check in
                                           # AAE.
                                           # (enums={true false}, default=false)
-enable_drv_with_delta_slew {true|false}
                                           # Enables SI slews reporting. (bool, default=false)
-enable_dynamic_receiver_peak_limits {true|false}
                                           # (bool, default=false)
-enable_glitch_propagation {true|false}    # Enables glitch propagation and
                                           # driver weakening through single
                                           # stage cells. (bool, default=false)
-enable_glitch_propagation_spice_deck {true|false}
                                           # Enables glitch propagation in
                                           # spice deck. (bool, default=false)
-enable_glitch_report {true|false}         # Enables AAE SI glitch analysis.
                                           # (bool, default=false)
-enable_logical_correlation {true|false}
                                           # Enables the AAE-SI logical
                                           # correlation.
                                           # (enums={true false}, default=false)
-enable_logical_correlation_for_bus {true|false}
                                           # (bool, default=false)
-enable_overshoot_undershoot_glitch {true|false}
                                           # Enables overshoot/undershoot
                                           # analysis and reporting.
                                           # (bool, default=false)
-enable_two_stage_driver_weakening {true|false}
                                           # (bool, default=true)
-enable_user_defined_bus_merging {true|false}
                                           # Enables bus merging feature - if a
                                           # net is in two groups, then the
                                           # groups are merged
                                           # (bool, default=false)
-enable_virtual_attacker_constituent_report {true|false}
                                           # (bool, default=false)
-glitch_accuracy_level <int>               # Specifies the accuracy levels for
                                           # glitch analysis (int, default=0)
-glitch_analysis_type {source|full_propagation}
                                           # (enums={source full_propagation}, default=source)
-hold_slack <double>                       # Specifies the slack reselection
                                           # threshold for hold.
                                           # (float, default=-1e-12)
-individual_attacker_clock_threshold <double>
                                           # Sets the glitch tolerance for
                                           # individual attacker nets on victim
                                           # clock nets. (float, default=0.015)
-individual_attacker_simulation_filtering {true|false}
                                           # Enables electrical filtering based
                                           # on attackers' simulated glitch
                                           # peaks. (bool, default=true)
-individual_attacker_threshold <double>    # AAE virtual attacker threshold
                                           # (float, default=0.015)
-input_glitch_full_propagation_threshold <double>
                                           # (float, default=0.75)
-input_glitch_full_propagation_vh_threshold <double>
                                           # (float, default=0.75)
-input_glitch_full_propagation_vl_threshold <double>
                                           # (float, default=0.75)
-input_glitch_threshold <double>           # Specifies the input glitch failure
                                           # threshold value during AAE
                                           # analysis. (float, default=0.4)
-input_glitch_vh_threshold <double>        # Specifies the input glitch vh
                                           # failure threshold value during AAE
                                           # analysis. (float, default=0.4)
-input_glitch_vl_threshold <double>        # Specifies the input glitch vl
                                           # failure threshold value during AAE
                                           # analysis. (float, default=0.4)
-max_bus_attacker_count <value>            # Max number of bus attacker per
                                           # victim net (int, default=999)
-nonlinear_attacker_slew {true|false}      # Uses a non-linear attacker. If set
                                           # to false , it uses a linear
                                           # attacker.
                                           # (enums={true false}, default=true)
-num_si_iteration <int>                    # Specifies the maximum number of
                                           # timing window iterations that
                                           # should be performed during SI
                                           # delay analysis. (int, default=2)
-pessimistic_mode {advanced|advanced_node|reduced_pessimism|increased_pessimism|high_pessimism}
                                           # Pessimistic Mode Settings (enums={advanced advanced_node reduced_pessimism increased_pessimism high_pessimism}, default=advanced)
-receiver_clk_peak_limit <double>          # Defines the glitch check limit for
                                           # clock inputs in receiver peak
                                           # mode. This parameter is specified
                                           # as a ratio of vdd.
                                           # (float, default=0.05)
-receiver_latch_peak_limit <double>        # Defines the glitch check limit for
                                           # latch inputs in receiver peak
                                           # mode. This parameter is specified
                                           # as a ratio of vdd.
                                           # (float, default=0.1)
-receiver_peak_limit <double>              # Defines the receiver peak/glitch
                                           # peak limit at all nodes. The value
                                           # specified for this parameter is a
                                           # ratio of vdd. (float, default=0.15)
-report_max_virtual_attacker_constituents <int>
                                           # (int, default=5)
-report_si_slew_max_transition {true|false}
                                           # report sislew violations (bool, default=false)
-secondary_attacker_decoupling_factor <double>
                                           # Specifies decoupling factor for
                                           # secondary aggressors.
                                           # (float, default=1)
-separate_delta_delay_on_data {true|false}
                                           # Separates the delta delay on data
                                           # (delta delay is always separated
                                           # for clock). (bool, default=false)
-setup_slack <double>                      # Specifies the slack reselection
                                           # threshold for setup.
                                           # (float, default=-1e-12)
-si_reselection {delta_delay|slack|xcap_ratio}
                                           # Specifies the SI reselection
                                           # criteria during timing window
                                           # iterations.
                                           # (enums={delta_delay slack xcap_ratio}, default=slack)
-si_reselection_delay_threshold <double>
                                           # Allows to change the delay
                                           # reselection criteria.
                                           # (float, default=1e-11)
-skip_noise_model_check <pins>             # Specifies a list of pins for which
                                           # noise model check will not take
                                           # place. (string, default="")
-skip_tw <nets>                            # Specifies the list of nets for
                                           # which timing window is to be
                                           # skipped. (string, default="")
-switch_prob <double>                      # Sets the attacker switching
                                           # probability.
                                           # (float, default=0.3, min=0, max=1)
-unconstrained_net_use_inf_tw {true|false}
                                           # Specifies that unconstrained nets
                                           # will have an infinite timing
                                           # window.
                                           # (enums={true false}, default=true)
-use_infinite_TW {true|false}              # (enums={true false}, default=false)
-view_specific_settings <view:setting:value>
                                           # Spicifies a global variable value
                                           # or macro settings for particular
                                           # view using
                                           # {viewName:eng_global|macro:value}
                                           # (string, default="")