Usage: addPGFTV [-help] [-area <box>] [-cell <string>] [-prePlace]
                [-prefix <prefix>] [-stepx <float>] [-stepy <float>] [-postRoute  [-cell_list <cell_list>]]

-help                      # Prints out the command usage
-area <box>                # Specifies the area in which PGFTV cells are to be
                           # inserted (box, optional)
-cell <string>             # Specifies the name of the single PGFTV cell to be
                           # used (string, optional)
-cell_list <cell_list>     # Specifies the name of all PGFTV cells to be used
                           # at the post-route stage (string, optional)
-postRoute                 # Specifies the PGFTV insertion is for the
                           # post-route stage (bool, optional)
-prePlace                  # Specifies the PGFTV insertion is for the pre-place
                           # stage (bool, optional)
-prefix <prefix>           # Specifies the prefix of the PGFTV cells to be
                           # inserted (string, optional)
-stepx <float>             # Specifies the distance between PGFTV cells in the
                           # horizontal direction (float, optional)
-stepy <float>             # Specifies the distance between PGFTV cells in the
                           # vertical direction (float, optional)