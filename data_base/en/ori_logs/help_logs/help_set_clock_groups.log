Usage: set_clock_groups [-help] [-comment <string>] [-group <clock_list>]
                        [-name <name>] [-logically_exclusive ] | [-physically_exclusive ] | [ [-asynchronous ] [-allow_paths ]]

-help                     # Prints out the command usage
-allow_paths              # Allows paths between asynchronous clock groups to
                          # be traced in timing analysis (bool, optional)
-asynchronous             # Defines clock group with asynchronous clocks
                          # (bool, optional)
-comment <string>         # Allows you to insert comments. The comments are
                          # read but are ignored with a one-time warning
                          # message.They are not used during timing analysis
                          # reporting nor are they written out during saving of
                          # constraints. (string, optional)
-group <clock_list>       # Defines a set of clocks that are exclusive or
                          # asynchronous to the clocks defined in all other
                          # groups (string, optional)
-logically_exclusive      # Defines clock group with clocks that do not have
                          # any functional paths between them, but coexist in
                          # the design at the same time (bool, optional)
-name <name>              # Name of clock groups to be added (string, optional)
-physically_exclusive     # Defines clock group with clocks that cannot exist
                          # in the design at the same time (bool, optional)