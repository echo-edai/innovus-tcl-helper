Usage: placeSdpGroup [-help] [-create_inst_group]
                     [-deleteOverlap {cell...} {sdp name...}]
                     [-sdpGroups {name...}] [-noResolveOverlap | [-keepSdpArea ]]

-help                                      # Prints out the command usage
-create_inst_group                         # convert failed top sdp groups to
                                           # instance group (bool, optional)
-deleteOverlap {cell...} {sdp name...}     # delete the cells which overlap
                                           # with sdp group (string, optional)
-keepSdpArea                               # keep sdp area when resolving
                                           # overlaps with other instances
                                           # (bool, optional)
-noResolveOverlap                          # don't resolve overlap with
                                           # column/row cells that specified in
                                           # setSdpMode, default is false
                                           # (bool, optional)
-sdpGroups {name...}                       # only place the specified sdp
                                           # groups (string, optional)