Usage: setSdpGroupAttribute [-help] [-flip {X Y XY NONE}]
                            [-justifyBy {SW SE NW NE MID}] -name <string>
                            [-orient {R0 MX MY R180 NONE}] [-origin {x y}]
                            [-padding {x y}] [-skipSpace <string>]

-help                            # Prints out the command usage
-flip {X Y XY NONE}              # Specify to flip the sdp group on X or Y axis
                                 # along with its elements. The alignment
                                 # information is adjusted accordingly.
                                 # (enum, optional)
-justifyBy {SW SE NW NE MID}     # Specify the anchor point that will be used
                                 # to align SDP group. (enum, optional)
-name <string>                   # Specify the name of sdp object
                                 # (string, required)
-orient {R0 MX MY R180 NONE}     # Specify the orient of sdp object.
                                 # (enum, optional)
-origin {x y}                    # Specify the location of top sdp group. It
                                 # can only be set to top group. (point, optional)
-padding {x y}                   # Specify the edge extend value of SDP
                                 # bounding box in horizontal and vertical
                                 # direction for specified top SDP group.
                                 # (point, optional)
-skipSpace <string>              # Specify the spacing pattern of SDP group.
                                 # The value for row skipping represents the
                                 # number of skipped rows. The value for column
                                 # skipping represents the number of the
                                 # default techsite size_x. If the sdp group is
                                 # skipSpace, will accept a value.
                                 # (string, optional)