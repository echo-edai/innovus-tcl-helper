Usage: set_well_tap_mode [-help] [-reset]
                         [-abut_boundary_tap_distance <cell1 cell2 rule>]
                         [-antenna_tap_break_cell <cell list>]
                         [-antenna_tap_cell <cell list>]
                         [-antenna_tap_left_cell <cell list>]
                         [-antenna_tap_pitch <microns>]
                         [-antenna_tap_right_cell <cell list>]
                         [-antenna_tap_right_top_edge_cell <cell list>]
                         [-avoid_vertical_well_abutment {none|ntap|ptap|all_tap}]
                         [-avoidAbutment {true|false}]
                         [-block_boundary_only {true|false}]
                         [-bottom_tap_cell <ListOfCellNames>]
                         [-bottom_termination_cell <cell list>]
                         [-cell <cellName>] [-channel_offset <microns>]
                         [-check_channel {true|false}]
                         [-column_cell <cell list>] [-create_rows {true|false}]
                         [-disable_check_zone_at_boundary {none|vdd|vss|both}]
                         [-inRowOffset <microns>]
                         [-insert_cells <cellName rule dense_layer dense_rule boundary_layer boundary_rule>]
                         [-rule <microns>] [-siteOffset <siteNums>]
                         [-tap_function_cells <cell list rule>]
                         [-tap_termination_alignment {true|false}]
                         [-termination_align {left|right|center}]
                         [-termination_cell <cell list>]
                         [-top_tap_cell <ListOfCellNames>]
                         [-top_termination_cell <cell list>]
                         [-vertical_boundary_spacing <microns>]
                         [-well_cut_cell <cell list>]

-help                                  # Prints out the command usage
-reset                                 # Resets all or specified options to default value
-abut_boundary_tap_distance <cell1 cell2 rule>
                                       # Specifies boundary cells and their tap
                                       # distance when they are vertically
                                       # abutted (string, default="")
-antenna_tap_break_cell <cell list>    # Specifies cells can break antenna tap
                                       # (string, default="")
-antenna_tap_cell <cell list>          # Specifies normal antenna tap cell
                                       # (string, default="")
-antenna_tap_left_cell <cell list>     # Specifies antenna tap cell for left
                                       # edge (string, default="")
-antenna_tap_pitch <microns>           # Specifies the pitch of antenna tap
                                       # cell (float, default=0)
-antenna_tap_right_cell <cell list>    # Specifies antenna tap cell for right
                                       # edge (string, default="")
-antenna_tap_right_top_edge_cell <cell list>
                                       # Specifies antenna tap cell for right
                                       # top edge (string, default="")
-avoid_vertical_well_abutment {none|ntap|ptap|all_tap}
                                       # Specifies which type of well-tap cells
                                       # to be forbidden from vertical abutment
                                       # (enums={none ntap ptap all_tap}, default=none)
-avoidAbutment {true|false}            # Specifies whether the inserted taps
                                       # should avoid horizontal and vertical
                                       # abutment  (bool, default=false)
-block_boundary_only {true|false}      # Specifies whether inserting
                                       # termination cells on the core boundary
                                       # (bool, default=false)
-bottom_tap_cell <ListOfCellNames>     # Cell to be used as bottom tap for
                                       # addEndCap boundary cell insertion flow
                                       # (string, default="")
-bottom_termination_cell <cell list>   # Specifies the list of bottom
                                       # termination cells to be used
                                       # (string, default="")
-cell <cellName>                       # Cell to be used as welltap
                                       # (string, default="")
-channel_offset <microns>              # Specifies the offset value between
                                       # taps and blockage in channel
                                       # (float, default=0, min=0, max=1.79769313486232e+308)
-check_channel {true|false}            # Specifies whether checking blockage
                                       # channel (bool, default=false)
-column_cell <cell list>               # Specifies the list of cells which can
                                       # be replaced by termination cell
                                       # (string, default="")
-create_rows {true|false}              # Create rows for welltap cell techSites
                                       # which do not have rows in the floor
                                       # plan (bool, default=false)
-disable_check_zone_at_boundary {none|vdd|vss|both}
                                       # disable check zone at bounadry (enums={none vdd vss both}, default=none)
-inRowOffset <microns>                 # Specifies the distance between the
                                       # first wellTap in a row and the start
                                       # of the row
                                       # (float, default=0, min=0, max=1.79769313486232e+308)
-insert_cells <cellName rule dense_layer dense_rule boundary_layer boundary_rule>
                                       # Insert well-taps based on cell, layer
                                       # and inertval (string, default="")
-rule <microns>                        # Specifies the well latch-up rule
                                       # (float, default=0)
-siteOffset <siteNums>                 # Specifies the offset value in number
                                       # of sites that vertical taps need to be
                                       # aware of
                                       # (int, default=1, min=1, max=INT_MAX)
-tap_function_cells <cell list rule>   # Specifies the list of tap function
                                       # cells to be used (string, default="")
-tap_termination_alignment {true|false}    # Specifies whether to align
                                           # well-taps and termination cells
                                           # (bool, default=false)
-termination_align {left|right|center} # Specifies the termination cell align
                                       # (enums={left right center}, default=left)
-termination_cell <cell list>          # Specifies the list of termination
                                       # cells to be used (string, default="")
-top_tap_cell <ListOfCellNames>        # Cell to be used as top tap for
                                       # addEndCap boundary cell insertion flow
                                       # (string, default="")
-top_termination_cell <cell list>      # Specifies the list of top termination
                                       # cells to be used (string, default="")
-vertical_boundary_spacing <microns>   # Specifies the spacing between center
                                       # of tap cell and vertical boundary
                                       # (float, default=-1, min=-1, max=1.79769313486232e+308)
-well_cut_cell <cell list>             # Specifies the list of cells with the
                                       # well cuts (string, default="")