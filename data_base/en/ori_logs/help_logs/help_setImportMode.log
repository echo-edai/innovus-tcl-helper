Usage: setImportMode [-help] [-reset] [-discardFloatingVNets {true|false}]
                     [-keepEmptyModule {true|false}]
                     [-minDBUPerMicron <dbuPerMicron>]
                     [-syncRelativePath {true|false}] [-timerMode {true|false}]

-help                                      # Prints out the command usage
-reset                                     # Resets all or specified options to default value
-discardFloatingVNets {true|false}         # If true, an hnet (Verilog wire
                                           # statement) that has nothing
                                           # connected to it, is deleted from
                                           # the netlist. The default value is
                                           # false in Innovus to allow for
                                           # netlist repair, but true in Tempus
                                           # to delete non-timed nets and
                                           # reduce memory. (bool, default=false)
-keepEmptyModule {true|false}              # By default, usage of an empty
                                           # Verilog module that has no
                                           # matching library cell name becomes
                                           # an empty hinst.  If this value is
                                           # false, a dummy library cell is
                                           # created, and usage of it becomes
                                           # an inst.  You should then use
                                           # other commands to 'fix' the dummy
                                           # library cell before proceeding in
                                           # the flow. (bool, default=true)
-minDBUPerMicron <dbuPerMicron>            # Minimum DBU per micron
                                           # (uint, default=0)
-syncRelativePath {true|false}             # Synchronize Relative paths
                                           # (bool, default=false)
-timerMode {true|false}                    # Timer Mode (bool, default=false)