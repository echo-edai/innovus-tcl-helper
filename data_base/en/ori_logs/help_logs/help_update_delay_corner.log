Usage: update_delay_corner [-help]
                           [-early_estimated_worst_irdrop_factor <percent>]
                           [-early_irdrop_data <files_or_directories>]
                           [-early_irdrop_file <list_of_files>]
                           [-early_library_set <libSetName>]
                           [-early_opcond <opcondName>]
                           [-early_opcond_library <libName>]
                           [-early_rc_corner <rcCornerObj>]
                           [-early_temp_file <tempName>]
                           [-irdrop_data <files_or_directories>]
                           [-irdrop_file <list_of_files>]
                           [-late_estimated_worst_irdrop_factor <percent>]
                           [-late_irdrop_data <files_or_directories>]
                           [-late_irdrop_file <list_of_files>]
                           [-late_library_set <libSetName>]
                           [-late_opcond <opcondName>]
                           [-late_opcond_library <libName>]
                           [-late_rc_corner <rcCornerObj>]
                           [-late_temp_file <tempName>]
                           [-library_set <libSetObj>] -name <delayCornerObj>
                           [-opcond <opcondName>] [-opcond_library <libName>]
                           [-pg_net_voltages <voltage_pairs>]
                           [-power_domain <powerDomainName>]
                           [-rc_corner <rcCornerObj>] [-si_enabled <true|false>]
                           [-supply_set <supplySetName>] [-temp_file <tempName>]

-help                                  # Prints out the command usage
-early_estimated_worst_irdrop_factor <percent>
                                       # Early voltage derating factor (float, optional)
-early_irdrop_data <files_or_directories>
                                       # Specifies the IR drop files or
                                       # directories to apply when calculating
                                       # early arrival times at a single delay
                                       # corner (string, optional)
-early_irdrop_file <list_of_files>     # Specifies the list of IR drop files to
                                       # apply when calculating early arrival
                                       # times at a single power domain
                                       # (string, optional)
-early_library_set <libSetName>        # Specifies the library set to associate
                                       # with the power domain for calculating
                                       # early arrival times for this power
                                       # domain (string, optional)
-early_opcond <opcondName>             # Specifies the operating condition name
                                       # to use for calculating early arrival
                                       # times for this power domain
                                       # (string, optional)
-early_opcond_library <libName>        # Specifies the internal library name
                                       # for the library in which the early
                                       # operating condition is defined. This
                                       # is not the library file name
                                       # (string, optional)
-early_rc_corner <rcCornerObj>         # Specifies the new RC corner object to
                                       # associate with this delay corner
                                       # (string, optional)
-early_temp_file <tempName>            # Specifies the temperature filename for
                                       # temperature aware delay calculation
                                       # for early corner (string, optional)
-irdrop_data <files_or_directories>    # Specifies the IR drop files or
                                       # directories to apply to both early and
                                       # late delay calculation for this delay
                                       # corner object (string, optional)
-irdrop_file <list_of_files>           # Specifies the list of IR drop files to
                                       # apply to both early and late delay
                                       # calculation for this power domain
                                       # object (string, optional)
-late_estimated_worst_irdrop_factor <percent>
                                       # Late voltage derating factor (float, optional)
-late_irdrop_data <files_or_directories>
                                       # Specifies the IR drop files or
                                       # directories to apply when calculating
                                       # late arrival times at a single delay
                                       # corner (string, optional)
-late_irdrop_file <list_of_files>      # Specifies the list of IR drop files to
                                       # apply when calculating late arrival
                                       # times at a single power domain
                                       # (string, optional)
-late_library_set <libSetName>         # Specifies the library set to associate
                                       # with this delay corner object for
                                       # calculating late arrival times for
                                       # this power domain (string, optional)
-late_opcond <opcondName>              # Specifies the operating condition name
                                       # to use for calculating late arrival
                                       # times for this power domain
                                       # (string, optional)
-late_opcond_library <libName>         # Specifies the internal library name
                                       # for the library in which the late
                                       # operating condition is defined. This
                                       # is not the library file name
                                       # (string, optional)
-late_rc_corner <rcCornerObj>          # Specifies the new RC corner object to
                                       # associate with this delay corner
                                       # (string, optional)
-late_temp_file <tempName>             # Specifies the temperature filename for
                                       # temperature aware delay calculation
                                       # for late corner (string, optional)
-library_set <libSetObj>               # Specifies the library set to associate
                                       # with the power domain (string, optional)
-name <delayCornerObj>                 # Specifies the delay calculation corner
                                       # to add the power domain definition, or
                                       # to update the delay corner or power
                                       # domain attribute values
                                       # (string, required)
-opcond <opcondName>                   # Specifies the operating condition name
                                       # to use for the power domain
                                       # (string, optional)
-opcond_library <libName>              # Specifies the internal library name
                                       # for the library in which the operating
                                       # condition is defined. This is not the
                                       # library file name (string, optional)
-pg_net_voltages <voltage_pairs>       # Power/ground net voltages to use for
                                       # both early/late analysis
                                       # (string, optional)
-power_domain <powerDomainName>        # Specifies the name of the power domain
                                       # to add to the delay calculation corner
                                       # (string, optional)
-rc_corner <rcCornerObj>               # Specifies the new RC corner object to
                                       # associate with this delay corner
                                       # (string, optional)
-si_enabled <true|false>               # Option to control SI behavior
                                       # (string, optional)
-supply_set <supplySetName>            # Specifies the name of the supply set
                                       # to add to the delay calculation corner
                                       # (string, optional)
-temp_file <tempName>                  # Specifies the temperature filename for
                                       # temperature aware delay calculation
                                       # for single corner (string, optional)