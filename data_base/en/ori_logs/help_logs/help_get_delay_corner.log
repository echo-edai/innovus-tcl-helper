Usage: get_delay_corner [-help] <delayCornerName> [-early_irdrop_data]
                        [-early_irdrop_file] [-early_library_set]
                        [-early_opcond] [-early_opcond_library]
                        [-early_rc_corner] [-early_temp_file] [-irdrop_data]
                        [-irdrop_file] [-late_irdrop_data] [-late_irdrop_file]
                        [-late_library_set] [-late_opcond]
                        [-late_opcond_library] [-late_rc_corner]
                        [-late_temp_file] [-library_set] [-opcond]
                        [-opcond_library] [-power_domain <powerDomainName>]
                        [-power_domain_list] [-rc_corner] [-si_enabled]
                        [-supply_set <supplySetName>] [-supply_set_list]
                        [-temp_file]

-help                               # Prints out the command usage
<delayCornerName>                   # Name of the delay calculation corner to
                                    # query (string, required)
-early_irdrop_data                  # Returns the list of IR drop files or
                                    # directories applied to early delay
                                    # calculation for this delay corner object
                                    # (bool, optional)
-early_irdrop_file                  # Returns the list of IR drop files applied
                                    # when calculating early arrival times at a
                                    # single delay corner (bool, optional)
-early_library_set                  # Returns the library set associated with
                                    # this delay corner object for calculating
                                    # early arrival times at a single delay
                                    # corner (bool, optional)
-early_opcond                       # Returns the operating condition name used
                                    # for calculating early arrival times at a
                                    # single delay corner (bool, optional)
-early_opcond_library               # Returns the internal library name for the
                                    # library in which the early operating
                                    # condition is defined. This is not the
                                    # library file name (bool, optional)
-early_rc_corner                    # Returns the RC corner object associated
                                    # with this delay corner object
                                    # (bool, optional)
-early_temp_file                    # Returns the temperature filename for
                                    # temperature aware delay calculation for
                                    # early corner (bool, optional)
-irdrop_data                        # Returns the list of IR drop files or
                                    # directories applied to both early and
                                    # late delay calculation for this delay
                                    # corner object (bool, optional)
-irdrop_file                        # Returns the list of IR drop files applied
                                    # to both early and late delay calculation
                                    # for this delay corner object
                                    # (bool, optional)
-late_irdrop_data                   # Returns the list of IR drop files or
                                    # directories applied to late delay
                                    # calculation for this delay corner object
                                    # (bool, optional)
-late_irdrop_file                   # Returns the list of IR drop files applied
                                    # when calculating late arrival times at a
                                    # single delay corner (bool, optional)
-late_library_set                   # Returns the library set associated with
                                    # this delay corner object for calculating
                                    # late arrival times at a single delay
                                    # corner (bool, optional)
-late_opcond                        # Returns the operating condition name used
                                    # for calculating late arrival times at a
                                    # single delay corner (bool, optional)
-late_opcond_library                # Returns the internal library name for the
                                    # library in which the late operating
                                    # condition is defined. This is not the
                                    # library filename (bool, optional)
-late_rc_corner                     # Returns the RC corner object associated
                                    # with this delay corner object
                                    # (bool, optional)
-late_temp_file                     # Returns the temperature filename for
                                    # temperature aware delay calculation for
                                    # late corner (bool, optional)
-library_set                        # Returns the library set associated with
                                    # this delay corner object (bool, optional)
-opcond                             # Returns the operating condition name used
                                    # for setup and hold analysis (bool, optional)
-opcond_library                     # Returns the internal library name for the
                                    # library in which the operating condition
                                    # is defined. This is not the library file
                                    # name (bool, optional)
-power_domain <powerDomainName>     # name of the power domain you want to
                                    # query (string, optional)
-power_domain_list                  # Returns a list of all  power domains
                                    # associated with the specified delay
                                    # calculation corner (bool, optional)
-rc_corner                          # Returns the RC corner object associated
                                    # with this delay corner object
                                    # (bool, optional)
-si_enabled                         # Returns option to control SI behavior
                                    # (bool, optional)
-supply_set <supplySetName>         # name of the supply set you want to query
                                    # (string, optional)
-supply_set_list                    # Returns a list of all supply sets
                                    # associated with the specified delay
                                    # calculation corner (bool, optional)
-temp_file                          # Returns the temperature filename for
                                    # temperature aware delay calculation for
                                    # single corner (bool, optional)