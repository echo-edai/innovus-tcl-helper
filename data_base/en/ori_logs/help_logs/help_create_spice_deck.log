-help                                     # Prints out the command usage
-add_driver_for_constraint_check {true false}
                                          # add real driver at clock and data (enum, optional)
-add_side_load_measurement {true false}   # add the side load measurement in
                                          # clock mesh Spice deck (enum, optional)
-add_voltage_for_missing_sensitization    # add_voltage_for_missing_sensitization
                                          # (bool, optional)
-aging_correlation_type {full timingonly}
                                          # create aging aware deck (enum, optional)
-aging_stress_num_cycles <integer>        # Uses that many # of cycles of
                                          # stimuli in stress deck.
                                          # (int, optional)
-aging_stress_use_timing_slew {true false}
                                          # correct slew to be used in stress
                                          # deck. (enum, optional)
-aginglevel_only <string>                 # For URI models (string, optional)
-bbox_cells <string>                      # list of cells to be considered as
                                          # black boxes (string, optional)
-constraint_check {true false}            # to enable constraint validation
                                          # flow (enum, optional)
-depth <integer>                          # create clock mesh spice deck of
                                          # depth (int, optional)
-enable_arrival_measurements {true false}
                                          # To add arrival measurements (enum, optional)
-enable_fast_simulation {true false}      # one transition simulation using
                                          # initial conditions (enum, optional)
-enable_mis {tied_input independent_input none}
                                          # (enum, optional)
-enable_spectre_x {true false}            # enable spectreX license checkout
                                          # when launching spectre
                                          # (enum, optional)
-exclude_side_load_cells <string>         # List of cells for which pin cap
                                          # will be used for side loads instead
                                          # instantiating them (string, optional)
-exclude_side_load_cells_for_missing_subckt {true false}
                                          # When true, it will add side load
                                          # pin cap for missing SPICE Subckt
                                          # cell instead instantiating it
                                          # (enum, optional)
-file_prefix <string>                     # Adds this prefix to the spice deck
                                          # files generated (string, optional)
-force_delete_output_dir                  # completely remove the directory
                                          # given by the user in the outdir
                                          # option (bool, optional)
-format <string>                          # changes run path simulation
                                          # internal reporting format. Format
                                          # columns should be compatible to
                                          # report_timing_format. Once set same
                                          # will be used for subsequent
                                          # create_spice_deck command
                                          # (string, optional)
-from <string>                            # creates the spice deck with mesh
                                          # net starting from pin
                                          # (string, optional)
-from_fall <string>                       # creates the spice deck with mesh
                                          # net starting from falling
                                          # transition of specified from pin
                                          # (string, optional)
-from_rise <string>                       # creates the spice deck with mesh
                                          # net starting from rising transition
                                          # of specified from pin
                                          # (string, optional)
-generate_output_only {true false}        # Generate output from existing
                                          # created database file (enum, optional)
-glitch_simulation_mode {input_output output}
                                          # input_output :	default (rip+rop
                                          # simulation)
                                          # output	:	SPICE ROP will be computed
                                          # using Tempus RIP (enum, optional)
-ground <string>                          # list of ground nodes
                                          # (string, optional)
-include_cell_variation {true false}      # to include in via variation
                                          # (enum, optional)
-lsf_job_string <string>                  # handle to the farm job for
                                          # launching simulation
                                          # (string, optional)
-mc_simulation_init_args <string>         # montecarlo simulation settings,
                                          # deafult: numruns=1000
                                          # variations=mismatch sampling=lhs
                                          # paramfile=Param.txt
                                          # scalarfile=MCData.txt dut=[%s]
                                          # (string, optional)
-mc_simulation_tran_args <string>         # montecarlo simulation settings,
                                          # deafult: start=0 stop=%g step=1p
                                          # errpreset=conservative
                                          # (string, optional)
-measure_point {all path stage none}      # whether to add all or path or stage
                                          # measurements. default is all
                                          # (enum, optional)
-merge_spice_deck {true false}            # option to enable merged SPICE deck
                                          # (enum, optional)
-model_file <string>                      # model file, to be included in
                                          # generated spice (string, optional)
-no_hard_stop_at_to_pins {true false}     # when it is true, it would traverse
                                          # down all the way till it hits clock
                                          # pin of flop or any stop point
                                          # specified with -to{} option or it
                                          # passes depth specified with -depth
                                          # option (enum, optional)
-omipath <string>                         # OMI model directory
                                          # (string, optional)
-outdir <string>                          # output directory for created spice
                                          # (string, optional)
-power <string>                           # list of power nodes
                                          # (string, optional)
-receiver_pin <string>                    # listof  receiver pins for glitch
                                          # spice deck (string, optional)
-reliability_commands <string>            # extra user commands for reliability
                                          # section (before transient analysis
                                          # statements in reliability section)
                                          # (string, optional)
-reliability_model_type {URI OMI TMI TI_URI}
                                          # create aging aware deck (enum, optional)
-report_noise <string>                    # arguments to report_noise command
                                          # for glitch spice deck creation
                                          # (string, optional)
-report_timing <string>                   # arguments to report_timing command
                                          # (string, optional)
-run_simulation                           # enable path simulation in adddition
                                          # to generating spice deck
                                          # (bool, optional)
-segment {data_path launch_path launch_clock_path capture_path all}
                                          # creates the spice deck of the
                                          # segment out of path spice deck
                                          # (enum, optional)
-segment_end <string>                     # specify segment end term name
                                          # (string, optional)
-segment_start <string>                   # specify segment start term name
                                          # (string, optional)
-side_path_level <integer>                # Specifies the number of levels of
                                          # side path stages to be included in
                                          # the SPICE trace. Only 0 or 1 can be
                                          # provided. Default is 1 (int, optional)
-spectre <string>                         # loaction of spectre path
                                          # (string, optional)
-spectre_analysis_options <string>        # spectre options (string, optional)
-spectre_cmd_options <string>             # command line options for spectre
                                          # (string, optional)
-spectre_lang_escape_chars <string>       # escape characters  list in spectre
                                          # (string, optional)
-spice_include <string>                   # included as is in the generated
                                          # spice deck (string, optional)
-spice_include_reliability <string>       # To specify user-provided
                                          # std::string inside reliability
                                          # (string, optional)
-start_from_cppr_pin {true false}         # Starts the SPICE simulations from
                                          # CPPR point (enum, optional)
-stimuli_file <string>                    # Allows you to specify the stimuli
                                          # to be used for cells where SPICE
                                          # deck has a difficult time
                                          # sensitizing. (string, optional)
-subckt_file <string>                     # subckt file, to be included in
                                          # generated spice (string, optional)
-supply_voltage_file <string>             # user defined power/ground voltage
                                          # file (string, optional)
-supply_voltage_file_stress <string>      # user defined power/ground voltage
                                          # file (string, optional)
-sweep_range <float>                      # Range to sweep the victim
                                          # (float, optional)
-sweep_steps <integer>                    # Number of steps by which the victim
                                          # is swept (int, optional)
-sweep_victim {true false}                # to enable victim sweep
                                          # (enum, optional)
-temperature <float>                      # user defined temperature to be used
                                          # in SPICE simulations. Unit:
                                          # Celsius. (float, optional)
-through <string>                         # creates the spice deck with mesh
                                          # net going by -through points
                                          # (string, optional)
-to <string>                              # creates the spice deck with mesh
                                          # net ending at to pins
                                          # (string, optional)
-uri_lib_file <string>                    # For URI models (e.g. Samsung)
                                          # (string, optional)
-uri_mode <string>                        # To specify URI appendage option;
                                          # #default=appendage (string, optional)
-use_control_param {true false}           # spice deck created will be
                                          # controlled throuh param
                                          # (enum, optional)
-use_distributed_load_for_side_receivers {true false}
                                          # whether to use receiver load as
                                          # distributed load or lumped load
                                          # (enum, optional)
-use_ndw_for_constraint_check {true false}
                                          # use ndw for constraint check (enum, optional)
-use_noise_model_when_cond {true false}   # use when condition from pin noise
                                          # model (enum, optional)
-use_predriver_waveform_at_startpoint {true false}
                                          # Specifies whether to use pre-driver
                                          # waveform or propagated waveform at
                                          # startpoint (enum, optional)
-user_defined_measure_statements {append overwrite}
                                          # user defined statements; deafault
                                          # is append (enum, optional)
-user_defined_measure_statements_file <string>
                                          # user defined measurements (string, optional)
-view <string>                            # view name, if glitch spice deck is
                                          # create for other than default view
                                          # (string, optional)
-waveform_aware_pulse_width_checks {true false}
                                          # deck for waveform aware pulse width
                                          # checks (enum, optional)
-xtalk {delay vl_glitch vh_glitch vlu_glitch vho_glitch}
                                          # si delay or vl/vh glitch (enum, optional)
> <filename>                              # redirect
                                          # -run_path_simulation/-run_simulation
                                          # output to file
                                          # (redirect_operator, optional)
>> <filename>                             # append
                                          # -run_path_simulation/-run_simulation
                                          # to output file
                                          # (redirect_operator, optional)