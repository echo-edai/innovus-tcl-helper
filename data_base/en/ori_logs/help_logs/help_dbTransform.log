Usage: dbTransform [-help] [-d] {-inst <inst|bump> | -hinst <hinst> | {-cell <cell> -orient <orientEnum> -pt {x y}}} {-localPt <list> | -globalPt <list>}

-help                 # Prints out the command usage
-cell <cell>          # Specifies a pointer to a library cell.
                      # ((libCell/ptnCell|vCell|topCell), optional)
-d                    # User specified values and return values are in database
                      # units: default is um (bool, optional)
-globalPt <list>      # Specifies the global coordinates to convert into local
                      # coordinates, a pt {x y}, rect {xl yl xu yu} or list of
                      # pts and/or rects {{x1 y1} {x2 y2} {xl yl xu yu} ...}
                      # inside design (string, required)
-hinst <hinst>        # Specifies the hierarchical instance of a database
                      # object. ((hInst), optional)
-inst <inst|bump>     # Specifies an instance/bump of a cell in the design.
                      # ((inst|bump), optional)
-localPt <list>       # Specifies the local coordinates to convert into global
                      # coordinates, a pt {x y}, rect {xl yl xu yu} or list of
                      # pts and/or rects {{x1 y1} {x2 y2} {xl yl xu yu} ...}
                      # inside cell (string, required)
-orient {R0 R90 R180 R270 MX MX90 MY MY90}
                      # Specifies the orientation of the cell specified with
                      # -cell. (enum, optional)
-pt {x y}             # Specifies the coordinates for the cell specified with
                      # -cell. (point, optional)