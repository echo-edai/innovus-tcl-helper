Usage: restore_module_model [-help] [-dynamic_view <string>]
                            [-hold_views <string>] [-leakage_view <string>]
                            [-lef_files <string>] [-mmmcFile <string>]
                            [-noTiming] [-noTimingGraph] [-setup_views <string>]
                            [-tag <string>] {<cellName> | -cell <string>} [<options>] [-add_ons <string>]

-help                     # Prints out the command usage
<cellName>                # <module name> (string, optional)
<options>                 # <restore options> (string, optional)
-add_ons <string>         # <associated with -type> 1801 mmmc spef eco latency
                          # scan_info timing_context extraction_context
                          # pin_assign (string, optional)
-cell <string>            # <CellName> (string, optional)
-dynamic_view <string>    # <dynamic view> (string, optional)
-hold_views <string>      # <active hold view> (string, optional)
-leakage_view <string>    # <leakage view> (string, optional)
-lef_files <string>       # <list of files> (string, optional)
-mmmcFile <string>        # <mmmcFile> (string, optional)
-noTiming                 # <no timing> (bool, optional)
-noTimingGraph            # <no timing graph> (bool, optional)
-setup_views <string>     # <active setup view> (string, optional)
-tag <string>             # <flow tag> (string, optional)