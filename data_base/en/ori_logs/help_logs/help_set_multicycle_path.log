Usage: set_multicycle_path [-help] <number_of_cycles> [-comment <string>]
                           [-fall] [-fall_through <through_list>] [-hold]
                           [-rise] [-rise_through <through_list>] [-setup]
                           [-through <through_list>] [-start  | -end ] [-from <from_list> | -rise_from <from_list> | -fall_from <from_list>] [-to <to_list]> | -rise_to <to_list> | -fall_to <to_list]>]

-help                            # Prints out the command usage
<number_of_cycles>               # Number of cycles allowed for the path
                                 # (int, required)
-comment <string>                # Not supported option (string, optional)
-end                             # Multicycle adjustment is to be applied
                                 # relative to the ending clock edge for the
                                 # path (bool, optional)
-fall                            # Apply the assertion at the falling edge of
                                 # the signal on the path endpoints
                                 # (bool, optional)
-fall_from <from_list>           # List all multicycle paths originating from
                                 # the from_list at falling edge
                                 # (string, optional)
-fall_through <through_list>     # Applies the assertion at the falling edge of
                                 # the signal on the through pins
                                 # (string, optional)
-fall_to <to_list]>              # List all multicycle paths originating from
                                 # the to_list at falling edge (string, optional)
-from <from_list>                # List all multicycle paths originating from
                                 # the from_list (string, optional)
-hold                            # Applies multicycles for hold times only
                                 # (bool, optional)
-rise                            # Applies the assertion at the rising edge of
                                 # the signal on the path endpoints
                                 # (bool, optional)
-rise_from <from_list>           # List all multicycle paths originating from
                                 # the from_list at rising edge (string, optional)
-rise_through <through_list>     # Applies the assertion at the rising edge of
                                 # the signal on the through pins
                                 # (string, optional)
-rise_to <to_list>               # List all multicycle paths originating from
                                 # the to_list at rising edge (string, optional)
-setup                           # Applies multicycles for setup and affects
                                 # the hold check. It does not change the hold
                                 # multiplier (bool, optional)
-start                           # Multicycle adjustment is to be applied
                                 # relative to the starting clock edge for the
                                 # path (bool, optional)
-through <through_list>          # Applies the assertion to both the rising and
                                 # the falling edges (string, optional)
-to <to_list]>                   # List all multicycle paths originating from
                                 # the to_list (string, optional)