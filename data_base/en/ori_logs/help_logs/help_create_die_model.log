Usage: create_die_model [-help] [-accuracy {hd xd}]
                        [-disable_global_node_zero {true false}]
                        [-disable_isrc_node_zero {true false}] [-effective_rc]
                        [-effective_rc_deck]
                        [-enable_package_pin_map {true false}]
                        [-enable_reference_node] [-enable_xp {true false}]
                        [-generate_SIPI_port_definition_file {true false}]
                        [-generate_demand_current_model {true false}]
                        [-grid_reduction_cut_layer <string>]
                        [-ignore_port_grouping_conflict]
                        [-local_reference_ground {true false}]
                        [-max_ports_per_net <integer>] [-multi_die {true false}]
                        [-output_directory <string>]
                        [-port_grouping_by_ploc_files {true false}]
                        [-port_grouping_file <string>]
                        [-port_grouping_tiles_file <string>]
                        [-probing_node_file <string>]
                        [-probing_region_file <string>] [-repeat <float>]
                        -state_directory <string>
                        [-temp_directory_name <string>] [-use_sigrity_repeat] {-rail_analysis_domain <string> | -net <string>}

-help                                      # Prints out the command usage
-accuracy {hd xd}                          # <hd|xd> (enum, optional)
-disable_global_node_zero {true false}     # <true|false> (enum, optional)
-disable_isrc_node_zero {true false}       # <true|false> (enum, optional)
-effective_rc                              # plot Rdie and Cdie
                                           # (bool, optional)
-effective_rc_deck                         # dump SPICE deck for measurement of
                                           # Rdie/Cdie (bool, optional)
-enable_package_pin_map {true false}       # enable the package pin map with
                                           # 6-column format (enum, optional)
-enable_reference_node                     # enable reference node
                                           # (bool, optional)
-enable_xp {true false}                    # <use full distributed partition
                                           # Voltus-XP invocation.>
                                           # (enum, optional)
-generate_SIPI_port_definition_file {true false}
                                           # generate xml format of port
                                           # definition files (enum, optional)
-generate_demand_current_model {true false}
                                           # generate demand current model (enum, optional)
-grid_reduction_cut_layer <string>         # specify the cut layer for die
                                           # model grid reduction
                                           # (string, optional)
-ignore_port_grouping_conflict             # ignore the conflict of port
                                           # grouping between different
                                           # scenarios. (bool, optional)
-local_reference_ground {true false}       # <true|false> (enum, optional)
-max_ports_per_net <integer>               # <max number of ports per net>
                                           # (int, optional)
-multi_die {true false}                    # <true|false> (enum, optional)
-net <string>                              # <net name> (string, optional)
-output_directory <string>                 # <die-model output dir>
                                           # (string, optional)
-port_grouping_by_ploc_files {true false}
                                           # load port grouping info that
                                           # defined in PLOC files
                                           # (enum, optional)
-port_grouping_file <string>               # <port grouping file name>
                                           # (string, optional)
-port_grouping_tiles_file <string>         # <port grouping tiles file name>
                                           # (string, optional)
-probing_node_file <string>                # <probing node file name>
                                           # (string, optional)
-probing_region_file <string>              # <probing region file name>
                                           # (string, optional)
-rail_analysis_domain <string>             # <domain name in rail analysis>
                                           # (string, optional)
-repeat <float>                            # <time unit in ns>
                                           # (float, optional, default unit=ns, current unit = ns)
-state_directory <string>                  # <top level state directory>
                                           # (string, required)
-temp_directory_name <string>              # <temporary dir name>
                                           # (string, optional)
-use_sigrity_repeat                        # use sigrity repeat
                                           # (bool, optional)