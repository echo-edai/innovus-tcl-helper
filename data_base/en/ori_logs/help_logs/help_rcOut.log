Usage: rcOut [-help] [-excludeIlm] [-noRes] [-useEEQCellWithLibertyInfo] {{{-spef <string>} [-excNetFile <string> | -net <string> | -netName <string>] } } [-view <string> | -rc_corner <string>] [-cUnit {pF fF}]

-help                               # Prints out the command usage
-cUnit {pF fF}                      # Specifies the unit of capacitance as fF
                                    # or pF in the output SPEF file.
                                    # (enum, optional)
-excNetFile <string>                # Specifies the name of the file that
                                    # contains nets to be excluded from the
                                    # output file (string, optional)
-excludeIlm                         # Writes out only top spef in rc out.
                                    # (bool, optional)
-net <string>                       # Specifies the name of the input file that
                                    # contains the net names to be extracted.
                                    # The default is to Extracts all net names.
                                    # (string, optional)
-netName <string>                   # Specify the name of the net to be written
                                    # in spef file. The default is to write all
                                    # nets. (string, optional)
-noRes                              # Generates a SPEF file without the
                                    # resistance information. The SPEF file
                                    # generated by this parameter can only be
                                    # used to improve the performance of
                                    # third-party simulator tools in early
                                    # stages of the design. (bool, optional)
-rc_corner <string>                 # Specifies the RC corner that is used to
                                    # generate the output SPEF file in the
                                    # multi-corner flow. (string, optional)
-spef <string>                      # Specifies the name of the SPEF output
                                    # file. (string, optional)
-useEEQCellWithLibertyInfo          # Writes EEQ master cell in case EEQ cells
                                    # are present (bool, optional)
-view <string>                      # Specifies that the RC corner associated
                                    # with the specified view is used to
                                    # generate the output SPEF file in the
                                    # multi-corner flow. (string, optional)