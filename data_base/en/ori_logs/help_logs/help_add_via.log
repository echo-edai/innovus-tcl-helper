Usage: add_via [-help] [-net <net>] -pt {x y}
               [-shape {blockring blockagewire blockwire corewire drcfill fillopc fillwire followpin iowire none padring ring stripe}]
               [-shield_net <net>] [-status {routed fixed cover shield}]
               [-user_class <value>] -via <via_def>

-help                                   # Prints out the command usage
-net <net>                              # The name or pointer of the net to
                                        # associate with the via instance. If
                                        # not specified, the via will be
                                        # assigned as a floating fillwire via.
                                        # ((net), optional)
-pt {x y}                               # The placement location (in microns)
                                        # of the via instance. (point, required)
-shape {blockring blockagewire blockwire corewire drcfill fillopc fillwire followpin iowire none padring ring stripe}
                                        # Special route shape (DEF SPECIALNETS
                                        # wiring+ SHAPE) specification. If not
                                        # given, the default is none, unless
                                        # -net is not specified in which case
                                        # the shape will be set to fillwire.
                                        # (enum, optional)
-shield_net <net>                       # The name or pointer of the net to be
                                        # shielded by the via instance. Only
                                        # valid when -status is set to shield.
                                        # ((net), optional)
-status {routed fixed cover shield}     # Special route (DEF SPECIALNETS)
                                        # wiring status. If not specified, the
                                        # status is set to routed.
                                        # (enum, optional)
-user_class <value>                     # User defined string to be added to
                                        # the via instance that is created.
                                        # (string, optional)
-via <via_def>                          # The via-master name or pointer of the
                                        # via master to place.
                                        # ((viaDef), required)