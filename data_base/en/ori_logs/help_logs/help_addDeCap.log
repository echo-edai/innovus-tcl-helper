Usage: addDeCap [-help] [-addFixAttr] [-cells <cellName>] [-effort {low high}]
                [-fromFile <fileName>] [-log <logName>] [-maxNrIter <number>]
                [-prefix <prefixName>] -totCap <totoal_cap_in_fF> [ -noFixDRC ] [-area <llx> <lly> <urx> <ury> | -exclude {{<llx> <lly> <urx> <ury>} ...}] [ -pgNet <netName>]

-help                                      # Prints out the command usage
-addFixAttr                                # make the inserted decap cell fixed
                                           # for placement. (bool, optional)
-area <llx> <lly> <urx> <ury>              # Defines an area within the design
                                           # in which add decoupling
                                           # capacitance. (box, optional)
-cells <cellName>                          # Specifies the cells to use for
                                           # decoupling capacitance insertion.
                                           # (string, optional)
-effort {low high}                         # Specifies the approach for
                                           # inserting decoupling capacitance.
                                           # (enum, optional)
-exclude {{<llx> <lly> <urx> <ury>} {} ...}
                                           # Defines blockage areas within the
                                           # decoupling capacitance cannot be
                                           # inserted. (string, optional)
-fromFile <fileName>                       # Using the info in the specified
                                           # file. (string, optional)
-log <logName>                             # Specifies the output log file
                                           # name. (string, optional)
-maxNrIter <number>                        # define the iteration for inserting
                                           # decap if there's DRC. (int, optional)
-noFixDRC                                  # Disables correction of DRC errors.
                                           # (bool, optional)
-pgNet <netName>                           # Adds decap cells on the specified
                                           # power rail (string, optional)
-prefix <prefixName>                       # Defines the prefix to use for the
                                           # decoupling capacitance cells.
                                           # (string, optional)
-totCap <totoal_cap_in_fF>                 # Specifies the total decpupling
                                           # capacitance (in fF).
                                           # (float, required)