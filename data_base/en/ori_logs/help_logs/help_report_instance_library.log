Usage: report_instance_library [-help] [-file <string>] [ -view <string> | -delay_corner <string> ] [  -instance <string> | -power_domain <string>   ] [ -early  | -late  ]

-help                      # Prints out the command usage
-delay_corner <string>     # Select the instance library from the specified
                           # delay corner. (string, optional)
-early                     # Select instance(s) from early libset.
                           # (bool, optional)
-file <string>             # Name of the output file. If no file is specified
                           # the report will be printed on stdout.
                           # (string, optional)
-instance <string>         # The instance(s) for which the report is to be
                           # printed. If no instance is provided the report
                           # will print the information for all the instances.
                           # The value of instance can be a list of regular
                           # expressions. (string, optional)
-late                      # Select instance(s) from late libset.
                           # (bool, optional)
-power_domain <string>     # The power domain from which instances are to be
                           # selected. (string, optional)
-view <string>             # Select the instance library from the specified
                           # view. (string, optional)