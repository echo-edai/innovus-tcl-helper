Usage: reportUnalignedNets [-help] [-alignDistance <float>]
                           [-alignFeedThruPins]
                           [-considerMacroPinWithinDistance <float>]
                           [-ignoreLength <float>] [-noHighlight]
                           [-reportAllWithinChannelWidth <float>]
                           [-rptFile <string>] [-statistics] [-steinerBox]
                           [-verbose] [[ -ptnToPtn {aligned unaligned layerMismatch samePtn nonNbr multiFanout all unplaced none} ] [ -topToPtn {aligned unaligned layerMismatch samePtn nonNbr multiFanout all unplaced none} ]] [ -pin_file <fileName> | -exclude_pin_file <fileName> ]

-help                                    # Prints out the command usage
-alignDistance <float>                   # assumes pins are aligned upto
                                         # specified distance (in microns)
                                         # eventhough they are not phycially
                                         # aligned. (float, optional)
-alignFeedThruPins                       # Report deviation of partition pins
                                         # from chain's source-target box.
                                         # (bool, optional)
-considerMacroPinWithinDistance <float>  # Reports nets connected to macro-pin
                                         # which are within specified distance
                                         # from nearest partition boundary.
                                         # (float, optional)
-exclude_pin_file <fileName>             # Specify pin-list to be excluded for
                                         # partition in a file (string, optional)
-ignoreLength <float>                    # Does not report nets with length
                                         # more than ignoreLength.
                                         # (float, optional)
-noHighlight                             # Disables the highlight capability.
                                         # (bool, optional)
-pin_file <fileName>                     # Specify pin-list for partition in a
                                         # file (string, optional)
-ptnToPtn {aligned unaligned layerMismatch samePtn nonNbr multiFanout all unplaced none}
                                         # Reports nets that have 2 pins on 2
                                         # different partitions and/or clones
                                         # and  are not connected to top level
                                         # hard-macro,std cell,or I/O.
                                         # (enum_list, optional)
-reportAllWithinChannelWidth <float>     # Report all unaligned nets within
                                         # specified channel width
                                         # (float, optional)
-rptFile <string>                        # Specifies an output report file.
                                         # (string, optional)
-statistics                              # Report average misalignment with
                                         # standard deviation and layer
                                         # difference count for aligned,
                                         # layerMismatch and unaligned ptnToPtn
                                         # 2-pin nets of partitions.
                                         # (bool, optional)
-steinerBox                              # Report deviation of partition pins
                                         # from connectivity box of the
                                         # partition. (bool, optional)
-topToPtn {aligned unaligned layerMismatch samePtn nonNbr multiFanout all unplaced none}
                                         # Reports nets that have one pin
                                         # connected to top level hard-macro or
                                         # I/O and other pin connected to a
                                         # partition or a clone.
                                         # (enum_list, optional)
-verbose                                 # Reports all categories in log file.
                                         # (bool, optional)