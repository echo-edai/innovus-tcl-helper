Usage: read_design_stack_config [-help] [-avoid_floorplan_change]
                                [-chipName <string>]
                                [-manufacturing_grid <float>]
                                [-power_config_file <string>]
                                [-topNetlist <string>] [ -xml <string>]

-help                           # Prints out the command usage
-avoid_floorplan_change         # read_design_stack_config is called inside
                                # restoreDesign, floorplan and die inst will
                                # not be created by this command. (bool, optional)
-chipName <string>              # name used when current die is instantiated
                                # (string, optional)
-manufacturing_grid <float>     # Specify manufacturing grid (float, optional)
-power_config_file <string>     # Power Connection file name.
                                # (string, optional)
-topNetlist <string>            # Top level netlist verilog file name.
                                # (string, optional)
-xml <string>                   # Stacked Die file name. (string, optional)