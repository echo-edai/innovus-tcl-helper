Usage: createBusNetGroup [-help] [-considerClone] [-createBusSinkGroup]
                         [-dontCommit] [-file <string>]
                         [-ignoreBusSize <integer>] [-ignoreConnectivity]
                         [-ignoreMultiPartitionPinNet]
                         [-netGroupOptionsList <string>] [-overwrite]
                         [-prefix <string>] [-reverseOrder] [-useShortName] [ -bus <string> | -all  ] [ -forTopOnly  | -forPartitionOnly  ] [ -includeMacro  | -forPartitionOnly  ] [ -checkOnly  | {[-bus <string>] [-all ]} ]

-help                             # Prints out the command usage
-all                              # To create net-group connected to design
                                  # partition for all the buses.  (bool, optional)
-bus <string>                     # Create net-group connected to different
                                  # partitions only for the mentioned bus.
                                  # (string, optional)
-checkOnly                        # Checks and reports all the buses present in
                                  # the design. (bool, optional)
-considerClone                    # Make net-group for clone connected bus
                                  # (bool, optional)
-createBusSinkGroup               # Create BusSinkGroup instead of net-group
                                  # (bool, optional)
-dontCommit                       # Creates net-groups and store in file
                                  # instead of creating in DB (bool, optional)
-file <string>                    # Specifies the name of the file in which the
                                  # defined groups are stored. (string, optional)
-forPartitionOnly                 # Net-group connected to ptn-only
                                  # (bool, optional)
-forTopOnly                       # Net-group connected to top-only
                                  # (bool, optional)
-ignoreBusSize <integer>          # Ingnore bus of size smaller than equal to
                                  # size specified. (int, optional)
-ignoreConnectivity               # To ignore ptn connectivity and create
                                  # netgroup for whole bus. (bool, optional)
-ignoreMultiPartitionPinNet       # Ignore buses connected to multiple
                                  # ptn/clones (bool, optional)
-includeMacro                     # Make bus-net-group which has connection
                                  # with macro (bool, optional)
-netGroupOptionsList <string>     # To add attribute to created-net-groups like
                                  # optimizeOrder/spread etc. (string, optional)
-overwrite                        # Overwrites already created net-group by
                                  # deleting current netgroup element from
                                  # earlier association (bool, optional)
-prefix <string>                  # Add specified prefix to name of generated
                                  # net-groups. (string, optional)
-reverseOrder                     # To reverse the bus-bit in the created
                                  # net-groups.  (bool, optional)
-useShortName                     # Keep net-group names simple
                                  # (bool, optional)