Usage: getDensityMapMode [-help] [-gridInMicron] [-gridInRow] [-ignoreBlock]
                         [-ignoreFiller] [-threshold] [-quiet] [-nonDefault]

-help                      # Prints out the command usage
-gridInMicron              # specify the value (in micron) of side of square
                           # grid for density calculations.
                           # (float, default=50, min=0, max=1000)
-gridInRow                 # specify the value (in row-height) of side of
                           # square grid for density calculations.
                           # (int, default=10, min=1, max=100)
-ignoreBlock               # (bool, default=false)
-ignoreFiller              # (bool, default=false)
-threshold                 # threshold value over which the densities must be
                           # reported. (float, default=0.75, min=0, max=2)
-quiet                     # Displays the current settings in Tcl list format only
-nonDefault                # Displays the current settings which are not default settings