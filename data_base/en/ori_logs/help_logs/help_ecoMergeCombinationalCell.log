Usage: ecoMergeCombinationalCell [-help] [-area] [-cell <targetCellNameList>]
                                 [-force] [-power] {-preCTS  | -postCTS } {-inst <comboInstName> | -listFile <instNamesFile> | -all }

-help                         # Prints out the command usage
-all                          # Merge all single-bit cell instances to
                              # multi-bit cell instances. Default is false.
                              # (bool, optional)
-area                         # Merge the combinational cell for area purpose.
                              # Default is false. (bool, optional)
-cell <targetCellNameList>    # The names of the merge target cells.
                              # (string, optional)
-force                        # Force to merge the combinational cell
                              # regardless timing gains. Default is false.
                              # (bool, optional)
-inst <comboInstName>         # The names of the combinational instance to be
                              # merged. (string, optional)
-listFile <instNamesFile>     # The file containing names of single bit
                              # instances to merge. Specify one instance on one
                              # line. Comment with Instance name should not
                              # contain spaces or backslashes. (string, optional)
-postCTS                      # Set -postCTS if design stage is postCTS.
                              # (bool, optional)
-power                        # Merge the combinational cell for power purpose.
                              # Default is false. (bool, optional)
-preCTS                       # Set -preCTS if design stage is preCTS.
                              # (bool, optional)