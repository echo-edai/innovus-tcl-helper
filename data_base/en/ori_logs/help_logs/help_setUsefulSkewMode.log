Usage: setUsefulSkewMode [-help] [-reset]
                         [-opt_skew_apply_delay_limits_to_full_flow {true|false}]
                         [-opt_skew_delay_pre_cts {true|false}]
                         [-opt_skew_macro_only {true|false}]
                         [-opt_skew_max_allowed_delay <value>]
                         [-opt_skew_min_allowed_delay <value>]
                         [-opt_skew_no_boundary {true|false}]

-help                                     # Prints out the command usage
-reset                                    # Resets all or specified options to default value
-opt_skew_apply_delay_limits_to_full_flow {true|false}
                                          # delay limits apply to whole flow (bool, default=false)
-opt_skew_delay_pre_cts {true|false}      # delaying mode in preCTS
                                          # (bool, default=true)
-opt_skew_macro_only {true|false}         # skew hard blocks
                                          # (bool, default=false)
-opt_skew_max_allowed_delay <value>       # max allowed skewing delay, unit is
                                          # 'ns'
                                          # (float, default=1, min=0, max=1000)
-opt_skew_min_allowed_delay <value>       # min allowed skewing delay, unit is
                                          # 'ns'
                                          # (float, default=0, min=0, max=1000)
-opt_skew_no_boundary {true|false}        # consider boundary sequential
                                          # elements (bool, default=false)