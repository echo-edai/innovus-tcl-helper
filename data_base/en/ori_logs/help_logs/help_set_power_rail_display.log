                              [-thermal_layer_name <thermal_layer>] [-tile_count_x <interger> -tile_count_y <interger>] [-tile_size_x <float> -tile_size_y <float>]

-help                                    # Prints out the command usage
-customized_range <range>                # set customized range for basic mode
                                         # (string, optional)
-enable_auto_apply <true|false>          # enable/disable auto apply for
                                         # colorscale (bool, optional)
-enable_percentage_range <true|false>    # enable percentage range. Default is
                                         # false. (bool, optional)
-enable_result_browser <true|false>      # enable result browser. Default is
                                         # false. (bool, optional)
-enable_rlrp <true|false>                # enable rlrp path display. Default is
                                         # false. (bool, optional)
-enable_voltage_sources <true|false>     # enable voltage sources. Default is
                                         # false. (bool, optional)
-filter_color <on|off|color name>        # show filtered out resistors with
                                         # color or off. Reserved and no
                                         # implemntation (string, optional)
-filter_max <filter_max>                 # specifies the max value of color
                                         # scale filter. (float, optional)
-filter_min <filter_min>                 # specifies the min value of color
                                         # scale filter. (float, optional)
-grid <on|off>                           # show grid for vu or vc plot
                                         # (string, optional)
-legend {off ne nw se sw}                # off - turn off the legend 
                                         # ne - north east 
                                         # nw - north west 
                                         # se - south east
                                         # sw - south west (enum, optional)
-plot [none ir tc rc rj jpeak jrms sem_fit sem_rms sem_avg sem_peak sem_ddt rv_sem_rms rv_sem_avg rv_sem_mavg rv_sem_peak unc ivdn ivdd ipc ipceiv isweiv effr thermal tile_thermal cvi1 pi pv pix tot vu ibu vc ibc er rlrp res rv_rms rv_peak rv_avg ivde ip ip_i ip_s ip_l ip_clk ip_tr ipd ipd_i ipd_s ipd_t ipd_l freq slack activity td cap load dd node_effr icm tpd ptpd fit sem_jrms sem_javg sem_jpeak rv_sem_jrms rv_sem_javg rv_sem_jpeak rv_sem_jlpeak rv_sem_jspeak unc_inst unc_pinnodes lunc_inst]
                                         # none - Clear
                                         # ir - IRdrop
                                         # tc - Tap Current
                                         # rc - Resistor Current
                                         # rj - Iavg/Ilimit
                                         # jpeak - Ipeak/Ilimit
                                         # jrms - Irms/Ilimit
                                         # sem_fit - Failure In Time
                                         # sem_rms - RMS Current
                                         # sem_avg - AVG Current
                                         # sem_peak - PEAK Current
                                         # sem_ddt - Detailed Delta
                                         # Tempertaure
                                         # rv_sem_rms - RV RMS
                                         # Current
                                         # rv_sem_avg - RV AVG
                                         # Current
                                         # rv_sem_mavg - RV MAX AVG
                                         # Current
                                         # rv_sem_peak - RV PEAK Current
                                         # unc - unconnected power-grid
                                         # sections
                                         # ivdn - net based voltage drop
                                         # ivdd - domain based drop
                                         # ipc - Instance Peak Current
                                         # ipceiv - EIV Window instance peak
                                         # current
                                         # isweiv - EIV Window instance switch
                                         # status
                                         # effr - effective resistance 
                                         # thermal - Instance thermal 
                                         # tile_thermal - Tile Thermal 
                                         # cvi1 - Customized file 1 
                                         # pi - power-gate current I/Idsat
                                         # pv - power-gate voltage drop 
                                         # pix - power-gate current 
                                         # tot - turn-on time
                                         # vu - voltage drop across package
                                         # ibu - inter die bump vu
                                         # er - electromigration risk
                                         # rlrp - instance resistance of LRP
                                         # 
                                         # res - Grid Resistance
                                         # rv_rms - RV RMS
                                         # rv_peak - RV PEAK
                                         # rv_avg - RV AVG
                                         # ivde - Instance voltage drop in
                                         # ESD
                                         # ip - instance total power
                                         # ip_i - instance internal power
                                         # ip_s - instance switching power
                                         # ip_l - instance leakage power
                                         # ipd - instance total power
                                         # density
                                         # ipd_i - instance internal power
                                         # density
                                         # ipd_s - instance switching power
                                         # density
                                         # ipd_t - instance total power
                                         # density
                                         # ipd_l - instance leakage power
                                         # density
                                         # freq - fastest frequency domain for
                                         # instance
                                         # ip_tr - instance toggle rate
                                         # slack - worst slack for
                                         # instance
                                         # activity - instance activity
                                         # td - transition density for
                                         # instance
                                         # cap - power-grid capacitance
                                         # load - output loading capacitance
                                         # for instance
                                         # dd - decap density
                                         # node_effr - noded based reff
                                         # icm - instance current movie
                                         # tpd - tile power density
                                         # ptpd - profiling tile power
                                         # density
                                         # fit - failures in time
                                         # sem_jrms - RMS I/Ilimit
                                         # sem_javg - AVG I/Ilimit
                                         # sem_jpeak - PEAK
                                         # I/Ilimit
                                         # rv_sem_jrms - RV RMS
                                         # I/Ilimit
                                         # rv_sem_javg - RV AVG
                                         # I/Ilimit
                                         # rv_sem_jpeak - RV PEAK
                                         # I/Ilimit
                                         # rv_sem_jlpeak - RV Long PEAK
                                         # I/Ilimit
                                         # rv_sem_jspeak - RV Short PEAK
                                         # I/Ilimit
                                         # unc_inst - Unconnected Inst
                                         # Pins
                                         # unc_pinnodes -
                                         # Unconnected/WeaklyConnected Pin
                                         # Nodes
                                         # lunc_inst - Logically Unconnected
                                         # Inst (enum, optional)
-range_max <max>                         # specifies the max value of color
                                         # scale. (float, optional)
-range_min <min>                         # specifies the max value of color
                                         # scale. (float, optional)
-reset_color_scale                       # reset color scale (bool, optional)
-thermal_layer_name <thermal_layer>      # set current thermal_layer_name for
                                         # thermal plot (string, optional)
-tile_count_x <interger>                 # set x tile count of tpd plot.
                                         # (int, optional)
-tile_count_y <interger>                 # set y tile count of tpd plot.
                                         # (int, optional)
-tile_size_x <float>                     # set x tile size of tpd plot.
