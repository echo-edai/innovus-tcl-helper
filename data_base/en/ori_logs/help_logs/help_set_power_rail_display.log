                              [-filter_min <filter_min>] [-grid <on|off>]
                              [-legend {off ne nw se sw}]
                              [-plot [none ir tc rc rj jpeak jrms sem_fit sem_rms sem_avg sem_peak sem_ddt rv_sem_rms rv_sem_avg rv_sem_mavg rv_sem_peak unc ivdn ivdd ipc ipceiv isweiv effr thermal tile_thermal cvi1 pi pv pix tot vu ibu vc ibc er rlrp res rv_rms rv_peak rv_avg ivde ip ip_i ip_s ip_l ip_clk ip_tr ipd ipd_i ipd_s ipd_t ipd_l freq slack activity td cap load dd node_effr icm tpd ptpd fit sem_jrms sem_javg sem_jpeak rv_sem_jrms rv_sem_javg rv_sem_jpeak rv_sem_jlpeak rv_sem_jspeak unc_inst unc_pinnodes lunc_inst]]
