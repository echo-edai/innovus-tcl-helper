Usage: report_lib_arcs [-help] -arc <string> [-fall] [-nldm] [-quiet] [-rise] [-lvf  [-early ]] [-lvf  [-late ]] [-moments  [-mean_shift ]] [-moments  [-std_dev ]] [-moments  [-skewness ]] [-input_net_transition <float> | -constrained_pin_transition <float>] [-input_net_transition <float> | -related_pin_transition <float>] [-total_output_net_capacitance <float> | -constrained_pin_transition <float>] [-total_output_net_capacitance <float> | -related_pin_transition <float>] [-constrained_pin_transition <float> | -delay ] [-constrained_pin_transition <float> | -transition ] [-related_pin_transition <float> | -delay ] [-related_pin_transition <float> | -transition ]

-help                                     # Prints out the command usage
-arc <string>                             # The arc(s) for which the report is
                                          # to be printed. (string, required)
-constrained_pin_transition <float>       # Specifies the constrained_pin slew
                                          # (valid for constraint arcs) at
                                          # which the parameters need to be
                                          # reported. The slew is to be given
                                          # in the units specified by
                                          # 'get_time_unit'. (float, optional)
-delay                                    # Specifies if delay is to be
                                          # reported. (bool, optional)
-early                                    # Specifies if early LVF data is to
                                          # be reported. This option can only
                                          # be used in conjuction with '-lvf'
                                          # option. (bool, optional)
-fall                                     # Specifies if details of fall tables
                                          # are to be reported. (bool, optional)
-input_net_transition <float>             # Specifies the slew at which the
                                          # parameters need to be reported. The
                                          # slew is to be given in the units
                                          # specified by 'get_time_unit'.
                                          # (float, optional)
-late                                     # Specifies if late LVF data is to be
                                          # reported. This option can only be
                                          # used in conjuction with '-lvf'
                                          # option. (bool, optional)
-lvf                                      # Specifies if LVF data is to be
                                          # reported. (bool, optional)
-mean_shift                               # Specifies if mean_shift data is to
                                          # be reported. This option can only
                                          # be used in conjuction with
                                          # '-moments' option. (bool, optional)
-moments                                  # Specifies if moments data is to be
                                          # reported. (bool, optional)
-nldm                                     # Specifies if NLDM data is to be
                                          # reported. (bool, optional)
-quiet                                    # To disable output on screen.
                                          # (bool, optional)
-related_pin_transition <float>           # Specifies the related_pin slew
                                          # (valid for constraint arcs) at
                                          # which the parameters need to be
                                          # reported. The slew is to be given
                                          # in the units specified by
                                          # 'get_time_unit'. (float, optional)
-rise                                     # Specifies if details of rise tables
                                          # are to be reported. (bool, optional)
-skewness                                 # Specifies if skewness data is to be
                                          # reported. This option can only be
                                          # used in conjuction with '-moments'
                                          # option. (bool, optional)
-std_dev                                  # Specifies if std_dev data is to be
                                          # reported. This option can only be
                                          # used in conjuction with '-moments'
                                          # option. (bool, optional)
-total_output_net_capacitance <float>     # Specifies the load at which the
                                          # parameters need to be reported. The
                                          # load is to be given in the units
                                          # specified by
                                          # 'get_capacitance_unit'.
                                          # (float, optional)
-transition                               # Specifies if output slew is to be
                                          # reported. (bool, optional)