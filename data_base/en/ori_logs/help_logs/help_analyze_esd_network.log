Usage: analyze_esd_network [-help] -ta  | -task_assistant  | { <name> -type {domain net} -config_file <string> [-output <string>] [-use_power_pad {true false}] [-clamp_lowest_layer_taps {true false}] [-remove_layers_below <string>]  [-clamp_pin_short_file <string>] }

-help                                     # Prints out the command usage
<name>                                    # <domain or net name>
                                          # (string, required)
-clamp_lowest_layer_taps {true false}     # keep only lowest layer of clamp
                                          # taps for effective resistance
                                          # analysis (enum, optional)
-clamp_pin_short_file <string>            # clamps cell/inst layers to be
                                          # shorted for effective resistance
                                          # analysis (string, optional)
-config_file <string>                     # <configuration file of the run>
                                          # (string, required)
-output <string>                          # <result dir> (string, optional)
-remove_layers_below <string>             # Layer below which all layers are
                                          # dropped from analysis
                                          # (string, optional)
-ta                                       # task assistant using cadence help
                                          # api (bool, optional)
-task_assistant                           # task assistant using cadence help
                                          # api (bool, optional)
-type {domain net}                        # <type: domain | net>
                                          # (enum, required)
-use_power_pad {true false}               # specify if power pad file is to be
                                          # used (enum, optional)