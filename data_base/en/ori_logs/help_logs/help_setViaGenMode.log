Usage: setViaGenMode [-help] [-reset] [-accuracy_effort {low|medium|high}]
                     [-add_pin_to_pin_via {true|false}]
                     [-align_merged_stack_via_metals {true|false}]
                     [-allow_via_expansion {true|false}]
                     [-allow_wire_shape_change {true|false}]
                     [-area_only {true|false}]
                     [-bot_enclosure {overhang1 overhang2}]
                     [-create_double_row_cut_via {0|1|2}]
                     [-create_max_row_cut_via {true|false}]
                     [-cut_spacing {x_spacing y_spacing}]
                     [-cutclass_preference <default|{[square] [bar] [large]}|<list of cut class names>|<file name>>]
                     [-disable_via_merging {true|false}]
                     [-extend_out_wire_end {true|false}]
                     [-full_cut_via_only {true|false}]
                     [-genvia_naming_prefix <viaNamePrefix>]
                     [-hookup_contact_max <min max>]
                     [-hookup_contact_pg_track <start pitch>]
                     [-hookup_preplace_fix <0|1>]
                     [-hookup_rail_pair {true|false}]
                     [-hookup_via_distance <distance1 distance2 boundary_spacing>]
                     [-hookup_via_fixed_grid {true|false}]
                     [-hookup_via_min_distance <distance>]
                     [-hookup_via_style {none|loose|compact|moderate}]
                     [-hookup_via_viarule {filler {default |{list_of_via rule/cell_names }} ...}]
                     [-hookup_virtual_trim_grid {default |{-layer -mask1 {-pitch -core_offset}}...}]
                     [-ignore_design_boundary {true|false}]
                     [-ignore_DRC {true|false}]
                     [-ignore_viarule_enclosure {true|false}]
                     [-inherit_wire_status {true|false}]
                     [-invoke_verifyGeometry {true|false}]
                     [-keep_existing_via {0|1|2}] [-keep_fixed_via {true|false}]
                     [-mincut_preference <value>]
                     [-optimize_cross_via {true|false}]
                     [-optimize_via_on_routing_track {true|false}]
                     [-parameterized_via_only {auto|true|false}]
                     [-partial_overlap_threshold <threshold>]
                     [-preferred_vias_only {use_lef|open|keep}]
                     [-reference_boundary {design|core}]
                     [-respect_signal_routes {0|1|2}]
                     [-respect_stdcell_geometry {true|false}]
                     [-respect_wire_ndr {true|false}]
                     [-set_via_expansion_dir {auto|horizontal|vertical}]
                     [-snap_via_center_to_grid {layer1 {{none | grid | half_grid | either} [hard]} layer2 {{none | grid | half_grid | either} [hard]} ...}]
                     [-split_long_via_global_grid <x_offset x_pitch x_length_threshold x_length_multiplier y_offset y_pitch y_length_threshold y_length_multiplier>]
                     [-symmetrical_via_only {auto|true|false}]
                     [-top_enclosure {overhang1 overhang2}]
                     [-use_track_offset {true|false}]
                     [-use_trim_metal_enclosure {true|false}]
                     [-viarule_preference <default|predefined|generated|<list of via rule/cell names>|<file name>>]

-help                                     # Prints out the command usage
-reset                                    # Resets all or specified options to default value
-accuracy_effort {low|medium|high}        # Specifies viagen effort to generate
                                          # vias.
                                          # (enums={low medium high}, default=high)
-add_pin_to_pin_via {true|false}          # Inserts vias to connect pins
                                          # between cover macros
                                          # (bool, default=false)
-align_merged_stack_via_metals {true|false}
                                          # Aligns merged stack vias (bool, default=false)
-allow_via_expansion {true|false}         # Allows via expansion to meet LEF
                                          # rules (bool, default=true)
-allow_wire_shape_change {true|false}     # Allows via to change the metal
                                          # shape of existing wire
                                          # (bool, default=true)
-area_only {true|false}                   # adds via only within the specified
                                          # area (bool, default=false)
-bot_enclosure {overhang1 overhang2}      # Customize bot enclosure
                                          # (string, default="")
-create_double_row_cut_via {0|1|2}        # Expands vias to have an additional
                                          # cut than original for one-row or
                                          # one-column vias if possible
                                          # (enums={0 1 2}, default=0)
-create_max_row_cut_via {true|false}      # Creates max rows of via cuts
                                          # (bool, default=false)
-cut_spacing {x_spacing y_spacing}        # Customize cut spacing
                                          # (string, default="")
-cutclass_preference <default|{[square] [bar] [large]}|<list of cut class names>|<file name>>
                                          # Specifies via cut class preference (string, default=default)
-disable_via_merging {true|false}         # Disables via merging
                                          # (bool, default=false)
-extend_out_wire_end {true|false}         # Extends via outside of existing
                                          # wires end (bool, default=true)
-full_cut_via_only {true|false}           # allows to create full cut via only
                                          # (bool, default=false)
-genvia_naming_prefix <viaNamePrefix>     # Specifies prefix name for all vias
                                          # (string, default="")
-hookup_contact_max <min max>             # Sets the max distance to create
                                          # hookup via from contact, and the
                                          # max distance between two hookup via
                                          # on a continuous M0 PG pin.
                                          # (string, default=0, 0)
-hookup_contact_pg_track <start pitch>    # Sets start point and the pitch of
                                          # PG track used by hookup contact.
                                          # (string, default=0, 0)
-hookup_preplace_fix <0|1>                # Enhance hookup via generation
                                          # runtime (int, default=0)
-hookup_rail_pair {true|false}            # Create hookup vias over pairing
                                          # followpins (bool, default=false)
-hookup_via_distance <distance1 distance2 boundary_spacing>
                                          # Sets via hookup distance and
                                          # boundary spacing
                                          # (string, default=4pitch 4pitch 0)
-hookup_via_fixed_grid {true|false}       # Specifies to add hookup via over
                                          # the fixed Grid. (bool, default=false)
-hookup_via_min_distance <distance>       # min distance between two pg vias
                                          # (string, default=min)
-hookup_via_style {none|loose|compact|moderate}
                                          # Sets via hookup style (enums={none loose compact moderate}, default=none)
-hookup_via_viarule {filler {default |{list_of_via rule/cell_names }} ...}
                                          # Specifies the viarule used in
                                          # specified area (string, default="")
-hookup_virtual_trim_grid {default |{-layer -mask1 {-pitch -core_offset}}...}
                                          # Specifies the virtual trim grid for
                                          # pg hookup (string, default="")
-ignore_design_boundary {true|false}      # Allow vias to be on design boundary
                                          # (bool, default=false)
-ignore_DRC {true|false}                  # Ignores DRC (bool, default=false)
-ignore_viarule_enclosure {true|false}    # Ignores enclosures defined in
                                          # VIARULE GENERATE (bool, default=true)
-inherit_wire_status {true|false}         # Inherits wire status
                                          # (bool, default=false)
-invoke_verifyGeometry {true|false}       # Invokes verify_drc
                                          # (bool, default=false)
-keep_existing_via {0|1|2}                # Keeps existing vias
                                          # (enums={0 1 2}, default=0)
-keep_fixed_via {true|false}              # Keeps fixed vias not modifiable
                                          # (bool, default=true)
-mincut_preference <value>                # Specifies min cut preference
                                          # (int, default=1)
-optimize_cross_via {true|false}          # Controls the creation of additional
                                          # via cuts (bool, default=false)
-optimize_via_on_routing_track {true|false}
                                          # Frees up via tracks (bool, default=false)
-parameterized_via_only {auto|true|false}
                                          # generate parameterized vias only,
                                          # auto sets true for OA flow, false
                                          # for non-OA flow.
                                          # (enums={auto true false}, default=auto)
-partial_overlap_threshold <threshold>    # Specifies ratio threshold of via
                                          # creation on partial overlap wires
                                          # (float, default=0)
-preferred_vias_only {use_lef|open|keep}
                                          # Generate only vias set in
                                          # -viarule_preference
                                          # (enums={use_lef open keep}, default=use_lef)
-reference_boundary {design|core}         # Sets reference boundary
                                          # (enums={design core}, default=design)
-respect_signal_routes {0|1|2}            # Honors pre-existing signal routes
                                          # (enums={0 1 2}, default=0)
-respect_stdcell_geometry {true|false}    # Respects all standard cell patterns
                                          # (bool, default=false)
-respect_wire_ndr {true|false}            # Control whether viagen support ndr
                                          # rules (bool, default=false)
-set_via_expansion_dir {auto|horizontal|vertical}
                                          # Sets via expansion direction (enums={auto horizontal vertical}, default=auto)
-snap_via_center_to_grid {layer1 {{none | grid | half_grid | either} [hard]} layer2 {{none | grid | half_grid | either} [hard]} ...}
                                          # Specifies the via center alignment
                                          # style per routing layer
                                          # (string, default="")
-split_long_via_global_grid <x_offset x_pitch x_length_threshold x_length_multiplier y_offset y_pitch y_length_threshold y_length_multiplier>
                                          # Controls global grids so vias on
                                          # them are in line
                                          # (string, default=0 0 0 0 0 0 0 0)
-symmetrical_via_only {auto|true|false}   # adds symmetrical via only, auto
                                          # sets true for OA flow, false for
                                          # non-OA flow.
                                          # (enums={auto true false}, default=auto)
-top_enclosure {overhang1 overhang2}      # Customize top enclosure
                                          # (string, default="")
-use_track_offset {true|false}            # Uses track offset
                                          # (bool, default=false)
-use_trim_metal_enclosure {true|false}    # Force tool to use enclosures with
                                          # trim layer (bool, default=false)
-viarule_preference <default|predefined|generated|<list of via rule/cell names>|<file name>>
                                          # Specifies via rule preference (string, default=default)