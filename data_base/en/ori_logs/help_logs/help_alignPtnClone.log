Usage: alignPtnClone [-help] [<ptnName>] [-outFile <string>] [-checkOnly | -snapAllCorners ] [[-stripeOffset ] | [[-pgHGrid ] [-pgVGrid ] [-pgLayer {layeridList}] [-updateUserGrid ] [-snapAllCorners ] [-skipFinFETGrid ] [-includeStdCellPinLayers {layeridList}]] | [[-symmetryPatternReference <string> [-symmetryPatternTarget <string> [ [-targetOrientation {R0 R90 R180 R270 MX MX90 MY MY90}] [-targetOrigin {x y}] ]]]] | [-symmetricOrientation ]] [-pgLayer {layeridList} [-pgNet <pgNetName> | -pgCenterLine <float>]] [-pgPitch <float> [-pgCenterLine <float>]]

-help                                      # Prints out the command usage
<ptnName>                                  # Specifies name of the partition.
                                           # If not specified, the command is
                                           # run on all partitions
                                           # (string, optional)
-checkOnly                                 # Specifies that the design should
                                           # not be modified. When enabled, it
                                           # only reports messages.
                                           # (bool, optional)
-includeStdCellPinLayers {layeridList}     # Specifies layers of the standard
                                           # cell pins. (string, optional)
-outFile <string>                          # Specifies the name of the output
                                           # file for additional information.
                                           # (string, optional)
-pgCenterLine <float>                      # Specifies center-line of the first
                                           # virtual symmetric P/G stripe (in
                                           # microns). This option can be
                                           # repeated. (float, optional)
-pgHGrid                                   # Provide information about
                                           # symmetric horizontal P/G grid
                                           # (-pgLayer, -pgNet, -pgPitch and
                                           # -pgCenterLine). (bool, optional)
-pgLayer {layeridList}                     # Specifies layer(s) for the
                                           # symmetric P/G stripe. This option
                                           # can be repeated. (string, optional)
-pgNet <pgNetName>                         # Specifies name of the symmetric
                                           # P/G stripe net. This option can be
                                           # repeated. (string, optional)
-pgPitch <float>                           # Specifies pitch of the P/G
                                           # symmetric stripe (in microns).
                                           # This option can be repeated.
                                           # (float, optional)
-pgVGrid                                   # Provide information about
                                           # symmetric vertical P/G grid
                                           # (-pgLayer, -pgNet, -pgPitch and
                                           # -pgCenterLine). (bool, optional)
-skipFinFETGrid                            # Disables alignment with FinFet
                                           # grid. (bool, optional)
-snapAllCorners                            # Snaps all corners of master and
                                           # its clone partition to the user
                                           # grid. (bool, optional)
-stripeOffset                              # For backward compatibility and to
                                           # enable private switch -track,
                                           # -layer, -snap and -skip_row
                                           # (bool, optional)
-symmetricOrientation                      # Find correct symmetric orientation
                                           # of clones. (bool, optional)
-symmetryPatternReference <string>         # Specifies name of the partitions
                                           # as reference for symmetry pattern.
                                           # (string, optional)
-symmetryPatternTarget <string>            # Specifies name of the partitions
                                           # as target for symmetry pattern.
                                           # (string, optional)
-targetOrientation {R0 R90 R180 R270 MX MX90 MY MY90}
                                           # Specifies new orientation of the
                                           # target partition (enum, optional)
-targetOrigin {x y}                        # Specifies new origin of the target
                                           # partition (point, optional)
-updateUserGrid                            # Updates the user grid with the new
                                           # values. (bool, optional)