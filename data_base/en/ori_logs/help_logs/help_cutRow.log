Usage: cutRow [-help] [-keepCell] [-site <name>] [-area box | -object <string> | -selected | -fromIo {left bottom right top} ] [[-halo <float>] | [[-leftGap <float>] [-rightGap <float>] [-topGap <float>] [-bottomGap <float>]]]

-help                               # Prints out the command usage
-area <box>                         # box in <llx> <lly> <urx> <ury>
                                    # (box, optional)
-bottomGap <float>                  # overhang in addition to cut area
                                    # (float, optional)
-fromIo {left bottom right top}     # cut row away from IO cells
                                    # (box, optional)
-halo <float>                       # overhang in addition to cut area on all 4
                                    # sides (float, optional)
-keepCell                           # donot unplace cells (bool, optional)
-leftGap <float>                    # overhang in addition to cut area
                                    # (float, optional)
-object <string>                    # object id (string, optional)
-rightGap <float>                   # overhang in addition to cut area
                                    # (float, optional)
-selected                           # cut by selected objects (bool, optional)
-site <name>                        # name of site to be cut (string, optional)
-topGap <float>                     # overhang in addition to cut area
                                    # (float, optional)