Usage: create_constraint_mode [-help]
                              [-ilm_sdc_files {file1.sdc file2.sdc ...}]
                              -name <modeName>
                              -sdc_files {file1.sdc file2.sdc ...}
                              [-tcl_vars {{var_name1 value1} {var_name2 value2} {var_name3 value3} ...}]

-help                                    # Prints out the command usage
-ilm_sdc_files {file1.sdc file2.sdc ...}
                                         # Specifies a Tcl list of ILM SDC
                                         # files to be included in the
                                         # constraint mode (string, optional)
-name <modeName>                         # Specifies the name of the constraint
                                         # mode to be created (string, required)
-sdc_files {file1.sdc file2.sdc ...}     # Specifies a Tcl list of SDC files to
                                         # be included in the constraint mode
                                         # (string, required)
-tcl_vars {{var_name1 value1} {var_name2 value2} {var_name3 value3} ...}
                                         # Specifies a list of tcl variables
                                         # and values to be used in the
                                         # constraint mode (string, optional)