Usage: ecoSplitFlop [-help] [-batch] [-force] [-fullSplit] [-legal]
                    [-skipRoute] {-inst <flopInstName | {{Mbff1 flopCell1} {Mbff2 flopCell2}...}> | -listFile <fileName> | -all } {-preCTS | -postCTS | -postRoute } [ -power ]

-help                                 # Prints out the command usage
-all                                  # Split all MBFF instances to SBFF
                                      # instances. Default is false.
                                      # (bool, optional)
-batch                                # Batch split. Default is false.
                                      # (bool, optional)
-force                                # Force to split the flip-flop regardless
                                      # timing gains. Default is false.
                                      # (bool, optional)
-fullSplit                            # set -fullSplit to completely split to
                                      # single bits. (bool, optional)
-inst <flopInstName | {{Mbff1 flopCell1} {Mbff2 flopCell2}...}>
                                      # The names of the flop instance to be
                                      # splitted.
                                      # When the input is a string of MBFF/Cell
                                      # pairs list, it will split the MBFF to
                                      # the specified cell without evaluation
                                      # (supported for full split only).
                                      # (string, required)
-legal                                # To place the split flip-flop at legal
                                      # location. Default is false.
                                      # (bool, optional)
-listFile <fileName>                  # The file containing names of MBFF
                                      # instances to split. Specify one
                                      # instance on one line. Comment with #.
                                      # Instance name should not contain spaces
                                      # or backslashes.
                                      # When specifying one instance and one
                                      # cell on one line, it will split the
                                      # MBFF to the specified cell without
                                      # evaluation (supported for full split
                                      # only). (string, required)
-postCTS                              # Set -postCTS if design stage is
                                      # postCTS. (bool, optional)
-postRoute                            # Set -postRoute if design stage is
                                      # postRoute. (bool, optional)
-power                                # Split the flip-flop for power purpose.
                                      # Default is false. (bool, optional)
-preCTS                               # Set -preCTS if design stage is preCTS.
                                      # (bool, optional)
-skipRoute                            # set -skipRoute if stage is postRoute
                                      # and globalDetailRoute is not necessary
                                      # after split. (bool, optional)