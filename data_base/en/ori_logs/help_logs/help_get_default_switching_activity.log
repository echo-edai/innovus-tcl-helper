Usage: get_default_switching_activity [-help] [-clip_activity_to_domain_freq]
                                      [-clock_gates_enable]
                                      [-clock_gates_output]
                                      [-clock_gates_output_ratio]
                                      [-comb_clockgate_ratio] [-duty]
                                      [-global_activity] [-icg_ratio]
                                      [-input_activity] [-macro_activity]
                                      [-period] [-seq_activity]

-help                               # Prints out the command usage
-clip_activity_to_domain_freq       # domain-based activity clipping
                                    # (bool, optional)
-clock_gates_enable                 # set clock gates enable activity
                                    # (bool, optional)
-clock_gates_output                 # set clock gates output activity
                                    # (bool, optional)
-clock_gates_output_ratio           # set clock gates output ratio
                                    # (bool, optional)
-comb_clockgate_ratio               # set propagation ratio for combinational
                                    # clock gate cell outputs (bool, optional)
-duty                               # Specifies the duty cycle, which is the
                                    # probability that the signal is a logical
                                    # 1. Default : 0.5, (bool, optional)
-global_activity                    # Specifies the average number of times
                                    # that all unset nodes switch in a clock
                                    # cycle. (bool, optional)
-icg_ratio                          # set propagation ratio for integrated
                                    # clock gate cell outputs (bool, optional)
-input_activity                     # Specifies the average number of times
                                    # that a primary input switches in a clock
                                    # cycle. (bool, optional)
-macro_activity                     # set macro activity (bool, optional)
-period                             # Specifies the default operating period
                                    # (1/frequency). (bool, optional)
-seq_activity                       # Specifies the activity of outputs of
                                    # sequential logic. (bool, optional)