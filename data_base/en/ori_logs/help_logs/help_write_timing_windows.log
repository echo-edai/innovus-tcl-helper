Usage: write_timing_windows [-help] <output_file> [-pin]
                            [-ssta_sigma_multiplier <value>] [-view <view_name>]
                            [-voltage_threshold <lower_threshold upper_threshold>] [-power_compatible ]

-help                                   # Prints out the command usage
<output_file>                           # Writes the TWF file to the specified
                                        # file name (string, required)
-pin                                    # Generates a TWF for each pin instead
                                        # of each net (bool, optional)
-power_compatible                       # Generates a Timing Windows File
                                        # suitable for Power Analysis
                                        # (bool, optional)
-ssta_sigma_multiplier <value>          # Specifies a sigma multiplier between
                                        # 0 and 3. The value that you specify
                                        # increases the arrival window by that
                                        # amount (float, optional)
-view <view_name>                       # Generates a TWF for the specified
                                        # multi-mode multi-corner view only
                                        # (string, optional)
-voltage_threshold <lower_threshold upper_threshold>
                                        # Specifies voltage threshold values (string, optional)