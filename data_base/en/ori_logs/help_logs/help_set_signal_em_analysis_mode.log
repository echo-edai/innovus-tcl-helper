                                          # (float, default=1000000)
-net <net_name_list>                      # Specifies whether to check named or
                                          # selected nets (string, default="")
-net_file <list_file>                     # Specifies from file the net to
                                          # check in signalEM analysis
                                          # (string, default="")
-net_freq_file <filename>                 # Specify net freq file for user
                                          # input net frequency.
                                          # (string, default="")
-read_detail_delta_temperature_file <filename>
                                          # Specify detail delta temperature
                                          # file for thermal aware checking.
                                          # (string, default="")
-report <filename>                        # Specifies the report file for the
