                                          # expression. (string, default="")
-minPeakDutyRatio <double>                # Do not check Ipeak for nets with
                                          # duty ratio below <duty_ratio>.
                                          # default = 0.05, range 0.0 to 1.0.
                                          # (float, default=-1, min=0, max=1)
-minPeakFreq <double>                     # Do not check Ipeak for nets with
