                                          # effective_width_from_integration,
                                          # effective_half_peak_width,
                                          # max_equivalent_dc_peak,
                                          # sum_half_peak_width. Default:
                                          # effective_width_from_integration.
                                          # (enums={effective_width_from_integration effective_half_peak_width max_equivalent_dc_peak sum_half_peak_width}, default=effective_width_from_integration)
-ircx_models <filename>                   # Specify ircx model file.
                                          # (string, default="")
-lifetime <double>                        # Specifies the hours of operation
                                          # used to lookup the lifetime scaling
                                          # factor. By default, no scaling is
                                          # done. Unit: hour.
                                          # (float, default=87600)
-method <value>                           # Specifies the current waveform
