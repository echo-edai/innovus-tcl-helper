-help                                     # Prints out the command usage
-reset                                    # Resets all or specified options to default value
-additional_individual_violation_report {true|false}
                                          # Report calculated duty ratio in
                                          # addition with applied duty ratio in
                                          # report file. (bool, default=false)
-avgRecovery <double>                     # override QRC tech em_recover factor
                                          # for all layers used in Iavg limits.
                                          # (float, default=1, min=-1, max=1)
-check_thermal_aware_em {true|false}      # check thermal aware EM
                                          # (bool, default=false)
-current_scale_factor <currentScale>      # Scale Signal EM current, syntax:
                                          # -current_scale_factor { [rms
                                          # <rms_value>] [peak <peak_value>]
                                          # [avg <avg_value>] }
                                          # (string, default="")
-current_scale_table <current_scale_table_file>
                                          # Specifies the layer-based scale
                                          # table for current (string, default="")
-default_freq_for_unconstrained_nets <freq_in_Hz>
                                          # Specifies the frequency for EM
                                          # calculation when a net has no
                                          # defined frequency or a defined
                                          # frequency of 0Hz in the design.
                                          # Unit: Hz. (float, default=1000000)
-delta_T <double>                         # maximum change in temperature
                                          # allowed in units of Celsius.  Used
                                          # in the QRC tech for RMS limits.
                                          # Default=5. (float, default=5)
-delta_T_layer_list <value>               # Specifies layer based delta
                                          # temperature for EM RMS currnet
                                          # limit analysis (string, default="")
-detailed {true|false}                    # Generates a detailed report
                                          # containing information for all
                                          # signal nets, including those
                                          # without violations
                                          # (bool, default=false)
-effort_level {low|medium|high}           # Enum_list legal values are: low,
                                          # medium, high. Default: low.
                                          # (enums={low  medium high}, default=low)
-em_cdf_percentage <float value>          # Specify em cumulative distribution
                                          # factor (cdf) percentage.
                                          # (float, default=1e-09)
-em_limit_scale_factor <limitScale>       # Scale Signal EM limit, syntax:
                                          # -em_limit_scale_factor { [rms
                                          # <rms_value>] [peak <peak_value>]
                                          # [avg <avg_value>] }
                                          # (string, default="")
-em_limit_scale_table <em_limit_scale_table_file>
                                          # Specifies the layer-based scale
                                          # table for em_limit
                                          # (string, default="")
-em_res_width {drawn|silicon}             # Specifies width used to get EM
                                          # limit. enum_list legal values are:
                                          # drawn, silicon. Default: drawn.
                                          # (enums={drawn silicon}, default=drawn)
-em_temperature <double>                  # Specifies the temperature used to
                                          # lookup the temperature scaling
                                          # factor. By default, no scaling is
                                          # done. Unit: Celsius.
                                          # (float, default=-1)
-em_temperature_layer_list <value>        # Specifies layer based EM
                                          # temperature for EM AVG current
                                          # limit analysis (string, default="")
-em_threshold <double>                    # The value is the ratio of signal
                                          # current (avg/peak/rms) to the
                                          # respective EM limit. Default: 1.0.
                                          # (float, default=1)
-enable_seb {true|false}                  # Enable SEB calculation
                                          # (bool, default=false)
-env_temperature <double>                 # environment temperature. Unit:
                                          # Celsius. (float, default=-1)
-error <integer>                          # Specifies the maximam number of
                                          # errors to report. (int, default=10000)
-extraction_tech_file <filename>          # Specify qrcTechFile name.
                                          # (string, default="")
-forceHoldView {true|false}               # Turn this on to force hold view.
                                          # (bool, default=false)
-handle_pin_obs_via {true|false}          # Turn on to handle pin obs via.
                                          # (bool, default=false)
-ict_em_models <filename>                 # Specify ict EM file to provide EM
                                          # rule if EM rule not exists in
