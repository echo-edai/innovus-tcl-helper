Usage: get_verify_drc_mode [-help] [-area] [-check_illegal_trim_shapes]
                           [-check_ndr_spacing] [-check_only] [-check_reverse]
                           [-check_routing_halo] [-check_routing_halo_corner]
                           [-check_same_via_cell] [-check_short_only]
                           [-check_trim_length] [-check_uncolored]
                           [-disable_rules] [-enable_post_passive_fill_check]
                           [-exclude_pg_net] [-ignore_cell_blockage]
                           [-ignore_fill_wire] [-ignore_non_rectangle_shapes]
                           [-ignore_trial_route] [-layer_range] [-limit]
                           [-max_wrong_way_halo] [-report]
                           [-use_min_spacing_on_block_obs]
                           [-quiet] [-nonDefault]

-help                                    # Prints out the command usage
-area                                    # Specifies the coordinates of the
                                         # area to verify (box, default={0 0 0 0})
-check_illegal_trim_shapes               # check illegal trim shapes.
                                         # (bool, default=false)
-check_ndr_spacing                       # Specifies what kind of non-default
                                         # rule spacing to be checked
                                         # (enums={true false auto}, default=auto)
-check_only                              # Specifies what kind of shapes to be
                                         # checked.
                                         # (enums={all regular special selected_net selected cell default}, default=default)
-check_reverse                           # report CONVEXCORNER REVERSE
                                         # violation. (bool, default=false)
-check_routing_halo                      # Check routing halo.
                                         # (bool, default=false)
-check_routing_halo_corner               # Check routing halo in the corner
                                         # (bool, default=false)
-check_same_via_cell                     # Check the cut spacing from the same
                                         # via (bool, default=true)
-check_short_only                        # Exclude all DRC check except short.
                                         # (bool, default=false)
-check_trim_length                       # Consider max length in the trim
                                         # shape layer. (bool, default=false)
-check_uncolored                         # report color change violation when
                                         # the dpt layer shape is free color.
                                         # (bool, default=false)
-disable_rules                           # Disable the rule that from the
                                         # provided rule list. the rule list as
                                         # follow: (jog2jog_spacing |
                                         # eol_spacing cut_spacing min_cut
                                         # enclosure color min_step protrusion
                                         # min_area out_of_die
                                         # off_manufacturing_grid
                                         # off_routing_track)
                                         # (enums={jog2jog_spacing eol_spacing cut_spacing min_cut enclosure color min_step protrusion min_area out_of_die off_manufacturing_grid off_routing_track}_list, default= )
-enable_post_passive_fill_check          # Check full fill trim.
                                         # (bool, default=false)
-exclude_pg_net                          # Excludes the checking of power and
                                         # ground nets. (bool, default=false)
-ignore_cell_blockage                    # Ignore geometries of cell blockage.
                                         # (bool, default=false)
-ignore_fill_wire                        # Ignore metalfill wires when check
                                         # drc. (bool, default=false)
-ignore_non_rectangle_shapes             # ignore non-rectangle shapes.
                                         # (bool, default=false)
-ignore_trial_route                      # Ignore trial route when check drc.
                                         # (bool, default=false)
-layer_range                             # Checks between the range of metal
                                         # layers including cut layers in
                                         # between (string, default="")
-limit                                   # Specifies the maximum number of
                                         # errors to report (int, default=1000)
-max_wrong_way_halo                      # Specifies the maximum wrong way halo
                                         # (float, default=-1)
-report                                  # Specifies the report file that
                                         # contains the violations information
                                         # (string, default="")
-use_min_spacing_on_block_obs            # Use min spacing to check for block
                                         # OBS.
                                         # (enums={true false auto}, default=auto)
-quiet                                   # Displays the current settings in Tcl list format only
-nonDefault                              # Displays the current settings which are not default settings