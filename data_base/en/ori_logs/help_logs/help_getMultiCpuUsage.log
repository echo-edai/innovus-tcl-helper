Usage: getMultiCpuUsage [-help] [-autoPageFaultMonitor] [-cpuPerRemoteHost]
                        [-gpuPerRemoteHost] [-keepLicense] [-localCpu]
                        [-localGpu] [-localMem] [-memPerRemoteHost]
                        [-remoteHost] [-threadInfo] [-verbose]

-help                        # Prints out the command usage
-autoPageFaultMonitor        # Get the value of the autoPageFaultMonitor option
                             # (bool, optional)
-cpuPerRemoteHost            # Get the number of CPUs available on every remote
                             # host (server) (bool, optional)
-gpuPerRemoteHost            # Get the number of GPUs available on every remote
                             # host (server) (bool, optional)
-keepLicense                 # Get the keep mcpu license setting
                             # (bool, optional)
-localCpu                    # Get the number of available local CPUs
                             # (bool, optional)
-localGpu                    # Get the number of available local GPUs
                             # (bool, optional)
-localMem                    # Get memory in mb available on local host
                             # (bool, optional)
-memPerRemoteHost            # Get memory in MB available on every remote host
                             # (server) (bool, optional)
-remoteHost                  # Get the number of available remote hosts
                             # (servers) (bool, optional)
-threadInfo                  # Get the level of thread informational messages
                             # (bool, optional)
-verbose                     # Print a message indicating the parameter and the
                             # return value (bool, optional)