Usage: addRepeaterByRule [-help] [-allowMixedSignal] [-copyNetAttribute]
                         [-excNet <string>] [-netMapping <string>]
                         [-nets <tcl_obj>] [-outDir <string>]
                         [-reportIgnoredNets <string>] [-rule <string>]
                         [-selNet <string>] [-selected] [-template] [ -preRoute  | -postRoute  | -alongRoute  ]

-help                           # Prints out the command usage
-allowMixedSignal               # allow buffering on mixed signal nets
                                # (bool, optional)
-alongRoute                     # original route is preserved. refinePlace and
                                # route are needed afterwards (bool, optional)
-copyNetAttribute               # copy net attribute (bool, optional)
-excNet <string>                # file name for excluded nets
                                # (string, optional)
-netMapping <string>            # file name for the map of the original nets to
                                # the new nets created by the command
                                # (string, optional)
-nets <tcl_obj>                 # list of nets to buffer (tcl_obj, optional)
-outDir <string>                # directory for output of report files
                                # (string, optional)
-postRoute                      # design must be routed, and detail RC
                                # extraction is conducted. refinePlace and
                                # route are needed afterwards (bool, optional)
-preRoute                       # different routing topologies are explored
                                # (bool, optional)
-reportIgnoredNets <string>     # file name for ignored nets (string, optional)
-rule <string>                  # rule file name (string, optional)
-selNet <string>                # file name for selected nets
                                # (string, optional)
-selected                       # buffer nets selected by the selectNet tcl
                                # command or in the gui (bool, optional)
-template                       # generate template rule file with name
                                # template.rule. It will omit other options
                                # once being used. (bool, optional)