Usage: create_relative_floorplan [-help] {{{-place <string> | -reshape <string>} [-ref <string>]} } [-place <string> {-ref_type {object core_boundary die_boundary} -horizontal_edge_separate <string> -vertical_edge_separate <string>} [[-bbox {none target reference both}] [-orient {R0 R90 R180 R270 MX MY MX90 MY90}]]] [-reshape <string> { -dimension {height width} } [ [-fixed_edges <string>] [-density <string>] [-offset <string>]]]

-help                                  # Prints out the command usage
-bbox {none target reference both}     # Specifies whether to use bounding box
                                       # instead of the rectilinear shape of
                                       # target or reference object. Default:
                                       # none. (enum_list, optional)
-density <string>                      # Specifies the target utilization (TU).
                                       # By default, reshaping the object will
                                       # keep the current TU. (string, optional)
-dimension {height width}              # Specifies width or height of
                                       # referenced object as the reference
                                       # dimension.Default: width 
                                       # (enum_list, optional)
-fixed_edges <string>                  # Specifies that the reshape object will
                                       # be stretched while fixing 2
                                       # perpendicular edges.Default: {-1 0}.
                                       # fixed_edges {-1 0} represents the low
                                       # left corner for rectangle fplan and
                                       # the origin that has smallest x,y
                                       # coordinates for rectilinear fplan, the
                                       # edge with index -1 is the first edge
                                       # after zero edge in counter-clockwise
                                       # counting. (string, optional)
-horizontal_edge_separate <string>     # Specifies the vertical spacing between
                                       # horizontal edge of target and
                                       # reference objects. (string, optional)
-offset <string>                       # Offset value from reference object in
                                       # specified dimension. (string, optional)
-orient {R0 R90 R180 R270 MX MY MX90 MY90}
                                       # Specifies the orientation of target
                                       # object.Default: R0. (enum_list, optional)
-place <string>                        # Specifies the target object name for
                                       # relative place (string, optional)
-ref <string>                          # Specifies the reference object name.
                                       # It cannot be used with -ref_type
                                       # core_boundary or -ref_type
                                       # die_boundary.  (string, optional)
-ref_type {object core_boundary die_boundary}
                                       # Specifies the type of reference.
                                       # Default: object. (enum_list, optional)
-reshape <string>                      # Specifies the target object name for
                                       # relative reshape (string, optional)
-vertical_edge_separate <string>       # Specifies the horizontal spacing
                                       # between vertical edge of target and
                                       # reference objects. (string, optional)