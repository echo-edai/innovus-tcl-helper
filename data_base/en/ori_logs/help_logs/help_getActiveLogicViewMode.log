Usage: getActiveLogicViewMode [-help] [-keepAsync] [-keepHighFanoutPorts]
                              [-keepInstInSdc] [-keepLoopBack]
                              [-quiet] [-nonDefault]

-help                                 # Prints out the command usage
-keepAsync                            # Keep paths from asynchronous input
                                      # ports (bool, default=false)
-keepHighFanoutPorts                  # Keep high fanout input port paths
                                      # (bool, default=true)
-keepInstInSdc                        # Keep instances which have constraints
                                      # on it (bool, default=false)
-keepLoopBack                         # Keep loop back paths
                                      # (bool, default=false)
-quiet                                # Displays the current settings in Tcl list format only
-nonDefault                           # Displays the current settings which are not default settings