Usage: set_data_check [-help] <check_value> [-clock <clock_object>] [-hold]
                      [-setup] {-from <pin_or_port_list> | -rise_from <pin_or_port_list> | -fall_from <pin_or_port_list>} {-to <pin_or_port_list> | -rise_to <pin_or_port_list> | -fall_to <pin_or_port_list>}

-help                             # Prints out the command usage
<check_value>                     # Value of the setup or hold time for the
                                  # check (float, required)
-clock <clock_object>             # Name of the clock that triggers the data
                                  # event for the related (-from) pin
                                  # (string, optional)
-fall_from <pin_or_port_list>     # Checks at the rising edge of the signal on
                                  # the from pins (string, optional)
-fall_to <pin_or_port_list>       # Checks at the falling edge of the signal on
                                  # the to pins (string, optional)
-from <pin_or_port_list>          # Checks both the rising and the falling
                                  # edges (string, optional)
-hold                             # Data check value is for hold check
                                  # (bool, optional)
-rise_from <pin_or_port_list>     # Checks at the falling edge of the signal on
                                  # the from pins (string, optional)
-rise_to <pin_or_port_list>       # Checks at the rising edge of the signal on
                                  # the to pins (string, optional)
-setup                            # Data check value is for setup check
                                  # (bool, optional)
-to <pin_or_port_list>            # Checks both the rising and the falling
                                  # edges (string, optional)