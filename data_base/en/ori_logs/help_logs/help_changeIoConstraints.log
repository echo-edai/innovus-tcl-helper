Usage: changeIoConstraints [-help] [-forceIt] [-removeAll]
                           [-firstCellSpacing <float> | -removeFirstCellSpacing]
                           [-row <string> | -ioOrder <string>]
                           [-endspace <float> | -removeEndSpace]
                           [-spacing <float> | -removeSpacing]

-help                       # Prints out the command usage
-endspace <float>           # EndSpace constraint (float, optional)
-firstCellSpacing <float>   # spacing from row edge to first cell
                            # (float, optional)
-forceIt                    # Force to run on non-io-row flow (bool, optional)
-ioOrder <string>           # Change I/O placing order (string, optional)
-removeAll                  # remove all constraint (bool, optional)
-removeEndSpace             # remove endspace constraint (bool, optional)
-removeFirstCellSpacing     # remove spacing constraint from first cell
                            # (bool, optional)
-removeSpacing              # remove spacing constraint (bool, optional)
-row <string>               # I/O row name (string, optional)
-spacing <float>            # spacing constraint for all cells
                            # (float, optional)