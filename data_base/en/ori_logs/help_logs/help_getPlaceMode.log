                                           # limited routing capacity
                                           # (enums={none soft partial}, default=partial)
-place_global_clock_gate_aware             # find better placement for clock
                                           # gating elements towards the center
                                           # of gravity for fanout
                                           # (bool, default=true)
-place_global_clock_power_driven           # clock power driven
                                           # (bool, default=true)
-place_global_clock_power_driven_effort    # -place_global_clock_power_driven_effort
                                           # mode
                                           # (enums={low standard high}, default=low)
-place_global_cong_effort                  # level of effort for congestion
