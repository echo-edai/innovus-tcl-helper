-help                                      # Prints out the command usage
-place_3d_use_existing_bump_tsv            # reuse pre-placed bumps or TSVs
                                           # (bool, default=false)
-place_design_enable_3d                    # enable 3d placement
                                           # (bool, default=false)
-place_design_floorplan_mode               # run placement in floorplan mode
                                           # (bool, default=false)
-place_design_integrity_ir_fix_effort      # set power integrity placement IR
                                           # fixing effort
                                           # (enums={low medium high}, default=medium)
-place_design_refine_macro                 # specify whether to run
                                           # refine_macro_place after
                                           # place_design -concurrent_macro
                                           # (bool, default=false)
-place_design_refine_place                 # if set to false, calls to
                                           # refinePlace from other apps (such
                                           # as placeDesign, optDesign) will
                                           # not run refinePlace
                                           # (bool, default=true)
-place_detail_activity_power_driven        # (bool, default=false)
-place_detail_allow_border_pin_abut        # allow instance abut with its
                                           # neighbors when it has pins near by
                                           # the cell boundary
                                           # (bool, default=false)
-place_detail_allow_single_height_row_symmetry_x
                                           # allow single height row to be
                                           # symmetryX (string, default="")
-place_detail_check_cut_spacing            # Check via cut spacing during DRC
                                           # checking (bool, default=false)
-place_detail_check_inst_space_group       # check inst space group
                                           # (bool, default=false)
-place_detail_check_route                  # do DRV checks against FIXED wires
                                           # during legalization, along with
                                           # preroutes (bool, default=false)
-place_detail_color_aware_legal            # enable adjacent cell color
                                           # conflict check in legalization
                                           # (bool, default=false)
-place_detail_context_aware_legal          # specify the types of cell context
                                           # rules the placer needs to honor.
                                           # The argument values [optional,
                                           # required, user ignore_soft] can be
                                           # used separately or combined, but
                                           # they are exclusive to all | none
                                           # (default=all)
                                           # (enums={none all optional required user ignore_soft}_list, default=all)
-place_detail_eco_max_distance             # specify max distance (in micron)
                                           # for refinePlace ECO mode
                                           # (float, default=0, min=0, max=9999)
-place_detail_eco_priority_insts           # select instance priority for
                                           # refinePlace ECO mode
                                           # (enums={placed fixed eco}, default=placed)
-place_detail_fixed_shifter                # mark shifters FIXED once placed
                                           # (bool, default=false)
-place_detail_honor_inst_pad               # honor padding from specifyInstPad
                                           # in detail placement
                                           # (bool, default=false)
-place_detail_io_pin_blockage              # ioPins from top-level are treated
                                           # as pre-routes during DRV checks   
                                           # in legalization (bool, default=false)
-place_detail_iraware_max_drive_strength
                                           # (float, default=0, min=0, max=2147483647)
-place_detail_irdrop_aware_effort          # selects which IR drop optimization
                                           # effort level to use during
                                           # refinePlace
                                           # (enums={none low medium high}, default=none)
-place_detail_irdrop_aware_timing_effort
                                           # selects which timing effort level
                                           # to use during refinePlace
                                           # (enums={none standard high}, default=high)
-place_detail_irdrop_region_number         # value for debug_irdrop -nregion in
                                           # native API (uint, default=100)
-place_detail_legalization_inst_gap        # minimum gap between instances
                                           # (unit sites) (int, default=0)
-place_detail_max_shifter_column_depth     # maximum distance from vertical
                                           # power domain boundary that a
                                           # shifter can be placed
                                           # (float, default=9999)
-place_detail_max_shifter_depth            # maximum distance from a horizontal
                                           # or vertical power domain boundary
                                           # that a shifter can be placed
                                           # (float, default=9999)
-place_detail_max_shifter_row_depth        # maximum distance from a horizontal
                                           # power domain bounary that a
                                           # shifter can be placed
                                           # (float, default=9999)
-place_detail_no_filler_without_implant    # there is no cell which  has no
                                           # implant obs (bool, default=false)
-place_detail_pad_fixed_insts              # honor cell-padding for FIXED
                                           # instances in refinePlace
                                           # (bool, default=false)
-place_detail_pad_physical_cells           # padding overlap with physcial
                                           # cells would be honored
                                           # (bool, default=false)
-place_detail_PGFTV_insertion_cell_list    # Specify list of cells as PG FTV
                                           # cells (string, default="")
-place_detail_preroute_as_obs              # specify layers on which preroute
                                           # are taken as OBS (string, default="")
-place_detail_preserve_routing             # do not delete routed wires during
                                           # refinePlace (bool, default=true)
-place_detail_remove_affected_routing      # delete only wires whose nets were
                                           # touched due to moved cells
                                           # (bool, default=false)
-place_detail_swap_eeq_cells               # replace master cells by its EEQ
                                           # cell during legalization, to keep
                                           # max-dist move low
                                           # (bool, default=false)
-place_detail_use_check_drc                # Use FGC based DRC engine in
                                           # legalization (bool, default=false)
-place_detail_use_diffusion_transition_fill
                                           # insert OD transition filler in 1X
                                           # gap (bool, default=false)
-place_detail_use_GA_filler_groups         # filler cell insts will only be
                                           # replaced by logic insts that
                                           # belong to same GA groups.
                                           # (bool, default=false)
-place_detail_use_no_diffusion_one_site_filler
                                           # override -fillerGapMinGap to 0 and
                                           # all source-drain spacing rule to 1
                                           # site during legalizing
                                           # (bool, default=false)
-place_detail_wire_length_opt_effort       # selects which wire-length
                                           # optimization effort level to use
                                           # during refinePlace
                                           # (enums={none medium high}, default=medium)
-place_global_activity_power_driven        # identifies and constrains
                                           # power-critical nets to reduce
                                           # switching power
                                           # (enums={false true}, default=false)
-place_global_activity_power_driven_effort
                                           # -place_global_activity_power_driven_effort
                                           # mode
                                           # (enums={standard high}, default=standard)
-place_global_align_macro                  # enable mixed-placer to align
                                           # nearby same-size macros during
                                           # global placement (bool, default=true)
-place_global_allow_3d_stack               # (bool, default=false)
-place_global_auto_blockage_in_channel     # Placement will (temporarily) block
