                                           # (enums={low medium high extreme auto}, default=auto)
-place_global_cpg_effort                   # level of effort for CPG
                                           # (enums={low medium high extreme}, default=low)
-place_global_cpg_file                     # (string, default="")
-place_global_enable_advanced_pipeline     # (bool, default=false)
-place_global_enable_distributed_place     # enable distributed placement
                                           # platform (bool, default=false)
-place_global_ignore_scan                  # ignore scan net during placement
                                           # (enums={true 1 false 0 auto}, default=true)
-place_global_ignore_spare                 # discard spare cell connections
                                           # during global placement
                                           # (bool, default=false)
-place_global_max_density                  # placement strives to not let
                                           # density exceed given value, in any
                                           # part of design (float, default=-1)
-place_global_module_aware_spare           # Spare insts are placed randomly
                                           # along with the containing module's
                                           # insts (bool, default=false)
-place_global_module_padding               # define the padding factor for the
                                           # given module to reduce the local
                                           # density and congestion
                                           # (string, default="")
-place_global_place_io_pins                # place IO Pins concurrently with
                                           # std.cell placement, and do layer
                                           # assignment (bool, default=false)
-place_global_reorder_scan                 # turn on reorder scan during
                                           # placement (bool, default=true)
-place_global_soft_guide_strength          # level of effort for user definded
                                           # softGuide for global placer
                                           # (enums={low medium high}, default=low)
-place_global_timing_effort                # level of effort for timing driven
                                           # global placer
                                           # (enums={medium high}, default=medium)
-place_global_uniform_density              # enable even cell distribution for
