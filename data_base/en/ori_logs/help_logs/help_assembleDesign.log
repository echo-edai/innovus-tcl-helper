Usage: assembleDesign [-help] [-dontMergeBlockPGNets] [-keepPGPinGeometry]
                      [-keep_block_halo] [-outFile <fileName>] [-skipNets] { { [-topDir <dirname> [-mmmcFile <mmmcFile>] [-cpfFile <cpfFile>] ] {[-blockDir <dirname> [ [-fplan ]]][-blockData {defFileName netListFileName} | {-fplan } ] } } | {[-topDesign {topLib topCell topView} [-mmmcFile <mmmcFile>] [-cpfFile <cpfFile>] ] {[-block {blockLib blockCell blockView} | -blockCell <blockCell> ] [-allTimingBlocks [-exceptBlocks {list of blocks}] [-reportOnly ]]}} } [ -fplan ] [-keepPinGeometry ] [{-blockData {defFileName netListFileName} } [-skipCells ] [-skipComponents ] [-skipSpecialNets ]]

-help                                   # Prints out the command usage
-allTimingBlocks                        # Enables automatic detection and
                                        # assembly of blocks with digital
                                        # content. (bool, optional)
-block {blockLib blockCell blockView}   # The OpenAccess database's directory,
                                        # cell and view for the block cell.
                                        # (string, optional)
-blockCell <blockCell>                  # The cell name for the block cell.
                                        # (string, optional)
-blockData {defFileName netListFileName}
                                        # The def file and the netlist file (string, optional)
-blockDir <dirname>                     # The diretory which contains the block
                                        # level design (string, optional)
-cpfFile <cpfFile>                      # Chip level cpf file
                                        # (string, optional)
-dontMergeBlockPGNets                   # Don't Merge Block PG nets to top
                                        # (bool, optional)
-exceptBlocks {list of blocks}          # List of block names not to assemble
                                        # even if they do contain digital
                                        # content. This option only applies to
                                        # the case where -allTimingBlocks is
                                        # used. If not specified, there is no
                                        # restriction on the detection and
                                        # assembly that is automatically
                                        # determined. (string, optional)
-fplan                                  # Only assemble floorplan data
                                        # (bool, optional)
-keepPGPinGeometry                      # Retain partition PG pin geometry
                                        # (bool, optional)
-keepPinGeometry                        # Create DRCFILL shape corresponding to
                                        # partition pin geometry (bool, optional)
-keep_block_halo                        # Preserve block place and route halo
                                        # (bool, optional)
-mmmcFile <mmmcFile>                    # Chip level mmmc file
                                        # (string, optional)
-outFile <fileName>                     # Specifies name of the output file.
                                        # Default:
                                        # ./<design>.assembleDesign.rpt
                                        # (string, optional)
-reportOnly                             # With this option, the command only
                                        # reports the list of blocks which
                                        # would be assembled and does not
                                        # perform actual assembling.
                                        # (bool, optional)
-skipCells                              # Skip merging std cells
                                        # (bool, optional)
-skipComponents                         # Skip merging all components
                                        # (bool, optional)
-skipNets                               # Skip merging signal routes
                                        # (bool, optional)
-skipSpecialNets                        # Skip merging special routes
                                        # (bool, optional)
-topDesign {topLib topCell topView}     # The OpenAccess database's directory,
                                        # cell and view for the top cell.
                                        # (string, optional)
-topDir <dirname>                       # The directory which contains the top
                                        # level design (string, optional)