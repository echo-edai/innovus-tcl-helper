Usage: add_ndr [-help] [-add_via <string>] [-exclude_backside_via]
               [-generate_via] [-hard_spacing] [-init <string>]
               [-min_cut <string>] [-use_via_cut_class <string>] [-via <string>] { -name <ruleName> } [-width <string> | -width_multiplier <string>] [-spacing <string> | -spacing_multiplier <string>]

-help                          # Prints out the command usage
-add_via <string>              # {via_name1 via_name2} Append the list of via
                               # or via rule generate name (string, optional)
-exclude_backside_via          # do not include backside via in the rule
                               # (bool, optional)
-generate_via                  # auto-generate vias with the generateVias
                               # command. If getGenerateViaMode -auto is true,
                               # then this is done by default even if
                               # -generate_via is not given. (bool, optional)
-hard_spacing                  # set the NONDEFAULTRULE to HARDSPACING
                               # (bool, optional)
-init <string>                 # clone from specified rule (string, optional)
-min_cut <string>              # {layer1[:layer2] min_cut} the min cut limit
                               # for via layers (string, optional)
-name <ruleName>               # name of NDR rule (string, optional)
-spacing <string>              # {layer1[:layer2] spacing} spacing for routing
                               # layers (string, optional)
-spacing_multiplier <string>   # {layer1[:layer2] spacing_multiplier} spacing
                               # multiplier for routing layers (string, optional)
-use_via_cut_class <string>    # {layer cut_class [nr_row nr_col]} ... The
                               # layer and cut_class list (string, optional)
-via <string>                  # {via_name1 via_name2} Reset and add the list
                               # of via or via rule generate name
                               # (string, optional)
-width <string>                # {layer1[:layer2] width} width for routing
                               # layers (string, optional)
-width_multiplier <string>     # {layer1[:layer2] width_multiplier} width
                               # multiplier for routing layers (string, optional)