Usage: setPromotedMacroPin [-help] {-reset  | -reportOnlyFile <fileName.tcl> | {[-insts <instName | instNameList>] [-pins {pinName | pinNameList}] [-layers {layerId | layerIdList}] [-override ] [-abuttedToBoundaryOnly ]}}

-help                                # Prints out the command usage
-abuttedToBoundaryOnly               # Specifies to promote selected macro pin
                                     # if macro pin is abutted with partition
                                     # boundary. (bool, optional)
-insts <instName | instNameList>     # Specifies name of the instances,
                                     # wildcard can be specified
                                     # (string, optional)
-layers {layerId | layerIdList}      # Specifies layers of the macro pins.
                                     # (string, optional)
-override                            # Specifies to override specific promoted
                                     # pin selection. (bool, optional)
-pins {pinName | pinNameList}        # Specifies name of the macro pins,
                                     # wildcard can be specified
                                     # (string, optional)
-reportOnlyFile <fileName.tcl>       # Specifies all setPromotedMacroPin
                                     # settings into an output TCL file.
                                     # (string, optional)
-reset                               # Specifies to reset all promoted pin
                                     # selection. (bool, optional)