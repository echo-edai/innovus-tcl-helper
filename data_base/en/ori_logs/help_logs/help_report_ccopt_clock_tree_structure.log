Usage: report_ccopt_clock_tree_structure [-help]
                                         [-clock_trees {string1 string2 ...}]
                                         [-expand_below_logic] [-file <name>]
                                         [-show_sinks] [-update_timing] [ -include_reporting_only_skew_groups ] [ -delay_corner <delay_corner> ] [ -check_type <type> ] [ -delay_type <type> ] [ -expand_generated_clock_trees {independently inline independently_and_inline} ]

-help                                  # Prints out the command usage
-check_type {setup hold}               # Report in the specified check type
                                       # (enum, optional)
-clock_trees {string1 string2 ...}     # Restricts the report to the specified
                                       # clock trees. (list, optional)
-delay_corner <delay_corner>           # Report in the specified delay corner
                                       # ((delay_corner), optional)
-delay_type {early late}               # Report in this delay type
                                       # (enum, optional)
-expand_below_logic                    # Subtrees below multi-input logic will
                                       # be fully listed below each logic input
                                       # (bool, optional)
-expand_generated_clock_trees {independently inline independently_and_inline}
                                       # Specifies how generated clock trees
                                       # should be displayed (enum, optional)
-file <name>                           # Save a copy of the contents of the
                                       # report to the specified file name
                                       # (string, optional)
-include_reporting_only_skew_groups    # Additionally include the
                                       # reporting-only skew groups in the
                                       # report. (bool, optional)
-show_sinks                            # Include all clock network sinks in the
                                       # report (bool, optional)
-update_timing                         # Update and include detailed timing
                                       # information such as pin slew,
                                       # capacitance (bool, optional)