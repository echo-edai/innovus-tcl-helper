Usage: set_add_target_pg_mode [-help] [-reset]
                              [-allow_weak_connect {true|false}]
                              [-max_extension_distance <value>]
                              [-pins {<cell1>:<pin1> <cell1>:<pin2> <cell2>:<pin1> ...}]
                              [-pins_group_distance <value>]
                              [-respect_routes {none|||fixed|||fixed_and_clock|||all}]
                              [-share_resource {true|false}]

-help                            # Prints out the command usage
-reset                           # Resets all or specified options to default value
-allow_weak_connect {true|false} # Decreate specified pillar number to avoid
                                 # drc (bool, default=false)
-max_extension_distance <value>  # Specify the max distance that target PG pin
                                 # can extend to target layer
                                 # (float, default=2147483647)
-pins {<cell1>:<pin1> <cell1>:<pin2> <cell2>:<pin1> ...}
                                 # Specify the cell pins to be connected (string, default="")
-pins_group_distance <value>     # Specify the side_to_side distance of pins to
                                 # be treated as a group during connecting
                                 # target PG pins (string, default=auto)
-respect_routes {none|||fixed|||fixed_and_clock|||all}
                                 # Specifies whether to honor pre-existing
                                 # routes check during stripe generation
                                 # (enums={none | fixed | fixed_and_clock | all}, default=fixed_and_clock)
-share_resource {true|false}     # New added PG connect to the existing PG at
                                 # middle layer (bool, default=true)