Usage: report_proto_model [-help] [-constraint] [-file <string>] [ -min_inst <integer> | -identified | -created ] [ -min_inst <integer> ] [-instance_ratio <float> | -min_inst <integer> ]

-help                   # Prints out the command usage
-constraint             # Report physical constraint information
                        # (bool, optional)
-created                # Reports the statistics including reduction ratio of
                        # the models that have been created. (bool, optional)
-file <string>          # Specifies output report file name. (string, optional)
-identified             # Reports the statistics of the modules/instgroups that
                        # have been identified as models. (bool, optional)
-instance_ratio <float> # Specifies ratio value where report_proto__model only
                        # reports flexModels that have instance ratio greater
                        # than or equal to this specified value.
                        # (float, optional, min=0, max=1.79769313486232e+308)
-min_inst <integer>     # Specifies the threshold of an instance count that is
                        # used to filter modules. (int, optional)