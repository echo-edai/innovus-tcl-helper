Usage: uiFind [-help] [<name>] [-before <name>] [-checked <true|false>]
              [-command <string>] [-disabled <true|false>] [-enablevar <string>]
              [-foreground <string>] [-icon <file>] [-in <name>]
              [-label <string>] [-menuseparate <true|false>]
              [-movable <true|false>] [-newline <true|false>]
              [-shortcut <string>] [-tooltip <string>]
              [-type {menu toolbar submenu command check radio separator toolbutton}]
              [-underline <integer>] [-value <string>] [-variable <string>]
              [-visiblevar <string>]

-help                              # Prints out the command usage
<name>                             # Widget Name (string, optional)
-before <name>                     # Next Sibling Widget Name
                                   # (string, optional)
-checked <true|false>              # On/Off for Check Box and Radio Button
                                   # (bool, optional)
-command <string>                  # Tcl Command (string, optional)
-disabled <true|false>             # Widget State (bool, optional)
-enablevar <string>                # Tcl Global Variable For Enable
                                   # (string, optional)
-foreground <string>               # Icon Foreground color (string, optional)
-icon <file>                       # Icon File Name (string, optional)
-in <name>                         # Parent Widget Name (string, optional)
-label <string>                    # Widget Label (string, optional)
-menuseparate <true|false>         # the menu tear off status (bool, optional)
-movable <true|false>              # Movable or Not (bool, optional)
-newline <true|false>              # Start With New Row (bool, optional)
-shortcut <string>                 # Shortcut Key (string, optional)
-tooltip <string>                  # Tooltip (string, optional)
-type {menu toolbar submenu command check radio separator toolbutton}
                                   # Widget Type (enum, optional)
-underline <integer>               # Index of a Character for Underline
                                   # (int, optional)
-value <string>                    # Widget Value (string, optional)
-variable <string>                 # Tcl Global Variable (string, optional)
-visiblevar <string>               # Tcl Global Variable For Visible
                                   # (string, optional)