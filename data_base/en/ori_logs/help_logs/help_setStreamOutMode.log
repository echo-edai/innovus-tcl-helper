Usage: setStreamOutMode [-help] [-reset] [-cellInstanceColor {true|false}]
                        [-cellMasterColor {true|false}]
                        [-cellNameUserPrefix {prefix}]
                        [-cellNameUserSuffix {suffix}]
                        [-check_map_file {true|false}]
                        [-ignoreFixedMask {true|false}]
                        [-labelAllPinShape {true|false}]
                        [-noPinLabelOnNets {list of net names}]
                        [-oasisCompression {true|false}]
                        [-oasisLayerName {true|false}]
                        [-oasisSCellOffset {true|false}]
                        [-pinTextOrientation {default|automatic}]
                        [-remove_short_metal_within_cell_boundary {FTV_cell_list}]
                        [-removeNets {list of net names}]
                        [-SEcompatible {true|false}] [-SEvianames {true|false}]
                        [-snapToMGrid {true|false}]
                        [-specifyViaName {default | %t_%v_%l(lcu)_%n_%r_%c_%u}]
                        [-streamConvertRectToPath {true|false}]
                        [-streamVersion <number>]
                        [-supportPathType4 {true|false}]
                        [-textSize <realNumber>]
                        [-uniquifyCellNamesPrefix {true|false}]
                        [-virtualConnection {true|false}] [-mergeAppend {true|false} ]

-help                                     # Prints out the command usage
-reset                                    # Resets all or specified options to default value
-cellInstanceColor {true|false}           # stream out the instance based
                                          # color. The instance mask shift is
                                          # honored in streamOut. When the
                                          # option is on and -merge option is
                                          # used, the merged gds files with
                                          # mask shift suffix must be provided
                                          # through option -merge.
                                          # (bool, default=false)
-cellMasterColor {true|false}             # stream out the cell based color
                                          # from innovus color engine.
                                          # (bool, default=true)
-cellNameUserPrefix {prefix}              # Add a prefix to ALL cell names
                                          # being written out, use user
                                          # specified prefix can avoid
                                          # potential conflict when integrating
                                          # different macros, which potentially
                                          # 2 different cells (in 2 different
                                          # libraries) with the same name.
                                          # (string, default="")
-cellNameUserSuffix {suffix}              # Instead of appending color pattern
                                          # to normal cell names, use user
                                          # specified suffix. This applies to
                                          # fixed color shift (flip) pattern
                                          # only. i.e., only single shift
                                          # (flip) pattern applied to the
                                          # design. (string, default="")
-check_map_file {true|false}              # Check the specified map file. If
                                          # the objects existed in innovus, but
                                          # the objects have no objects mapping
                                          # in map file, print the missed
                                          # objects mapping and missed objects
                                          # in log file, only the main objects
                                          # mapping are checked by the option.
                                          # (bool, default=false)
-ignoreFixedMask {true|false}             # Ignore macro FIXEDMASK keywords,
                                          # enable color flip function.
                                          # (bool, default=false)
-labelAllPinShape {true|false}            # If true, label pin name to its all
                                          # shapes. (bool, default=false)
-mergeAppend {true|false}                 # Append cell color information in
                                          # current design to cell geometries
                                          # that are from merging files. This
                                          # option is for TSMC 10nm fixed-mask
                                          # design. It is exclusive with
                                          # -ignoreInstanceColor and
                                          # -ignoreInstanceCCEColor, it will
                                          # set those two options to false
                                          # automatically when it is set to
                                          # true. (bool, default=false)
-noPinLabelOnNets {list of net names}     # Do not label pin text on specified
                                          # nets. (string, default="")
-oasisCompression {true|false}            # CBLOCK compression is
                                          # partial-selective encryption
                                          # technology uses OASIS CBLOCK
                                          # records to encrypt arbitrarily
                                          # encapsulated sets of data records
                                          # within an OASIS layout
                                          # file.
                                          # REPETITION compression supports an
                                          # 'array' of cell placements,
                                          # geometries, or text elements,
                                          # instead of write each the element
                                          # separate only different in
                                          # position, this can save duplicate
                                          # information for an OASIS layout
                                          # file size. (bool, default=true)
-oasisLayerName {true|false}              # Support LAYERNAME in OASIS file.
                                          # (bool, default=false)
-oasisSCellOffset {true|false}            # Include cell offset table to
                                          # declare the byte offset from the
                                          # beginning of the file (byte 0) to
                                          # where the corresponding CELL record
                                          # appears in the file.
                                          # (bool, default=false)
-pinTextOrientation {default|automatic}   # Output pin name on the boundary of
                                          # design to improve readability.
                                          # (string, default="")
-remove_short_metal_within_cell_boundary {FTV_cell_list}
                                          # The trim metal short inside
                                          # FTV_cell_list should be cut off.
                                          # (string, default="")
-removeNets {list of net names}           # Don't output nets in the list.
                                          # (string, default="")
-SEcompatible {true|false}                # Output instance only is FOREIGN is
                                          # specified. (bool, default=false)
-SEvianames {true|false}                  # Determines the naming convention
                                          # used for vias declared in the LEF
                                          # file. (bool, default=false)
-snapToMGrid {true|false}                 # Snap net's wire to manufacture grid
                                          # if it is not. (bool, default=false)
-specifyViaName {default | %t_%v_%l(lcu)_%n_%r_%c_%u}
                                          # Specifies the naming convention
                                          # that the streamOut command uses for
                                          # via cells declared in the DEF file.
                                          # (string, default=default)
-streamConvertRectToPath {true|false}     # When enabled, DEF SPECIALNETS
                                          # path/rect and FILLS shapes are
                                          # converted to GDSII/stream PATH data
                                          # instead of BOUNDARY data.
                                          # Conversion to path data can result
                                          # in significantly smaller output
                                          # database when there are many
                                          # rectangle shapes (example: after
                                          # metal fill is included).
                                          # (bool, default=false)
-streamVersion <number>                   # Specify GDSII version to output.
                                          # (int, default=3, min=1, max=32767)
-supportPathType4 {true|false}            # If false, converts PATHTYPE4 to
                                          # PATHTYPE0. (bool, default=true)
-textSize <realNumber>                    # Changes the size of the text used
                                          # in the text labels. (float, default=1)
-uniquifyCellNamesPrefix {true|false}     # Adds a prefix, instead of a suffix,
                                          # to uniquified cell names.
                                          # (bool, default=false)
-virtualConnection {true|false}           # Specifies whether a colon (:) label
                                          # is appended to pin names for DEF
                                          # pins with the .extraN syntax and to
                                          # LEF pins with multiple ports (if
                                          # -outputMacros is specified for LEF
                                          # pin ports that have disjoint
                                          # shapes). (bool, default=true)