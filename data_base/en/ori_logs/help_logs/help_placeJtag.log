Usage: placeJtag [-help] [-areaIo <flag>] [-blockNetWeight <#>]
                 [-contour <flag>] [-hardMacro <flag>] [-ignoreScan <flag>]
                 [-ioNetWeight <#>] [-nrRow <#>] [-nrRowBottom <#>]
                 [-nrRowLeft <#>] [-nrRowRight <#>] [-nrRowTop <#>]
                 [-orientBottom <R0|R90|R180|R270|MX|MX90|MY|MY90>]
                 [-orientLeft <R0|R90|R180|R270|MX|MX90|MY|MY90>]
                 [-orientRight <R0|R90|R180|R270|MX|MX90|MY|MY90>]
                 [-orientTop <R0|R90|R180|R270|MX|MX90|MY|MY90>]

-help                     # Prints out the command usage
-areaIo <flag>            # place jtag cells only along the boundary of area IO
                          # cells (bool, optional)
-blockNetWeight <#>       # specify net weight to io nets
                          # (int, optional, min=0, max=512)
-contour <flag>           # place jtag cells only along the boundary using
                          # contour (bool, optional)
-hardMacro <flag>         # place jtag cells also along the boundary of
                          # hardmacros (bool, optional)
-ignoreScan <flag>        # place jtag with scan chain ignored (bool, optional)
-ioNetWeight <#>          # specify net weight to io nets
                          # (int, optional, min=0, max=512)
-nrRow <#>                # number of row at boundary to place jtag inst
                          # (int, optional, min=0, max=10000)
-nrRowBottom <#>          # number of row at bottom boundary to place jtag inst
                          # (int, optional, min=0, max=10000)
-nrRowLeft <#>            # number of row at left boundary to place jtag inst
                          # (int, optional, min=0, max=10000)
-nrRowRight <#>           # number of row at right boundary to place jtag inst
                          # (int, optional, min=0, max=10000)
-nrRowTop <#>             # number of row at top boundary to place jtag inst
                          # (int, optional, min=0, max=10000)
-orientBottom <R0|R90|R180|R270|MX|MX90|MY|MY90>
                          # orient of small blocks placed at bottom boundray (string, optional)
-orientLeft <R0|R90|R180|R270|MX|MX90|MY|MY90>
                          # orient of small blocks placed at left boundray (string, optional)
-orientRight <R0|R90|R180|R270|MX|MX90|MY|MY90>
                          # orient of small blocks placed at right boundray (string, optional)
-orientTop <R0|R90|R180|R270|MX|MX90|MY|MY90>
                          # orient of small blocks placed at top boundray (string, optional)