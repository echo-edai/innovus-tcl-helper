Usage: movePowerSwitch [-help] [-area {x1 y1 x2 y2}] [-columnx <string>]
                       [-fixOverlap] [-honorSoftBlockage]
                       [-powerDomain <string>] [-reportFile <string>]
                       [-selected] [-switchInstances <string>]
                       [-xOffset <float>] [-yOffset <float>]

-help                         # Prints out the command usage
-area {x1 y1 x2 y2}           # (box, optional)
-columnx <string>             # (string, optional)
-fixOverlap                   # (bool, optional)
-honorSoftBlockage            # (bool, optional)
-powerDomain <string>         # (string, optional)
-reportFile <string>          # (string, optional)
-selected                     # (bool, optional)
-switchInstances <string>     # (string, optional)
-xOffset <float>              # (float, optional)
-yOffset <float>              # (float, optional)