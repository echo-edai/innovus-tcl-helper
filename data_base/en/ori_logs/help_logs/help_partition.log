Usage: partition [-help] [<partitionName {list}>]
                 [-addPinForPGWireLayersInDistance {{layer1 X1} {layer2 X2}}]
                 [-inputNetsForWireDistribution <string>] [-noTopPushDown]
                 [-noViaCutSpace] [-pgPushDownHonorUPF] [-pushAllRoutes]
                 [-pushDownHonorInsidePinForSpecialNet]
                 [-pushDownSelectedPGWiresAsRouteBlockage]
                 [-pushDownSpecialNetAsObs {SNet list}]
                 [-skipRouteBlockagesOutsidePartition] [-tcf] [-pinCutSpace ] [ -noInheritPhysical ] [ -pushRoute ]     [ -pushdownAllBumps | -pushDownSelectedPGBump ]

-help                                      # Prints out the command usage
<partitionName {list}>                     # Specifies list of partition names
                                           # (string, optional)
-addPinForPGWireLayersInDistance {{layer1 X1} {layer2 X2}}
                                           # Specifies the layers and distance
                                           # to consider for creating pins on
                                           # pg-stripes (string, optional)
-inputNetsForWireDistribution <string>     # Specifies file containing net
                                           # names to use for wire distribution
                                           # (string, optional)
-noInheritPhysical                         # Physical cells are not pushed down
                                           # into the partition (bool, optional)
-noTopPushDown                             # Nothing is pushed down on layers
                                           # reserved for top design
                                           # (bool, optional)
-noViaCutSpace                             # Do not cut cell obstruction aorund
                                           # vias (bool, optional)
-pgPushDownHonorUPF                        # Pushdown UPF information to
                                           # partition (bool, optional)
-pinCutSpace                               # Cuts cell obstruction around pins
                                           # (bool, optional)
-pushAllRoutes                             # Push down all signal routes
                                           # (bool, optional)
-pushDownHonorInsidePinForSpecialNet       # Push down selected PG routes as
                                           # route blockage into the partition
                                           # (bool, optional)
-pushDownSelectedPGBump                    # Push down selected PG bumps into
                                           # the partition (bool, optional)
-pushDownSelectedPGWiresAsRouteBlockage    # Push down selected PG routes as
                                           # route blockage into the partition
                                           # (bool, optional)
-pushDownSpecialNetAsObs {SNet list}       # Specifies list of special Nets,
                                           # which will be pushed down as
                                           # routing blockage (string, optional)
-pushRoute                                 # Push down hierarchical correct
                                           # signal routes (bool, optional)
-pushdownAllBumps                          # pushdown all bump to partition
                                           # block (bool, optional)
-skipRouteBlockagesOutsidePartition        # Skips pushing of objects which are
                                           # close to partition fence.
                                           # (bool, optional)
-tcf                                       # Enable tcf writing for the block
                                           # (bool, optional)