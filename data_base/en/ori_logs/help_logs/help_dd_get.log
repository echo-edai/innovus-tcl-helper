Usage: dd_get [-help] { {-all_lib } | { { -dd <ddObject handle>  | -lib <libName> | -cell <libName cellName> | -cellview <libName cellName viewName> } [ -children  | -file  | -path  | -type  | -name  ] } }

-help                                     # Prints out the command usage
-all_lib                                  # Option returns a list of dd object
                                          # handles for list of libraries
                                          # present in cds.lib file.
                                          # (bool, required)
-cell <libName cellName>                  # Option requires a libName and
                                          # cellName. (string, required)
-cellview <libName cellName viewName>     # Option requires a libName cellName
                                          # and viewName. (string, required)
-children                                 # Operator gives the ddObject handles
                                          # of children in a given dd object
                                          # handle. (bool, optional)
-dd <ddObject handle>                     # Option requires a single dd object
                                          # handle. (string, required)
-file                                     # Operator gives the ddObject handles
                                          # of all files in a given dd object
                                          # handle. (bool, optional)
-lib <libName>                            # Option requires a single libName.
                                          # (string, required)
-name                                     # Operator gives the name of given dd
                                          # object handle. (bool, optional)
-path                                     # Operator gives the absolute
                                          # path(i.e ddpath) of a given dd
                                          # object handle. (bool, optional)
-type                                     # Operator gives the type of given dd
                                          # object handle. (bool, optional)