Usage: synthesize_ccopt_flexible_htrees [-help] [-block_master_clone]
                                        [-dry_run] [-report_out_file <filename>] [ -spec_file <filename> ] [ -use_estimated_routes | -trial_mode {true false placement_only routing_only} ]

-help                               # Prints out the command usage
-block_master_clone                 # If specified, block master/clone
                                    # partitions for H-tree instances and nets
                                    # (bool, optional)
-dry_run                            # Run the synthesis algorithm but do not
                                    # insert the H-tree into the DB
                                    # (bool, optional)
-report_out_file <filename>         # Write the final flexible H-tree metrics
                                    # to the specified file. (string, optional)
-spec_file <filename>               # Do not amend the clock tree spec to
                                    # reflect the new state of the clock tree
                                    # but write the amendments to a file with
                                    # the given name (string, optional)
-trial_mode {true false placement_only routing_only}
                                    # If specified, enable trial routing and
                                    # placement mode for flexH (true false
                                    # placement_only routing_only).
                                    # (enum, optional)
-use_estimated_routes               # Do not call NanoRoute, so leave the
                                    # estimates in the netlist (bool, optional)