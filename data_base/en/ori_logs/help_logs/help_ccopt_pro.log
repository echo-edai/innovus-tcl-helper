Usage: ccopt_pro [-help] [-enable_average_id_reduction {true false}]
                 [-enable_downsizing_pass {true false}]
                 [-enable_drv_fixing {true false}]
                 [-enable_drv_fixing_by_rebuffering {true false}]
                 [-enable_refine_place {true false}]
                 [-enable_routing_eco {true false}]
                 [-enable_skew_fixing {true false}]
                 [-enable_skew_fixing_by_rebuffering {true false}]

-help                                # Prints out the command usage
-enable_average_id_reduction {true false}
                                     # enable/disable average insertion delay
                                     # reduction (enum, optional)
-enable_downsizing_pass {true false} # enable/disable a global cell downsizing
                                     # pass (enum, optional)
-enable_drv_fixing {true false}      # enable/disable DRV fixing
                                     # (enum, optional)
-enable_drv_fixing_by_rebuffering {true false}
                                     # enable/disable DRV fixing with
                                     # rebuffering (enum, optional)
-enable_refine_place {true false}    # enable/disable refine placement of
                                     # design. May result in cell overlaps
                                     # (enum, optional)
-enable_routing_eco {true false}     # enable/disable the ECO routing step
                                     # (enum, optional)
-enable_skew_fixing {true false}     # enable/disable fixing of clock tree skew
                                     # (enum, optional)
-enable_skew_fixing_by_rebuffering {true false}
                                     # enable/disable fixing by rebuffering of
                                     # clock tree skew (enum, optional)