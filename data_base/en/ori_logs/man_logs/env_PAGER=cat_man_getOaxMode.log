Name
       getOaxMode

Syntax
       getOaxMode

       [-help]

       [-allowAnalysisOnly]

       [-allowBitConnection]

       [-allowTechUpdate]

        [-bindkeyFile]

       [-compressLevel]

       [-convertTo]

       [-cutRows]

        [-displayDrfFile]

        [-displayDrfInLibrary]

       [-drcFillPurpose]

       [-encloseQuickAbstractPins]

       [-fullLayerList]

        [-fullPath]

       [-hybridRows]

       [-instPlacedIfUnknown]

        [-libCreateMode]

       [-locking]

        [-logicOnlyImport]

       [-merge_trim]

       [-nonRectilinearShapes]

        [-pinPurpose]

       [-pushPinConstraint]

       [-quickAbstractForCustomCells]

       [-readSystemReservedLayers]

       [-saveCdsFixedVias]

       [-saveMaskDataLocked]

       [-saveNetVoltage]

       [-saveRelativePath]

       [-saveRestoreFile]

       [-silently_ignore_unsupported_vias]

        [-textPurpose]

