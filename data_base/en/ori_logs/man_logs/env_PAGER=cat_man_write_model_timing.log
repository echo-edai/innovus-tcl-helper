                reset                  NA    NA      2.700     15.000     NA

                int                    NA    NA      2.700     15.000     NA

                port_pad_data_in[15]   NA    NA      2.700     15.000     NA

                port_pad_data_in[14]   NA    NA      2.700     15.000     NA

