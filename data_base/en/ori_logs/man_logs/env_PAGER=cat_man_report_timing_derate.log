                Cell  Delay         1.200000           1.200000       1.200000
                1.200000

                Net Delay Static   1.200000           1.200000        1.200000
                1.200000

                Net  Delay  Dynamic  1.200000          1.200000       1.200000
                1.200000

                Cell   Check          --                  --                --
                --

                Retain    delay        --                  --               --
                --

                Cell (hier): h4

                Cell Delay         1.200000           1.100000        1.200000
                1.100000

                inherited            top                  --               top
                --

                Net Delay Static   1.200000           1.100000        1.200000
                1.100000

                inherited            top                  --               top
                --

                Net Delay Dynamic  1.200000           1.100000        1.200000
                1.100000

                inherited            top                  --               top
                --

                Cell Check         1.200000           1.200000        1.200000
                1.200000

                inherited            --                   --                --
                --

                Cell (hier): h4/h2

                Cell Delay         1.200000           1.100000        1.200000
                1.100000

                inherited            --                   h4                --
                h4

                Net Delay Static   1.200000           1.100000        1.200000
                1.100000

                inherited            --                   h4                --
                h4

                Net Delay Dynamic  1.200000           1.100000        1.200000
