{
  "command": "write_power_intent",
  "is_cmd": true,
  "summary": "Writes power intent.",
  "description": "Writes power intent.",
  "usage": "write_power_intent [-help] <fileName> [-no_extra_connects] {-cpf | -1801 | -incremental_1801 } [{ -inst <string> | {-topHier -hierInst <string>}}]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage <fileName> # output filename",
      "required": true,
      "type": "string"
    },
    {
      "name": "-1801",
      "description": "output file in IEEE1801 format",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-cpf",
      "description": "output file in CPF format",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-hierInst",
      "description": "list of hinsts",
      "required": false,
      "type": "string"
    },
    {
      "name": "-incremental_1801",
      "description": "incremental IEEE1801 power intent",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-inst",
      "description": "inst name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-no_extra_connects",
      "description": "do not write out extra gnc (csn)",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-topHier",
      "description": "is top hierarchy",
      "required": false,
      "type": "flag"
    }
  ]
}