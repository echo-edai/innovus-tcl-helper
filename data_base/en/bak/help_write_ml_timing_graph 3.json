{
  "command": "write_ml_timing_graph",
  "is_cmd": true,
  "summary": "Writes ml timing graph.",
  "description": "Writes ml timing graph.",
  "usage": "write_ml_timing_graph [-help] [-noedge] -prefix <string> [-register_only] [-views <view_list>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noedge",
      "description": "Don't dump edge, for time saving",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-prefix",
      "description": "Prefix for output files",
      "required": true,
      "type": "string"
    },
    {
      "name": "-register_only",
      "description": "Only dump nodes for register",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-views",
      "description": "Dump data for the specified analysis view(s).",
      "required": false,
      "type": "string"
    }
  ]
}