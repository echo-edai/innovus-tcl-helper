{
  "command": "set_net_group",
  "is_cmd": true,
  "summary": "Sets net group.",
  "description": "Sets net group.",
  "usage": "set_net_group [-help] -reset | {-name <string> -type <string> -nets <string> }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "<net group name>>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-nets",
      "description": "<net names>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "<reset all previous set_net_group commands>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "<net group type>",
      "required": true,
      "type": "string"
    }
  ]
}