{
  "command": "set_glitch_derate",
  "is_cmd": true,
  "summary": "Sets glitch derate.",
  "description": "Sets glitch derate.",
  "usage": "set_glitch_derate [-help] [-derate_height <float>] [-derate_width <float>] [-glitch_type <string>] [-instance_pin <string>] [-offset <float>] [-pin <string>] [-view <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-derate_height",
      "description": "derate height value",
      "required": false,
      "type": "float"
    },
    {
      "name": "-derate_width",
      "description": "derate width value",
      "required": false,
      "type": "float"
    },
    {
      "name": "-glitch_type",
      "description": "glitch type vl or vh or all",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance_pin",
      "description": "instance pin names on which derate is to be applied",
      "required": false,
      "type": "string"
    },
    {
      "name": "-offset",
      "description": "derate offset value",
      "required": false,
      "type": "float"
    },
    {
      "name": "-pin",
      "description": "library pin names on which derate is to be applied",
      "required": false,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "view name",
      "required": false,
      "type": "string"
    }
  ]
}