{
  "command": "write_generalized_feedthru_paths",
  "is_cmd": true,
  "summary": "Writes generalized feedthru paths.",
  "description": "Writes generalized feedthru paths.",
  "usage": "write_generalized_feedthru_paths [-help] [-dont_generalize_reverse_paths] [-dont_generalize_sub_paths] [-topological_out_file <string>] -use_topological_file <string>",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-dont_generalize_reverse_paths",
      "description": "Generalization algorithm not to generalize reverse chain paths",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-dont_generalize_sub_paths",
      "description": "Generalization algorithm not to generalize sub-paths",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-topological_out_file",
      "description": "output topo 2.0 filename. Default: path.topo",
      "required": false,
      "type": "string"
    },
    {
      "name": "-use_topological_file",
      "description": "user feedthrough path guidance file",
      "required": true,
      "type": "string"
    }
  ]
}