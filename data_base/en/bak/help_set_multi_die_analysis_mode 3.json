{
  "command": "set_multi_die_analysis_mode",
  "is_cmd": true,
  "summary": "Sets multi die analysis mode.",
  "description": "Sets multi die analysis mode.",
  "usage": "set_multi_die_analysis_mode [-help] -die_list <string> -name <string> [-report_rlrp_path_instance_list <string>] [-stacked_die_mapping <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-die_list",
      "description": "<die_instance_name1 die_instance_name2 ...>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "<analysis_name>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-report_rlrp_path_instance_list",
      "description": "<string> <die_instance_list_file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-stacked_die_mapping",
      "description": "<EDI_map_file1 EDI_map_file2 ...>",
      "required": false,
      "type": "string"
    }
  ]
}