{
  "command": "set_voltus_insight_mode",
  "is_cmd": true,
  "summary": "Sets voltus insight mode.",
  "description": "Sets voltus insight mode.",
  "usage": "set_voltus_insight_mode [-help] -config <string> [-db_mapping <string>] -domain <string> [-hier_block_instance <string>] [-hierarchical] [-import_analysis_data] [-ir_effort <string>] [-nParallel <integer>] [-scenario_default <string>] [-skip] [-timing_effort <string>] [-watch_box <string>] [-watch_inst <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-config",
      "description": "config file",
      "required": true,
      "type": "string"
    },
    {
      "name": "-db_mapping",
      "description": "scenario mapping file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-domain",
      "description": "domain name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-hier_block_instance",
      "description": "hier block instance list",
      "required": false,
      "type": "string"
    },
    {
      "name": "-hierarchical",
      "description": "hierarchical flow",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-import_analysis_data",
      "description": "indicate if we need to import exsiting rail results",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ir_effort",
      "description": "effort level for RPG and IRAP",
      "required": false,
      "type": "string"
    },
    {
      "name": "-nParallel",
      "description": "#dbs for each iteration in multi-db mode",
      "required": false,
      "type": "int"
    },
    {
      "name": "-scenario_default",
      "description": "default scenario list",
      "required": false,
      "type": "string"
    },
    {
      "name": "-skip",
      "description": "skip user defined instances or box",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-timing_effort",
      "description": "timing effort for repair flow",
      "required": false,
      "type": "string"
    },
    {
      "name": "-watch_box",
      "description": "instances inside the box will be watched",
      "required": false,
      "type": "string"
    },
    {
      "name": "-watch_inst",
      "description": "defined user specified instances",
      "required": false,
      "type": "string"
    }
  ]
}