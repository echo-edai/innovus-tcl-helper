{
  "command": "setCycleBudgetRatio",
  "is_cmd": true,
  "summary": "Sets cycle budget ratio.",
  "description": "Sets cycle budget ratio.",
  "usage": "setCycleBudgetRatio [-help] {[[[{-fromTop | -fromPtn {hinst ratio}} {-toTop | -toPtn {hinst ratio}}] ] [-clock <string>]] | [-reset ]}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clock",
      "description": "clock name on which ratio to be applied",
      "required": false,
      "type": "string"
    },
    {
      "name": "-fromPtn",
      "description": "For paths starting from partition",
      "required": true,
      "type": "string"
    },
    {
      "name": "-fromTop",
      "description": "For paths starting from Top",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "reset all previously declared ratio budgets",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-toPtn",
      "description": "For paths in partition",
      "required": true,
      "type": "string"
    },
    {
      "name": "-toTop",
      "description": "For paths ending in Top",
      "required": true,
      "type": "flag"
    }
  ]
}