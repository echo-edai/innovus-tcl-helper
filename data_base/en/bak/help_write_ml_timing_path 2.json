{
  "command": "write_ml_timing_path",
  "is_cmd": true,
  "summary": "Writes ml timing path.",
  "description": "Writes ml timing path.",
  "usage": "write_ml_timing_path [-help] [-anchor_file <string>] [-begin_end_pair] [-chain_levels <int>] [-chain_path] [-each_endpoint] [-from <pin_list>] [-gen_anchor] [-hpin] [-io_only] [-max_paths <int>] [-max_slack <float>] [-nworst <int>] [-partitions <partition_list>] [-path_group <string>] [-per_partition] -prefix <string> [-retime {aocv ssta path_slew_propagation aocv_path_slew_propagation}] [-retime_mode {path exhaustive}] [-start_pathid <int>] [-to <pin_list>] [-verbose] [-views <view_list>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-anchor_file",
      "description": "Input anchor file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-begin_end_pair",
      "description": "Report all violation between unique source and target register pairs",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-chain_levels",
      "description": "chain level if chain_path is enabled",
      "required": false,
      "type": "int"
    },
    {
      "name": "-chain_path",
      "description": "Get chained paths",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-each_endpoint",
      "description": "Whether to dump at least one path for each end point",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-from",
      "description": "Dump data from the specified pin(s).",
      "required": false,
      "type": "string"
    },
    {
      "name": "-gen_anchor",
      "description": "Generate anchor file",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hpin",
      "description": "Dump hpin in timing points",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-io_only",
      "description": "io path only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-max_paths",
      "description": "max_paths for report_timing",
      "required": false,
      "type": "int"
    },
    {
      "name": "-max_slack",
      "description": "max_slack for report_timing",
      "required": false,
      "type": "float"
    },
    {
      "name": "-nworst",
      "description": "nworst for report_timing, default: 1",
      "required": false,
      "type": "int"
    },
    {
      "name": "-partitions",
      "description": "partition list if per_partition is set",
      "required": false,
      "type": "string"
    },
    {
      "name": "-path_group",
      "description": "the path_group for report_timing",
      "required": false,
      "type": "string"
    },
    {
      "name": "-per_partition",
      "description": "Only dump paths through top level partitions",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-prefix",
      "description": "Prefix for output files",
      "required": true,
      "type": "string"
    },
    {
      "name": "-retime",
      "description": "{aocv ssta path_slew_propagation aocv_path_slew_propagation} retime for report_timing",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-retime_mode",
      "description": "retime_mode for report_timing",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-start_pathid",
      "description": "Starting path id, default is 1",
      "required": false,
      "type": "int"
    },
    {
      "name": "-to",
      "description": "Dump data to the specified pin(s).",
      "required": false,
      "type": "string"
    },
    {
      "name": "-verbose",
      "description": "Display performance message",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-views",
      "description": "Dump timing path for the specified analysis view(s).",
      "required": false,
      "type": "string"
    }
  ]
}