{
  "command": "verifyPowerDomain",
  "is_cmd": true,
  "summary": "Verifies power domain.",
  "description": "Verifies power domain.",
  "usage": "verifyPowerDomain [-help] [-allInstInPD] [-antennaDiode {fileName ...}] [-aoBufferType] [-bind] [-cell_bind {cell ...}] [-drcFile <string>] [-isoNetPD {fileName ...}] [-libBindingVoltage] [-noFTermIsoC] [-noFTermShifter] [-powerSwitch {fileName ...}] [-pwrWithinMinGap] [-retention {fileName ...}] [-xNetPD {fileName ...}] [-place  [-place_rpt <string>]] [-gconn {module ...} [-aobBiasConn ]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allInstInPD",
      "description": "all insts are in domain",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-antennaDiode",
      "description": "verify antenna diode",
      "required": false,
      "type": "string"
    },
    {
      "name": "-aoBufferType",
      "description": "check AOB type in domain",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-aobBiasConn",
      "description": "check AOB bias net connection",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bind",
      "description": "verify library binding",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell_bind",
      "description": "list of cells",
      "required": false,
      "type": "string"
    },
    {
      "name": "-drcFile",
      "description": "create Design Rule Checking (DRC) violation markers and save them in the specified file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-gconn",
      "description": "list of modules",
      "required": false,
      "type": "string"
    },
    {
      "name": "-isoNetPD",
      "description": "verify isolation",
      "required": false,
      "type": "string"
    },
    {
      "name": "-libBindingVoltage",
      "description": "check voltage against binding library",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noFTermIsoC",
      "description": "ignore iso fterm",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noFTermShifter",
      "description": "ignore shifter fterm",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-place",
      "description": "check placement",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-place_rpt",
      "description": "placement output file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-powerSwitch",
      "description": "verify power_switch",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pwrWithinMinGap",
      "description": "check ring in minGap",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-retention",
      "description": "verify retention",
      "required": false,
      "type": "string"
    },
    {
      "name": "-xNetPD",
      "description": "verify shifter",
      "required": false,
      "type": "string"
    }
  ]
}