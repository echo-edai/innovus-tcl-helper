{
  "command": "set_cell_binding",
  "is_cmd": true,
  "summary": "Sets cell binding.",
  "description": "Sets cell binding.",
  "usage": "set_cell_binding [-help] [-abstract ] [-lib <list_of_libs>] { -cell <list_of_cell_patterns> -view <list_of_views> }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-abstract",
      "description": "abstract",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "Specifies one or more cell name patterns to replace",
      "required": true,
      "type": "string"
    },
    {
      "name": "-lib",
      "description": "Specifies the OpenAccess library to use to look for the cell abstracts",
      "required": true,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "Specifies the cell view",
      "required": true,
      "type": "string"
    }
  ]
}