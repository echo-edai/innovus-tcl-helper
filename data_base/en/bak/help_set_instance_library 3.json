{
  "command": "set_instance_library",
  "is_cmd": true,
  "summary": "Sets instance library.",
  "description": "Sets instance library.",
  "usage": "set_instance_library [-help] -library <string> -instance <string> [ -early  | -late  ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-early",
      "description": "Use this library binding for early timing analysis.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-instance",
      "description": "The instance for which the library binding needs to be done.",
      "required": true,
      "type": "string"
    },
    {
      "name": "-late",
      "description": "Use this library binding for late timing analysis.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-library",
      "description": "Library File Path",
      "required": true,
      "type": "string"
    }
  ]
}