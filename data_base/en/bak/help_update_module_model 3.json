{
  "command": "update_module_model",
  "is_cmd": true,
  "summary": "Updates module model.",
  "description": "Updates module model.",
  "usage": "update_module_model [-help] [-cpu <integer>] [-distribute_job] [-eco_report] [-log_dir <string>] [-return_tag <string>] [-return_type {lef flexIlm ilm pnr}] [-tag <string>] { [-cell <string>] [-distribute_run ] [ -interactive | -plugin_tcl <string> | -gen_eco_only ]}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "<cellName>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cpu",
      "description": "<number of cpus>",
      "required": false,
      "type": "int"
    },
    {
      "name": "-distribute_job",
      "description": "<setup update_module_model job for distributed run>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-distribute_run",
      "description": "<run update_module_model in distribute>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-eco_report",
      "description": "<report module model change>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-gen_eco_only",
      "description": "<generate eco file only>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-interactive",
      "description": "<interactive mode>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-log_dir",
      "description": "log file directory",
      "required": false,
      "type": "string"
    },
    {
      "name": "-plugin_tcl",
      "description": "<tcl_commands>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-return_tag",
      "description": "<tag of module model returned>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-return_type",
      "description": "<type of module model returned>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-tag",
      "description": "<module tag>",
      "required": false,
      "type": "string"
    }
  ]
}