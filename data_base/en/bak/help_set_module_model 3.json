{
  "command": "set_module_model",
  "is_cmd": true,
  "summary": "Sets module model.",
  "description": "Sets module model.",
  "usage": "set_module_model [-help] [-allow_port_mismatch] [-dir <string>] [-hold_views <string>] [-phys_hier] [-setup_views <string>] [-tag <string>] [-type <string>] [-update] {[[[[-cell <string>] [-default_set_options <string>]] | [-top <string> [-logical_only ]]] [-add_ons <string>]] | -default_dir <string> | -default_create_options <string> | -default_commit_options <string> | -active_rc_corners <string> }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-active_rc_corners",
      "description": "<active rc corner>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-add_ons",
      "description": "<associated with -type> 1801 boundary_model etm latency pnr_view scan_info spef timing_context extraction_context",
      "required": false,
      "type": "string"
    },
    {
      "name": "-allow_port_mismatch",
      "description": "Allow top-level I/O ports mismatching from the original db",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "<module name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-default_commit_options",
      "description": "<default commit options>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-default_create_options",
      "description": "<default create options>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-default_dir",
      "description": "<default model data directory>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-default_set_options",
      "description": "<set default options>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-dir",
      "description": "<model data directory>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-hold_views",
      "description": "<hold_views>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-logical_only",
      "description": "<read in logical data only>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-phys_hier",
      "description": "<setup physical hierarchy>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-setup_views",
      "description": "<setup views>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tag",
      "description": "<flow tag>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-top",
      "description": "<top module name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "<type of module model> lef flexIlm ilm pnr pnr_shell",
      "required": false,
      "type": "string"
    },
    {
      "name": "-update",
      "description": "Forced model update",
      "required": false,
      "type": "flag"
    }
  ]
}