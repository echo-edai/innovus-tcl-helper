{
  "command": "set_voltage_regulator_module",
  "is_cmd": true,
  "summary": "Sets voltage regulator module.",
  "description": "Sets voltage regulator module.",
  "usage": "set_voltage_regulator_module [-help] {-reset  | {-name <string> -netlist <string> -input_pwr_pin_mapping <string> -output_pwr_pin_mapping <string> -ground_pin_mapping <string> -component_list <string> [-subckt_name <string>]}}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-component_list",
      "description": "vrm_component_list",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ground_pin_mapping",
      "description": "{spice_pin_name [DEF_net_name]}+",
      "required": false,
      "type": "string"
    },
    {
      "name": "-input_pwr_pin_mapping",
      "description": "{spice_pin_name [DEF_net_name]}+",
      "required": false,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "<vrm_name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-netlist",
      "description": "<vrm_spice_netlist_file_name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output_pwr_pin_mapping",
      "description": "{spice_pin_name [DEF_net_name]}+",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "reset all vrm options",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-subckt_name",
      "description": "vrm_subckt_name",
      "required": false,
      "type": "string"
    }
  ]
}