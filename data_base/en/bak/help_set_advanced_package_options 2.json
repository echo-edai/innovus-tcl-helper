{
  "command": "set_advanced_package_options",
  "is_cmd": true,
  "summary": "Sets advanced package options.",
  "description": "Sets advanced package options.",
  "usage": "set_advanced_package_options [-help] -reset | {[-tool_path <string>] [{-net_mapping_file <string> }] }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-net_mapping_file",
      "description": "<def_name pkg_name two column format>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "<clear all settings>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tool_path",
      "description": "<bin folder of package analysis tool>",
      "required": false,
      "type": "string"
    }
  ]
}