{
  "command": "setAnalysisMode",
  "is_cmd": true,
  "summary": "Sets analysis mode.",
  "description": "Sets analysis mode.",
  "usage": "setAnalysisMode [-help] [-reset] [-aging {true|false}] [-analysisType {single|bcwc|onChipVariation}] [-asyncChecks {async|noAsync|asyncOnly|auto}] [-caseAnalysis {true|false}] [-checkType {setup|hold}] [-clkNetsMarking {beforeConstProp|afterConstProp}] [-clkSrcPath {true|false}] [-clockGatingCheck {true|false}] [-clockPropagation {sdcControl|forcedIdeal|autoDetectClockTree}] [-cppr {both|none|setup|hold}] [-honorActiveLogicView {true|false}] [-honorClockDomains {true|false}] [-log {true|false}] [-multi_input_switching_mode <value>] [-propSlew {true|false}] [-sequentialConstProp {true|false}] [-skew {true|false}] [-slackBalancing {true|false}] [-timeBorrowing {true|false}] [-timing_robustness {true|false}] [-timingEngine {statistical|static|rql}] [-timingSelfLoopsNoSkew {true|false}] [-usefulSkew {true|false}] [-useOutputPinCap {true|false}] [-warn {true|false}] [-socv {true|false} | -aocv {true|false}]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "Resets all or specified options to default value",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-aging",
      "description": "Aging Analysis",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-analysisType",
      "description": "{single|bcwc|onChipVariation} Single or BCWC or OCV TimingAnalysis type",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-aocv",
      "description": "AOCV Analysis",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-asyncChecks",
      "description": "{async|noAsync|asyncOnly|auto} Async checks",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-caseAnalysis",
      "description": "caseAnalysis",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-checkType",
      "description": "Report Violations for hold, setup",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-clkNetsMarking",
      "description": "{beforeConstProp|afterConstProp} clkNetsMarking",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-clkSrcPath",
      "description": "clkSrcPath",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clockGatingCheck",
      "description": "clockGatingCheck",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clockPropagation",
      "description": "{sdcControl|forcedIdeal|autoDetectClockTree} Timing arc attributes effect on timing analysis",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-cppr",
      "description": "Removes pessimism from clock paths that have a portion of the clock network in common between the clock source and clock destination paths",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-honorActiveLogicView",
      "description": "Honor Active Logic View",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-honorClockDomains",
      "description": "Honor Clock Domains",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-log",
      "description": "log",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-multi_input_switching_mode",
      "description": "Specify MIS mode: 0,Simultaneous input switching is not considered 1,MIS analysis consider cells for which multiple inputs of a cell tied together (tied-inputs) 2,MIS analysis consider both tied-inputs and inputs of a cells switching independent to each other 3,derate based MIS analysis",
      "required": false,
      "type": "int"
    },
    {
      "name": "-propSlew",
      "description": "Controls interconnect slew degradation for early paths.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-sequentialConstProp",
      "description": "sequentialConstProp",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skew",
      "description": "skew",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-slackBalancing",
      "description": "",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-socv",
      "description": "SOCV Analysis",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-timeBorrowing",
      "description": "timeBorrowing",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-timing_robustness",
      "description": "Timing Robustness Analysis",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-timingEngine",
      "description": "Statistical or Static or Rql",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-timingSelfLoopsNoSkew",
      "description": "Eliminates clock skew due to clock uncertainty for a path starting and ending at the same register. If the clock skew is not eliminated, the timing for such paths is pessimistic",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-usefulSkew",
      "description": "UsefulSkew",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-useOutputPinCap",
      "description": "useOutputPinCap",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-warn",
      "description": "warn",
      "required": false,
      "type": "flag"
    }
  ]
}