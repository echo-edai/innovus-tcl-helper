{
  "command": "selectPGPin",
  "is_cmd": true,
  "summary": "Selects pgpin.",
  "description": "Selects pgpin.",
  "usage": "selectPGPin [-help] [-all] [-area {x1 y1 x2 y2}] [-layer <layer> | {list_of_layer}] [-net <name>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "Specifies whether to select all PG pins",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-area",
      "description": "Specifies the coordinates of the area",
      "required": false,
      "type": "point"
    },
    {
      "name": "-layer",
      "description": "Specifies layers",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "Specifies net name ((net)+, optional)",
      "required": false,
      "type": "string"
    }
  ]
}