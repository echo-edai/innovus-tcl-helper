{
  "command": "set_self_heat_analysis_mode",
  "is_cmd": true,
  "summary": "Sets self heat analysis mode.",
  "description": "Sets self heat analysis mode.",
  "usage": "set_self_heat_analysis_mode [-help] [-alpha_parameters <string>] [-beta_parameters <string>] [-cell_thermal_resistance_file <string>] [-detail_delta_temperature_file <string>] [-detail_delta_temperature_region <string>] [-die_instance_input_signal_em <string>] [-die_instance_name <string>] [-instance_power_file <string>] [-report_conn_pin_wire <string>] [-scale_rms_limit <float>] [-tiles <string>] [ -tile_delta_temperature_file <string> ] [ -instance_delta_temperature_file <string> ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-alpha_parameters",
      "description": "self heat alpha layer parameters",
      "required": false,
      "type": "string"
    },
    {
      "name": "-beta_parameters",
      "description": "self heat beta parameters",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell_thermal_resistance_file",
      "description": "<input: cell's equivalent thermal resistance file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-detail_delta_temperature_file",
      "description": "detailed delta temperature file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-detail_delta_temperature_region",
      "description": "<string> detailed delta temperature region",
      "required": false,
      "type": "string"
    },
    {
      "name": "-die_instance_input_signal_em",
      "description": "input signal self-heat related setting per die",
      "required": false,
      "type": "string"
    },
    {
      "name": "-die_instance_name",
      "description": "<die instance name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance_delta_temperature_file",
      "description": "<string> instance delta temperature file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance_power_file",
      "description": "instance power file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-report_conn_pin_wire",
      "description": "report results on wires connecting to cell pins",
      "required": false,
      "type": "string"
    },
    {
      "name": "-scale_rms_limit",
      "description": "<RMS EM limit scale factor>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-tile_delta_temperature_file",
      "description": "tile delta temperature file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tiles",
      "description": "number of map tiles <num_x num_y>",
      "required": false,
      "type": "string"
    }
  ]
}