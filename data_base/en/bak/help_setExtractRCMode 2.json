{
  "command": "setExtractRCMode",
  "is_cmd": true,
  "summary": "Sets extract rcmode.",
  "description": "Sets extract rcmode.",
  "usage": "setExtractRCMode [-help] [-reset] [-assumeMetFill <scalevalue>] [-capFilterMode {relOnly|relAndCoup|relOrCoup}] [-cerebrus_license_only {true|false}] [-compressOptMemRCDB {true|false}] [-coupled {true|false}] [-coupling_c_th <value>] [-defViaCap {true|false}] [-effortLevel {low|medium|high|signoff}] [-engine {preRoute|postRoute}] [-extraCmdFile <file>] [-extract_rc_quantus_executable <file_path>] [-extract_rc_signoff_stream_layer_map_ccl <file_name>] [-extractionFillStreamMapFile <file>] [-hardBlockObs {true|false}] [-incremental {true|false}] [-iquantus_cap_high_accuracy_mode {true|false}] [-layerIndependent {0|1}] [-lefTechFileMap <file_name>] [-localCpu <number>] [-pvs_fill {true|false}] [-qrcCmdFile <file_name>] [-qrcCmdType {auto|partial|custom}] [-qrcOutputMode {spef|rcdb}] [-qrcRunMode {concurrent|sequential}] [-relative_c_th <value>] [-signoff_stream_layer_map <file_name>] [-total_c_th <value>] [-tQuantusModelFile <file_name>] [-tsvSubcktFile <file_name>] [-turboReduce {true|false|auto}] [-useQrcOAInterface {true|false}] [-useShieldingInDetailMode {true|false}] [-viaCap {true|false}] [-writeDefOptionsForSignoffExtract <def_options>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "Resets all or specified options to default value",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-assumeMetFill",
      "description": "Assume metal fill",
      "required": false,
      "type": "float"
    },
    {
      "name": "-capFilterMode",
      "description": "{relOnly|relAndCoup|relOrCoup} Coupling Capacitance Filtering Mode",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-cerebrus_license_only",
      "description": "Fall back to the regular QTS license(s) when Cerebrus is not available",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-compressOptMemRCDB",
      "description": "Create compressed RCDB",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-coupled",
      "description": "Extract coupling cap",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-coupling_c_th",
      "description": "Coupling C threshold value",
      "required": false,
      "type": "float"
    },
    {
      "name": "-defViaCap",
      "description": "Consider via caps for extraction",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-effortLevel",
      "description": "Specifies the effort level of the post-route extraction engine",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-engine",
      "description": "Extraction engine",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-extraCmdFile",
      "description": "Extra command file for Quantus QRC",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extract_rc_quantus_executable",
      "description": "<file_path> QRC Executable file path",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extract_rc_signoff_stream_layer_map_ccl",
      "description": "<file_name> QRC stream map file in CCL format",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extractionFillStreamMapFile",
      "description": "Quantus stream/oasis file",
      "required": false,
      "type": "string"
    },
    {
