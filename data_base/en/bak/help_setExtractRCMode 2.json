      "required": false,
      "type": "flag"
    },
    {
      "name": "-incremental",
      "description": "Use incremental signoff mode",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-iquantus_cap_high_accuracy_mode",
      "description": "{true|false} Use for iquantus capacitance high accuracy mode",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-layerIndependent",
      "description": "Enable layer independent extraction",
      "required": false,
      "type": "int"
    },
    {
      "name": "-lefTechFileMap",
      "description": "LEF-QRCTechfile layer map file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-localCpu",
      "description": "",
      "required": false,
      "type": "int"
    },
    {
      "name": "-pvs_fill",
      "description": "Use to send the PVS fill data attached to the Innovus DB (see set_pvs_fill) to Quantus",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-qrcCmdFile",
      "description": "Quantus QRC user command file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-qrcCmdType",
      "description": "Quantus QRC command input type",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-qrcOutputMode",
      "description": "Quantus QRC output mode",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-qrcRunMode",
      "description": "Quantus QRC MMMC run mode",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-relative_c_th",
      "description": "Relative C threshold value",
      "required": false,
      "type": "float"
    },
    {
      "name": "-signoff_stream_layer_map",
      "description": "QRC stream map file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-total_c_th",
      "description": "Total C threshold value",
      "required": false,
      "type": "float"
    },
    {
      "name": "-tQuantusModelFile",
      "description": "TQuantus model file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tsvSubcktFile",
      "description": "TSV subckt file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-turboReduce",
      "description": "Reduce XCap (IQuantus)",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-useQrcOAInterface",
      "description": "Use OA interface for invoking Quantus QRC extraction",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-useShieldingInDetailMode",
      "description": "Considers shielding for a wire segment",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-viaCap",
      "description": "Consider via caps for extraction",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-writeDefOptionsForSignoffExtract",
      "description": "<def_options> write_def options",
      "required": false,
      "type": "string"
    }
  ]
}