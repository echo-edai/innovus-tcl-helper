{
  "command": "update_partition",
  "is_cmd": true,
  "summary": "Updates partition.",
  "description": "Updates partition.",
  "usage": "update_partition [-help] [-pinLocation] [-postECOSuffix <string>] {-flexIlmECO } { -goldenBlockDir <string>} -flexIlmDir <string> [-ecoDir <string>] [-fullNetlistWithECODir <string> -flexILMECODir <string> ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ecoDir",
      "description": "<directory to run ECO job>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-flexILMECODir",
      "description": "<directory to store ECO job>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-flexIlmDir",
      "description": "<postOpt FlexILM data directory>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-flexIlmECO",
      "description": "<perform ECO on FlexILM modules>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-fullNetlistWithECODir",
      "description": "<directory to store full netllist ECO result>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-goldenBlockDir",
      "description": "<original block directory>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pinLocation",
      "description": "<update pin location in golden DB>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-postECOSuffix",
      "description": "<user specified post ECO DB suffix>",
      "required": false,
      "type": "string"
    }
  ]
}