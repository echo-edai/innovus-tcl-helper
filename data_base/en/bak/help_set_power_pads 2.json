{
  "command": "set_power_pads",
  "is_cmd": true,
  "summary": "Sets power pads.",
  "description": "Sets power pads.",
  "usage": "set_power_pads [-help] {-reset  | {[-format {defpin padcell xy xyiv boundary} [-file <string>] [-short_pin_nodes {true false}]] [-net <string>] [-auto_voltage_source_creation {true false} [-tile <string>] [-region <string>] [-layer <string>] [-number_of_voltage_source <integer>] [-def_shape_only {true false}] [-consider_partial_small_tiles_for_vsrc {true false}] [-enable_switchnet_ploc_generation {true false}]] [-die_instance_name <string>]}}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-auto_voltage_source_creation",
      "description": "{true false} <true | false>",
      "required": true,
      "type": "enum"
    },
    {
      "name": "-consider_partial_small_tiles_for_vsrc",
      "description": "{true false} <true | false>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-def_shape_only",
      "description": "<true | false>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-die_instance_name",
      "description": "<die instance name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-enable_switchnet_ploc_generation",
      "description": "{true false} <true | false>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-file",
      "description": "<power pad file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-format",
      "description": "{defpin padcell xy xyiv boundary} <format: defpin | padcell | xy | xyiv | boundary>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-layer",
      "description": "<via layer name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "<net name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-number_of_voltage_source",
      "description": "<restrict max number of bump>",
      "required": false,
      "type": "int"
    },
    {
      "name": "-region",
      "description": "region {llx lly urx ury} (um)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "<reset all previous set_power_pads commands>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-short_pin_nodes",
      "description": "<true | false>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-tile",
      "description": "tile {x y} (um)",
      "required": false,
      "type": "string"
    }
  ]
}