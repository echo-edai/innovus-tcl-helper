{
  "command": "route_pg",
  "is_cmd": true,
  "summary": "Routes pg.",
  "description": "Routes pg.",
  "usage": "route_pg [-help] [-check_psdl_only] [-connect_floating_net <string>] [-delete_floating] [-fast] [-post_cut_color] [-psdl_file <file_name>] [-skip_block_pin] [-skip_partial_overlap_via] [-skip_physical_pin] [-skip_via] [-stop_on_error] [-use_full_pattern] [-use_namespace] [-write_psdl <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-check_psdl_only",
      "description": "Perform sanity check on PSDL input file only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-connect_floating_net",
      "description": "Connect floating wires of specified net name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-delete_floating",
      "description": "Remove floating wires",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-fast",
      "description": "Generate PG in fast mode",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-post_cut_color",
      "description": "Enable post cut color",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-psdl_file",
      "description": "PSDL input file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-skip_block_pin",
      "description": "Skip connection to block pins",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skip_partial_overlap_via",
      "description": "Skip building via on partial overlap intersection",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skip_physical_pin",
      "description": "Skip creating physical pin on the design boundary",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skip_via",
      "description": "Skip building via object",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-stop_on_error",
      "description": "Stop pgroute process if there is any error in PSDL file",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-use_full_pattern",
      "description": "Only allow full PATTERN",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-use_namespace",
      "description": "Use namespace for METAL id",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-write_psdl",
      "description": "Write a PSDL file for checking",
      "required": false,
      "type": "string"
    }
  ]
}