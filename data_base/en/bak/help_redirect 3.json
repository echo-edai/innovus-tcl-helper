{
  "command": "redirect",
  "is_cmd": true,
  "summary": "Executes the 'redirect' command.",
  "description": "Executes the 'redirect' command.",
  "usage": "redirect [-help] [<file_or_var_name>] [<command>] [-tee] [-stdin | -append ] [-stdin | -variable ] [ -variable ] [-stderr | -stdin ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage <file_or_var_name> # file name or variable name, for outputs to go (string, optional) <command> # command to execute",
      "required": false,
      "type": "string"
    },
    {
      "name": "-append",
      "description": "append stdout/stderr to file",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-stderr",
      "description": "redirect stderr also",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-stdin",
      "description": "redirect stdin",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-tee",
      "description": "redirect output to both screen and file or variable",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-variable",
      "description": "redirect to a Tcl variable",
      "required": false,
      "type": "flag"
    }
  ]
}