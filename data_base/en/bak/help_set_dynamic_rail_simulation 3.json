{
  "command": "set_dynamic_rail_simulation",
  "is_cmd": true,
  "summary": "Sets dynamic rail simulation.",
  "description": "Sets dynamic rail simulation.",
  "usage": "set_dynamic_rail_simulation [-help] [-auto_repeat] [-reset] [-resolution <float>] [-start <float>] [-stop <float>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-auto_repeat",
      "description": "repeat waveform to stop time",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "reset all values",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-resolution",
      "description": "<pace in ps>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-start",
      "description": "<start time in ns>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-stop",
      "description": "<stop time in ns>",
      "required": false,
      "type": "float"
    }
  ]
}