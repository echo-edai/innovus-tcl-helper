{
  "command": "trim_pg_library",
  "is_cmd": true,
  "summary": "Trims pg library.",
  "description": "Trims pg library.",
  "usage": "trim_pg_library [-help] [-delete_cells <string>] [-delete_cells_file <string>] -library_list_file <string> [-output <string>] -output_library <string>",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-delete_cells",
      "description": "cellName",
      "required": false,
      "type": "string"
    },
    {
      "name": "-delete_cells_file",
      "description": "cellNameFile",
      "required": false,
      "type": "string"
    },
    {
      "name": "-library_list_file",
      "description": "<absolute library path>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-output",
      "description": "<directory name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output_library",
      "description": "newLibraryName",
      "required": true,
      "type": "string"
    }
  ]
}