      "required": false,
      "type": "flag"
    },
    {
      "name": "-line",
      "description": "Deselect by line",
      "required": false,
      "type": "point"
    },
    {
      "name": "-point",
      "description": "Deselect by point",
      "required": false,
      "type": "int"
    },
    {
      "name": "-rect",
      "description": "Deselect by box",
      "required": false,
      "type": "point"
    }
  ]
}