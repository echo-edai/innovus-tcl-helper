{
  "command": "check_ufc",
  "is_cmd": true,
  "summary": "Checks ufc.",
  "description": "Checks ufc.",
  "usage": "check_ufc [-help] <fn> [-report_file <string>] [-report_unplaced_block] [ -selected_rules <string>] [ -include_all_rules ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<fn>",
      "description": "Specify filename",
      "required": true,
      "type": "string"
    },
    {
      "name": "-include_all_rules",
      "description": "Specify whether tool report all rules' summary of violations.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-report_file",
      "description": "Specify file name which tool will puts the summary of violations.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-report_unplaced_block",
      "description": "Enable tool to show the number of unplaced macros in summary",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-selected_rules",
      "description": "selected rules only",
      "required": false,
      "type": "string"
    }
  ]
}