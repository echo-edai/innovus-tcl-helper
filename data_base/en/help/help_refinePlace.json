{
  "command": "refinePlace",
  "is_cmd": true,
  "summary": "Refines place.",
  "description": "Refines place.",
  "usage": "refinePlace [-help] [-area {lx ly ux uy}] [-eco {true|false}] [-inst <value>] [-wire_length_reclaim {true|false}]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-area",
      "description": "specify refinePlace area in um",
      "required": false,
      "type": "point"
    },
    {
      "name": "-eco",
      "description": "activate ECO mode for post-route design",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-inst",
      "description": "specify a list of instances for refinePlace to legalizes only",
      "required": false,
      "type": "string"
    },
    {
      "name": "-wire_length_reclaim",
      "description": "activate wire length reclaim mode",
      "required": false,
      "type": "flag"
    }
  ]
}