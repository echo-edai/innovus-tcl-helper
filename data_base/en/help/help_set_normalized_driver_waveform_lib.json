{
  "command": "set_normalized_driver_waveform_lib",
  "is_cmd": true,
  "summary": "Sets normalized driver waveform lib.",
  "description": "Sets normalized driver waveform lib.",
  "usage": "set_normalized_driver_waveform_lib [-help] [-fall_waveform <string>] [-rise_waveform <string>] -ref_lib <string>  -libs <string>",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-fall_waveform",
      "description": "Fall normalized driver waveform name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-libs",
      "description": "List of space separated libraries to which normalized driver waveform is to be applied",
      "required": true,
      "type": "string"
    },
    {
      "name": "-ref_lib",
      "description": "Reference library from which normalized driver waveform is to be selected.",
      "required": true,
      "type": "string"
    },
    {
      "name": "-rise_waveform",
      "description": "Rise normalized driver waveform name",
      "required": false,
      "type": "string"
    }
  ]
}