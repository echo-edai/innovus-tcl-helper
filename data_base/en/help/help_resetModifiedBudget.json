{
  "command": "resetModifiedBudget",
  "is_cmd": true,
  "summary": "Resets modified budget.",
  "description": "Resets modified budget.",
  "usage": "resetModifiedBudget [-help] -pin <string> [-view <string>] {-ptn <string> | -inst <string>} [-setup  | -hold  ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hold",
      "description": "reset hold information",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-inst",
      "description": "hierarchical instance for which manual budgets would be reset",
      "required": true,
      "type": "string"
    },
    {
      "name": "-pin",
      "description": "pin to be reset, use * for all pins",
      "required": true,
      "type": "string"
    },
    {
      "name": "-ptn",
      "description": "partition for which manual budgets would be reset",
      "required": true,
      "type": "string"
    },
    {
      "name": "-setup",
      "description": "reset setup information",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view",
      "description": "reset modified budgets for a specific view only",
      "required": false,
      "type": "string"
    }
  ]
}