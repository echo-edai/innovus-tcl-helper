{
  "command": "reset_glitch_derate",
  "is_cmd": true,
  "summary": "Resets glitch derate.",
  "description": "Resets glitch derate.",
  "usage": "reset_glitch_derate [-help] [-derate_height] [-derate_width] [-glitch_type <string>] [-instance_pin <string>] [-offset] [-pin <string>] [-view <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-derate_height",
      "description": "reset derate height",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-derate_width",
      "description": "reset derate width",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-glitch_type",
      "description": "glitch type vl, vh or both",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance_pin",
      "description": "instane pin names on which derate is to be reset",
      "required": false,
      "type": "string"
    },
    {
      "name": "-offset",
      "description": "reset derate offset",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pin",
      "description": "library pin names on which derate is to be reset",
      "required": false,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "view name",
      "required": false,
      "type": "string"
    }
  ]
}