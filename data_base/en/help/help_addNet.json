{
  "command": "addNet",
  "is_cmd": true,
  "summary": "Adds net.",
  "description": "Adds net.",
  "usage": "addNet [-help] [-bus <msb:lsb>] { <netName> } [ -moduleBased <moduleName> ] [-power | -ground ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<netName>",
      "description": "Name of Net",
      "required": true,
      "type": "string"
    },
    {
      "name": "-bus",
      "description": "Bit range for bus nets",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ground",
      "description": "Create a ground net",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-moduleBased",
      "description": "Name of verilog module ((vCell|topCell), optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-power",
      "description": "Create a power net",
      "required": false,
      "type": "flag"
    }
  ]
}