{
  "command": "alias",
  "is_cmd": true,
  "summary": "Executes the 'alias' command.",
  "description": "Executes the 'alias' command.",
  "usage": "alias [-help] <new_cmd> [<old_cmd>] [-args {{<new> <old>} ...}]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<new_cmd>",
      "description": "A new alias command name. It can be the same as <old_name> if you only want to add -args aliases.",
      "required": true,
      "type": "string"
    },
    {
      "name": "<old_cmd>",
      "description": "An existing command name.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-args",
      "description": "A list of old arg and new alias arg names.",
      "required": false,
      "type": "string"
    }
  ]
}