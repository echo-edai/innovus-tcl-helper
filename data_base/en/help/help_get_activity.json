{
  "command": "get_activity",
  "is_cmd": true,
  "summary": "Gets activity.",
  "description": "Gets activity.",
  "usage": "get_activity [-help] [-instance <string>] [-list_of_nets_based_on_driver <string>] [-list_of_nets_based_on_source_of_activity_info <string>] [-net <string>] [-outfile <string>] [-pin <string>] [-port <string>] [-report_average_switching_activity] [-report_cell_group_activity_summary_report] [-summary] [-tcl_list]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-instance",
      "description": "instance name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-list_of_nets_based_on_driver",
      "description": "list of nets based on driver",
      "required": false,
      "type": "string"
    },
    {
      "name": "-list_of_nets_based_on_source_of_activity_info",
      "description": "<string> list of nets based on source of activity info",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "net list to get activity source",
      "required": false,
      "type": "string"
    },
    {
      "name": "-outfile",
      "description": "output file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pin",
      "description": "pin list to get activity source",
      "required": false,
      "type": "string"
    },
    {
      "name": "-port",
      "description": "port list to get activity source",
      "required": false,
      "type": "string"
    },
    {
      "name": "-report_average_switching_activity",
      "description": "report average switching activity",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-report_cell_group_activity_summary_report",
      "description": "generate summary report of cell group activity",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-summary",
      "description": "turn on type summary",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-tcl_list",
      "description": "return tcl list",
      "required": false,
      "type": "flag"
    }
  ]
}