    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bump",
      "description": "specifies the name of bump",
      "required": true,
      "type": "string"
    },
    {
      "name": "-instName",
      "description": "specifies the name of I/O instance",
      "required": true,
      "type": "string"
    },
    {
      "name": "-pinName",
      "description": "specifies the name of pin on I/O instance",
      "required": true,
      "type": "string"
    }
  ]
}