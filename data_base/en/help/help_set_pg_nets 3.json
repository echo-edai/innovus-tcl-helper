{
  "command": "set_pg_nets",
  "is_cmd": true,
  "summary": "Sets pg nets.",
  "description": "Sets pg nets.",
  "usage": "set_pg_nets [-help] [-die_instance_name <string>] [-force] [-pkg_net_name <string>] [-vu_limit <float>] -reset  | {-net <string> -voltage <float> [-lib_binding_voltage <float>] [-threshold <float>] [-tolerance <float>] }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-die_instance_name",
      "description": "<die instance name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-force",
      "description": "<skip validity checking>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-lib_binding_voltage",
      "description": "<voltage for lib binding>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-net",
      "description": "<net name>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-pkg_net_name",
      "description": "<specify net name on the package side>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "<reset all pg data>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-threshold",
      "description": "<net threshold>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-tolerance",
      "description": "<net tolerance>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-voltage",
      "description": "<net voltage>",
      "required": true,
      "type": "float"
    },
    {
      "name": "-vu_limit",
      "description": "<vu limit>",
      "required": false,
      "type": "float"
    }
  ]
}