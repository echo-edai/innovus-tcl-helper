{
  "command": "defIn",
  "is_cmd": true,
  "summary": "Executes the 'defIn' command.",
  "description": "Executes the 'defIn' command.",
  "usage": "defIn [-help] <fileName> [-add_blockage] [-add_power_switch] [-allWarning] [-components] [-deleteBump] [-deleteSpecialRoute] [-ignore_drcfill] [-ignore_pg_connectivity] [-nets] [-override_special_routing {pg signal logical physical all}] [-preserveShape] [-removeHalfWireExtensionOnPin] [-specialRouteUserClass <string>] [-specialnets] [-verilog_from_def_netlist_flow] [ -incremental_routing ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<fileName>",
      "description": "Def filename",
      "required": true,
      "type": "string"
    },
    {
      "name": "-add_blockage",
      "description": "indicate it's a reduced netlist and undefined instances are converted to blockages",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-add_power_switch",
      "description": "Add power switch for missing DEF components",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allWarning",
      "description": "Lists all warning message",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-components",
      "description": "Read COMPONENTS",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-deleteBump",
      "description": "Delete bump",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-deleteSpecialRoute",
      "description": "Delete special route",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ignore_drcfill",
      "description": "Ignore the special routing with DRCFILL shape attribute",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ignore_pg_connectivity",
      "description": "Ignore the pg connectivity in both SPECIALNETS and NETS section",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-incremental_routing",
      "description": "Incremental read nets",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-nets",
      "description": "Read NETS",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-override_special_routing",
      "description": "{pg signal logical physical all} Delete special routing in db on nets specified in def file by net type",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-preserveShape",
      "description": "preserveShape",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-removeHalfWireExtensionOnPin",
      "description": "Truncates the half-width",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-specialRouteUserClass",
      "description": "User Class for special route",
      "required": false,
      "type": "string"
    },
    {
      "name": "-specialnets",
      "description": "Read SPECIALNETS",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-verilog_from_def_netlist_flow",
      "description": "Reconciles name in DEF and Verilog",
      "required": false,
      "type": "flag"
    }
  ]
}