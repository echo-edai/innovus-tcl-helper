{
  "command": "assemble_proto_model",
  "is_cmd": true,
  "summary": "Assembles proto model.",
  "description": "Assembles proto model.",
  "usage": "assemble_proto_model [-help] [-cpf_file <cpfFileName>] [-mmmc_file <mmmcfileName>] {-blockdir {blockDesignDir [protoModeldirName]}} {-topdir {topDesignDir [protoModelDirName]}}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-blockdir",
      "description": "{blockDesignDir [protoModeldirName]} The directory which contains the block level design",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cpf_file",
      "description": "Chip level cpf file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mmmc_file",
      "description": "Chip level mmmc file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-topdir",
      "description": "{topDesignDir [protoModelDirName]} The directory which contains the top level design",
      "required": false,
      "type": "string"
    }
  ]
}