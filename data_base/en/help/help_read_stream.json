{
  "command": "read_stream",
  "is_cmd": true,
  "summary": "Reads stream.",
  "description": "Reads stream.",
  "usage": "read_stream [-help] -layer_map <string> {[-pvs_fill ] | [[<in_files>] [-cells <string> [-offset {x y}]]]}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<in_files>",
      "description": "GDS and OASIS file list",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cells",
      "description": "Only read in the specified cells from gds files.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer_map",
      "description": "layer map file map GDS layer to design layer",
      "required": true,
      "type": "string"
    },
    {
      "name": "-offset",
      "description": "-offset x y",
      "required": false,
      "type": "int"
    },
    {
      "name": "-pvs_fill",
      "description": "PVS FILL data need to be processed in read process",
      "required": false,
      "type": "flag"
    }
  ]
}