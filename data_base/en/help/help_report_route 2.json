{
  "command": "report_route",
  "is_cmd": true,
  "summary": "Reports route.",
  "description": "Reports route.",
  "usage": "report_route [-help] [-clock] [-em] [-fanout <integer>] [-fill] [-inst <string>] [-multi_cut] [-ndr] [-net <string>] [-net_length <float>] [-patch] [-pg_net <string>] [-secondary_pg_nets <string>] [-selected] [-shield] [-summary] [-tap_cells] [-via_pillar] [-track_utilization  [-area {{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...} | -view_window ] [-layer <string>] [-include_regular_routes ]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-area",
      "description": "{{lx1 ly1 ux1 uy1} {lx2 ly2 ux2 uy2}...} specify one or more areas",
      "required": false,
      "type": "point"
    },
    {
      "name": "-clock",
      "description": "clock net",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-em",
      "description": "report EM statistics of nets",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-fanout",
      "description": "minimum fanout for limit",
      "required": false,
      "type": "int"
    },
    {
      "name": "-fill",
      "description": "patch wire and active fill information",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-include_regular_routes",
      "description": "report track utilization",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-inst",
      "description": "Instance name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer",
      "description": "limit report to layer or layer_range as in -layer <> | -layer <>:<>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-multi_cut",
      "description": "multiple cut vias",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ndr",
      "description": "Non Default Rule",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-net",
      "description": "net name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net_length",
      "description": "minimal net length in um",
      "required": false,
      "type": "float"
    },
    {
      "name": "-patch",
      "description": "add patch wire info section",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pg_net",
      "description": "PG net name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-secondary_pg_nets",
      "description": "second pg pin information",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selected",
      "description": "selected net",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-shield",
      "description": "shielded net",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-summary",
      "description": "summary",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-tap_cells",
      "description": "report shield with tap cells",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-track_utilization",
      "description": "report track utilization",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-via_pillar",
      "description": "Via Pillar",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view_window",
      "description": "report area in ui_view_box",
      "required": false,
      "type": "flag"
    }
  ]
}