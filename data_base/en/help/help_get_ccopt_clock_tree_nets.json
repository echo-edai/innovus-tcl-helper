{
  "command": "get_ccopt_clock_tree_nets",
  "is_cmd": true,
  "summary": "Gets ccopt clock tree nets.",
  "description": "Gets ccopt clock tree nets.",
  "usage": "get_ccopt_clock_tree_nets [-help] [<pattern>] [-in_clock_trees <trees>] [-net_types <leaf|trunk|top>] [-not_in_clock_trees <trees>] [-regexp]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pattern>",
      "description": "pattern for clock trees to return",
      "required": false,
      "type": "string"
    },
    {
      "name": "-in_clock_trees",
      "description": "return nets only in these clock trees",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net_types",
      "description": "return nets of this type",
      "required": false,
      "type": "string"
    },
    {
      "name": "-not_in_clock_trees",
      "description": "return nets not in these clock trees",
      "required": false,
      "type": "string"
    },
    {
      "name": "-regexp",
      "description": "use regexp matching instead of wildcard (glob)",
      "required": false,
      "type": "flag"
    }
  ]
}