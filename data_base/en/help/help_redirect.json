{
  "command": "redirect",
  "is_cmd": true,
  "summary": "Redirects the design.",
  "description": "Redirects the design.",
  "usage": "redirect [-help] [<file_or_var_name>] [<command>] [-tee] [-stdin | -append ] [-stdin | -variable ] [ -variable ] [-stderr | -stdin ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<file_or_var_name>",
      "description": "file name or variable name, for outputs to go",
      "required": false,
      "type": "string"
    },
    {
      "name": "<command>",
      "description": "command to execute",
      "required": false,
      "type": "string"
    },
    {
      "name": "-append",
      "description": "append stdout/stderr to file",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-stderr",
      "description": "redirect stderr also",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-stdin",
      "description": "redirect stdin",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-tee",
      "description": "redirect output to both screen and file or variable",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-variable",
      "description": "redirect to a Tcl variable",
      "required": false,
      "type": "flag"
    }
  ]
}