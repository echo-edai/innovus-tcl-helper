{
  "command": "runCLP",
  "is_cmd": true,
  "summary": "Runs clp.",
  "description": "Runs clp.",
  "usage": "runCLP [-help] [-cmd <string>] [-cpf <string>] [-extraLib <string>] [-extraVlog <string>] [-post_synthesis] [-setupOnly] [-useEEQCellWithLibertyInfo] [-user_config <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cmd",
      "description": "user do file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cpf",
      "description": "user CPF",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extraLib",
      "description": "extr libraries",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extraVlog",
      "description": "extra Verilog",
      "required": false,
      "type": "string"
    },
    {
      "name": "-post_synthesis",
      "description": "-post_synthesis mode",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-setupOnly",
      "description": "setup only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-useEEQCellWithLibertyInfo",
      "description": "use EEQ cell in netlist",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-user_config",
      "description": "user config file",
      "required": false,
      "type": "string"
    }
  ]
}