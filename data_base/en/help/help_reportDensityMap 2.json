{
  "command": "reportDensityMap",
  "is_cmd": true,
  "summary": "Reports density map.",
  "description": "Reports density map.",
  "usage": "reportDensityMap [-help] [-gridInMicron <micron>] [-gridInRow <nrRow>] [-ignoreBlock {true|false}] [-ignoreFiller {true|false}] [-threshold <density>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-gridInMicron",
      "description": "specify the value (in micron) of side of square grid for density calculations.",
      "required": false,
      "type": "float"
    },
    {
      "name": "-gridInRow",
      "description": "specify the value (in row-height) of side of square grid for density calculations.",
      "required": false,
      "type": "int"
    },
    {
      "name": "-ignoreBlock",
      "description": "",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ignoreFiller",
      "description": "",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-threshold",
      "description": "threshold value over which the densities must be reported.",
      "required": false,
      "type": "float"
    }
  ]
}