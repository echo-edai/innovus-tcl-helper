{
  "command": "setPGPinUseSignalRoute",
  "is_cmd": true,
  "summary": "Sets pgpin use signal route.",
  "description": "Sets pgpin use signal route.",
  "usage": "setPGPinUseSignalRoute [-help] [<cellPins>] [-all] [-off] [-well]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage <cellPins> # cell:pin pair",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "route all backup and non-main_rail primary power/ground pins",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-off",
      "description": "reset",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-well",
      "description": "include nwell and pwell pins",
      "required": false,
      "type": "flag"
    }
  ]
}