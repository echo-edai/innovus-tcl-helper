{
  "command": "check_tcic",
  "is_cmd": true,
  "summary": "Checks tcic.",
  "description": "Checks tcic.",
  "usage": "check_tcic [-help] [<files>] [-pre_opt] [-report_area] [-report_file <string>] [-report_unplaced_block] [ -include_all_rules ] [-selected_rules <string> ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<files>",
      "description": "Specify the tcic file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-include_all_rules",
      "description": "report all the rules even if there is no violation of that rule",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pre_opt",
      "description": "Enable pre opt",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-report_area",
      "description": "Enable tool to report the object area data in summary file",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-report_file",
      "description": "Specify the summary file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-report_unplaced_block",
      "description": "Enable tool to show the number of unplaced macros in summary",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-selected_rules",
      "description": "Specify the rule names",
      "required": false,
      "type": "string"
    }
  ]
}