{
  "command": "define_proc_arguments",
  "is_cmd": true,
  "summary": "Defines proc arguments.",
  "description": "Defines proc arguments.",
  "usage": "define_proc_arguments [-help] <command_name> [-define_args <string>] [-hide] [-info <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<command_name>",
      "description": "command name to be defined",
      "required": true,
      "type": "string"
    },
    {
      "name": "-define_args",
      "description": "argument definition list",
      "required": false,
      "type": "string"
    },
    {
      "name": "-hide",
      "description": "hide command name and body",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-info",
      "description": "Provides help information for the procedure",
      "required": false,
      "type": "string"
    }
  ]
}