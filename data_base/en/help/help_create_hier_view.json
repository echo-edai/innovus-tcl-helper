{
  "command": "create_hier_view",
  "is_cmd": true,
  "summary": "Creates hier view.",
  "description": "Creates hier view.",
  "usage": "create_hier_view [-help] [-cell_name <string>] [-cluster_via1_ports {true false}] [-cluster_via_rule <string>] [-cluster_via_size <integer>] [-compress_powergrid_database {true false}] [-extraction_mode {fast accurate}] [-force_library_merging {true false}] [-ground_nets <string>] [-ignore_decaps {true false}] [-ignore_fillers {true false}] [-ignore_shorts {true false}] [-libgen_command_file <string>] -library_name <string> [-max_viacluster_mode {true false}] [-output_dir <string>] [-parasitic_extractor_command_file <string>] [-power_nets <string>] [-powergrid_view_libraries <string>] [-block_lef <string> | -block_gds <string>] [-block_lef <string> | -oaRef <string>] [-block_lef <string> | -gds_port_file <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-block_gds",
      "description": "<gds file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-block_lef",
      "description": "<lef file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell_name",
      "description": "cell name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cluster_via1_ports",
      "description": "<enable clustering equidistant vias on VIA1 layer >",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-cluster_via_rule",
      "description": "<{{<via layer> <number of equidistant vias>}+}>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cluster_via_size",
      "description": "<via cluster size>",
      "required": false,
      "type": "int"
    },
    {
      "name": "-compress_powergrid_database",
      "description": "{true false} <true|false>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-def",
      "description": "list of block def files",
      "required": true,
      "type": "string"
    },
    {
      "name": "-extraction_mode",
      "description": "<fast | accurate>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-extraction_work_directory",
      "description": "<dir name>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-force_library_merging",
      "description": "<true|false>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-gds_port_file",
      "description": "<gds port file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ground_nets",
      "description": "<ground nets for hier_extraction_view>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ignore_decaps",
      "description": "<ignore decap cells>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-ignore_fillers",
      "description": "<ignore filler cells>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-ignore_shorts",
      "description": "<ignore shorts>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-libgen_command_file",
      "description": "<file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-library_name",
      "description": "<library name>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-max_viacluster_mode",
      "description": "<true|false>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-oaRef",
      "description": "read the OA reference libraries",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output_dir",
      "description": "<dir name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-parasitic_extractor_command_file",
      "description": "<string> <file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-power_nets",
      "description": "<power nets and values for hier_extraction_view net1 value1 net2 value2 ...>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-powergrid_view_libraries",
      "description": "<list of cell libraries for hier_extraction_view>",
      "required": false,
      "type": "string"
    }
  ]
}