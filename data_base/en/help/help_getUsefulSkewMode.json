{
  "command": "getUsefulSkewMode",
  "is_cmd": true,
  "summary": "Gets useful skew mode.",
  "description": "Gets useful skew mode.",
  "usage": "getUsefulSkewMode [-help] [-opt_skew_apply_delay_limits_to_full_flow] [-opt_skew_delay_pre_cts] [-opt_skew_macro_only] [-opt_skew_max_allowed_delay] [-opt_skew_min_allowed_delay] [-opt_skew_no_boundary] [-quiet] [-nonDefault]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-opt_skew_apply_delay_limits_to_full_flow",
      "description": "delay limits apply to whole flow",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-opt_skew_delay_pre_cts",
      "description": "delaying mode in preCTS",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-opt_skew_macro_only",
      "description": "skew hard blocks",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-opt_skew_max_allowed_delay",
      "description": "max allowed skewing delay, unit is 'ns'",
      "required": false,
      "type": "float"
    },
    {
      "name": "-opt_skew_min_allowed_delay",
      "description": "min allowed skewing delay, unit is 'ns'",
      "required": false,
      "type": "float"
    },
    {
      "name": "-opt_skew_no_boundary",
      "description": "consider boundary sequential elements",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-quiet",
      "description": "Displays the current settings in Tcl list format only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-nonDefault",
      "description": "Displays the current settings which are not default settings",
      "required": false,
      "type": "flag"
    }
  ]
}