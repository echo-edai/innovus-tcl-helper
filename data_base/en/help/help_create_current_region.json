{
  "command": "create_current_region",
  "is_cmd": true,
  "summary": "Creates current region.",
  "description": "Creates current region.",
  "usage": "create_current_region [-help] [-die_instance_name <string>] [-file <string>] [-label <string>] [-series_resistance <string>] [-current <string> | -current_pwl_file <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "cell name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-current",
      "description": "mA for static, {{#ns #mA }...} for dynamic",
      "required": false,
      "type": "string"
    },
    {
      "name": "-current_pwl_file",
      "description": "file_name for dynamic",
      "required": false,
      "type": "string"
    },
    {
      "name": "-die_instance_name",
      "description": "Name of die to apply current region to",
      "required": false,
      "type": "string"
    },
    {
      "name": "-file",
      "description": "Name of file to merge with params, including die name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-gndnet",
      "description": "ground net name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance",
      "description": "instance name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-intrinsic_cap",
      "description": "intrinsic capacitance (pf)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-label",
      "description": "Label of current region",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer",
      "description": "layer name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-loading_cap",
      "description": "loading capacitance (pf)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "net name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-polygon",
      "description": "polygon <x1 y1 x2 y2 x3 y3 .....> (um)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pwrnet",
      "description": "power net name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-region",
      "description": "region <x1 y1 x2 y2> (um)",
      "required": true,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "reset all options",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-series_resistance",
      "description": "series resistance (ohm)",
      "required": false,
      "type": "string"
    }
  ]
}