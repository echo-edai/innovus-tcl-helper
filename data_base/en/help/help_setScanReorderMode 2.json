{
  "command": "setScanReorderMode",
  "is_cmd": true,
  "summary": "Sets scan reorder mode.",
  "description": "Sets scan reorder mode.",
  "usage": "setScanReorderMode [-help] [-reset] [-addScanPortPrefix <value>] [-clkAware {true|false}] [-compLogic {true|false}] [-enable_for_partition {true|false}] [-keepPDPorts {true|false}] [-keepPort <keepPortHInstFile>] [-preferH {true|false}] [-preferV {true|false}] [-scanEffort {low|medium|high|auto}] [-skipMode {skipNone|skipBuffer|skipFloatingBuffer}] [-swapEffort {low|medium|high}]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "Resets all or specified options to default value",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-addScanPortPrefix",
      "description": "prefix of scan hport",
      "required": false,
      "type": "string"
    },
    {
      "name": "-clkAware",
      "description": "Clock tree aware reorder",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-compLogic",
      "description": "trace considering multiple input logic",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-enable_for_partition",
      "description": "enable scanReorder for design with partition",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-keepPDPorts",
      "description": "Maintains hierarchical ports without adding or deleting shifters",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-keepPort",
      "description": "Specifies filename which contains HInsts",
      "required": false,
      "type": "string"
    },
    {
      "name": "-preferH",
      "description": "Makes horizontal scan chain connections if possible",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-preferV",
      "description": "Makes vertical scan chain connections if possible",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-scanEffort",
      "description": "Specifies effort level for scanReorder",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-skipMode",
      "description": "{skipNone|skipBuffer|skipFloatingBuffer} Specifies method for handling buffers and inverters",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-swapEffort",
      "description": "Specifies effort level for scanReorder different chains swapping",
      "required": false,
      "type": "enum"
    }
  ]
}