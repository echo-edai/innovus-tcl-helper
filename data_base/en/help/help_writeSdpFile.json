{
  "command": "writeSdpFile",
  "is_cmd": true,
  "summary": "Writes sdp file.",
  "description": "Writes sdp file.",
  "usage": "writeSdpFile [-help] -file <fileName> [-template  | -topGroup <topGroupName>] [-template  | -command ] [-template  | [-updateRelativePlaceConstraint  | -updateOrientation ]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-command",
      "description": "dump command file",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "file name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-template",
      "description": "dump template file",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-topGroup",
      "description": "top group to be dumped",
      "required": false,
      "type": "string"
    },
    {
      "name": "-updateOrientation",
      "description": "update orientation of sdp instances before dumping them",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-updateRelativePlaceConstraint",
      "description": "update relative place constraint of sdps before dumping them",
      "required": false,
      "type": "flag"
    }
  ]
}