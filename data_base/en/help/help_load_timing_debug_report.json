{
  "command": "load_timing_debug_report",
  "is_cmd": true,
  "summary": "Loads timing debug report.",
  "description": "Loads timing debug report.",
  "usage": "load_timing_debug_report [-help] {{<file> [-name <string>]}|{ -proto  [-additional_slack_past_wns <float>] [-num_path <integer>]}}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<file>",
      "description": "Specifies the name of the timing debug file.",
      "required": true,
      "type": "string"
    },
    {
      "name": "-additional_slack_past_wns",
      "description": "Plus the additional specified slack",
      "required": false,
      "type": "float"
    },
    {
      "name": "-name",
      "description": "Specifies the report name to load the machine readable timing report files incrementally.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-num_path",
      "description": "Number of paths to be reported in path violations",
      "required": false,
      "type": "int"
    },
    {
      "name": "-proto",
      "description": "Specifies the FlexModel prototyping.",
      "required": true,
      "type": "flag"
    }
  ]
}