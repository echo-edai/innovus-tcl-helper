{
  "command": "reportSpecialRoute",
  "is_cmd": true,
  "summary": "Reports special route.",
  "description": "Reports special route.",
  "usage": "reportSpecialRoute [-help] [<reportName>] [-center_line] [-net <netName>] [-interposer_shielding_ratio [-exclude_nets <netName>]] [-interposer_ndr_check [-exclude_nets <netName>]] [-interposer_route [-exclude_nets <netName>]] [-interposer_route [[-interposer_route_constraint_file <ircFileName>] [-interposer_layers <layerName>]]] [[ [-summary ] [-wirelength ] [-wire_segment ] [-selected ] [-highlight45layer <layerName>] [-lengththreshold <value>] [-resfile <resFileName>] [-by_layer ]] | [-interposer_route ] | [-interposer_ndr_check ] | [-interposer_shielding_ratio ]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<reportName>",
      "description": "Specifies report file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-by_layer",
      "description": "Specifies the layer",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-center_line",
      "description": "Routing length is calculated by center line",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-exclude_nets",
      "description": "Specifies exclude net name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-highlight45layer",
      "description": "Specifies the layer to highlight nets with 45-degree routing",
      "required": false,
      "type": "string"
    },
    {
      "name": "-interposer_layers",
      "description": "Specifies interposer layers",
      "required": false,
      "type": "string"
    },
    {
      "name": "-interposer_ndr_check",
      "description": "interposer routing ndr rule and missing shield check",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-interposer_route",
      "description": "Reports interposer route",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-interposer_route_constraint_file",
      "description": "<ircFileName> Specifies interposer route constraint file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-interposer_shielding_ratio",
      "description": "Reports interposer shielding ratio",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-lengththreshold",
      "description": "Specifies length threshold",
      "required": false,
      "type": "float"
    },
    {
      "name": "-net",
      "description": "Specifies net name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-resfile",
      "description": "Specifies resistance file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selected",
      "description": "Reports the length of the selected wire segmnets of SPECIALNET",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-summary",
      "description": "Summarizes the wire length and VIAs for special nets",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-wire_segment",
      "description": "Reports on wire segments of each SPECIALNET",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-wirelength",
      "description": "Reports wire length",
      "required": false,
      "type": "flag"
    }
  ]
}