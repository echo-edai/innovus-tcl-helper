{
  "command": "gui_dump_picture",
  "is_cmd": true,
  "summary": "Executes the 'gui_dump_picture' command.",
  "description": "Executes the 'gui_dump_picture' command.",
  "usage": "gui_dump_picture [-help] <name> [-format {BMP GIF JPG JPEG PNG PBM PGM PPM XBM XPM}] [-honor_umask] [-window <string>] [-width <integer> -height <integer>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<name>",
      "description": "file name of the picture",
      "required": true,
      "type": "string"
    },
    {
      "name": "-format",
      "description": "{BMP GIF JPG JPEG PNG PBM PGM PPM XBM XPM} format of the picture, default is PNG",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-height",
      "description": "height of the picture",
      "required": false,
      "type": "int"
    },
    {
      "name": "-honor_umask",
      "description": "honor umask to save the pic",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-width",
      "description": "width of the picture",
      "required": false,
      "type": "int"
    },
    {
      "name": "-window",
      "description": "id of layout window",
      "required": false,
      "type": "string"
    }
  ]
}