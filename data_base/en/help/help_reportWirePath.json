{
  "command": "reportWirePath",
  "is_cmd": true,
  "summary": "Reports wire path.",
  "description": "Reports wire path.",
  "usage": "reportWirePath [-help] [-detail] -end <string> [-include_pin] -start <string> [-tcl  [-no_output ]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-detail",
      "description": "Specify whether to print detail information of the path",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-end",
      "description": "Specify end term name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-include_pin",
      "description": "Specify whether to include pin in report",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-no_output",
      "description": "Specify whether to print the path when -tcl is specified",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-start",
      "description": "Specify start term name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-tcl",
      "description": "Specify whether return tcl dict of the wire path",
      "required": false,
      "type": "flag"
    }
  ]
}