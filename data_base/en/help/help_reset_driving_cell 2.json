{
  "command": "reset_driving_cell",
  "is_cmd": true,
  "summary": "Resets driving cell.",
  "description": "Resets driving cell.",
  "usage": "reset_driving_cell [-help] <port_list> [-fall] [-max] [-min] [-rise]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage <port_list> # List of ports",
      "required": true,
      "type": "string"
    },
    {
      "name": "-fall",
      "description": "Resets the falling drive assertion",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-max",
      "description": "Resets the late drive assertion",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-min",
      "description": "Resets the early drive assertion",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-rise",
      "description": "Resets the rising drive assertion",
      "required": false,
      "type": "flag"
    }
  ]
}