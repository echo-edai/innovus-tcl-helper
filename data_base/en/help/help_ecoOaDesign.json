{
  "command": "ecoOaDesign",
  "is_cmd": true,
  "summary": "Engineering change order oa design.",
  "description": "Engineering change order oa design.",
  "usage": "ecoOaDesign [-help] <lib> <cell> <view> -ecoVerilogFile <input_fileName> [-reportFile <output_fileName>] [-useGACells <string>] [-postMask  [-suffix <suffix_name>]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<lib>",
      "description": "Specifies the OpenAccess library name",
      "required": true,
      "type": "string"
    },
    {
      "name": "<cell>",
      "description": "Specifies the OpenAccess cell name of the top cell to import",
      "required": true,
      "type": "string"
    },
    {
      "name": "<view>",
      "description": "Specifies OpenAccess view name to import",
      "required": true,
      "type": "string"
    },
    {
      "name": "-ecoVerilogFile",
      "description": "Specifies a Verilog netlist",
      "required": true,
      "type": "string"
    },
    {
      "name": "-postMask",
      "description": "Specifies the postmask option",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reportFile",
      "description": "Specifies a report file. Default: eco.log",
      "required": false,
      "type": "string"
    },
    {
      "name": "-suffix",
      "description": "Specifies the suffix name for the the spare cells Default: _SPARE",
      "required": false,
      "type": "string"
    },
    {
      "name": "-useGACells",
      "description": "Specifies the GA core site",
      "required": false,
      "type": "string"
    }
  ]
}