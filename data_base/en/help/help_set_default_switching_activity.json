{
  "command": "set_default_switching_activity",
  "is_cmd": true,
  "summary": "Sets default switching activity.",
  "description": "Sets default switching activity.",
  "usage": "set_default_switching_activity [-help] [-black_box_density <string>] [-black_box_duty <string>] [-block <string>] [-clip_activity_to_domain_freq <string>] [-clock_gates_enable <string>] [-clock_gates_output <string>] [-clock_gates_output_ratio <string>] [-comb_clockgate_ratio <string>] [-duty <string>] [-global_activity <string>] [-hier <string>] [-icg_ratio <string>] [-input_activity <string>] [-macro_activity <string>] [-name <string>] [-period <string>] [-reset] [-reset_type <string>] [-seq_activity <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-black_box_density",
      "description": "set default tdensity on all blackbox's output pin",
      "required": false,
      "type": "string"
    },
    {
      "name": "-black_box_duty",
      "description": "set default duty on all blackbox's output pin",
      "required": false,
      "type": "string"
    },
    {
      "name": "-block",
      "description": "Specify master cell name for activity setting",
      "required": false,
      "type": "string"
    },
    {
      "name": "-clip_activity_to_domain_freq",
      "description": "domain-based activity clipping",
      "required": false,
      "type": "string"
    },
    {
      "name": "-clock_gates_enable",
      "description": "set clock gates enable activity",
      "required": false,
      "type": "string"
    },
    {
      "name": "-clock_gates_output",
      "description": "set clock gates output activity",
      "required": false,
      "type": "string"
    },
    {
      "name": "-clock_gates_output_ratio",
      "description": "set clock gates output ratio",
      "required": false,
      "type": "string"
    },
    {
      "name": "-comb_clockgate_ratio",
      "description": "set propagation ratio for combinational clock gate cell outputs",
      "required": false,
      "type": "string"
    },
    {
      "name": "-duty",
      "description": "Specifies the duty cycle, which is the probability that the signal is a logical 1. Default : 0.5,",
      "required": false,
      "type": "string"
    },
    {
      "name": "-global_activity",
      "description": "Specifies the average number of times that all unset nodes switch in a clock cycle.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-hier",
      "description": "set hierarchy name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-icg_ratio",
      "description": "set propagation ratio for integrated clock gate cell outputs",
      "required": false,
      "type": "string"
    },
    {
      "name": "-input_activity",
      "description": "Specifies the average number of times that a primary input switches in a clock cycle.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-macro_activity",
      "description": "set macro activity",
      "required": false,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "set jitter activity name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-period",
      "description": "Specifies the default operating period (1/frequency).",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "reset all options",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset_type",
      "description": "reset the following type",
      "required": false,
      "type": "string"
    },
    {
      "name": "-seq_activity",
      "description": "Specifies the activity of outputs of sequential logic.",
      "required": false,
      "type": "string"
    }
  ]
}