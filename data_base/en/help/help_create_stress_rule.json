{
  "command": "create_stress_rule",
  "is_cmd": true,
  "summary": "Creates stress rule.",
  "description": "Creates stress rule.",
  "usage": "create_stress_rule [-help] { {-layer <layerName> -spacing_table <spacing_table> [-chip_name <chipName>]} | [-reset ] }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-chip_name",
      "description": "chip names, { chipName }",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer",
      "description": "stress layer name, { layerName }",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "reset all stress rules",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-spacing_table",
      "description": "spacing table definition, { {x1 y1} {x2 y2} ...}",
      "required": false,
      "type": "string"
    }
  ]
}