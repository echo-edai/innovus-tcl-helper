{
  "command": "addIoRowFiller",
  "is_cmd": true,
  "summary": "Adds io row filler.",
  "description": "Adds io row filler.",
  "usage": "addIoRowFiller [-help] -cell {name list} [-fillAnyGap] [-from <coord>] [-ignoreSiteType] [-logic] [-prefix <string>] [-to <coord>] [-useSmallIoHeight] [[-ioRow <rowName> | -powerDomain <string>] [-fillerOrient <R0|R90|R180|R270|MX|MX90|MY|MY90>]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "name list of IO filler cell",
      "required": true,
      "type": "string"
    },
    {
      "name": "-fillAnyGap",
      "description": "fill smaller gap by overlapping filler cell",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-fillerOrient",
      "description": "<R0|R90|R180|R270|MX|MX90|MY|MY90> orientation of new filler instances",
      "required": false,
      "type": "string"
    },
    {
      "name": "-from",
      "description": "staring offset from edge for adding fillers",
      "required": false,
      "type": "float"
    },
    {
      "name": "-ignoreSiteType",
      "description": "don't check site type",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ioRow",
      "description": "name of IO row to be processed",
      "required": false,
      "type": "string"
    },
    {
      "name": "-logic",
      "description": "add fillers to net list in top module",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-powerDomain",
      "description": "add filler to power domain associated io rows",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "prefix for new filler instances",
      "required": false,
      "type": "string"
    },
    {
      "name": "-to",
      "description": "ending offset from edge for adding fillers",
      "required": false,
      "type": "float"
    },
    {
      "name": "-useSmallIoHeight",
      "description": "match site before adding filler",
      "required": false,
      "type": "flag"
    }
  ]
}