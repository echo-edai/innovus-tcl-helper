      "type": "flag"
    },
    {
      "name": "-suffix",
      "description": "Name of suffix",
      "required": false,
      "type": "string"
    },
    {
      "name": "-useGACells",
      "description": "Name of core site name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-verbose",
      "description": "verbose",
      "required": false,
      "type": "flag"
    }
  ]
}