{
  "command": "setUsefulSkewMode",
  "is_cmd": true,
  "summary": "Sets useful skew mode.",
  "description": "Sets useful skew mode.",
  "usage": "setUsefulSkewMode [-help] [-reset] [-opt_skew_apply_delay_limits_to_full_flow {true|false}] [-opt_skew_delay_pre_cts {true|false}] [-opt_skew_macro_only {true|false}] [-opt_skew_max_allowed_delay <value>] [-opt_skew_min_allowed_delay <value>] [-opt_skew_no_boundary {true|false}]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "Resets all or specified options to default value",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-opt_skew_apply_delay_limits_to_full_flow",
      "description": "{true|false} delay limits apply to whole flow",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-opt_skew_delay_pre_cts",
      "description": "delaying mode in preCTS",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-opt_skew_macro_only",
      "description": "skew hard blocks",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-opt_skew_max_allowed_delay",
      "description": "max allowed skewing delay, unit is 'ns'",
      "required": false,
      "type": "float"
    },
    {
      "name": "-opt_skew_min_allowed_delay",
      "description": "min allowed skewing delay, unit is 'ns'",
      "required": false,
      "type": "float"
    },
    {
      "name": "-opt_skew_no_boundary",
      "description": "consider boundary sequential elements",
      "required": false,
      "type": "flag"
    }
  ]
}