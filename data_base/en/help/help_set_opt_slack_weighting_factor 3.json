{
  "command": "set_opt_slack_weighting_factor",
  "is_cmd": true,
  "summary": "Sets opt slack weighting factor.",
  "description": "Sets opt slack weighting factor.",
  "usage": "set_opt_slack_weighting_factor [-help] <factor> [-hold] [-setup] -view <string>",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage <factor> # slack weighting factor",
      "required": true,
      "type": "float"
    },
    {
      "name": "-hold",
      "description": "apply factor to hold",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-setup",
      "description": "apply factor to setup",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view",
      "description": "view for which slack weights are defined",
      "required": true,
      "type": "string"
    }
  ]
}