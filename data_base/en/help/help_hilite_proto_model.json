{
  "command": "hilite_proto_model",
  "is_cmd": true,
  "summary": "Executes the 'hilite_proto_model' command.",
  "description": "Executes the 'hilite_proto_model' command.",
  "usage": "hilite_proto_model [-help] [-keep_existing_hilite] [-type {flex_module flex_instgroup partition power_domain}] -reset  | -level <integer> | {[-min_level <integer>] [-max_level <integer>]}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-keep_existing_hilite",
      "description": "Hilite in addition to existing hilited objects",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-level",
      "description": "Level to hilite",
      "required": false,
      "type": "int"
    },
    {
      "name": "-max_level",
      "description": "Maximum level to hilite",
      "required": false,
      "type": "int"
    },
    {
      "name": "-min_level",
      "description": "Minimum level to hilite",
      "required": false,
      "type": "int"
    },
    {
      "name": "-reset",
      "description": "Un-hilite hilited objects",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-type",
      "description": "{flex_module flex_instgroup partition power_domain} Set types to hilite (default=flex_module flex_instgroup)",
      "required": false,
      "type": "enum"
    }
  ]
}