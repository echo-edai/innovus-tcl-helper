{
  "command": "reportInstPad",
  "is_cmd": true,
  "summary": "Reports inst pad.",
  "description": "Reports inst pad.",
  "usage": "reportInstPad [-help] {-all  | <instName>}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<instName>",
      "description": "report given inst's padding",
      "required": true,
      "type": "string"
    },
    {
      "name": "-all",
      "description": "report all insts that have padding",
      "required": true,
      "type": "flag"
    }
  ]
}