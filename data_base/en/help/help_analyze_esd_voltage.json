{
  "command": "analyze_esd_voltage",
  "is_cmd": true,
  "summary": "Analyzes esd voltage.",
  "description": "Analyzes esd voltage.",
  "usage": "analyze_esd_voltage [-help] -current_distribution_layer <string> [-detailed_report <string>] -driver_receiver_file <string> -esd_pin_location_file <string> [-maximum_violations <integer>] -net <string> [-report <string>] [-threshold <float>] -total_current <string>",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-current_distribution_layer",
      "description": "current distribution layer",
      "required": true,
      "type": "string"
    },
    {
      "name": "-detailed_report",
      "description": "output detail report file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-driver_receiver_file",
      "description": "<driver/receiver file of the net>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-esd_pin_location_file",
      "description": "<esd pin location file>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-maximum_violations",
      "description": "number of max worst violations to be reported",
      "required": false,
      "type": "int"
    },
    {
      "name": "-net",
      "description": "<name of the net to be analyzed>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-report",
      "description": "output report file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-threshold",
      "description": "minimum threshold driver/receiver voltage in volt for report filtering",
      "required": false,
      "type": "float"
    },
    {
      "name": "-total_current",
      "description": "total esd current to be distributed",
      "required": true,
      "type": "string"
    }
  ]
}