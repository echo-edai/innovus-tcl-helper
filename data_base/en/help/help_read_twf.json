{
  "command": "read_twf",
  "is_cmd": true,
  "summary": "Reads twf.",
  "description": "Reads twf.",
  "usage": "read_twf [-help] [<filenames>] [-cell <string>] [-prefix <string>] [-quiet] [-reset] [-scope <string>] [-skipconst] [-skiptw] [-strip_prefix <string>] [-total_load_only] [-verbose] [-view <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<filenames>",
      "description": "Specifies the names of the timing window files",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "Specifies master cell for the timing window file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "Adds a prefix to the net or pin name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-quiet",
      "description": "Skips infor and warning messages",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "Clears the previously read TWF files",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-scope",
      "description": "Specifies the scope for the given hierarchical timing window file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-skipconst",
      "description": "Skips constant processing",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skiptw",
      "description": "Skips timing windows processing",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-strip_prefix",
      "description": "Removes hierarchical path name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-total_load_only",
      "description": "If only read TOTAL_LOAD from Twf",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-verbose",
      "description": "Generates a detail report",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view",
      "description": "Specifies the view for the timing window file",
      "required": false,
      "type": "string"
    }
  ]
}