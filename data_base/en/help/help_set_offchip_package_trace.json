{
  "command": "set_offchip_package_trace",
  "is_cmd": true,
  "summary": "Sets offchip package trace.",
  "description": "Sets offchip package trace.",
  "usage": "set_offchip_package_trace [-help] -reset  | {-name <string> -ploc_file_list <string> -spice <string> -mapping <string> [-subckt <string>] }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-mapping",
      "description": "<mapping file>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "<trace model name>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-ploc_file_list",
      "description": "<list of bump location file>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "<reset all previous set_offchip_package_trace commands>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spice",
      "description": "<Spice model>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-subckt",
      "description": "<top level sub-circuit name>",
      "required": false,
      "type": "string"
    }
  ]
}