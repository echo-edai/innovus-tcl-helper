{
  "command": "scale_what_if_capacitance",
  "is_cmd": true,
  "summary": "Executes the 'scale_what_if_capacitance' command.",
  "description": "Executes the 'scale_what_if_capacitance' command.",
  "usage": "scale_what_if_capacitance [-help] [-add] [-layer <string>] [-net <string>] -reset  | {{-global  | -region <string> | -cell <string> | -instance <string> | -file <string>} [-intrinsic_cap <string>] [-loading_cap <string>] [-grid_cap <string>]}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-add",
      "description": "add cap instaed of scaling, all scaling values are assumed to be in absoulte in farad(F) unit",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "cell name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-file",
      "description": "file name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-global",
      "description": "is global",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-grid_cap",
      "description": "grid capacitance scale factor",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance",
      "description": "instance name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-intrinsic_cap",
      "description": "intrinsic capacitance scale factor",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer",
      "description": "lef layer for added capacitance",
      "required": false,
      "type": "string"
    },
    {
      "name": "-loading_cap",
      "description": "loading capacitance scale factor",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "net name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-region",
      "description": "region <x1 y1 x2 y2> (um)",
      "required": true,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "reset all scale capacitance options",
      "required": false,
      "type": "flag"
    }
  ]
}