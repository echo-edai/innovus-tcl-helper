{
  "command": "report_ccopt_worst_chain",
  "is_cmd": true,
  "summary": "Reports ccopt worst chain.",
  "description": "Reports ccopt worst chain.",
  "usage": "report_ccopt_worst_chain [-help] [-file <filename>] [-view <analysis_view>] [ -check_type <type> ] [ -through <pin> | -through_file <filename> ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-check_type",
      "description": "the check type to query",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-file",
      "description": "write report to this file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-through",
      "description": "worst chain through this pin ((instTerm|term), optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-through_file",
      "description": "create a worst chain report for each pin in this file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "the view for which the worst chain is reported ((analysis_view), optional)",
      "required": false,
      "type": "string"
    }
  ]
}