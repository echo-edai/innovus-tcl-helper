{
  "command": "checkTimingLibrary",
  "is_cmd": true,
  "summary": "Checks timing library.",
  "description": "Checks timing library.",
  "usage": "checkTimingLibrary [-help] [-cellname <string>] [-checkpower] [-library <string>] [-outfile <string>] [-reportMissingPowerOnly]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cellname",
      "description": "Specify the cell name.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-checkpower",
      "description": "Checks if power constructs are defined for the cells, such as internal_power, leakage_power, or ecsm_power.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-library",
      "description": "Specify the library name.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-outfile",
      "description": "Output File Name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reportMissingPowerOnly",
      "description": "Reports only the cells that do not have internal_power (at pin level), or leakage_power defined.",
      "required": false,
      "type": "flag"
    }
  ]
}