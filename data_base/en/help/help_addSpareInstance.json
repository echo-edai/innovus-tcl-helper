{
  "command": "addSpareInstance",
  "is_cmd": true,
  "summary": "Adds spare instance.",
  "description": "Adds spare instance.",
  "usage": "addSpareInstance [-help] [-async <netName>] [-clock <netName>] -file <fname> [-fix_placed_insts {TRUE|FALSE}] [-prefix <prefix>] [-tie <0|1>] [-hier <module> | -powerDomain <domain> [-submodule <name>]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-async",
      "description": "async net information",
      "required": false,
      "type": "string"
    },
    {
      "name": "-clock",
      "description": "name of clock net",
      "required": false,
      "type": "string"
    },
    {
      "name": "-file",
      "description": "file of cell names and numbers",
      "required": true,
      "type": "string"
    },
    {
      "name": "-fix_placed_insts",
      "description": "do not move existing placed instances to find location for newly spare insts",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hier",
      "description": "module in which to add spares",
      "required": false,
      "type": "string"
    },
    {
      "name": "-powerDomain",
      "description": "power domain in which to add spares",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "prefix for spare instances",
      "required": false,
      "type": "string"
    },
    {
      "name": "-submodule",
      "description": "module created for spares",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tie",
      "description": "tie net for spare instances",
      "required": false,
      "type": "int"
    }
  ]
}