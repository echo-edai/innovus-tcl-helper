{
  "command": "createRow",
  "is_cmd": true,
  "summary": "Creates row.",
  "description": "Creates row.",
  "usage": "createRow [-help] [-flip1st] [-limitInCore] [-noCheck] [-noFlip] [-site <string>] [-spacing <float>] [-noAbut  | -noAbut1st ] [-area {x1 y1 x2 y2} | -boxList {{x1 y1} {x2 y2}...} | -polygon {{x1 y1} {x2 y2}...}]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-area",
      "description": "create rows inside this area(box).",
      "required": false,
      "type": "point"
    },
    {
      "name": "-boxList",
      "description": "create rows inside this boxList.",
      "required": false,
      "type": "int"
    },
    {
      "name": "-flip1st",
      "description": "flip the first row",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-limitInCore",
      "description": "limit new rows inside of core",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noAbut",
      "description": "no abut any row",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noAbut1st",
      "description": "not abut the first row",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noCheck",
      "description": "donot align row to existing row and not support redo undo",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noFlip",
      "description": "Specifies that the rows should not be flipped. The Rows are flipped if the option isn't specified.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-polygon",
      "description": "create rows inside this boxList.",
      "required": false,
      "type": "int"
    },
    {
      "name": "-site",
      "description": "site name for new rows",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spacing",
      "description": "spacing between rows",
      "required": false,
      "type": "float"
    }
  ]
}