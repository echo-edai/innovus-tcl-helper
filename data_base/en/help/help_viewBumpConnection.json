{
  "command": "viewBumpConnection",
  "is_cmd": true,
  "summary": "Views bump connection.",
  "description": "Views bump connection.",
  "usage": "viewBumpConnection [-help] [-honor_color] [-multiBumpsToPad] [-multiPadsToBump] [-remove] [[[-net {net_list}] [-bump {bump_list}] [-io_inst {io_inst_list}] [-selected ]]|[[-bumpType {all power signal}] [-target {pad ring}]]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bump",
      "description": "Specifies connecting bumps",
      "required": false,
      "type": "string"
    },
    {
      "name": "-bumpType",
      "description": "Specifies connecting bump type",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-honor_color",
      "description": "colorize flight line by the setting defined by command ciopLoadBumpColorMapFile",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-io_inst",
      "description": "Specifies connecting IO instances",
      "required": false,
      "type": "string"
    },
    {
      "name": "-multiBumpsToPad",
      "description": "connect multiple bumps to one pad",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-multiPadsToBump",
      "description": "connect multiple pads to one bump",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-net",
      "description": "Specifies connecting nets",
      "required": false,
      "type": "string"
    },
    {
      "name": "-remove",
      "description": "remove bump connection",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-selected",
      "description": "connect selected bumps and IO instances",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-target",
      "description": "Specifies connecting target",
      "required": false,
      "type": "enum"
    }
  ]
}