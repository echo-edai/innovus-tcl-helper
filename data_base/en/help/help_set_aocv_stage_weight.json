{
  "command": "set_aocv_stage_weight",
  "is_cmd": true,
  "summary": "Sets aocv stage weight.",
  "description": "Sets aocv stage weight.",
  "usage": "set_aocv_stage_weight [-help] <stage_weight> <port_list> [-early] [-input] [-late] [-output]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<stage_weight>",
      "description": "Value of stage weight",
      "required": true,
      "type": "float"
    },
    {
      "name": "<port_list>",
      "description": "List or collection of input, output and bidi ports",
      "required": true,
      "type": "string"
    },
    {
      "name": "-early",
      "description": "Specifies weight for early paths",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-input",
      "description": "Specifies input weight for port",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-late",
      "description": "Specifies weight for late paths",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-output",
      "description": "Specifies output weight for port",
      "required": false,
      "type": "flag"
    }
  ]
}