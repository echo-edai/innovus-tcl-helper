{
  "command": "createExclusiveGroups",
  "is_cmd": true,
  "summary": "Creates exclusive groups.",
  "description": "Creates exclusive groups.",
  "usage": "createExclusiveGroups [-help] [<groupName>] [-gap <float>] [-min_gap <float>] [-exclusiveGroups <string> | -mutuallyExclusiveGroups <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<groupName>",
      "description": "Specify one group name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-exclusiveGroups",
      "description": "Specify groups which need to be excluded",
      "required": false,
      "type": "string"
    },
    {
      "name": "-gap",
      "description": "Specify gap value.",
      "required": false,
      "type": "float"
    },
    {
      "name": "-min_gap",
      "description": "Specify the min_gap value",
      "required": false,
      "type": "float"
    },
    {
      "name": "-mutuallyExclusiveGroups",
      "description": "Specify groups which need to be excluded with each other. This option can be used independently",
      "required": false,
      "type": "string"
    }
  ]
}