      "description": "row flip",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-rowPatternSite",
      "description": "site name for row pattern",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rowSpaceType",
      "description": "row space type",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-rowSpacing",
      "description": "row spacing",
      "required": false,
      "type": "float"
    },
    {
      "name": "-rsExts",
      "description": "rsExt values for 4 sides",
      "required": false,
      "type": "float"
    }
  ]
}