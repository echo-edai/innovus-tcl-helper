      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pd>",
      "description": "power domain name ((pd), required)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-addBlockBox",
      "description": "list of block boxes to add",
      "required": false,
      "type": "string"
    },
    {
      "name": "-core2Bot",
      "description": "core to bottom (micron)",
      "required": false,
      "type": "float"
    },
    {
      "name": "-core2Left",
      "description": "core to left (micron)",
      "required": false,
      "type": "float"
    },
    {
      "name": "-core2Right",
      "description": "core to right (micron)",
      "required": false,
      "type": "float"
    },
    {
      "name": "-core2Top",
      "description": "core to top (micron)",
      "required": false,
      "type": "float"
    },
    {
      "name": "-defaultTechSite",
      "description": "set default techsite",
      "required": false,
      "type": "string"
    },
    {
      "name": "-disjointHInstBoxList",
      "description": "list of disjoint HInst boxes",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extEdges",
      "description": "{ext. search distances per edge}",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extraRowPattern",
      "description": "site name for extra row pattern",
      "required": false,
      "type": "string"
    },
    {
      "name": "-firstRowSiteIndex",
