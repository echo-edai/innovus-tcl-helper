{
  "command": "extract_package",
  "is_cmd": true,
  "summary": "Extracts package.",
  "description": "Extracts package.",
  "usage": "extract_package [-help] [-output <string>] [-spd_file <string>] { [<domain> [-workspace <string>] [-reference_net <string>] [-pkg_die_name <string>] [-pkg_bga_name <string>] ]}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<domain>",
      "description": "<rail analysis domain name>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-output",
      "description": "<output directory of package model>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pkg_bga_name",
      "description": "<specify bga circuit>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pkg_die_name",
      "description": "<specify die circuit>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reference_net",
      "description": "<def net name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spd_file",
      "description": "<package extraction spd file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-workspace",
      "description": "<package extraction workspace .ximx>",
      "required": false,
      "type": "string"
    }
  ]
}