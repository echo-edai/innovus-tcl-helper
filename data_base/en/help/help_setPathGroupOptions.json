{
  "command": "setPathGroupOptions",
  "is_cmd": true,
  "summary": "Sets path group options.",
  "description": "Sets path group options.",
  "usage": "setPathGroupOptions [-help] <pathgroupName> [-early] [-effortLevel {low high}] [-late] [-skewingSlackConstraint <float>] [-slackAdjustment <float>] [-slackAdjustmentPriority <integer>] [-targetSlack <float>] [-view <string>] [-weight <integer>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pathgroupName>",
      "description": "pathgroup name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-early",
      "description": "early mode only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-effortLevel",
      "description": "effort level option",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-late",
      "description": "late mode only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skewingSlackConstraint",
      "description": "slack constraint when skewing",
      "required": false,
      "type": "float"
    },
    {
      "name": "-slackAdjustment",
      "description": "slack adjustment",
      "required": false,
      "type": "float"
    },
    {
      "name": "-slackAdjustmentPriority",
      "description": "slack adjustment priority",
      "required": false,
      "type": "int"
    },
    {
      "name": "-targetSlack",
      "description": "target slack option",
      "required": false,
      "type": "float"
    },
    {
      "name": "-view",
      "description": "views",
      "required": false,
      "type": "string"
    },
    {
      "name": "-weight",
      "description": "optimization priority",
      "required": false,
      "type": "int"
    }
  ]
}