{
  "command": "attachTerm",
  "is_cmd": true,
  "summary": "Attaches term.",
  "description": "Attaches term.",
  "usage": "attachTerm [-help] <instName> <termName> <netName> [-moduleBased <moduleName>] [-noNewPort] [-pin <refInstName> <refTermName>] [-port <portName>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<instName>",
      "description": "Name of Inst",
      "required": true,
      "type": "string"
    },
    {
      "name": "<termName>",
      "description": "Name of Term",
      "required": true,
      "type": "string"
    },
    {
      "name": "<netName>",
      "description": "Name of Net",
      "required": true,
      "type": "string"
    },
    {
      "name": "-moduleBased",
      "description": "Name of verilog module",
      "required": false,
      "type": "string"
    },
    {
      "name": "-noNewPort",
      "description": "do not create new port if net did not exist at hierarchy of term",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pin",
      "description": "Using the hterm that used for the refInst term to do the connection.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-port",
      "description": "Name of Port on module containing instance",
      "required": false,
      "type": "string"
    }
  ]
}