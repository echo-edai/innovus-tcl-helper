{
  "command": "assignSigToBump",
  "is_cmd": true,
  "summary": "Assigns sig to bump.",
  "description": "Assigns sig to bump.",
  "usage": "assignSigToBump [-help] { {{-net <net_name> | {-top_pin <port> }} {-bumps <bump_name_list> | -selected }} }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bumps",
      "description": "specifies the bumps to assign.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "specifies the net name ((net), optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selected",
      "description": "assigns the selected bumps to specified net.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-top_pin",
      "description": "specifies the toplevel pin name",
      "required": false,
      "type": "string"
    }
  ]
}