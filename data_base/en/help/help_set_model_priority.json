{
  "command": "set_model_priority",
  "is_cmd": true,
  "summary": "Sets model priority.",
  "description": "Sets model priority.",
  "usage": "set_model_priority [-help] [-objects <string>] [-priority_list <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-objects",
      "description": "list of lib_cells/lib_pins for which priority is specified",
      "required": false,
      "type": "string"
    },
    {
      "name": "-priority_list",
      "description": "list of pin model priority, default = {ecsm ccs nldm cdb udn}",
      "required": false,
      "type": "string"
    }
  ]
}