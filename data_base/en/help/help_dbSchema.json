      "required": false,
      "type": "flag"
    },
    {
      "name": "<objNamePattern>",
      "description": "Object Name or Pattern",
      "required": false,
      "type": "string"
    },
    {
      "name": "<objAttrNamePattern>",
      "description": "Object Attribute Name or Pattern",
      "required": false,
      "type": "string"
    },
    {
      "name": "-list",
      "description": "To print as a list of parent objects",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-parent",
      "description": "Type of Object/Attribute for which parent needs to be found",
      "required": false,
      "type": "string"
    }
  ]
}