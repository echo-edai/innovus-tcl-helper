{
  "command": "analyze_joule_heat",
  "is_cmd": true,
  "summary": "Analyzes joule heat.",
  "description": "Analyzes joule heat.",
  "usage": "analyze_joule_heat [-help] [-detail_delta_temperature_file <string>] [-detail_delta_temperature_region <string>] [-domain <string>] [-net <string>] [-output_directory <string>] [-report_conn_pin_wire <string>] [-scale_rms_limit <float>] [-tile_delta_temperature_file <string>] [-tiles <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-detail_delta_temperature_file",
      "description": "detailed delta temperature file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-detail_delta_temperature_region",
      "description": "<string> detailed delta temperature region",
      "required": false,
      "type": "string"
    },
    {
      "name": "-domain",
      "description": "domain name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "net name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output_directory",
      "description": "joule-heat output dir",
      "required": false,
      "type": "string"
    },
    {
      "name": "-report_conn_pin_wire",
      "description": "report results on wires connecting to cell pins",
      "required": false,
      "type": "string"
    },
    {
      "name": "-scale_rms_limit",
      "description": "RMS EM limit scale factor",
      "required": false,
      "type": "float"
    },
    {
      "name": "-tile_delta_temperature_file",
      "description": "tile delta temperature file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tiles",
      "description": "number of map tiles <num_x num_y>",
      "required": false,
      "type": "string"
    }
  ]
}