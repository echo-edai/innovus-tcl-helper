{
  "command": "reset_mode",
  "is_cmd": true,
  "summary": "Resets mode.",
  "description": "Resets mode.",
  "usage": "reset_mode [-help] <list_of_modes> <object_list> [-type {cell}]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<list_of_modes>",
      "description": "Specifies the name(s) of library mode value",
      "required": true,
      "type": "string"
    },
    {
      "name": "<object_list>",
      "description": "List of instances",
      "required": true,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "Specifies the library mode at instance level",
      "required": false,
      "type": "enum"
    }
  ]
}