{
  "command": "get_ir_insight",
  "is_cmd": true,
  "summary": "Gets ir insight.",
  "description": "Gets ir insight.",
  "usage": "get_ir_insight [-help] [-cap_lower_limit <float>] [-cap_upper_limit <float>] [-domain <string>] [-domain_threshold <float>] [-eco_list <string>] [-eco_mode <string>] [-ir_drop_histogram_bin_size <float>] [-ir_drop_histogram_lower_limit <float>] [-ir_drop_histogram_upper_limit <float>] [-mode <string>] [-nregion <integer>] [-nworst_aggressors <integer>] [-nworst_instances <integer>] [-output_directory <string>] [-pdn_model <string>] [-reset_predict] [-scenario <string>] [-state_directory <string>] [-watch_box <string>] [-watch_inst <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cap_lower_limit",
      "description": "lower limit for aggr capacitance in eco_report mode",
      "required": false,
      "type": "float"
    },
    {
      "name": "-cap_upper_limit",
      "description": "upper limit for aggr capacitance in eco_report mode",
      "required": false,
      "type": "float"
    },
    {
      "name": "-domain",
      "description": "domain name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-domain_threshold",
      "description": "domain_threshold",
      "required": false,
      "type": "float"
    },
    {
      "name": "-eco_list",
      "description": "Provide the eco list for prediction",
      "required": false,
      "type": "string"
    },
    {
      "name": "-eco_mode",
      "description": "dump violation||aggressor||both||load_split for eco report",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ir_drop_histogram_bin_size",
      "description": "bin size for IR histogram",
      "required": false,
      "type": "float"
    },
    {
      "name": "-ir_drop_histogram_lower_limit",
      "description": "lower limit for IR histogram in summary only mode",
      "required": false,
      "type": "float"
    },
    {
      "name": "-ir_drop_histogram_upper_limit",
      "description": "upper limit for IR histogram in summary only mode",
      "required": false,
      "type": "float"
    },
    {
      "name": "-mode",
      "description": "different modes summary_only|report_by_region|report_aggressor|eco_report|predict_ir|skip|compare|pdn_check",
      "required": false,
      "type": "string"
    },
    {
      "name": "-nregion",
      "description": "number of regions",
      "required": false,
      "type": "int"
    },
    {
      "name": "-nworst_aggressors",
      "description": "How many aggressor per violation to report",
      "required": false,
      "type": "int"
    },
    {
      "name": "-nworst_instances",
      "description": "number of worst instances",
      "required": false,
      "type": "int"
    },
    {
      "name": "-output_directory",
      "description": "output_directory",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pdn_model",
      "description": "Assign the power deliver network model for aggressor-based features",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset_predict",
      "description": "reset the previous rounds of eco",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-scenario",
      "description": "scenario list",
      "required": false,
      "type": "string"
    },
    {
      "name": "-state_directory",
      "description": "state_directory",
      "required": false,
      "type": "string"
    },
    {
      "name": "-watch_box",
      "description": "instances inside the box will be watched for prediction",
      "required": false,
      "type": "string"
    },
    {
      "name": "-watch_inst",
      "description": "instances who be watched for prediction",
      "required": false,
      "type": "string"
    }
  ]
}