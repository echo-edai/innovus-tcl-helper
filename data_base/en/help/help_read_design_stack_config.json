{
  "command": "read_design_stack_config",
  "is_cmd": true,
  "summary": "Reads design stack config.",
  "description": "Reads design stack config.",
  "usage": "read_design_stack_config [-help] [-avoid_floorplan_change] [-chipName <string>] [-manufacturing_grid <float>] [-power_config_file <string>] [-topNetlist <string>] [ -xml <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-avoid_floorplan_change",
      "description": "read_design_stack_config is called inside restoreDesign, floorplan and die inst will not be created by this command.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-chipName",
      "description": "name used when current die is instantiated",
      "required": false,
      "type": "string"
    },
    {
      "name": "-manufacturing_grid",
      "description": "Specify manufacturing grid",
      "required": false,
      "type": "float"
    },
    {
      "name": "-power_config_file",
      "description": "Power Connection file name.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-topNetlist",
      "description": "Top level netlist verilog file name.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-xml",
      "description": "Stacked Die file name.",
      "required": false,
      "type": "string"
    }
  ]
}