{
  "command": "flipOrRotateObject",
  "is_cmd": true,
  "summary": "Flips or rotate object.",
  "description": "Flips or rotate object.",
  "usage": "flipOrRotateObject [-help] [-group] [-keepRelative] {-flip <MX|MY> | -rotate <R90|R180|R270>} [-name <string> ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-flip",
      "description": "flip axis",
      "required": true,
      "type": "string"
    },
    {
      "name": "-group",
      "description": "rotate all selected instance as a group",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-keepRelative",
      "description": "call relative floorplan command",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "name of the Object you want to flip or rotate",
      "required": true,
      "type": "string"
    },
    {
      "name": "-rotate",
      "description": "rotate angle",
      "required": true,
      "type": "string"
    }
  ]
}