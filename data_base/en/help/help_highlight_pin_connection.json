{
  "command": "highlight_pin_connection",
  "is_cmd": true,
  "summary": "Highlights pin connection.",
  "description": "Highlights pin connection.",
  "usage": "highlight_pin_connection [-help] -from_pin <pin|port> [-mode {wire_segment whole_net flight_line}] -to_pin <pin|port> [ -with_arrow  | -select_only  ] [ -net_color_index <integer> | -select_only  ] [ -inst_color_index <integer> | -select_only  ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-from_pin",
      "description": "Specify the from term. ((instTerm|term), required)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-inst_color_index",
      "description": "specify inst color",
      "required": false,
      "type": "int"
    },
    {
      "name": "-mode",
      "description": "{wire_segment whole_net flight_line} specify draw mode",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-net_color_index",
      "description": "specify net color",
      "required": false,
      "type": "int"
    },
    {
      "name": "-select_only",
      "description": "",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-to_pin",
      "description": "Specify the to term. ((instTerm|term), required)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-with_arrow",
      "description": "define connection with arrow or not",
      "required": false,
      "type": "flag"
    }
  ]
}