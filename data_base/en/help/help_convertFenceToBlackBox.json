{
  "command": "convertFenceToBlackBox",
  "is_cmd": true,
  "summary": "Converts fence to black box.",
  "description": "Converts fence to black box.",
  "usage": "convertFenceToBlackBox [-help] [-noRebuildTiming] [-size {x y}] { -cell <string> | -hinst <string> }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "Specifies name of the partition.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-hinst",
      "description": "Specifies name of the hinst.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-noRebuildTiming",
      "description": "Skips re-building the time graph and re-initializing the top cell information.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-size",
      "description": "Specifies the width and height of the blackbox.",
      "required": false,
      "type": "int"
    }
  ]
}