{
  "command": "createLogicHierarchy",
  "is_cmd": true,
  "summary": "Creates logic hierarchy.",
  "description": "Creates logic hierarchy.",
  "usage": "createLogicHierarchy [-help] -cell <string> [-commit] -newHinst <string> [-objects <string>] [-selected]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "new cell name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-commit",
      "description": "commit group result",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-newHinst",
      "description": "new hier inst name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-objects",
      "description": "Specifies list of hinst and/or instance groups",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selected",
      "description": "specifies that grouping is done for the current selected hinsts or instant groups",
      "required": false,
      "type": "flag"
    }
  ]
}