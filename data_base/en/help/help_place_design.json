{
  "command": "place_design",
  "is_cmd": true,
  "summary": "Places design.",
  "description": "Places design.",
  "usage": "place_design [-help] [-concurrent_macros] [-incremental] [-noPrePlaceOpt] [-sdp]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-concurrent_macros",
      "description": "mixed size placement",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-incremental",
      "description": "Incremental placement",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noPrePlaceOpt",
      "description": "Disable pre-place optimization",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-sdp",
      "description": "Enables SDP-aware (Structured Data Path) placement",
      "required": false,
      "type": "flag"
    }
  ]
}