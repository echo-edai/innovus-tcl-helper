{
  "command": "placeInstance",
  "is_cmd": true,
  "summary": "Places instance.",
  "description": "Places instance.",
  "usage": "placeInstance [-help] <inst> <location> [{R0 R90 R180 R270 MX MX90 MY MY90}] [{ -fixed  | -placed  | -softFixed  }]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<inst>",
      "description": "instance name ((inst), required)",
      "required": false,
      "type": "string"
    },
    {
      "name": "<location>",
      "description": "coordinate of new origin (point, required) {R0 R90 R180 R270 MX MX90 MY MY90} # new orientation",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-fixed",
      "description": "mark instance as fixed",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-placed",
      "description": "mark instance as placed",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-softFixed",
      "description": "mark instance as softFixed",
      "required": false,
      "type": "flag"
    }
  ]
}