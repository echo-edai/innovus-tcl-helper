{
  "command": "cutRectilinearInst",
  "is_cmd": true,
  "summary": "Cuts rectilinear inst.",
  "description": "Cuts rectilinear inst.",
  "usage": "cutRectilinearInst [-help] -inst <inst|hInst|group>+ [-pushOut <string>] {{-refInst <inst|hInst|group>+ [-spacingX <float>] [-spacingY <float>]} | {-corner <string> [-x <float> -y <float>]} | {-cutBox {x1 y1 x2 y2}}}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-corner",
      "description": "name of a corner",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cutBox",
      "description": "rectilinear box that is to be cut",
      "required": false,
      "type": "point"
    },
    {
      "name": "-inst",
      "description": "name of a hierarchical instance ((inst|hInst|group)+, required)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pushOut",
      "description": "name of a side or edge",
      "required": false,
      "type": "string"
    },
    {
      "name": "-refInst",
      "description": "name of a referenced instance ((inst|hInst|group)+, required)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spacingX",
      "description": "X",
      "required": false,
      "type": "float"
    },
    {
      "name": "-spacingY",
      "description": "Y",
      "required": false,
      "type": "float"
    },
    {
      "name": "-x",
      "description": "x offset value",
      "required": false,
      "type": "float"
    },
    {
      "name": "-y",
      "description": "y offset value",
      "required": false,
      "type": "float"
    }
  ]
}