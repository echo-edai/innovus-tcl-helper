{
  "command": "placePIO",
  "is_cmd": true,
  "summary": "Places pio.",
  "description": "Places pio.",
  "usage": "placePIO [-help] [-assignBump] [-cellList <{cellNamePattern}>] [-extraConfig <fileName>] [-instList <{instNamePattern}>] [-ioFile <fileName>] [-maxIOHeight] [-noRandomPlacement] [-optIOs] [-overflowMap] [-powerDomain <powerDomainName>] [-rdlConstraintFile <fileName>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-assignBump",
      "description": "allows signal bumps to be reassigned to improve routing",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cellList",
      "description": "specifies the Area IO cells to be placed",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extraConfig",
      "description": "specifies extra configuration file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instList",
      "description": "specifies the Area IO instances to be placed",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ioFile",
      "description": "specifies the io file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-maxIOHeight",
      "description": "specifies the maximum height for the I/O row",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noRandomPlacement",
      "description": "will not do random initial IO placement",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-optIOs",
      "description": "optimizes the initial placement to improve routing",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-overflowMap",
      "description": "display the congestion map",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-powerDomain",
      "description": "places IOs in the row of specified power domain",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rdlConstraintFile",
      "description": "specifies rdl constraint file",
      "required": false,
      "type": "string"
    }
  ]
}