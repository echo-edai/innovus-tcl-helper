{
  "command": "swapSignal",
  "is_cmd": true,
  "summary": "Swaps signal.",
  "description": "Swaps signal.",
  "usage": "swapSignal [-help] [[-from <{nameList}> -to <{nameList}>] | -circle_offset <int>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-circle_offset",
      "description": "specifies the offset value to swap bump in circle. It's required to be positive and less than the number of the selected bumps.",
      "required": false,
      "type": "int"
    },
    {
      "name": "-from",
      "description": "bump names swap from",
      "required": false,
      "type": "string"
    },
    {
      "name": "-to",
      "description": "bump names swap to",
      "required": false,
      "type": "string"
    }
  ]
}