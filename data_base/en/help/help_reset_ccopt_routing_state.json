{
  "command": "reset_ccopt_routing_state",
  "is_cmd": true,
  "summary": "Resets ccopt routing state.",
  "description": "Resets ccopt routing state.",
  "usage": "reset_ccopt_routing_state [-help] [-excluded <nets>] [-no_delete_routes] [-reset_preroutes]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-excluded",
      "description": "list of excluded nets ((net)+, optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-no_delete_routes",
      "description": "do not remove clock routes",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset_preroutes",
      "description": "Reset the status of pre-routes",
      "required": false,
      "type": "flag"
    }
  ]
}