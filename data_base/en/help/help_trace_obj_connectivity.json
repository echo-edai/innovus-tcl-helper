{
  "command": "trace_obj_connectivity",
  "is_cmd": true,
  "summary": "Traces obj connectivity.",
  "description": "Traces obj connectivity.",
  "usage": "trace_obj_connectivity [-help] [-clear_trace] [-level <integer>] [-mode {netlist_based timing_based}] [-out_file <string>] [-insts <string>] | [-ports <string>] | [-selected ] | [-in_files <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clear_trace",
      "description": "clear existing trace result",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-in_files",
      "description": "load saved trace result",
      "required": false,
      "type": "string"
    },
    {
      "name": "-insts",
      "description": "specify the macros to be traced",
      "required": false,
      "type": "string"
    },
    {
      "name": "-level",
      "description": "specify the trace level, default:1",
      "required": false,
      "type": "int"
    },
    {
      "name": "-mode",
      "description": "specify the trace mode. netlist_based|timing_based",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-out_file",
      "description": "save trace result to specified file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ports",
      "description": "specify the IO ports to be traced",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selected",
      "description": "trace the selected macros or IO ports",
      "required": false,
      "type": "flag"
    }
  ]
}