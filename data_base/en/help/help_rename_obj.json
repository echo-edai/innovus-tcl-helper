{
  "command": "rename_obj",
  "is_cmd": true,
  "summary": "Renames obj.",
  "description": "Renames obj.",
  "usage": "rename_obj [-help]",
  "options": [
    {
      "name": "<new_name>",
      "description": "<new_name> [-escape_ok] [-flexible] [-quiet]",
      "required": false,
      "type": "string"
    },
    {
      "name": "-help",
      "description": "Prints out the command usage <inst|hInst|vCell|topCell|term|hTerm|hNet|test_clock|test_clock_domain> Object to rename ((inst|hInst|vCell|topCell|term|hTerm|hNet|test_clock|test_clock_domain), required)",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<new_name>",
      "description": "New base_name for object",
      "required": true,
      "type": "string"
    },
    {
      "name": "-escape_ok",
      "description": "Automatically escape special characters in <new_name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-flexible",
      "description": "Fix name collisions by adding _1, _2, etc. suffix",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-quiet",
      "description": "Suppress messages about renamed objects",
      "required": false,
      "type": "flag"
    }
  ]
}