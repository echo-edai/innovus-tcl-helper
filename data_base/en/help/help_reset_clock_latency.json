{
  "command": "reset_clock_latency",
  "is_cmd": true,
  "summary": "Resets clock latency.",
  "description": "Resets clock latency.",
  "usage": "reset_clock_latency [-help] <pin_or_clock_list> [-clock <clock_list>] [-source]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pin_or_clock_list>",
      "description": "List of pins, ports or clock objects for which the assertions are removed",
      "required": true,
      "type": "string"
    },
    {
      "name": "-clock",
      "description": "Removes latency associated with the clock list",
      "required": false,
      "type": "string"
    },
    {
      "name": "-source",
      "description": "Removes source latency",
      "required": false,
      "type": "flag"
    }
  ]
}