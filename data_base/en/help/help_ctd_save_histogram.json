{
  "command": "ctd_save_histogram",
  "is_cmd": true,
  "summary": "Clock tree debug save histogram.",
  "description": "Clock tree debug save histogram.",
  "usage": "ctd_save_histogram [-help] [-csv] -file <string> [-id <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-csv",
      "description": "Save in CSV format.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "File Name.",
      "required": true,
      "type": "string"
    },
    {
      "name": "-id",
      "description": "CTD Window ID, the default value is the id of active ctd window.",
      "required": false,
      "type": "string"
    }
  ]
}