{
  "command": "generate_esd_rlrp_report",
  "is_cmd": true,
  "summary": "Generates esd rlrp report.",
  "description": "Generates esd rlrp report.",
  "usage": "generate_esd_rlrp_report [-help] -net <string> [-number_threads <integer>] -state_directory <string> [-instance_pair_list <string> | -instance_pair_list_file <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-instance_pair_list",
      "description": "instance pair list {{INST1 INST2 [PIN1 PIN2]}+}",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance_pair_list_file",
      "description": "instance pair list file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "net name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-number_threads",
      "description": "<number of threads>",
      "required": false,
      "type": "int"
    },
    {
      "name": "-state_directory",
      "description": "<top level state directory>",
      "required": true,
      "type": "string"
    }
  ]
}