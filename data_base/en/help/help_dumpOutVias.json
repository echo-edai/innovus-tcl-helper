{
  "command": "dumpOutVias",
  "is_cmd": true,
  "summary": "Dumps out vias.",
  "description": "Dumps out vias.",
  "usage": "dumpOutVias [-help] [-autogen] [-file <filename>] [-all_via  | -signal  | -all_rule  | -default  | -ndr ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all_rule",
      "description": "dump out vias from all routing rules",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all_via",
      "description": "dump out all vias",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-autogen",
      "description": "dump out auto-gen'ed vias",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-default",
      "description": "dump out vias of default routing rule (the default)",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "output file name (default: 'dump_via.out')",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ndr",
      "description": "dump out vias of nondefault routing rules",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-signal",
      "description": "dump out signal vias",
      "required": false,
      "type": "flag"
    }
  ]
}