{
  "command": "flipSdpObject",
  "is_cmd": true,
  "summary": "Flips sdp object.",
  "description": "Flips sdp object.",
  "usage": "flipSdpObject [-help] -object {objName(s)} [-x  | -y ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-object",
      "description": "Name(s) of object to be flipped",
      "required": true,
      "type": "string"
    },
    {
      "name": "-x",
      "description": "flip x direction, default is y",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-y",
      "description": "flip y direction, default flip Y",
      "required": false,
      "type": "flag"
    }
  ]
}