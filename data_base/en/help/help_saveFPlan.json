{
  "command": "saveFPlan",
  "is_cmd": true,
  "summary": "Saves fplan.",
  "description": "Saves fplan.",
  "usage": "saveFPlan [-help] <file> [-noName] [-objType <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<file>",
      "description": "fplan file name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-noName",
      "description": "do not save object name",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-objType",
      "description": "objects section in floor plan file you want to update: {macro | pin | bndry | special_route | pin_constraint}",
      "required": false,
      "type": "string"
    }
  ]
}