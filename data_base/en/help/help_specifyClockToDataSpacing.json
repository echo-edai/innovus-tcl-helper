{
  "command": "specifyClockToDataSpacing",
  "is_cmd": true,
  "summary": "Specifies clock to data spacing.",
  "description": "Specifies clock to data spacing.",
  "usage": "specifyClockToDataSpacing [-help] {{-cell <string> {[-x <float> ] [-y <float> ]}} | -reset }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "specify clock cell",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "clear all clock-to-data spacing rules",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-x",
      "description": "specify spacing on both left/right sides",
      "required": false,
      "type": "float"
    },
    {
      "name": "-y",
      "description": "specify spacing on both top/bottom sides",
      "required": false,
      "type": "float"
    }
  ]
}