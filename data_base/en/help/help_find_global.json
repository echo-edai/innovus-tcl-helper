{
  "command": "find_global",
  "is_cmd": true,
  "summary": "Finds global.",
  "description": "Finds global.",
  "usage": "find_global [-help] [<pattern> | -non_default ] [[-tcl ] | [[-name ] [-value ] [-type ] [-default ] [-info ] [-range_or_enum ] [-transient ]]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pattern>",
      "description": "variable name or pattern, if not given all variables are returned",
      "required": false,
      "type": "string"
    },
    {
      "name": "-default",
      "description": "show default value of variables",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-info",
      "description": "show description of variables",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "show name of variables",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-non_default",
      "description": "return the list of variables that whose values are not the same as their default values",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-range_or_enum",
      "description": "show range or legal enum value list if they exist",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-tcl",
      "description": "return a tcl list that has every field value of the variables",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-transient",
      "description": "show if variable is transient",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-type",
      "description": "show type of variables, which is one of: bool int string enum double",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-value",
      "description": "show current value of variables",
      "required": false,
      "type": "flag"
    }
  ]
}