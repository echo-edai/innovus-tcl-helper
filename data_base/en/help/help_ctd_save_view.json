{
  "command": "ctd_save_view",
  "is_cmd": true,
  "summary": "Clock tree debug save view.",
  "description": "Clock tree debug save view.",
  "usage": "ctd_save_view [-help] -file <string> [-id <string>] [-legend_on] [-type {PNG GIF}]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "File Name.",
      "required": true,
      "type": "string"
    },
    {
      "name": "-id",
      "description": "Win ID, the default value is the returned value of command get_ctd_win_id.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-legend_on",
      "description": "Save whole window.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-type",
      "description": "Type of saved file. The default format is PNG.",
      "required": false,
      "type": "enum"
    }
  ]
}