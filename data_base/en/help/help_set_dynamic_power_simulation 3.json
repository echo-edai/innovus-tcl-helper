{
  "command": "set_dynamic_power_simulation",
  "is_cmd": true,
  "summary": "Sets dynamic power simulation.",
  "description": "Sets dynamic power simulation.",
  "usage": "set_dynamic_power_simulation [-help] [-activity_pattern <string>] [-period <string>] [-reset] [-resolution <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-activity_pattern",
      "description": "jitter activity pattern",
      "required": false,
      "type": "string"
    },
    {
      "name": "-period",
      "description": "Specifies the simulation period that dynamic power analysis will use.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "Resets all specified options back to default values.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-resolution",
      "description": "Specifies the transient time step size or resolution. Default: ps (picosecond),",
      "required": false,
      "type": "string"
    }
  ]
}