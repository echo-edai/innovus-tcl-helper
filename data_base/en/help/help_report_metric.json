{
  "command": "report_metric",
  "is_cmd": true,
  "summary": "Reports metric.",
  "description": "Reports metric.",
  "usage": "report_metric [-help] [<pattern>] [-format {html json excel text vivid}] [-id <string>] [-names <string>] [-out_file <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pattern>",
      "description": "Pattern to match",
      "required": false,
      "type": "string"
    },
    {
      "name": "-format",
      "description": "Output format",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-id",
      "description": "IDs of metrics to report (multiple IDs will produce a comparison, first is gold)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-names",
      "description": "List of names (wildcards supported)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-out_file",
      "description": "Target file name",
      "required": false,
      "type": "string"
    }
  ]
}