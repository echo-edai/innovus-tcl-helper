{
  "command": "get_default_switching_activity",
  "is_cmd": true,
  "summary": "Gets default switching activity.",
  "description": "Gets default switching activity.",
  "usage": "get_default_switching_activity [-help] [-clip_activity_to_domain_freq] [-clock_gates_enable] [-clock_gates_output] [-clock_gates_output_ratio] [-comb_clockgate_ratio] [-duty] [-global_activity] [-icg_ratio] [-input_activity] [-macro_activity] [-period] [-seq_activity]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clip_activity_to_domain_freq",
      "description": "domain-based activity clipping",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clock_gates_enable",
      "description": "set clock gates enable activity",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clock_gates_output",
      "description": "set clock gates output activity",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clock_gates_output_ratio",
      "description": "set clock gates output ratio",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-comb_clockgate_ratio",
      "description": "set propagation ratio for combinational clock gate cell outputs",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-duty",
      "description": "Specifies the duty cycle, which is the probability that the signal is a logical 1. Default : 0.5,",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-global_activity",
      "description": "Specifies the average number of times that all unset nodes switch in a clock cycle.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-icg_ratio",
      "description": "set propagation ratio for integrated clock gate cell outputs",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-input_activity",
      "description": "Specifies the average number of times that a primary input switches in a clock cycle.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-macro_activity",
      "description": "set macro activity",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-period",
      "description": "Specifies the default operating period (1/frequency).",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-seq_activity",
      "description": "Specifies the activity of outputs of sequential logic.",
      "required": false,
      "type": "flag"
    }
  ]
}