{
  "command": "checkFPlan",
  "is_cmd": true,
  "summary": "Checks fplan.",
  "description": "Checks fplan.",
  "usage": "checkFPlan [-help] [-keep_out_distance <value>] [-outFile <fileName>] [-reportUtil]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-keep_out_distance",
      "description": "specifies keep out distance for TSV check. This option is only used when -checkTypes tsv",
      "required": false,
      "type": "float"
    },
    {
      "name": "-outFile",
      "description": "report file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reportUtil",
      "description": "report core utilization",
      "required": false,
      "type": "flag"
    }
  ]
}