{
  "command": "create_module_model",
  "is_cmd": true,
  "summary": "Creates module model.",
  "description": "Creates module model.",
  "usage": "create_module_model [-help] [-allow_port_mismatch] [-cell <string>] [-phys_hier] [-tag <string>] [-type <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allow_port_mismatch",
      "description": "",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "<Specifies cell name to save. By default, current top cell will be saved. This option should only be used for 3DIC design and child partitions.>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-phys_hier",
      "description": "create whole hdb",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-tag",
      "description": "<flow tag>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "<type of module model> lef flexIlm ilm pnr etm 1801 spef mmmc boundary_model pnr_shell scan_info latency timing_context extraction_context pin_assign gds",
      "required": false,
      "type": "string"
    }
  ]
}