{
  "command": "place_connected",
  "is_cmd": true,
  "summary": "Places connected.",
  "description": "Places connected.",
  "usage": "place_connected [-help] -attractor <inst/IO NameList> [-attractor_pin <pinNameList>] [-fixed] [-move_fixed] [-placed] {-level <#> | -sequential <all_connected | direct_connected> | -stop_points <instName> | -before_points <instName> | -instance_pin <inst/pin>} [{ -stop_points <instName> | -key_cell <cellName> }] [{ -before_points <instName> | -key_cell <cellName> }] [{ -instance_pin <inst/pin> | -key_cell <cellName> }]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-attractor",
      "description": "attractor list",
      "required": true,
      "type": "string"
    },
    {
      "name": "-attractor_pin",
      "description": "only pull instances that have connection with certain pins.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-before_points",
      "description": "the attracting is stopped before these instances",
      "required": false,
      "type": "string"
    },
    {
      "name": "-fixed",
      "description": "set placement status as fixed",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-instance_pin",
      "description": "instances to force attract",
      "required": false,
      "type": "string"
    },
    {
      "name": "-key_cell",
      "description": "type of cell to be pulled close",
      "required": false,
      "type": "string"
    },
    {
      "name": "-level",
      "description": "> # logic level of connection",
      "required": false,
      "type": "int"
    },
    {
      "name": "-move_fixed",
      "description": "attract fixed instances as well",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-placed",
      "description": "set placement status as placed",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-sequential",
      "description": "{all_connected direct_connected} pull only directly connected or all sequential cells",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-stop_points",
      "description": "instances to stop by",
      "required": false,
      "type": "string"
    }
  ]
}