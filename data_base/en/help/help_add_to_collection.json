{
  "command": "add_to_collection",
  "is_cmd": true,
  "summary": "Adds to collection.",
  "description": "Adds to collection.",
  "usage": "add_to_collection [-help] <base_collection> <second_collection_or_list> [-unique]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<base_collection>",
      "description": "Base collection of objects",
      "required": true,
      "type": "string"
    },
    {
      "name": "<second_collection_or_list>",
      "description": "Second collection of objects, or an object list",
      "required": true,
      "type": "string"
    },
    {
      "name": "-unique",
      "description": "Retains any duplicate objects that already exist in the base collection",
      "required": false,
      "type": "flag"
    }
  ]
}