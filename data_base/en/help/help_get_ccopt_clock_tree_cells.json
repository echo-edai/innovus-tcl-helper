{
  "command": "get_ccopt_clock_tree_cells",
  "is_cmd": true,
  "summary": "Gets ccopt clock tree cells.",
  "description": "Gets ccopt clock tree cells.",
  "usage": "get_ccopt_clock_tree_cells [-help] [<pattern>] [-in_clock_trees <trees>] [-net_types <leaf|trunk|top>] [-node_types <buffer|inverter|clock_gate|logic|source|generator|all>] [-not_in_clock_trees <trees>] [-regexp]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pattern>",
      "description": "pattern for clock trees to return",
      "required": false,
      "type": "string"
    },
    {
      "name": "-in_clock_trees",
      "description": "return instances only in these clock trees",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net_types",
      "description": "return nodes driving nets of this type",
      "required": false,
      "type": "string"
    },
    {
      "name": "-node_types",
      "description": "<buffer|inverter|clock_gate|logic|source|generator|all> return instances of this type",
      "required": false,
      "type": "string"
    },
    {
      "name": "-not_in_clock_trees",
      "description": "return instances not in these clock trees",
      "required": false,
      "type": "string"
    },
    {
      "name": "-regexp",
      "description": "use regexp matching instead of wildcard (glob)",
      "required": false,
      "type": "flag"
    }
  ]
}