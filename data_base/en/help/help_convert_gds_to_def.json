{
  "command": "convert_gds_to_def",
  "is_cmd": true,
  "summary": "Converts gds to def.",
  "description": "Converts gds to def.",
  "usage": "convert_gds_to_def [-help] [-black_box_cell_file <string>] [-esd_cell_bbox_file <string>] [-esd_marker_layer_file <string>] [-extract_signal_net_logic_info_only] [-gds_file <string>] [-gds_layermap <string>] [-ignore_gds_inst_name] [-inst_name_file <string>] [-inst_name_prefix <string>] [-net_location_file <string>] [-output_components {ALL CONN NONE}] [-output_def_file <string>] [-output_lef_macros <string>] [-power_grid_library <string>] [-print_complete_short_path] [-spef_file <string>] [-tech_gds_layermap <string>] [-top_cell <string>] [-use_gds_label <string>] [-verilog_file <string>] [-zero_pin_size]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-black_box_cell_file",
      "description": "<black box cell file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-esd_cell_bbox_file",
      "description": "<esd cell bbox file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-esd_marker_layer_file",
      "description": "<esd marker layer file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extract_signal_net_logic_info_only",
      "description": "output only logical connectivity for signal net in NET section, no routing shapes",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-gds_file",
      "description": "<input gds file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-gds_layermap",
      "description": "<layer mapping file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ignore_gds_inst_name",
      "description": "ignore instance names read from gds file",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-inst_name_file",
      "description": "<instance name file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-inst_name_prefix",
      "description": "<instance name prefix>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net_location_file",
      "description": "<net location file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output_components",
      "description": "<format: ALL | CONN | NONE>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-output_def_file",
      "description": "<output def file name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output_lef_macros",
      "description": "<output lef macro list file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-power_grid_library",
      "description": "<power grid libraries>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-print_complete_short_path",
      "description": "print complete short path when shorted",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-spef_file",
      "description": "<input spef file name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tech_gds_layermap",
      "description": "<def/lef layer mapping file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-top_cell",
      "description": "<top cell name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-use_gds_label",
      "description": "<format: ALL | TOP | <tech layer name> | <cellname>:<tech layer name> | <cellname>:ALL>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-verilog_file",
      "description": "<output verilog file name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-zero_pin_size",
      "description": "set pin size to zero in the output def file",
      "required": false,
      "type": "flag"
    }
  ]
}