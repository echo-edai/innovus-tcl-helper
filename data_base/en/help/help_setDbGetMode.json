{
  "command": "setDbGetMode",
  "is_cmd": true,
  "summary": "Sets db get mode.",
  "description": "Sets db get mode.",
  "usage": "setDbGetMode [-help] [-reset] [-displayFormat {simple|table}] [-displayLimit <value>] [-escapeBusChar {true|false}]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "Resets all or specified options to default value",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-displayFormat",
      "description": "How to present the objects and attributes on stdout",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-displayLimit",
      "description": "Number of objects to be shown with dbGet",
      "required": false,
      "type": "int"
    },
    {
      "name": "-escapeBusChar",
      "description": "Whether to escape bus characters",
      "required": false,
      "type": "flag"
    }
  ]
}