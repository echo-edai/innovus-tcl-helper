{
  "command": "check_pg_library",
  "is_cmd": true,
  "summary": "Checks pg library.",
  "description": "Checks pg library.",
  "usage": "check_pg_library [-help] <power_library_name> [-cell_list_file <string>] [-check_parameters] [-command_dump] [-integrity_check] [-list] [-metal_density_map] [-output <string>] [-report] [-report_detail_multiple_voltage_cap] [-rule_file <string>] [-skip_layer_list_file <string>] [-skip_signal_net_check <string>] [-summary] [-tap_node_text_dump] [-tech_layers] [-total_currents] [-check_compatibility | -lef_consistency]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<power_library_name>",
      "description": "<absolute power library path(s)>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-cell_list_file",
      "description": "<file containing list of cells to be used in lef consistency check>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-check_compatibility",
      "description": "<check compatibility of a list of PGVs>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-check_parameters",
      "description": "<check PGV electrical parameters>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-command_dump",
      "description": "<dump commands with which .cl is formed>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-integrity_check",
      "description": "<integrity check>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-lef_consistency",
      "description": "<check lef pgv compatibility>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-list",
      "description": "<list the libraries and cells>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-metal_density_map",
      "description": "<generate metal density information>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output",
      "description": "<output directory where the reports have to be written>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-report",
      "description": "<generate report>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-report_detail_multiple_voltage_cap",
      "description": "<Reports multiple voltage cap table>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rule_file",
      "description": "<rule file for parameter checking>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-skip_layer_list_file",
      "description": "<to skip layer checks for list of layer>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-skip_signal_net_check",
      "description": "<to skip signal net check in check_pg_library>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-summary",
      "description": "<generate summary>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tap_node_text_dump",
      "description": "dump detailed report on tap nodes>",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-tech_layers",
      "description": "<dump tech layers>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-total_currents",
      "description": "<dump total current of each power/ground net for DDV>",
      "required": false,
      "type": "string"
    }
  ]
}