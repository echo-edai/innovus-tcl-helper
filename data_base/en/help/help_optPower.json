{
  "command": "optPower",
  "is_cmd": true,
  "summary": "Executes the 'optPower' command.",
  "description": "Executes the 'optPower' command.",
  "usage": "optPower [-help] [-allowResizing] [-effortLevel {high}] [-force] [-postCts] [-postRoute] [-preCts] [-prePlace] [-seqOnly]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allowResizing",
      "description": "Will only do sameSize/downSize/upSize",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-effortLevel",
      "description": "effort level option",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-force",
      "description": "forced leakage opt",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-postCts",
      "description": "is postcts mode",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-postRoute",
      "description": "is postroute mode",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-preCts",
      "description": "is prects mode",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-prePlace",
      "description": "is prePlace mode",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-seqOnly",
      "description": "recover power with focus on flops",
      "required": false,
      "type": "flag"
    }
  ]
}