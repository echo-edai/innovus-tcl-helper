{
  "command": "ctd_win",
  "is_cmd": true,
  "summary": "Clock tree debug win.",
  "description": "Clock tree debug win.",
  "usage": "ctd_win [-help] [-id <string>] [-include_reporting_only_skew_groups] [-title <string>] [-unit_delay]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-id",
      "description": "Specify unique window ID for the opening Clock Tree Debugger window.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-include_reporting_only_skew_groups",
      "description": "Include non-constraining skew groups.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-title",
      "description": "Specify the title of Clock Tree Debugger window.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-unit_delay",
      "description": "Open Clock Tree Debugger window in unit delay mode.",
      "required": false,
      "type": "flag"
    }
  ]
}