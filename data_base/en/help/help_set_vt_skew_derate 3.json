{
  "command": "set_vt_skew_derate",
  "is_cmd": true,
  "summary": "Sets vt skew derate.",
  "description": "Sets vt skew derate.",
  "usage": "set_vt_skew_derate [-help] [-delay_corner <string>] [-fast <float>] [-hold] [-mean] [-resetViewListVTSkew] [-setup] [-sigma] [-slow <float>] [-threshold_voltage_group <group name>] [-viewListVTSkew <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-delay_corner",
      "description": "delay corner list",
      "required": false,
      "type": "string"
    },
    {
      "name": "-fast",
      "description": "fast derate factor",
      "required": false,
      "type": "float"
    },
    {
      "name": "-hold",
      "description": "derate applied for hold",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-mean",
      "description": "derate applied to mean component",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-resetViewListVTSkew",
      "description": "VT skew view list",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-setup",
      "description": "derate applied for setup",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-sigma",
      "description": "derate applied to sigma component",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-slow",
      "description": "slow derate factor",
      "required": false,
      "type": "float"
    },
    {
      "name": "-threshold_voltage_group",
      "description": "VT group for which derates are to be applied",
      "required": false,
      "type": "string"
    },
    {
      "name": "-viewListVTSkew",
      "description": "VT skew view list",
      "required": false,
      "type": "string"
    }
  ]
}