      "required": false,
      "type": "string"
    },
    {
      "name": "-mmmcFile",
      "description": "<mmmcFile>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-noTiming",
      "description": "<no timing>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-noTimingGraph",
      "description": "<no timing graph>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-setup_views",
      "description": "<active setup view>",
      "required": false,
      "type": "string"
