{
  "command": "set_drive",
  "is_cmd": true,
  "summary": "Sets drive.",
  "description": "Sets drive.",
  "usage": "set_drive [-help] <resistance_value> <port_list> [-fall] [-max] [-min] [-rise]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<resistance_value>",
      "description": "Value of the drive resistance",
      "required": true,
      "type": "float"
    },
    {
      "name": "<port_list>",
      "description": "List of ports",
      "required": true,
      "type": "string"
    },
    {
      "name": "-fall",
      "description": "Specifies the drive resistance for falling transition",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-max",
      "description": "Specifies the drive resistance for late path",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-min",
      "description": "Specifies the drive resistance for early path",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-rise",
      "description": "Specifies the drive resistance for rising transition",
      "required": false,
      "type": "flag"
    }
  ]
}