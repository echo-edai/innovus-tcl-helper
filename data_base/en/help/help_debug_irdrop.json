{
  "command": "debug_irdrop",
  "is_cmd": true,
  "summary": "Executes the 'debug_irdrop' command.",
  "description": "Executes the 'debug_irdrop' command.",
  "usage": "debug_irdrop [-help] [-eco_report] [-enable_xp {true false}] [-non_violating_instslimit <float>] [-nworst_instances <integer>] [-output_directory <string>] -state_directory <string> [-summary_only] [ -net <string> | -domain <string> ] [ -net_threshold <float> | -domain_threshold <float> ] [ -region {x1 y1 x2 y2} | -nregion <integer> ] [ -tile_row_col {x y} | -tile_size {x y} ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-domain",
      "description": "domain name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-domain_threshold",
      "description": "domain threshold",
      "required": false,
      "type": "float"
    },
    {
      "name": "-eco_report",
      "description": "create eco report",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-enable_xp",
      "description": "<use full distributed partition Voltus-XP invocation.>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-net",
      "description": "net name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-net_threshold",
      "description": "net threshold",
      "required": false,
      "type": "float"
    },
    {
      "name": "-non_violating_instslimit",
      "description": "report non-violating instances that are close to threshold",
      "required": false,
      "type": "float"
    },
    {
      "name": "-nregion",
      "description": "number of regions",
      "required": false,
      "type": "int"
    },
    {
      "name": "-nworst_instances",
      "description": "number of worst instances",
      "required": false,
      "type": "int"
    },
    {
      "name": "-output_directory",
      "description": "output directory",
      "required": false,
      "type": "string"
    },
    {
      "name": "-region",
      "description": "region",
      "required": false,
      "type": "point"
    },
    {
      "name": "-state_directory",
      "description": "state directory",
      "required": true,
      "type": "string"
    },
    {
      "name": "-summary_only",
      "description": "only do summary report",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-tile_row_col",
      "description": "number of tiles in x and y direction",
      "required": false,
      "type": "int"
    },
    {
      "name": "-tile_size",
      "description": "size of each tile in x and y direction",
      "required": false,
      "type": "int"
    }
  ]
}