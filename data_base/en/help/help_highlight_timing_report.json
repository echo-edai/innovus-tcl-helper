{
  "command": "highlight_timing_report",
  "is_cmd": true,
  "summary": "Highlights timing report.",
  "description": "Highlights timing report.",
  "usage": "highlight_timing_report [-help] [-append] [-color_index <integer>] [-file <string>] [-noarrow] {-path <string> | -all }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "Higtlight all the path",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-append",
      "description": "Append to current highlight",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-color_index",
      "description": "specify the path color_index from 1 to 8.",
      "required": false,
      "type": "int"
    },
    {
      "name": "-file",
      "description": "Specifies the file name.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-noarrow",
      "description": "Removes the highlighted arrow.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-path",
      "description": "Specify the number of the path.",
      "required": true,
      "type": "string"
    }
  ]
}