{
  "command": "setLayerPreference",
  "is_cmd": true,
  "summary": "Sets layer preference.",
  "description": "Sets layer preference.",
  "usage": "setLayerPreference [-help] <layer_name> [-color <string>] [-isSelectable {1 0}] [-isVisible {1 0}] [-lineWidth <integer>] [-stipple <string>] [-stippleData <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<layer_name>",
      "description": "the name of the layer or the object type",
      "required": true,
      "type": "string"
    },
    {
      "name": "-color",
      "description": "a color name or a numeric RGB value",
      "required": false,
      "type": "string"
    },
    {
      "name": "-isSelectable",
      "description": "whether the object is selectable",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-isVisible",
      "description": "whether the object is visible",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-lineWidth",
      "description": "number of pixels in the border of the specified object",
      "required": false,
      "type": "int"
    },
    {
      "name": "-stipple",
      "description": "information about the stipple pattern of the object",
      "required": false,
      "type": "string"
    },
    {
      "name": "-stippleData",
      "description": "the stipple information for the object",
      "required": false,
      "type": "string"
    }
  ]
}