{
  "command": "reportPowerDomain",
  "is_cmd": true,
  "summary": "Reports power domain.",
  "description": "Reports power domain.",
  "usage": "reportPowerDomain [-help] [-bindLib] [-file <string>] [-isoInst] [-module <inst|hinst>+] [-partitionHports <pin|port|hpin>+] [-pgNet] [-pin <pin|port|hpin>+] [-powerDomainBoundaryPort <string>] [-powerDomainCoverage <pd1 pd2>] [-shifter] [-supplyCrossing <supp1 supp2>] [-verbose] [-voltage] [-powerDomain <pd> [-checkPgScope ] ] [-net <net>+} ] [-inst <inst>+ ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bindLib",
      "description": "report library binding",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-checkPgScope",
      "description": "pg should connect to scope net only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "output file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-inst",
      "description": "list of insts ((inst)*, optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-isoInst",
      "description": "report isolation",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-module",
      "description": "list of modules ((inst|hInst)*, optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "list of nets ((net)*, optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-partitionHports",
      "description": "list of hier. pins ((instTerm|term|hInstTerm)*, optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pgNet",
      "description": "report PG nets",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pin",
      "description": "list of pins ((instTerm|term|hInstTerm)*, optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-powerDomain",
      "description": "power domain name ((pd), optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-powerDomainBoundaryPort",
      "description": "port name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-powerDomainCoverage",
      "description": "",
      "required": false,
      "type": "string"
    },
    {
      "name": "-shifter",
      "description": "report shifter",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-supplyCrossing",
      "description": "",
      "required": false,
      "type": "string"
    },
    {
      "name": "-verbose",
      "description": "print out detail infomation",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-voltage",
      "description": "report domain voltages",
      "required": false,
      "type": "flag"
    }
  ]
}