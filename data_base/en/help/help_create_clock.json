{
  "command": "create_clock",
  "is_cmd": true,
  "summary": "Creates clock.",
  "description": "Creates clock.",
  "usage": "create_clock [-help] [<sources>] [-add] [-comment <string>] [-name <clock_name>] -period <period_value> [-waveform <edge_list>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<sources>",
      "description": "List of pins or ports associated with the clock",
      "required": false,
      "type": "string"
    },
    {
      "name": "-add",
      "description": "Multiple clocks on the same source",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-comment",
      "description": "Not supported option",
      "required": false,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "String name of the clock",
      "required": false,
      "type": "string"
    },
    {
      "name": "-period",
      "description": "Clock period in library time units",
      "required": true,
      "type": "float"
    },
    {
      "name": "-waveform",
      "description": "Rise and fall edge times of the clock",
      "required": false,
      "type": "string"
    }
  ]
}