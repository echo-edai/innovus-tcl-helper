{
  "command": "globalNetConnect",
  "is_cmd": true,
  "summary": "Executes the 'globalNetConnect' command.",
  "description": "Executes the 'globalNetConnect' command.",
  "usage": "globalNetConnect [-help] [<globalNetName>] [-all] [-autoTie] [-disconnect] [-hierarchicalInstance <string>] [-instanceBasename <string>] [-net <string>] [-netlistOverride] [-nonHierarchical] [-override] [-pin <string>] [-powerDomain <string>] [-region {x1 y1 x2 y2}] [-singleInstance <string>] [-type {pgpin tiehi tielo net}] [-verbose]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<globalNetName>",
      "description": "Name of the global net to be connected.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-all",
      "description": "apply to all specified nets/pins",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-autoTie",
      "description": "automatically tie off specified P/G pins",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-disconnect",
      "description": "disconnect p/g net connection, this option only works with -singleInstance/-hierarchicalInstance/-instanceBasename, -type pgpin and -pin options.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hierarchicalInstance",
      "description": "hierarchical instance name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instanceBasename",
      "description": "cell instance basename pattern",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "net basename pattern",
      "required": false,
      "type": "string"
    },
    {
      "name": "-netlistOverride",
      "description": "override netlist connections",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-nonHierarchical",
      "description": "non hierarchical cell instance",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-override",
      "description": "override existing setting",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pin",
      "description": "pin name pattern",
      "required": false,
      "type": "string"
    },
    {
      "name": "-powerDomain",
      "description": "power domain name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-region",
      "description": "region",
      "required": false,
      "type": "point"
    },
    {
      "name": "-singleInstance",
      "description": "cell instance name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "global net type",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-verbose",
      "description": "turn verbose on",
      "required": false,
      "type": "flag"
    }
  ]
}