{
  "command": "read_sai",
  "is_cmd": true,
  "summary": "Reads sai.",
  "description": "Reads sai.",
  "usage": "read_sai [-help] [<name>] [-partial] [-reduce_by_flexfiller] [-rule_only]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<name>",
      "description": "specify the sai file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-partial",
      "description": "Design has been loaded using restoreDesign",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reduce_by_flexfiller",
      "description": "specify the flexfiller whether is used",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-rule_only",
      "description": "only import rule in sai file",
      "required": false,
      "type": "flag"
    }
  ]
}