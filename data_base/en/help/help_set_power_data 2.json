{
  "command": "set_power_data",
  "is_cmd": true,
  "summary": "Sets power data.",
  "description": "Sets power data.",
  "usage": "set_power_data [-help] -reset | {-format {current ascii area ascii_current} [-instance <string>] [-strip_hier_instance <string>] [-offset <string>] [-power <float>] [-scale <float>] [-repeat <float>] [-repeat_window <string>] [-bias_voltage <float>] [-die_instance_name <string>] [<filename> | -power_output_directory <string>]}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage <filename> # <power filename>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-bias_voltage",
      "description": "<bias voltage value>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-die_instance_name",
      "description": "<die instance name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-format",
      "description": "{current ascii area ascii_current} <format: current | ascii | area | ascii_current>",
      "required": true,
      "type": "enum"
    },
    {
      "name": "-instance",
      "description": "<instance name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-offset",
      "description": "<cycle offset>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-power",
      "description": "<power value>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-power_output_directory",
      "description": "<power file directory>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-repeat",
      "description": "<repeat number>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-repeat_window",
      "description": "<repeat window {start end} (ns)>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "reset all power data",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-scale",
      "description": "<scale number>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-strip_hier_instance",
      "description": "<instance name>",
      "required": false,
      "type": "string"
    }
  ]
}