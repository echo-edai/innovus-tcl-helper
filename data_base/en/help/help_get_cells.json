{
  "command": "get_cells",
  "is_cmd": true,
  "summary": "Gets cells.",
  "description": "Gets cells.",
  "usage": "get_cells [-help] [-filter <expr>] [-hierarchical] [-hsc <char>] [-leaf] [-nocase] [-quiet] [-regexp] [ <patterns> | -of_objects <object_list> ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<patterns>",
      "description": "Patterns for instance names",
      "required": false,
      "type": "string"
    },
    {
      "name": "-filter",
      "description": "Filters the collection with the specified expression",
      "required": false,
      "type": "string"
    },
    {
      "name": "-hierarchical",
      "description": "Patterns should be matched hierarchically",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hsc",
      "description": "Hierarchical delimiter for patterns",
      "required": false,
      "type": "string"
    },
    {
      "name": "-leaf",
      "description": "Return leaf cells only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-nocase",
      "description": "Pattern matching is not case sensitive",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-of_objects",
      "description": "Creates a collection of all cells associated with the specified pins or nets",
      "required": false,
      "type": "string"
    },
    {
      "name": "-quiet",
      "description": "Suppresses all error and warning messages generated when the get_cells command is run",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-regexp",
      "description": "Treats the specified patterns as a regular expression patterns",
      "required": false,
      "type": "flag"
    }
  ]
}