{
  "command": "write_tcf",
  "is_cmd": true,
  "summary": "Writes tcf.",
  "description": "Writes tcf.",
  "usage": "write_tcf [-help] [<file>] [-block <string>] [-exclude_hier_insts <string>] [-macro_output] [-pin] [-primary_input] [-seq_output]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<file>",
      "description": "file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-block",
      "description": "dump block level duty and activity",
      "required": false,
      "type": "string"
    },
    {
      "name": "-exclude_hier_insts",
      "description": "-excludeHierInsts <hier-inst-list>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-macro_output",
      "description": "macro output only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pin",
      "description": "pin format",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-primary_input",
      "description": "primary input only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-seq_output",
      "description": "sequential output only",
      "required": false,
      "type": "flag"
    }
  ]
}