{
  "command": "placePipeline",
  "is_cmd": true,
  "summary": "Places pipeline.",
  "description": "Places pipeline.",
  "usage": "placePipeline [-help] [-netGroup <netGroupNames>] [-status {softFixed placed fixed}] [-timingBased] [{-region } [-utilization <val>]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-netGroup",
      "description": "name(s) of net group(s)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-region",
      "description": "create regions for flops",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-status",
      "description": "placement status of flops",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-timingBased",
      "description": "automatically find reserve lengths",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-utilization",
      "description": "expected utilization of regions for flops",
      "required": false,
      "type": "float"
    }
  ]
}