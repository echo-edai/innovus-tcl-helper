{
  "command": "set_proc_verbose",
  "is_cmd": true,
  "summary": "Sets proc verbose.",
  "description": "Sets proc verbose.",
  "usage": "set_proc_verbose [-help] {[<proc_name> [-quiet ]] | [-report ]}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<proc_name>",
      "description": "the name of the proc to make verbose",
      "required": true,
      "type": "string"
    },
    {
      "name": "-quiet",
      "description": "change the proc back to not verbose",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-report",
      "description": "report procs that are verbose",
      "required": false,
      "type": "flag"
    }
  ]
}