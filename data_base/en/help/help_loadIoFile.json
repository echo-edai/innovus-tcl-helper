{
  "command": "loadIoFile",
  "is_cmd": true,
  "summary": "Loads io file.",
  "description": "Loads io file.",
  "usage": "loadIoFile [-help] <file_name> [-noAdjustDieSize] [-specifiedIosOnly] [-ECO  [-padsOnly  | -bumpsOnly ]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<file_name>",
      "description": "file to be loaded",
      "required": true,
      "type": "string"
    },
    {
      "name": "-ECO",
      "description": "use IO file to perform IO/Bump ECO",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bumpsOnly",
      "description": "only do bump ECO operation",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noAdjustDieSize",
      "description": "don't adjust die size",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-padsOnly",
      "description": "only do pad ECO operation",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-specifiedIosOnly",
      "description": "only load the io in the specified io file",
      "required": false,
      "type": "flag"
    }
  ]
}