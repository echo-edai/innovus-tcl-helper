{
  "command": "reportVoltage",
  "is_cmd": true,
  "summary": "Reports voltage.",
  "description": "Reports voltage.",
  "usage": "reportVoltage [-help] [-quiet] [-view <string>] [-term <string> | -net <string> | -inst <string>] [-early | -late]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-early",
      "description": "early mode (default late)",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-inst",
      "description": "inst name or pointer",
      "required": false,
      "type": "string"
    },
    {
      "name": "-late",
      "description": "late mode",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-net",
      "description": "net name or pointer",
      "required": false,
      "type": "string"
    },
    {
      "name": "-quiet",
      "description": "only return the voltage and not printing information",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-term",
      "description": "term name or pointer",
      "required": false,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "analysis view",
      "required": false,
      "type": "string"
    }
  ]
}