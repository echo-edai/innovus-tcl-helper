{
  "command": "saveIoFile",
  "is_cmd": true,
  "summary": "Saves io file.",
  "description": "Saves io file.",
  "usage": "saveIoFile [-help] <fileName> [-includeCellName] [-only_selected_bump] [-relativeOrient] [-v2] [-temp  [-ioOrder <string>]] [-locations  | -byOrder ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<fileName>",
      "description": "name of I/O constraint file",
      "required": true,
      "type": "string"
    },
    {
      "name": "-byOrder",
      "description": "save order",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-includeCellName",
      "description": "if you specify this option, IO file will include cell name of IO instance",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ioOrder",
      "description": "order in template file: default | clockwise | counterclockwise",
      "required": false,
      "type": "string"
    },
    {
      "name": "-locations",
      "description": "save location",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-only_selected_bump",
      "description": "only save selected bump to file",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-relativeOrient",
      "description": "save orientation relative to the bottom side",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-temp",
      "description": "save template file",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-v2",
      "description": "save in version 2 syntax",
      "required": false,
      "type": "flag"
    }
  ]
}