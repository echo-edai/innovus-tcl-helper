  "usage": "deleteInst [-help] <instName> [-moduleBased <moduleName>] [-verbose]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<instName>",
      "description": "Name of instance",
      "required": true,
      "type": "string"
    },
    {
      "name": "-moduleBased",
      "description": "Name of verilog module ((vCell|topCell), optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-verbose",
      "description": "verbose",
      "required": false,
      "type": "flag"
    }
  ]
}