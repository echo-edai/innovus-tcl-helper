{
  "command": "add_sai_boundary_flops",
  "is_cmd": true,
  "summary": "Adds sai boundary flops.",
  "description": "Adds sai boundary flops.",
  "usage": "add_sai_boundary_flops [-help] [-clock <string>] [-delete_flops] -hinsts <string> -ports <string> [-ref_flop <string> [-clock_input_pin <string>] [-data_input_pin <string>] [-data_output_pin <string>]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clock",
      "description": "Specifies module's clock port name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-clock_input_pin",
      "description": "Specify cell CLK port name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-data_input_pin",
      "description": "Specify cell D port name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-data_output_pin",
      "description": "Specify cell Q port name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-delete_flops",
      "description": "remove all flops which are added",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hinsts",
      "description": "Specifies the module name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-ports",
      "description": "Specifies module pin name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-ref_flop",
      "description": "Specify the flop cell name to be inserted along the boundary",
      "required": false,
      "type": "string"
    }
  ]
}