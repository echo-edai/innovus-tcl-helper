{
  "command": "fcroute",
  "is_cmd": true,
  "summary": "Flip-chip route the design.",
  "description": "Flip-chip route the design.",
  "usage": "fcroute [-help] [-area {x1 y1 x2 y2}] [-connectInsideArea] [-connectTsvToBump] [-connectTsvToPad] [-connectTsvToRingStripe] [-constraintFile <filename>] [-deleteExistingRoutes] [-designStyle {aio pio}] [-doubleBendRoute] [-extraConfig <filename>] [-jogControl {preferWithChanges preferSameLayer preferDifferentLayer}] [-keepDRC] [-layerChangeBotLayer <layerName>] [-layerChangeTopLayer <layerName>] [-minEscapeDistance <value>] [-msgRate <value>] [-overflowMap] [-routeWidth <float>] [-route_pg_style {none finger mesh}] [-spreadWiresFactor <value>] [-straightConnections {straightWithDrcClean straightWithChanges}] [-subclass <subclass_string>] -type {power signal} [-verbose] [-eco | -incremental ] [-nets <net_list|<filename|~<filename> | -selected_bump ] [-globalOnly ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-area",
      "description": "Specifies coordinates for area",
      "required": false,
      "type": "point"
    },
    {
      "name": "-connectInsideArea",
      "description": "Connects inside area",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-connectTsvToBump",
      "description": "Connects tsv to bump",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-connectTsvToPad",
      "description": "Connects tsv to pad",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-connectTsvToRingStripe",
      "description": "Connects tsv to ring stripe",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-constraintFile",
      "description": "",
      "required": false,
      "type": "string"
    },
    {
      "name": "-deleteExistingRoutes",
      "description": "Deletes existing routes",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-designStyle",
      "description": "Specifies design style",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-doubleBendRoute",
      "description": "Allows double-bend routing",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-eco",
      "description": "Enable ECO mode Flipchip routing",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-extraConfig",
      "description": "Specifies extra config file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-globalOnly",
      "description": "Runs global routing only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-incremental",
      "description": "Runs PIO mode incrementally",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-jogControl",
      "description": "{preferWithChanges preferSameLayer preferDifferentLayer} Specifies jogging preference",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-keepDRC",
      "description": "Keeps DRC violations",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-layerChangeBotLayer",
      "description": "Specifies bottom-most metal layer",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layerChangeTopLayer",
      "description": "specifies top-most metal layer",
      "required": false,
      "type": "string"
    },
    {
      "name": "-minEscapeDistance",
      "description": "Specifies minimum escape distance",
      "required": false,
      "type": "float"
    },
    {
      "name": "-msgRate",
      "description": "Specifies message rate",
      "required": false,
      "type": "int"
    },
    {
      "name": "-nets",
      "description": "Specifies list of net name or net file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-overflowMap",
      "description": "Displays overflow map",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-routeWidth",
      "description": "Specifies routing width",
      "required": false,
      "type": "float"
    },
    {
      "name": "-route_pg_style",
      "description": "Specifies power routing style",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-selected_bump",
      "description": "Route the selected bumps",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-spreadWiresFactor",
      "description": "Specifies wire spreading factor",
      "required": false,
      "type": "float"
    },
    {
      "name": "-straightConnections",
      "description": "{straightWithDrcClean straightWithChanges} Specifies straight connections",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-subclass",
      "description": "Specific subclass name to be assigned to the wires and vias created",
      "required": false,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "Specifies the bump type",
      "required": true,
      "type": "enum"
    },
    {
      "name": "-verbose",
      "description": "Prints each progress message",
      "required": false,
      "type": "flag"
    }
  ]
}