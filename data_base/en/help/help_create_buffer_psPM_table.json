{
  "command": "create_buffer_psPM_table",
  "is_cmd": true,
  "summary": "Creates buffer ps pm table.",
  "description": "Creates buffer ps pm table.",
  "usage": "create_buffer_psPM_table [-help] [-file <string>] [-inverters <string>] [-layer <string>] -max_target_slew <float> -min_target_slew <float> [-rpt_file <string>] [-slew_interval <float>] [-buffers <string> ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-buffers",
      "description": "List of input buffers. Specified buffer should have only one input and one output.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-file",
      "description": "Suggested insertRepeater rule file name. Default is <designName>_repeater.rule.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-inverters",
      "description": "List of input inverters.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer",
      "description": "Specifies the list layer names.Default is all available routing layers.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-max_target_slew",
      "description": "Maximum target slew in picoseconds.",
      "required": true,
      "type": "float"
    },
    {
      "name": "-min_target_slew",
      "description": "Minimum target slew in picoseconds.",
      "required": true,
      "type": "float"
    },
    {
      "name": "-rpt_file",
      "description": "Report file name. Default is <designName>_buffer_psPM.rpt.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-slew_interval",
      "description": "Slew range interval. Specified value should be within [0.01 1.0]. Default is 0.1. It is used for the step calculation. step = (max_target_slew - min_target_slew) * slew_interval",
      "required": false,
      "type": "float"
    }
  ]
}