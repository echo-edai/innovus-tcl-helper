{
  "command": "reset_annotated_delay",
  "is_cmd": true,
  "summary": "Resets annotated delay.",
  "description": "Resets annotated delay.",
  "usage": "reset_annotated_delay [-help] { [-all ] |[ [-from <from_pins>] [-to <to_pins>] ]| [<object_spec>] }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<object_spec>",
      "description": "List of objects: instances, nets",
      "required": false,
      "type": "string"
    },
    {
      "name": "-all",
      "description": "Specifies to remove annotated delay from all arcs",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-from",
      "description": "Specifies the from pin of arc on which annotated delay is to be reset",
      "required": false,
      "type": "string"
    },
    {
      "name": "-to",
      "description": "Specifies the to pin of arc on which annotated delay is to be reset",
      "required": false,
      "type": "string"
    }
  ]
}