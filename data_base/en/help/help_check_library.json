{
  "command": "check_library",
  "is_cmd": true,
  "summary": "Checks library.",
  "description": "Checks library.",
  "usage": "check_library [-help] [-place [-cell <cells> | -all_lib_cell ] [-legal_frequency ] [-file <name>] ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all_lib_cell",
      "description": "check all lib cells",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "specify cells to check ((libCell/ptnCell)+, optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-file",
      "description": "output file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-legal_frequency",
      "description": "check multi-height cell legal frequency",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-place",
      "description": "do library checking for placement",
      "required": false,
      "type": "flag"
    }
  ]
}