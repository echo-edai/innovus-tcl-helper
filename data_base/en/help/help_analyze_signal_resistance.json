{
  "command": "analyze_signal_resistance",
  "is_cmd": true,
  "summary": "Analyzes signal resistance.",
  "description": "Analyzes signal resistance.",
  "usage": "analyze_signal_resistance [-help] [-instance_pair_list_file <string>] -net <string> [-output_dir <string>] [-report <string>] [-threshold <float>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-instance_pair_list_file",
      "description": "signal net instance-pin pairs for which reffective need to be computed",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "<name of signal net>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-output_dir",
      "description": "output directory",
      "required": false,
      "type": "string"
    },
    {
      "name": "-report",
      "description": "output file for Effective R",
      "required": false,
      "type": "string"
    },
    {
      "name": "-threshold",
      "description": "threshold R value in ohm",
      "required": false,
      "type": "float"
    }
  ]
}