      "required": false,
      "type": "flag"
    },
    {
      "name": "-show_all_attackers",
      "description": "Include small attackers in report",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-si",
      "description": "Report SI related information",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-thresholds",
      "description": "Report the threshold values.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-to",
      "description": "Specifies the name of the -to port or pin.",
      "required": true,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "Specifies the view name.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-voltage",
      "description": "Report the voltage of the cell or net timing arc.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-waveform",
      "description": "Report the waveforms of the pins.",
      "required": false,
      "type": "flag"
    }
