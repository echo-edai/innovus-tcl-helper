{
  "command": "reportDelayCalculation",
  "is_cmd": true,
  "summary": "Reports delay calculation.",
  "description": "Reports delay calculation.",
  "usage": "reportDelayCalculation [-help] [-active_arcs] -from <string> [-max] [-min] [-mis] [-outfile <string>] [-physical_context] [-show_all_attackers] [-si] [-thresholds] -to <string> [-view <string>] [-voltage] [-waveform]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-active_arcs",
      "description": "show active arcs only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-from",
      "description": "Specifies the name of the -from port or pin.",
      "required": true,
      "type": "string"
    },
    {
      "name": "-max",
      "description": "Report worst-case in min-max mode.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-min",
      "description": "Report best-case in min-max mode.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-mis",
      "description": "Report AMIS related information",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-outfile",
      "description": "Specifies the output file name.",
      "required": false,
      "type": "string"
    },
    {
