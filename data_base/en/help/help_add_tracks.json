{
  "command": "add_tracks",
  "is_cmd": true,
  "summary": "Adds tracks.",
  "description": "Adds tracks.",
  "usage": "add_tracks [-help] [-backside] [-honor_pitch] [-keep_default_width] [-mask_pattern <string>] [-mode {replace append}] [-offsets <string>] [-pitch_pattern <string>] [-pitches <string>] [-rect_only_pattern <string>] [-route_rule <string>] [-snap_m1_track_to_cell_pins] [-width_pitch_pattern <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-backside",
      "description": "generate tracks on backside layers",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-honor_pitch",
      "description": "honor pitches defined in LEF file",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-keep_default_width",
      "description": "keep user specified default width",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-mask_pattern",
      "description": "mask pattern",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mode",
      "description": "incremental mode",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-offsets",
      "description": "offset pattern",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pitch_pattern",
      "description": "pitch pattern",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pitches",
      "description": "pitch pattern",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rect_only_pattern",
      "description": "rect only pattern",
      "required": false,
      "type": "string"
    },
    {
      "name": "-route_rule",
      "description": "NDR rule name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-snap_m1_track_to_cell_pins",
      "description": "snap M1 tracks to cell pins",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-width_pitch_pattern",
      "description": "width pattern",
      "required": false,
      "type": "string"
    }
  ]
}