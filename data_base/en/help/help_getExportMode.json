{
  "command": "getExportMode",
  "is_cmd": true,
  "summary": "Gets export mode.",
  "description": "Gets export mode.",
  "usage": "getExportMode [-help] [-fullPinout] [-implicitPortMapping] [-quiet] [-nonDefault]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-fullPinout",
      "description": "Output all pins.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-implicitPortMapping",
      "description": "Do implicit port mapping.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-quiet",
      "description": "Displays the current settings in Tcl list format only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-nonDefault",
      "description": "Displays the current settings which are not default settings",
      "required": false,
      "type": "flag"
    }
  ]
}