{
  "command": "mark_physical_power_domains",
  "is_cmd": true,
  "summary": "Marks physical power domains.",
  "description": "Marks physical power domains.",
  "usage": "mark_physical_power_domains [-help] {-domains <string> | -reset | -checkOnly } [-domains <string> [-groupPhyLogicalDomains {{phyPd lpd1 lpd2 ...} ...}] ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-checkOnly",
      "description": "do checking of fence sharing against P/G nets",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-domains",
      "description": "name of domain with fence",
      "required": true,
      "type": "string"
    },
    {
      "name": "-groupPhyLogicalDomains",
      "description": "{{phyPd lpd1 lpd2 ...} ...} list of domains",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "reset sharing setting",
      "required": true,
      "type": "flag"
    }
  ]
}