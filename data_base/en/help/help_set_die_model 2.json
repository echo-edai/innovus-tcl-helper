{
  "command": "set_die_model",
  "is_cmd": true,
  "summary": "Sets die model.",
  "description": "Sets die model.",
  "usage": "set_die_model [-help] [-static_current <string>] [-subckt <string>] {-reset  | [[-die_instance_name <string> [-spice <string> [-mapping <string>]]] ]}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-die_instance_name",
      "description": "<die instance name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mapping",
      "description": "<mapping file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "<reset all previous set_die_model commands>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spice",
      "description": "<Spice die model>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-static_current",
      "description": "<use initial or averge current from pwl current for static analysis>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-subckt",
      "description": "<top level sub-circuit name>",
      "required": false,
      "type": "string"
    }
  ]
}