{
  "command": "map_dies",
  "is_cmd": true,
  "summary": "Maps dies.",
  "description": "Maps dies.",
  "usage": "map_dies [-help] [-3dic_design_stack_file <string>] [-component_config_file <string>] [-config <string>] [-die_pad_file_pair <string>] [-map_search_distance <string>] [-mode <string>] [-output <string>] [-stacked_die_mapping <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-3dic_design_stack_file",
      "description": "<XML file for placement of 3DIC design>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-component_config_file",
      "description": "<sanity check : config file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-config",
      "description": "<JSON config file for create_xml mode>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-die_pad_file_pair",
      "description": "<die pad file pair>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-map_search_distance",
      "description": "<sanity check : legal mapping distance range>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mode",
      "description": "<mode>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output",
      "description": "<output directory of mapping results>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-stacked_die_mapping",
      "description": "<sanity check : mapping result for check>",
      "required": false,
      "type": "string"
    }
  ]
}