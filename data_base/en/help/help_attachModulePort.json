{
  "command": "attachModulePort",
  "is_cmd": true,
  "summary": "Attaches module port.",
  "description": "Attaches module port.",
  "usage": "attachModulePort [-help] <moduleName> <portName> <netName> [-noNewPort]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<moduleName>",
      "description": "Name of module",
      "required": true,
      "type": "string"
    },
    {
      "name": "<portName>",
      "description": "Name of the port",
      "required": true,
      "type": "string"
    },
    {
      "name": "<netName>",
      "description": "Name of the net",
      "required": true,
      "type": "string"
    },
    {
      "name": "-noNewPort",
      "description": "No new port is allowed to be created regardless whether the given module port and net are in the same hierarchy or not",
      "required": false,
      "type": "flag"
    }
  ]
}