{
  "command": "set_package",
  "is_cmd": true,
  "summary": "Sets package.",
  "description": "Sets package.",
  "usage": "set_package [-help] [-mapping_type <string>] {-reset  | [[-spice <string> [-mapping <string>] [-subckt <string>]] [-offset {x y}] [-rotate <float>] [-flip {true false}] [-scale <float>] ]} [-die_instance_name <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-die_instance_name",
      "description": "<die instance name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-flip",
      "description": "<flip: true | false>",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-mapping",
      "description": "<Mapping file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mapping_type",
      "description": "<Mapping type: distributed | lumped>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-offset",
      "description": "<x y in microns>",
      "required": false,
      "type": "int"
    },
    {
      "name": "-reset",
      "description": "<reset all previous set_package commands>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rotate",
      "description": "<rotation angle in degrees>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-scale",
      "description": "<scaling factor number>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-spice",
      "description": "<Spice package model>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-subckt",
      "description": "<top level sub-circuit name>",
      "required": false,
      "type": "string"
    }
  ]
}