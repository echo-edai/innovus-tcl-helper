      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<fileName>",
      "description": "input filename",
      "required": true,
      "type": "string"
    },
    {
      "name": "-1801",
      "description": "input file in IEEE1801 format",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-cpf",
      "description": "input file in CPF format",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-msvDB",
      "description": "EDI IEEE1801 data file (.cpfdb)",
      "required": true,
      "type": "flag"
    }
  ]
}