{
  "command": "colorize_cell_library",
  "is_cmd": true,
  "summary": "Colorizes cell library.",
  "description": "Colorizes cell library.",
  "usage": "colorize_cell_library [-help] [-cell <cells>] [ [-reset ] | [-enforce ] ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "specify cells to colorize ((libCell/ptnCell)+, optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-enforce",
      "description": "force to re-colorize",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "reset lib cell color data",
      "required": false,
      "type": "flag"
    }
  ]
}