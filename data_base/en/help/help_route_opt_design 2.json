{
  "command": "route_opt_design",
  "is_cmd": true,
  "summary": "Routes opt design.",
  "description": "Routes opt design.",
  "usage": "route_opt_design [-help] [-drv] [-hold] [-ideal_clock] [-incremental] [-num_paths <string>] [-opt] [-out_dir <string>] [-prefix <string>] [-route] [-setup] [-timing_debug_report]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-drv",
      "description": "DRV fixing only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hold",
      "description": "Hold fixing",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ideal_clock",
      "description": "Ideal Clock option",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-incremental",
      "description": "PostRoute incremental optimization",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-num_paths",
      "description": "Specify number of timing paths generated in timing report",
      "required": false,
      "type": "string"
    },
    {
      "name": "-opt",
      "description": "PostRoute Optimization only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-out_dir",
      "description": "Specify dir for reports",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "Specify prefix for reports",
      "required": false,
      "type": "string"
    },
    {
      "name": "-route",
      "description": "Do route only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-setup",
      "description": "Setup and DRV fixing",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-timing_debug_report",
      "description": "Generate machine readable timing report",
      "required": false,
      "type": "flag"
    }
  ]
}