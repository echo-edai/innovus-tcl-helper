{
  "command": "query_power_data",
  "is_cmd": true,
  "summary": "Queries power data.",
  "description": "Queries power data.",
  "usage": "query_power_data [-help] [<in_file <file1[file2] ...>>] [-average_current] [-clock_average] [-dump_pwl] [-frame <string>] [-instance_list <string>] [-instance_list_file <string>] [-list] [-output <string>] [-output_tap_name <string>] [-peak_current] [-peak_time] [-pin] [-stdout] [-time_steps] [-total_current]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage <in_file <file1[file2] ...>> # read the pti files",
      "required": false,
      "type": "string"
    },
    {
      "name": "-average_current",
      "description": "write average current of all instances",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clock_average",
      "description": "write clock based current report",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-dump_pwl",
      "description": "write tap current in pwl format",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-frame",
      "description": "specify numerical intervals [t1 t2 t3] for clock_average report (ns)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance_list",
      "description": "specify list of instances",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance_list_file",
      "description": "specify file with list of instances",
      "required": false,
      "type": "string"
    },
    {
      "name": "-list",
      "description": "write list of instances",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-output",
      "description": "specify output report prefix",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output_tap_name",
      "description": "specify output tap name for total current report",
      "required": false,
      "type": "string"
    },
    {
      "name": "-peak_current",
      "description": "write peak current of all instances",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-peak_time",
      "description": "write peak current time of all instances",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pin",
      "description": "report instance pin",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-stdout",
      "description": "print on stdout",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-time_steps",
      "description": "write total current",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-total_current",
      "description": "write total current of all taps",
      "required": false,
      "type": "flag"
    }
  ]
}