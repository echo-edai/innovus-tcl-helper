{
  "command": "deleteIoRowFiller",
  "is_cmd": true,
  "summary": "Deletes io row filler.",
  "description": "Deletes io row filler.",
  "usage": "deleteIoRowFiller [-help] [-cell {name list}] [-from <coord>] [-ioRow <rowName>] [-logic] [-prefix <string>] [-to <coord>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "name list of IO filler cell",
      "required": false,
      "type": "string"
    },
    {
      "name": "-from",
      "description": "staring offset from edge for adding fillers",
      "required": false,
      "type": "float"
    },
    {
      "name": "-ioRow",
      "description": "name of IO row to be processed",
      "required": false,
      "type": "string"
    },
    {
      "name": "-logic",
      "description": "delete NON-physical IO filler",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-prefix",
      "description": "prefix for new filler instances",
      "required": false,
      "type": "string"
    },
    {
      "name": "-to",
      "description": "ending offset from edge for adding fillers",
      "required": false,
      "type": "float"
    }
  ]
}