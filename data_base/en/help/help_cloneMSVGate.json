{
  "command": "cloneMSVGate",
  "is_cmd": true,
  "summary": "Clones msvgate.",
  "description": "Clones msvgate.",
  "usage": "cloneMSVGate [-help] [-honorDontTouch] [-honorPrePlaced] [-instances <string>] [-iso] [-maxCap <string>] [-maxFanout <integer>] [-maxTran <string>] [-shifter]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-honorDontTouch",
      "description": "do not clone dont touch instances / cells",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-honorPrePlaced",
      "description": "do not clone preplaced (fixed) instances",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-instances",
      "description": "clone selected instances",
      "required": false,
      "type": "string"
    },
    {
      "name": "-iso",
      "description": "clone isolation only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-maxCap",
      "description": "max cap violation",
      "required": false,
      "type": "string"
    },
    {
      "name": "-maxFanout",
      "description": "max fanout violation",
      "required": false,
      "type": "int"
    },
    {
      "name": "-maxTran",
      "description": "max transition violation",
      "required": false,
      "type": "string"
    },
    {
      "name": "-shifter",
      "description": "clone level shifter only",
      "required": false,
      "type": "flag"
    }
  ]
}