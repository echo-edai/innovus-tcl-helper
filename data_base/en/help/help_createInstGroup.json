      "description": "create it as a physical hierarchy",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-region",
      "description": "create region",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-softGuide",
      "description": "create softGuide",
      "required": false,
      "type": "flag"
    }
