  "usage": "createInstGroup [-help] <group name> [<box>] [-isPhyHier] [-guide <box> | -region | -fence | -softGuide ] [[-ar <num>] -density <num>] [ -softGuide ] [-floating | -softGuide ] [-floating | -guide <box>]",
  "options": [
