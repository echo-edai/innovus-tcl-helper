{
  "command": "finishFloorplan",
  "is_cmd": true,
  "summary": "Executes the 'finishFloorplan' command.",
  "description": "Executes the 'finishFloorplan' command.",
  "usage": "finishFloorplan [-help] [-mask <integer>] { [[-autoHalo | [-autoHaloBasedOnPitch [-margin <float>]] | -addHalo <float> | [-fillPlaceBlockage <string> [-density <string>] [-excludeFlops ] [-deadArea <float>] [-honor_placement_density ]] | [-fillRouteBlockage <float> [-layer <string>] [-cutLayer <string>] [-fills | -exceptFill ] [-exceptpgnet ] [-spacing <float> | -designRuleWidth <float>] [-deadArea <float>]] | -addCornerBlockage <string> | [-drcRegionLayer <string> [-edgeExtend {x y}] [-edgeShrink {x y}] ] | -addCoreEOLBlockage | -addBoundaryBlockage | -addRowBasedRegionBlockage | -undo ] [-area {x1 y1 x2 y2}] [-namePrefix <string>] ]}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-addBoundaryBlockage",
      "description": "add boundary routing blockages",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-addCoreEOLBlockage",
      "description": "add core end-of-line(EOL) blockages",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-addCornerBlockage",
      "description": "<width> <height>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-addHalo",
      "description": "<width>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-addRowBasedRegionBlockage",
      "description": "add row based region blockages",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-area",
      "description": "{x1 y1 x2 y2}",
      "required": false,
      "type": "point"
    },
    {
      "name": "-autoHalo",
      "description": "auto add halo",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-autoHaloBasedOnPitch",
      "description": "auto add halo based on pitch",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cutLayer",
      "description": "specify routeblkg's cutLayerId",
      "required": false,
      "type": "string"
    },
    {
      "name": "-deadArea",
      "description": "<maxDeadArea>, maximum value of dead area",
      "required": false,
      "type": "float"
    },
    {
      "name": "-density",
      "description": "<value>, only for partial place blkg",
      "required": false,
      "type": "string"
    },
    {
      "name": "-designRuleWidth",
      "description": "<width>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-drcRegionLayer",
      "description": "region layer name list",
      "required": false,
      "type": "string"
    },
    {
      "name": "-edgeExtend",
      "description": "extend drc region from edges",
      "required": false,
      "type": "int"
    },
    {
      "name": "-edgeShrink",
      "description": "shrink drc region from edges",
      "required": false,
      "type": "int"
    },
    {
      "name": "-exceptFill",
      "description": "set 'exceptFill' attribute. Specifies that the routing blockage is to be applied to other all net routings but not on metal fills",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-exceptpgnet",
      "description": "specify if routeblkg exceptPGNet",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-excludeFlops",
      "description": "flops and latches are excluded from the partial placement blockage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-fillPlaceBlockage",
      "description": "<type> <maxGap>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-fillRouteBlockage",
      "description": "<maxGap>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-fills",
      "description": "specify if routeblkg is fill",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-honor_placement_density",
      "description": "add std cell density check when adding placement blockage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-layer",
      "description": "specify routeblkg's layerId",
      "required": false,
      "type": "string"
    },
    {
      "name": "-margin",
      "description": "margin for halo based on pitch",
      "required": false,
      "type": "float"
    },
    {
      "name": "-mask",
      "description": "specify the mask number when adding routing blockages and creating DRC region",
      "required": false,
      "type": "int"
    },
    {
      "name": "-namePrefix",
      "description": "<name>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spacing",
      "description": "<spaceValue>",
      "required": false,
      "type": "float"
    },
    {
      "name": "-undo",
      "description": "undo recent action",
      "required": false,
      "type": "flag"
    }
  ]
}