{
  "command": "write_oa_techfile",
  "is_cmd": true,
  "summary": "Writes oa techfile.",
  "description": "Writes oa techfile.",
  "usage": "write_oa_techfile [-help] [<fileName>] [-include_rules] [-process_node <coord>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<fileName>",
      "description": "output ASCII filename",
      "required": false,
      "type": "string"
    },
    {
      "name": "-include_rules",
      "description": "include LDRS and VIA information",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-process_node",
      "description": "specify process node value(in nm)",
      "required": false,
      "type": "int"
    }
  ]
}