    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pattern>",
      "description": "command pattern, message id or keyword",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cmd",
      "description": "perform command search only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-k",
      "description": "perform keyword search",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-var",
      "description": "perform variable search only",
      "required": false,
      "type": "flag"
    }
  ]
}