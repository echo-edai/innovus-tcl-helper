{
  "command": "compare_release",
  "is_cmd": true,
  "summary": "Compares release.",
  "description": "Compares release.",
  "usage": "compare_release [-help] [-out_file <out_file>] {-base_version <version> | -base_file <in_file>} [-target_version <version> | -target_file <in_file>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-base_file",
      "description": "Older base release .info file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-base_version",
      "description": "Older base release (e.g 16.10-p001_1) from <install>/share/innovus/version_info",
      "required": false,
      "type": "string"
    },
    {
      "name": "-out_file",
      "description": "Output report file. Default is stdout",
      "required": false,
      "type": "string"
    },
    {
      "name": "-target_file",
      "description": "Compare target release .info file to older base release .info file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-target_version",
      "description": "Default is current version. Compare this (e.g 16.20-p002_1) to older base release. Looks in <install>/share/innovus/version_info for correct .info file",
      "required": false,
      "type": "string"
    }
  ]
}