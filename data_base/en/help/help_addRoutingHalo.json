{
  "command": "addRoutingHalo",
  "is_cmd": true,
  "summary": "Adds routing halo.",
  "description": "Adds routing halo.",
  "usage": "addRoutingHalo [-help] [-orientation <string>] { {-bottom <auto|name> -space <left bottom right top> -top <auto|name>} | -lithoHalo } {-allBlocks  | -block <name> | -cell <name> | -inst <name> | -designHalo  }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allBlocks",
      "description": "for all blocks",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-block",
      "description": "block names",
      "required": true,
      "type": "string"
    },
    {
      "name": "-bottom",
      "description": "bottom layer name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "cell names",
      "required": true,
      "type": "string"
    },
    {
      "name": "-designHalo",
      "description": "for all partitions",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-inst",
      "description": "instance names",
      "required": true,
      "type": "string"
    },
    {
      "name": "-lithoHalo",
      "description": "adds a litho halo to the instances on each routing layer with LEF LITHOMACROHALO defined",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-orientation",
      "description": "base on orientation",
      "required": false,
      "type": "string"
    },
    {
      "name": "-space",
      "description": "space on 4 sides",
      "required": true,
      "type": "string"
    },
    {
      "name": "-top",
      "description": "top layer name",
      "required": true,
      "type": "string"
    }
  ]
}