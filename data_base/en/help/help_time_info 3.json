{
  "command": "time_info",
  "is_cmd": true,
  "summary": "Executes the 'time_info' command.",
  "description": "Executes the 'time_info' command.",
  "usage": "time_info [-help] [<name>] [-current] [-report] [-stamp] [-table <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage <name> # Specifies stage name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-current",
      "description": "Specifies report current stage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-report",
      "description": "Specifies report all stages up to this point",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-stamp",
      "description": "Specifies create a time stamp",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-table",
      "description": "Specifies metrics table ID to support multiple tables (default is 'default')",
      "required": false,
      "type": "string"
    }
  ]
}