{
  "command": "analyze_package",
  "is_cmd": true,
  "summary": "Analyzes package.",
  "description": "Analyzes package.",
  "usage": "analyze_package [-help] [-computer_resources <string>] [-output <string>] [-result_name <string>] [-spd_file <string>] -type {dc transient} { [<domain> [-workspace <string>] [-pkg_die_name <string>] [-pkg_bga_name <string>] [-pkg_pin_current_file <string>] ]}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<domain>",
      "description": "<rail analysis domain name>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-computer_resources",
      "description": "<set up computer resources>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output",
      "description": "<output directory of package model>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pkg_bga_name",
      "description": "<specify bga circuit>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pkg_die_name",
      "description": "<specify die circuit>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pkg_pin_current_file",
      "description": "<specify pin current file from rail analysis, or {{ckt_name1 file1} {ckt_name2 file2}} for multi-die case>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-result_name",
      "description": "<tool will generate output/result_name.xml>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spd_file",
      "description": "<package extraction spd file>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "<specify one type of dc|transient>",
      "required": true,
      "type": "enum"
    },
    {
      "name": "-workspace",
      "description": "<package analysis workspace>",
      "required": false,
      "type": "string"
    }
  ]
}