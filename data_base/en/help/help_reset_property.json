{
  "command": "reset_property",
  "is_cmd": true,
  "summary": "Resets property.",
  "description": "Resets property.",
  "usage": "reset_property [-help] <object_list> <property_name> [-object_type <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<object_list>",
      "description": "List of objects on which property is to be appiled",
      "required": true,
      "type": "string"
    },
    {
      "name": "<property_name>",
      "description": "Name of property",
      "required": true,
      "type": "string"
    },
    {
      "name": "-object_type",
      "description": "Type of object on which property is to be defined. Types can be design, port, cell, pin, net, lib, lib_cell, lib_pin",
      "required": false,
      "type": "string"
    }
  ]
}