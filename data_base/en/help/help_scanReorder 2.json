{
  "command": "scanReorder",
  "is_cmd": true,
  "summary": "Executes the 'scanReorder' command.",
  "description": "Executes the 'scanReorder' command.",
  "usage": "scanReorder [-help] [-addScanPortPrefix <value>] [-clkAware {true|false}] [-preferH {true|false}] [-preferV {true|false}] [-keepPDPorts {true|false} ] [-scanEffort {low|medium|high|auto} ] [-skipMode {skipNone|skipBuffer} ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-addScanPortPrefix",
      "description": "prefix of scan hport",
      "required": false,
      "type": "string"
    },
    {
      "name": "-clkAware",
      "description": "specify whether scan reordering is clock tree aware",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-keepPDPorts",
      "description": "maintains or corrects the hierarchical ports without deleting or inserting shifters, and reorders the remaining scan chain",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-preferH",
      "description": "makes horizontal scan chain connections if possible",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-preferV",
      "description": "makes vertical scan chain connections if possible",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-scanEffort",
      "description": "effort level",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-skipMode",
      "description": "skip mode",
      "required": false,
      "type": "enum"
    }
  ]
}