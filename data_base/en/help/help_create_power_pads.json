{
  "command": "create_power_pads",
  "is_cmd": true,
  "summary": "Creates power pads.",
  "description": "Creates power pads.",
  "usage": "create_power_pads [-help] [-append_to_vsrc_file] [-format {padcell xy tsv}] [-layer <layerName>] [-package_capacitance <value>] [-package_inductance <value>] [-package_resistance <value>] [-vsrc_file <string>] [[-net <string> -region {x1 y1 x2 y2} -region_pitch {x y}] | [-net <string> -auto_fetch ] | [-net <string> -instance {instanceName +}] | [-net <string> -instance_pin {{<instName> <instPinName>}+}] | [-net <string> -cell {cellName +}] | [-net <string> -cell_pin {{<cellName> <cellPinName>}+}] | [-net <string> -add ] | [-net <string> -delete ]] [-snap_distance <value> | -honor_pin_connection ] [-clear   | -display  ] [-net <string>  | -clear  |  -list  ] [[-add  | -delete ] -loc {x y}]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-add",
      "description": "adding a vsrc source",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-append_to_vsrc_file",
      "description": "output file name",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-auto_fetch",
      "description": "auto fetch vsrc",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "cell names",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell_pin",
      "description": "cellName and cellPin name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-clear",
      "description": "clear display",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-delete",
      "description": "deleting a vsrc source",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-display",
      "description": "display the outfile",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-format",
      "description": "output file format, default is xy",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-honor_pin_connection",
      "description": "honor pin connection",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-instance",
      "description": "instance names",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance_pin",
      "description": "{{<instName> <instPinName>}+} instName and instPin input",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer",
      "description": "the lowest layer to snap",
      "required": false,
      "type": "string"
    },
    {
      "name": "-list",
      "description": "list all vsrc in memory",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-loc",
      "description": "location on which vsrc is to be added",
      "required": false,
      "type": "int"
    },
    {
      "name": "-net",
      "description": "net name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-package_capacitance",
      "description": "package capacitance",
      "required": false,
      "type": "float"
    },
    {
      "name": "-package_inductance",
      "description": "package inductance",
      "required": false,
      "type": "float"
    },
    {
      "name": "-package_resistance",
      "description": "package resistance",
      "required": false,
      "type": "float"
    },
    {
      "name": "-region",
      "description": "Generate dc sources in specified area.",
      "required": false,
      "type": "point"
    },
    {
      "name": "-region_pitch",
      "description": "region pitch in x and y direction.",
      "required": false,
      "type": "int"
    },
    {
      "name": "-snap_distance",
      "description": "the snapping distance",
      "required": false,
      "type": "float"
    },
    {
      "name": "-vsrc_file",
      "description": "vsrc file name",
      "required": false,
      "type": "string"
    }
  ]
}