{
  "command": "writeTimingCon",
  "is_cmd": true,
  "summary": "Writes timing con.",
  "description": "Writes timing con.",
  "usage": "writeTimingCon [-help] [<filename>] [-clocks <string>] [-commands <string>] [-exclude_annotated {delays checks transitions}] [-pins <string>] [-view <viewName>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<filename>",
      "description": "Specifes the name of the constraints file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-clocks",
      "description": "filter clocks",
      "required": false,
      "type": "string"
    },
    {
      "name": "-commands",
      "description": "filter commands",
      "required": false,
      "type": "string"
    },
    {
      "name": "-exclude_annotated",
      "description": "{delays checks transitions} Disables listing of annotated constraints",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-pins",
      "description": "filter pins",
      "required": false,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "Specifies a view name to obtain the desired SDC",
      "required": false,
      "type": "string"
    }
  ]
}