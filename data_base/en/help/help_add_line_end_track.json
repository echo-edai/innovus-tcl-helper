{
  "command": "add_line_end_track",
  "is_cmd": true,
  "summary": "Adds line end track.",
  "description": "Adds line end track.",
  "usage": "add_line_end_track [-help] [-eol_width <float>] -layer <string> -offset <float> [-track_distance <float>] [-track_pitch <float>] [-except_eol_spacing <float> [-within <float>]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-eol_width",
      "description": "eol width",
      "required": false,
      "type": "float"
    },
    {
      "name": "-except_eol_spacing",
      "description": "spacing of the eol edge and a neighbor wire to exempt the rule",
      "required": false,
      "type": "float"
    },
    {
      "name": "-layer",
      "description": "layer the track to be created on",
      "required": true,
      "type": "string"
    },
    {
      "name": "-offset",
      "description": "offset to core boundary",
      "required": true,
      "type": "float"
    },
    {
      "name": "-track_distance",
      "description": "distance between two sets of track",
      "required": false,
      "type": "float"
    },
    {
      "name": "-track_pitch",
      "description": "track pitch",
      "required": false,
      "type": "float"
    },
    {
      "name": "-within",
      "description": "extension in orthogonal direction to find a neighbor wire",
      "required": false,
      "type": "float"
    }
  ]
}