{
  "command": "gui_select",
  "is_cmd": true,
  "summary": "Executes the 'gui_select' command.",
  "description": "Executes the 'gui_select' command.",
  "usage": "gui_select [-help] {-point {x y} | -line {x1 y1 x2 y2} | -rect {x1 y1 x2 y2}} [-toggle  | -append  | -next ] [-point {x y} [-next ]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-append",
      "description": "Append the selection",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-line",
      "description": "Select by line",
      "required": false,
      "type": "int"
    },
    {
      "name": "-next",
      "description": "Step to next object under point",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-point",
      "description": "Select by point",
      "required": false,
      "type": "int"
    },
    {
      "name": "-rect",
      "description": "Select by box",
      "required": false,
      "type": "point"
    },
    {
      "name": "-toggle",
      "description": "Toggle the selection",
      "required": false,
      "type": "flag"
    }
  ]
}