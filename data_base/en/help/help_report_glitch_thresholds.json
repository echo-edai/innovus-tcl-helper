{
  "command": "report_glitch_thresholds",
  "is_cmd": true,
  "summary": "Reports glitch thresholds.",
  "description": "Reports glitch thresholds.",
  "usage": "report_glitch_thresholds [-help] [-failure_point {input output}] [-glitch_type <string>] [-instance_pins <string>] [-library_pins <string>] [-list_unannotated_instance_pins] [-list_unannotated_library_pins] [-view <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-failure_point",
      "description": "Specifies if threshold failure point is input or output. default=input",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-glitch_type",
      "description": "specify space seperated glitch types to be reported. Option: vl vh vlu vho all",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance_pins",
      "description": "specify list of instance pin names",
      "required": false,
      "type": "string"
    },
    {
      "name": "-library_pins",
      "description": "specify list of library pin names",
      "required": false,
      "type": "string"
    },
    {
      "name": "-list_unannotated_instance_pins",
      "description": "list un-annotated instance pins",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-list_unannotated_library_pins",
      "description": "list un-annotated library pins",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view",
      "description": "view name",
      "required": false,
      "type": "string"
    }
  ]
}