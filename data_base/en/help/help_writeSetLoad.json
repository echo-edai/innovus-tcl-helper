{
  "command": "writeSetLoad",
  "is_cmd": true,
  "summary": "Writes set load.",
  "description": "Writes set load.",
  "usage": "writeSetLoad [-help] [-direct] [-excludeZeroCap] -file <string> [-includePinCap] [-view <string>] [-wire_load]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-direct",
      "description": "Refers the ports directly.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-excludeZeroCap",
      "description": "Excludes the net which has zero net capacitance.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "Output file name.",
      "required": true,
      "type": "string"
    },
    {
      "name": "-includePinCap",
      "description": "Includes the pin capacitance.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view",
      "description": "View name for the output file.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-wire_load",
      "description": "Mark -wire_load option for port",
      "required": false,
      "type": "flag"
    }
  ]
}