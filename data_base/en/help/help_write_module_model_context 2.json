{
  "command": "write_module_model_context",
  "is_cmd": true,
  "summary": "Writes module model context.",
  "description": "Writes module model context.",
  "usage": "write_module_model_context [-help] -cell <name> [-master_clone_inst <name>] [-tag <name>] -type {extraction_context timing_context} [-type_specific_options <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "specifies the cell name of an instance",
      "required": true,
      "type": "string"
    },
    {
      "name": "-master_clone_inst",
      "description": "specifies the instance name of an master/clone. Use this option if the instance has clone(s)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tag",
      "description": "specifies an output tag name. Default: latest",
      "required": false,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "{extraction_context timing_context} <module model written out>",
      "required": true,
      "type": "enum"
    },
    {
      "name": "-type_specific_options",
      "description": "<type specific options>",
      "required": false,
      "type": "string"
    }
  ]
}