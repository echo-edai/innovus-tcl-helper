{
  "command": "set_trace_obj_connectivity_mode",
  "is_cmd": true,
  "summary": "Sets trace obj connectivity mode.",
  "description": "Sets trace obj connectivity mode.",
  "usage": "set_trace_obj_connectivity_mode [-help] [-reset] [-macro_pins <list_of_pins>] [-max_fanin_fanout <number>] [-register_inputs <list_of_pins>] [-register_outputs <list_of_pins>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "Resets all or specified options to default value",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-macro_pins",
      "description": "specify macro pin name patterns in regular expression",
      "required": false,
      "type": "string"
    },
    {
      "name": "-max_fanin_fanout",
      "description": "Specify the maximum number of a pin's fanin/fanout,a pin will be ignored in tracing connectivity if its fanin/fanout larger than the specified number",
      "required": false,
      "type": "int"
    },
    {
      "name": "-register_inputs",
      "description": "Specify register input pin names",
      "required": false,
      "type": "string"
    },
    {
      "name": "-register_outputs",
      "description": "Specify register output pin names",
      "required": false,
      "type": "string"
    }
  ]
}