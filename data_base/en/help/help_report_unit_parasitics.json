{
  "command": "report_unit_parasitics",
  "is_cmd": true,
  "summary": "Reports unit parasitics.",
  "description": "Reports unit parasitics.",
  "usage": "report_unit_parasitics [-help] -layer <string> -rc_corner <string> [-space <float>] [-via_res] [-width <float>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-layer",
      "description": "Specifies the name of the metal layer for which the unit parasitics are to be reported",
      "required": true,
      "type": "string"
    },
    {
      "name": "-rc_corner",
      "description": "Specifies the name of the RC corner for which the unit parasitics are to be reported",
      "required": true,
      "type": "string"
    },
    {
      "name": "-space",
      "description": "Wire spacing in microns",
      "required": false,
      "type": "float"
    },
    {
      "name": "-via_res",
      "description": "Via resistances for the layer",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-width",
      "description": "Wire width in microns",
      "required": false,
      "type": "float"
    }
  ]
}