{
  "command": "createPGPin",
  "is_cmd": true,
  "summary": "Creates pgpin.",
  "description": "Creates pgpin.",
  "usage": "createPGPin [-help] {-onDie {-selected | -net <netName>} [-width <float>] [-length <float>]} | {pgPinName [-net <netName>] [-geom <layerName> <llx> <lly> <urx> <ury>]} [-dir {bidi|input|output}]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pgPinName>",
      "description": "PG pin name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-dir",
      "description": "Direction of pg pin.",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-geom",
      "description": "<layerName> <llx> <lly> <urx> <ury> geometry",
      "required": false,
      "type": "string"
    },
    {
      "name": "-length",
      "description": "Pin Length. Default is same as width",
      "required": false,
      "type": "float"
    },
    {
      "name": "-net",
      "description": "create PG pins on specific net",
      "required": false,
      "type": "string"
    },
    {
      "name": "-onDie",
      "description": "create PG pins on die",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-selected",
      "description": "create PG pins on die for all selected stripes",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-width",
      "description": "Pin Width. Default is stripe width",
      "required": false,
      "type": "float"
    }
  ]
}