{
  "command": "eco_opt_ir_aggressor",
  "is_cmd": true,
  "summary": "Engineering change order opt ir aggressor.",
  "description": "Engineering change order opt ir aggressor.",
  "usage": "eco_opt_ir_aggressor [-help] [-create_margin] -domain_threshold <float> [-effort <string>] [-margin <float>] [-noEcoRoute] [-save_margin] [-single_iter] -state_directory <string> [-watch_box <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-create_margin",
      "description": "whether create margin for uncommits",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-domain_threshold",
      "description": "domain threshold",
      "required": true,
      "type": "float"
    },
    {
      "name": "-effort",
      "description": "effort level high||medium||low",
      "required": false,
      "type": "string"
    },
    {
      "name": "-margin",
      "description": "how many nano seconds to create",
      "required": false,
      "type": "float"
    },
    {
      "name": "-noEcoRoute",
      "description": "don't do ecoRoute in the end",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-save_margin",
      "description": "saves margin for the next run of ireco",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-single_iter",
      "description": "only run the 1st iteration with margin creation",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-state_directory",
      "description": "state_directory",
      "required": true,
      "type": "string"
    },
    {
      "name": "-watch_box",
      "description": "only the violations inside the box will be calc",
      "required": false,
      "type": "string"
    }
  ]
}