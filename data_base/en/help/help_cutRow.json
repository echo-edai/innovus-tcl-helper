{
  "command": "cutRow",
  "is_cmd": true,
  "summary": "Cuts row.",
  "description": "Cuts row.",
  "usage": "cutRow [-help] [-keepCell] [-site <name>] [-area box | -object <string> | -selected | -fromIo {left bottom right top} ] [[-halo <float>] | [[-leftGap <float>] [-rightGap <float>] [-topGap <float>] [-bottomGap <float>]]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-area",
      "description": "box in <llx> <lly> <urx> <ury>",
      "required": false,
      "type": "point"
    },
    {
      "name": "-bottomGap",
      "description": "overhang in addition to cut area",
      "required": false,
      "type": "float"
    },
    {
      "name": "-fromIo",
      "description": "cut row away from IO cells",
      "required": false,
      "type": "point"
    },
    {
      "name": "-halo",
      "description": "overhang in addition to cut area on all 4 sides",
      "required": false,
      "type": "float"
    },
    {
      "name": "-keepCell",
      "description": "donot unplace cells",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-leftGap",
      "description": "overhang in addition to cut area",
      "required": false,
      "type": "float"
    },
    {
      "name": "-object",
      "description": "object id",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rightGap",
      "description": "overhang in addition to cut area",
      "required": false,
      "type": "float"
    },
    {
      "name": "-selected",
      "description": "cut by selected objects",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-site",
      "description": "name of site to be cut",
      "required": false,
      "type": "string"
    },
    {
      "name": "-topGap",
      "description": "overhang in addition to cut area",
      "required": false,
      "type": "float"
    }
  ]
}