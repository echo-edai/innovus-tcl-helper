{
  "command": "clock_opt_design",
  "is_cmd": true,
  "summary": "Executes the 'clock_opt_design' command.",
  "description": "Executes the 'clock_opt_design' command.",
  "usage": "clock_opt_design [-help] [-check_cts_config] [-cts] [-expandedViews] [-num_paths <string>] [-out_dir <string>] [-prefix <string>] [-timing_debug_report]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-check_cts_config",
      "description": "Only check cts prerequisites, with no changes made to the design",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cts",
      "description": "Build Clock Tree only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-expandedViews",
      "description": "Expand View option",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-num_paths",
      "description": "Specify the number of paths generated in timing reports",
      "required": false,
      "type": "string"
    },
    {
      "name": "-out_dir",
      "description": "Output Directory option",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "File Name Prefix option",
      "required": false,
      "type": "string"
    },
    {
      "name": "-timing_debug_report",
      "description": "Generate timing debug report",
      "required": false,
      "type": "flag"
    }
  ]
}