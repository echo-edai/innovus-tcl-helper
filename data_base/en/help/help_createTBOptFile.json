{
  "command": "createTBOptFile",
  "is_cmd": true,
  "summary": "Creates tbopt file.",
  "description": "Creates tbopt file.",
  "usage": "createTBOptFile [-help] -bottleneckInstanceNumber <integer> [-early] [-max_paths <integer>] [-max_slack <float>] [-min_slack <float>] -outFile <string> [-path_group <string>] [-timingFile <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bottleneckInstanceNumber",
      "description": "Number of instances to generate.",
      "required": true,
      "type": "int"
    },
    {
      "name": "-early",
      "description": "Generate tbOpt file for hold.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-max_paths",
      "description": "Considers the specified number of worst paths, regardless of the endpoint.",
      "required": false,
      "type": "int"
    },
    {
      "name": "-max_slack",
      "description": "Considers only the paths with slack equal to or less than the specified value.",
      "required": false,
      "type": "float"
    },
    {
      "name": "-min_slack",
      "description": "Considers only the paths with slack greater than the specified value.",
      "required": false,
      "type": "float"
    },
    {
      "name": "-outFile",
      "description": "Specifies output file name.",
      "required": true,
      "type": "string"
    },
    {
      "name": "-path_group",
      "description": "Considers only the paths from the specified path group.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-timingFile",
      "description": "Timing report file name.",
      "required": false,
      "type": "string"
    }
  ]
}