{
  "command": "deleteIoFiller",
  "is_cmd": true,
  "summary": "Deletes io filler.",
  "description": "Deletes io filler.",
  "usage": "deleteIoFiller [-help] [-cell {name list}] [-from <float>] [-prefix <prefix>] [-ring <num>] [-side <top|bottom|left|right>] [-to <float>] [-logic  [ -deriveConnectivity ]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "name list of IO filler cell",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-deriveConnectivity",
      "description": "delete connectivity for io Filler",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-from",
      "description": "delete cell starting from this location",
      "required": false,
      "type": "float"
    },
    {
      "name": "-logic",
      "description": "delete NON-physical IO Filler created by addIoFiller",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-prefix",
      "description": "prefix of instance names",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ring",
      "description": "ring number in multiple io ring design",
      "required": false,
      "type": "int"
    },
    {
      "name": "-side",
      "description": "specify cells on which side of design",
      "required": false,
      "type": "string"
    },
    {
      "name": "-to",
      "description": "delete cell to this location",
      "required": false,
      "type": "float"
    }
  ]
}