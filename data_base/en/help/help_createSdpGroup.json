{
  "command": "createSdpGroup",
  "is_cmd": true,
  "summary": "Creates sdp group.",
  "description": "Creates sdp group.",
  "usage": "createSdpGroup [-help] [-justifyBy <SW|SE|NW|NE|N|W|S|E|MID>] -name <sdpGroupName> [-type <row|col|space>] {{-skip_space <val> } | -skip_space_by_site_width <val> <siteName> | -skip_space_by_micron <val>} | {{{-inst <WCardName...> [-keepOrder ]} | -selected } [[-spread_group <val> ] | [-spread_group_by_site_width <val> <siteName>] | [-spread_group_by_micron <val>] | [[-numRow <val>] [-numCol <val>] ]]}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-inst",
      "description": "wild card instance name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-justifyBy",
      "description": "justify by direction",
      "required": false,
      "type": "string"
    },
    {
      "name": "-keepOrder",
      "description": "honor the instance order in the input sdp instance list",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "name of the group to be created",
      "required": true,
      "type": "string"
    },
    {
      "name": "-numCol",
      "description": "number of column to be created",
      "required": false,
      "type": "int"
    },
    {
      "name": "-numRow",
      "description": "number of row to be created",
      "required": false,
      "type": "int"
    },
    {
      "name": "-selected",
      "description": "selected instances",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skip_space",
      "description": "number of row/column space",
      "required": false,
      "type": "string"
    },
    {
      "name": "-skip_space_by_micron",
      "description": "skip space is in unit microns",
      "required": false,
      "type": "string"
    },
    {
      "name": "-skip_space_by_site_width",
      "description": "<val> <siteName> number of row/column space and name of tech site. use the width of site as skip unit in horizontal direction",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spread_group",
      "description": "spread group using skip space",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spread_group_by_micron",
      "description": "spread group in unit microns",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spread_group_by_site_width",
      "description": "<val> <siteName> number of row/column space and name of tech site. Use the width of site as skip unit in horizontal direction",
      "required": false,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "record type",
      "required": false,
      "type": "string"
    }
  ]
}