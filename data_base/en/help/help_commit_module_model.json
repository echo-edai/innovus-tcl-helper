{
  "command": "commit_module_model",
  "is_cmd": true,
  "summary": "Commits module model.",
  "description": "Commits module model.",
  "usage": "commit_module_model [-help] [-copy_mmmc_latencies] [-merged_mmmc_map_file <string>] [-merged_mmmc_sdc_files <string>] [-mmmc_file <string>] [-mmmc_module_model_tag <string>] [-propagate_clocks] [-cpf_file <string> | -1801 <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-1801",
      "description": "Specifies ieee 1801 file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-copy_mmmc_latencies",
      "description": "keep MMMC Latencies",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cpf_file",
      "description": "Specifies full chip CPF file to use",
      "required": false,
      "type": "string"
    },
    {
      "name": "-merged_mmmc_map_file",
      "description": "Specifies merge hierarchical mmmc map files",
      "required": false,
      "type": "string"
    },
    {
      "name": "-merged_mmmc_sdc_files",
      "description": "Specifies merged sdc files",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mmmc_file",
      "description": "Specifies full chip MMMC view file",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mmmc_module_model_tag",
      "description": "Specifies MMMC module model tag",
      "required": false,
      "type": "string"
    },
    {
      "name": "-propagate_clocks",
      "description": "propagate clocks",
      "required": false,
      "type": "flag"
    }
  ]
}