{
  "command": "getRailPrototypeMode",
  "is_cmd": true,
  "summary": "Gets rail prototype mode.",
  "description": "Gets rail prototype mode.",
  "usage": "getRailPrototypeMode [-help] [-domain] [-railModel] [-totalPower] [-quiet] [-nonDefault]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-domain",
      "description": "Format: -domain {{PD1 <value1> net1} {PD2 <value2> net2}..}",
      "required": false,
      "type": "string"
    },
    {
      "name": "-railModel",
      "description": "Seletc rail model: virtual/existing.",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-totalPower",
      "description": "total power defined by user.",
      "required": false,
      "type": "float"
    },
    {
      "name": "-quiet",
      "description": "Displays the current settings in Tcl list format only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-nonDefault",
      "description": "Displays the current settings which are not default settings",
      "required": false,
      "type": "flag"
    }
  ]
}