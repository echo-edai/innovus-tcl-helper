{
  "command": "add_oa_library_property",
  "is_cmd": true,
  "summary": "Adds oa library property.",
  "description": "Adds oa library property.",
  "usage": "add_oa_library_property [-help] -lib <libName>} -name <prop_name> -type {boolean integer float string} -value <propValue>",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-lib",
      "description": "Name of OpenAccess library to add the property to.",
      "required": true,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "Name of property to create.",
      "required": true,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "Type of property to create",
      "required": true,
      "type": "enum"
    },
    {
      "name": "-value",
      "description": "Value of the property to set. Value is interpretted from the input string and converted to the specifed type",
      "required": true,
      "type": "string"
    }
  ]
}