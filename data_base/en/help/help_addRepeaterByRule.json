{
  "command": "addRepeaterByRule",
  "is_cmd": true,
  "summary": "Adds repeater by rule.",
  "description": "Adds repeater by rule.",
  "usage": "addRepeaterByRule [-help] [-allowMixedSignal] [-copyNetAttribute] [-excNet <string>] [-netMapping <string>] [-nets <tcl_obj>] [-outDir <string>] [-reportIgnoredNets <string>] [-rule <string>] [-selNet <string>] [-selected] [-template] [ -preRoute  | -postRoute  | -alongRoute  ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allowMixedSignal",
      "description": "allow buffering on mixed signal nets",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-alongRoute",
      "description": "original route is preserved. refinePlace and route are needed afterwards",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-copyNetAttribute",
      "description": "copy net attribute",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-excNet",
      "description": "file name for excluded nets",
      "required": false,
      "type": "string"
    },
    {
      "name": "-netMapping",
      "description": "file name for the map of the original nets to the new nets created by the command",
      "required": false,
      "type": "string"
    },
    {
      "name": "-nets",
      "description": "list of nets to buffer",
      "required": false,
      "type": "string"
    },
    {
      "name": "-outDir",
      "description": "directory for output of report files",
      "required": false,
      "type": "string"
    },
    {
      "name": "-postRoute",
      "description": "design must be routed, and detail RC extraction is conducted. refinePlace and route are needed afterwards",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-preRoute",
      "description": "different routing topologies are explored",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reportIgnoredNets",
      "description": "file name for ignored nets",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rule",
      "description": "rule file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selNet",
      "description": "file name for selected nets",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selected",
      "description": "buffer nets selected by the selectNet tcl command or in the gui",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-template",
      "description": "generate template rule file with name template.rule. It will omit other options once being used.",
      "required": false,
      "type": "flag"
    }
  ]
}