{
  "command": "saveColorPreference",
  "is_cmd": true,
  "summary": "Saves color preference.",
  "description": "Saves color preference.",
  "usage": "saveColorPreference [-help] [-dir <string>] [-include_customized] -name <string>",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-dir",
      "description": "Specify the directorpath, default is current folder",
      "required": false,
      "type": "string"
    },
    {
      "name": "-include_customized",
      "description": "Include Customize Tab Setting",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "Specify the saved filename",
      "required": true,
      "type": "string"
    }
  ]
}