{
  "command": "changeIoConstraints",
  "is_cmd": true,
  "summary": "Changes io constraints.",
  "description": "Changes io constraints.",
  "usage": "changeIoConstraints [-help] [-forceIt] [-removeAll] [-firstCellSpacing <float> | -removeFirstCellSpacing] [-row <string> | -ioOrder <string>] [-endspace <float> | -removeEndSpace] [-spacing <float> | -removeSpacing]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-endspace",
      "description": "EndSpace constraint",
      "required": false,
      "type": "float"
    },
    {
      "name": "-firstCellSpacing",
      "description": "spacing from row edge to first cell",
      "required": false,
      "type": "float"
    },
    {
      "name": "-forceIt",
      "description": "Force to run on non-io-row flow",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ioOrder",
      "description": "Change I/O placing order",
      "required": false,
      "type": "string"
    },
    {
      "name": "-removeAll",
      "description": "remove all constraint",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-removeEndSpace",
      "description": "remove endspace constraint",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-removeFirstCellSpacing",
      "description": "remove spacing constraint from first cell",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-removeSpacing",
      "description": "remove spacing constraint",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-row",
      "description": "I/O row name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spacing",
      "description": "spacing constraint for all cells",
      "required": false,
      "type": "float"
    }
  ]
}