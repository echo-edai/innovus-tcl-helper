{
  "command": "modifyBudget",
  "is_cmd": true,
  "summary": "Modifies budget.",
  "description": "Modifies budget.",
  "usage": "modifyBudget [-help] -file <string> -view <string> {-ptn <string> | -inst <string>} [-setup  | -hold  ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "input file containing manual budgets",
      "required": true,
      "type": "string"
    },
    {
      "name": "-hold",
      "description": "modify hold information",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-inst",
      "description": "hierarchical instance for which manual budgets would be applied",
      "required": true,
      "type": "string"
    },
    {
      "name": "-ptn",
      "description": "partition for which manual budgets would be applied",
      "required": true,
      "type": "string"
    },
    {
      "name": "-setup",
      "description": "modify setup information",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view",
      "description": "modify budgets for a specific view only",
      "required": true,
      "type": "string"
    }
  ]
}