{
  "command": "set_property",
  "is_cmd": true,
  "summary": "Sets property.",
  "description": "Sets property.",
  "usage": "set_property [-help] <object_list> <property_name> <property_value> [-object_type <string>] [-quiet]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<object_list>",
      "description": "List of objects on which property is to be appiled",
      "required": true,
      "type": "string"
    },
    {
      "name": "<property_name>",
      "description": "Name of property",
      "required": true,
      "type": "string"
    },
    {
      "name": "<property_value>",
      "description": "Value of property",
      "required": true,
      "type": "string"
    },
    {
      "name": "-object_type",
      "description": "Type of object on which property is to be defined. Types can be design, port, cell, pin, net, lib, lib_cell, lib_pin",
      "required": false,
      "type": "string"
    },
    {
      "name": "-quiet",
      "description": "Specifies to exit quietly without issuing error",
      "required": false,
      "type": "flag"
    }
  ]
}