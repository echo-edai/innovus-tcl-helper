{
  "command": "setRailPrototypeMode",
  "is_cmd": true,
  "summary": "Sets rail prototype mode.",
  "description": "Sets rail prototype mode.",
  "usage": "setRailPrototypeMode [-help] [-reset] [-domain <list>] [-railModel {virtual|existing}] [-totalPower <value>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "Resets all or specified options to default value",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-domain",
      "description": "Format: -domain {{PD1 <value1> net1} {PD2 <value2> net2}..}",
      "required": false,
      "type": "string"
    },
    {
      "name": "-railModel",
      "description": "Seletc rail model: virtual/existing.",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-totalPower",
      "description": "total power defined by user.",
      "required": false,
      "type": "float"
    }
  ]
}