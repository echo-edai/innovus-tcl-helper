{
  "command": "create_inst_space_group",
  "is_cmd": true,
  "summary": "Creates inst space group.",
  "description": "Creates inst space group.",
  "usage": "create_inst_space_group [-help] <groupName> -inst <inst list> {[{[ -spacing_y <value>] [-spacing_x <value>]} [-checking_box {all|cross_only}]] | [-spacing_radial <value>]}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<groupName>",
      "description": "space group name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-checking_box",
      "description": "checking all area or intersection area from -spacing_x & -spacing_y",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-inst",
      "description": "instance list",
      "required": true,
      "type": "string"
    },
    {
      "name": "-spacing_radial",
      "description": "radial spacing (in micron)",
      "required": false,
      "type": "float"
    },
    {
      "name": "-spacing_x",
      "description": "x spacing (in micron)",
      "required": false,
      "type": "float"
    },
    {
      "name": "-spacing_y",
      "description": "y spacing (in micron)",
      "required": false,
      "type": "float"
    }
  ]
}