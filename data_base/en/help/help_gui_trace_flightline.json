{
  "command": "gui_trace_flightline",
  "is_cmd": true,
  "summary": "Executes the 'gui_trace_flightline' command.",
  "description": "Executes the 'gui_trace_flightline' command.",
  "usage": "gui_trace_flightline [-help] -inst <string> [-max_inout_number <integer>] {[-sink  -sink_level <integer> [-sink_color <string>]] | [-source  -source_level <integer> [-source_color <string>]]}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-inst",
      "description": "Specify the flightline instance name which starts from",
      "required": true,
      "type": "string"
    },
    {
      "name": "-max_inout_number",
      "description": "Specify the max net terms, if the terms of one net on trace flightline exceed this value, flightline will be interrupted from this net. default : 50",
      "required": false,
      "type": "int"
    },
    {
      "name": "-sink",
      "description": "Always trace from output pin",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-sink_color",
      "description": "Speicify the color of sink trace",
      "required": false,
      "type": "string"
    },
    {
      "name": "-sink_level",
      "description": "Specify the sink trace level",
      "required": false,
      "type": "int"
    },
    {
      "name": "-source",
      "description": "Always trace from input pin",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-source_color",
      "description": "Speicify the color of source trace",
      "required": false,
      "type": "string"
    },
    {
      "name": "-source_level",
      "description": "Specify the source trace level",
      "required": false,
      "type": "int"
    }
  ]
}