{
  "command": "reportPipeline",
  "is_cmd": true,
  "summary": "Reports pipeline.",
  "description": "Reports pipeline.",
  "usage": "reportPipeline [-help] [-netGroup <netGroupNames>] [{-spacing <val> | -timingBased  | -psPMBased } [-file <fileName>]]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "analysis report file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-netGroup",
      "description": "name(s) of net group(s)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-psPMBased",
      "description": "automatically find max spacing using pspm model",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-spacing",
      "description": "maximum space between flops",
      "required": false,
      "type": "float"
    },
    {
      "name": "-timingBased",
      "description": "automatically find max spacing",
      "required": false,
      "type": "flag"
    }
  ]
}