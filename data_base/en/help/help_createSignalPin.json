{
  "command": "createSignalPin",
  "is_cmd": true,
  "summary": "Creates signal pin.",
  "description": "Creates signal pin.",
  "usage": "createSignalPin [-help] [-ignore_floating_pins] {-inst <instList> | -pins <pinLinst>}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ignore_floating_pins",
      "description": "ignore floating pins",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-inst",
      "description": "name list of insts",
      "required": true,
      "type": "string"
    },
    {
      "name": "-pins",
      "description": "name list of pins ((instTerm)+, optional)",
      "required": false,
      "type": "string"
    }
  ]
}