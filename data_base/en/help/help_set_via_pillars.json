{
  "command": "set_via_pillars",
  "is_cmd": true,
  "summary": "Sets via pillars.",
  "description": "Sets via pillars.",
  "usage": "set_via_pillars [-help] <stackViaRule>* [-required {0 | 1 | 2 | 3 |4}] {-term <term|term> | -instterm <instTerm|pgInstTerm>}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<stackViaRule>",
      "description": "A list of via pillars (for term) or a single via pillar (for instTerm). ((stackViaRule)*, required)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instterm",
      "description": "InstTerm name or pointer. ((instTerm|pgInstTerm), required)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-required",
      "description": "Specify whether stack vias are required for this term or instTerm. For term, the value can be 0/1/2/3/4, for instTerm, the value can be 0/1.",
      "required": false,
      "type": "int"
    },
    {
      "name": "-term",
      "description": "Term name or pointer. ((term|term), required)",
      "required": false,
      "type": "string"
    }
  ]
}