{
  "command": "summaryReport",
  "is_cmd": true,
  "summary": "Executes the 'summaryReport' command.",
  "description": "Executes the 'summaryReport' command.",
  "usage": "summaryReport [-help] [-outdir <string>] [-noText  | -noHtml ] [-outfile <string> | -noText ] [-noHtml  | -browser ] [-exclude_base_cell_for_density <libCell/ptnCell>+ | -exclude_inst_prefix <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-browser",
      "description": "display results in browser",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-exclude_base_cell_for_density",
      "description": "<libCell/ptnCell>+ specifies the list of cells to be exclude from density report ((libCell/ptnCell)+, optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-exclude_inst_prefix",
      "description": "specifies the list of prefixes to map all instance names to be exclude from density report",
      "required": false,
      "type": "string"
    },
    {
      "name": "-noHtml",
      "description": "not in html format",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noText",
      "description": "not in text format",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-outdir",
      "description": "out dir name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-outfile",
      "description": "out file name",
      "required": false,
      "type": "string"
    }
  ]
}