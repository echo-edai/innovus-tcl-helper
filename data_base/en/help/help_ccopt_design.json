{
  "command": "ccopt_design",
  "is_cmd": true,
  "summary": "Clock concurrent optimization design.",
  "description": "Clock concurrent optimization design.",
  "usage": "ccopt_design [-help] [-check_prerequisites] [-ckSpec] [-cts] [-expandedViews] [-num_paths <string>] [-outDir <string>] [-prefix <string>] [-timing_debug_report]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-check_prerequisites",
      "description": "Only check prerequisites, with no changes made to the design",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ckSpec",
      "description": "run design using edi cts spec",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cts",
      "description": "run design using icts",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-expandedViews",
      "description": "expandedViews option",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-num_paths",
      "description": "Specify the number of paths generated in timing reports",
      "required": false,
      "type": "string"
    },
    {
      "name": "-outDir",
      "description": "output directory",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "File Name Prefix option (native only)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-timing_debug_report",
      "description": "Generate timing debug report",
      "required": false,
      "type": "flag"
    }
  ]
}