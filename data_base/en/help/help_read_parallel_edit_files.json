{
  "command": "read_parallel_edit_files",
  "is_cmd": true,
  "summary": "Reads parallel edit files.",
  "description": "Reads parallel edit files.",
  "usage": "read_parallel_edit_files [-help] [-check] [-conflict_mode {only_one stop_all}] -files <string> [-ignore_error] [-report_file <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-check",
      "description": "Specifies only check the syntax and conflict of the files",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-conflict_mode",
      "description": "Specifies the conflict mode",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-files",
      "description": "Specifies the list of reading file",
      "required": true,
      "type": "string"
    },
    {
      "name": "-ignore_error",
      "description": "Specifies whether ignore the errors in files",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-report_file",
      "description": "Specifies the name of conflict report",
      "required": false,
      "type": "string"
    }
  ]
}