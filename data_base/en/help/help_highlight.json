{
  "command": "highlight",
  "is_cmd": true,
  "summary": "Highlights the design.",
  "description": "Highlights the design.",
  "usage": "highlight [-help] [<object>+] [-index <integer>] [ -color <string> | -auto_color  | -original  ] [ -pattern <string> | -original  ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<object>",
      "description": "Specifies Object Pointer List. ((any_object)+, optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-auto_color",
      "description": "Specifies Object color automatically.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-color",
      "description": "Specifies the color value for the specified object.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-index",
      "description": "Specifies the index value for the specified object.",
      "required": false,
      "type": "int"
    },
    {
      "name": "-original",
      "description": "Highlight the object through original color.",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pattern",
      "description": "Specifies the pattern value for the specified object.",
      "required": false,
      "type": "string"
    }
  ]
}