{
  "command": "set_aocv_interface_path_offset",
  "is_cmd": true,
  "summary": "Sets aocv interface path offset.",
  "description": "Sets aocv interface path offset.",
  "usage": "set_aocv_interface_path_offset [-help] <derateOffsetVal> [<lib_cells>] [-cell] [-delay_corner <dc_corner_name>] [-net] -power_domain <power_domain_name_list> [-view <view_name>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<derateOffsetVal>",
      "description": "Value of derate offset",
      "required": true,
      "type": "float"
    },
    {
      "name": "<lib_cells>",
      "description": "Specifies a list of library cells for a specific interface derate",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "Specifies a list of cells",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-delay_corner",
      "description": "Specifies a list of delay corners",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "Applies derate offset to net objects only. Default: the derate offset value will be applied to both the cell and net type of objects",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-power_domain",
      "description": "Specifies a list of power domains",
      "required": true,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "Specifies a list of views",
      "required": false,
      "type": "string"
    }
  ]
}