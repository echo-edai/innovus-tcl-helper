{
  "command": "optDesign",
  "is_cmd": true,
  "summary": "Executes the 'optDesign' command.",
  "description": "Executes the 'optDesign' command.",
  "usage": "optDesign [-help] [-excludeNets <fileName>] [-expandedViews] [-idealClock] [-noEcoRoute] [-outDir <directoryName>] [-postRoute] [-prefix <fileNamePrefix>] [-selectedNets <fileName>] [-selectedTerms <fileName>] [-setup] [-targeted] [-timingDebugReport] [-useTransitionFiles] [{ -drv }] [{ -incr }] [{ -hold }]    [{-preCTS | -postCTS } ]   [-drv ] [ -hold [-holdVioData <fileName>] ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-drv",
      "description": "DRV Fixing option",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-excludeNets",
      "description": "List of Nets NOT to optimize",
      "required": false,
      "type": "string"
    },
    {
      "name": "-expandedViews",
      "description": "expandedViews option",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hold",
      "description": "Hold Fixing option",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-holdVioData",
      "description": "Dump remaining hold violations data",
      "required": false,
      "type": "string"
    },
    {
      "name": "-idealClock",
      "description": "Ideal Clock option",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-incr",
      "description": "Incremental optimization",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noEcoRoute",
      "description": "No Eco Route with -postRoute",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-outDir",
      "description": "Directory for report files",
      "required": false,
      "type": "string"
    },
    {
      "name": "-postCTS",
      "description": "postCTS option",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-postRoute",
      "description": "postRoute option",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-preCTS",
      "description": "preCTS option",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-prefix",
      "description": "File Name Prefix option",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selectedNets",
      "description": "List of Nets to optimize",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selectedTerms",
      "description": "List of Terms to optimize",
      "required": false,
      "type": "string"
    },
    {
      "name": "-setup",
      "description": "Setup/DRV Fixing option",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-targeted",
      "description": "Target based optmization option",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-timingDebugReport",
      "description": "generate machine readable timing report",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-useTransitionFiles",
      "description": "Fix max_tran from external file",
      "required": false,
      "type": "flag"
    }
  ]
}