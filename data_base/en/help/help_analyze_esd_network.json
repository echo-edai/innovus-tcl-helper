{
  "command": "analyze_esd_network",
  "is_cmd": true,
  "summary": "Analyzes esd network.",
  "description": "Analyzes esd network.",
  "usage": "analyze_esd_network [-help] -ta  | -task_assistant  | { <name> -type {domain net} -config_file <string> [-output <string>] [-use_power_pad {true false}] [-clamp_lowest_layer_taps {true false}] [-remove_layers_below <string>]  [-clamp_pin_short_file <string>] }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<name>",
      "description": "<domain or net name>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-clamp_lowest_layer_taps",
      "description": "keep only lowest layer of clamp taps for effective resistance analysis",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-clamp_pin_short_file",
      "description": "clamps cell/inst layers to be shorted for effective resistance analysis",
      "required": false,
      "type": "string"
    },
    {
      "name": "-config_file",
      "description": "<configuration file of the run>",
      "required": true,
      "type": "string"
    },
    {
      "name": "-output",
      "description": "<result dir>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-remove_layers_below",
      "description": "Layer below which all layers are dropped from analysis",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ta",
      "description": "task assistant using cadence help api",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-task_assistant",
      "description": "task assistant using cadence help api",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-type",
      "description": "<type: domain | net>",
      "required": true,
      "type": "enum"
    },
    {
      "name": "-use_power_pad",
      "description": "specify if power pad file is to be used",
      "required": false,
      "type": "enum"
    }
  ]
}