{
  "command": "readSdpFile",
  "is_cmd": true,
  "summary": "Reads sdp file.",
  "description": "Reads sdp file.",
  "usage": "readSdpFile [-help] -file <sdpFileName> [-leftoverGroup] [-origin <llx> <lly>] [-skipPlacement] [-hierPath <path> ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "Sdp file name.",
      "required": true,
      "type": "string"
    },
    {
      "name": "-hierPath",
      "description": "hierarcial path name.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-leftoverGroup",
      "description": "store remaining instances to a group",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-origin",
      "description": "sdp block origin",
      "required": false,
      "type": "int"
    },
    {
      "name": "-skipPlacement",
      "description": "don't place the sdp group, only read in the group definition",
      "required": false,
      "type": "flag"
    }
  ]
}