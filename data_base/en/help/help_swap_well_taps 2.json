{
  "command": "swap_well_taps",
  "is_cmd": true,
  "summary": "Swaps well taps.",
  "description": "Swaps well taps.",
  "usage": "swap_well_taps [-help] [-both_violation <cellName>] [-cells <cellList>] [-check_only] [-default_cell <cellName>] -diffusion_forbidden_spacing <float> [-left_violation <cellName>] [-right_violation <cellName>] [-skip_cells <cellList>] [-swap_report <fileName>] [-violation_report <fileName>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-both_violation",
      "description": "Specify well taps to swap if only violating rules on both side.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cells",
      "description": "Specify well taps to swap if violating rules.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-check_only",
      "description": "Check only without swapping",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-default_cell",
      "description": "Swap to default well tap first. Must be one of cells.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-diffusion_forbidden_spacing",
      "description": "Specify forbidden spacing rule (unit:um)",
      "required": true,
      "type": "float"
    },
    {
      "name": "-left_violation",
      "description": "Specify well taps to swap if only violating rules on left side.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-right_violation",
      "description": "Specify well taps to swap if only violating rules on right side.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-skip_cells",
      "description": "Specify cells to skip rule check.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-swap_report",
      "description": "Report swapped instances.",
      "required": false,
      "type": "string"
    },
    {
      "name": "-violation_report",
      "description": "Report violated instances.",
      "required": false,
      "type": "string"
    }
  ]
}