{
  "command": "addModulePort",
  "is_cmd": true,
  "summary": "Adds module port.",
  "description": "Adds module port.",
  "usage": "addModulePort [-help] <moduleName> <portName> <portDir> [-bus <startId:endId>] [-moduleBased]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<moduleName>",
      "description": "Name of hinstance or module if -moduleBased specified",
      "required": true,
      "type": "string"
    },
    {
      "name": "<portName>",
      "description": "Name of the port",
      "required": true,
      "type": "string"
    },
    {
      "name": "<portDir>",
      "description": "port direction, the value can be - input, output, bidi",
      "required": true,
      "type": "string"
    },
    {
      "name": "-bus",
      "description": "bus bit startId:endId",
      "required": false,
      "type": "string"
    },
    {
      "name": "-moduleBased",
      "description": "is module based",
      "required": false,
      "type": "flag"
    }
  ]
}