{
  "command": "selectNet",
  "is_cmd": true,
  "summary": "Selects net.",
  "description": "Selects net.",
  "usage": "selectNet [-help] { <netName> | -allDefClock  | -clock  | -nonDefaultRule  | -shield  }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<net>",
      "description": "Specify the net name ((net)*, optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-allDefClock",
      "description": "Selects all nets that have a DEF attribute + USE CLOCK",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clock",
      "description": "Select all clock nets",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-nonDefaultRule",
      "description": "Select all nets that have a DEF attribute + USE NONDEFAULTRULE",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-shield",
      "description": "Select all nets that have a DEF attribute + USE SHIELDNETS",
      "required": false,
      "type": "flag"
    }
  ]
}