{
  "command": "ecoRoute",
  "is_cmd": true,
  "summary": "Engineering change order route.",
  "description": "Engineering change order route.",
  "usage": "ecoRoute [-help] [-ignore_route <string>] [-handlePartition ] [-fix_drc [-cut_color_flip {0 1}] [-trim_layer_patch ] [-layer_range <string>] [<area>]] [-fix_filler_drc_with_patch_only [-passive_fill ] [-layer_range <string>] [area]] [ -fix_filler_drc_with_patch_only | -fix_drc ] [-target | -fix_drc | -prototype ] [-modifyOnlyLayers <string> | -fix_drc ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<area>",
      "description": "route area",
      "required": false,
      "type": "point"
    },
    {
      "name": "-cut_color_flip",
      "description": "fix cut color drc by flipping",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-fix_drc",
      "description": "fix drc",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-fix_filler_drc_with_patch_only",
      "description": "fix filler related drc with metal patch only",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-handlePartition",
      "description": "turn on handling partition flag",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ignore_route",
      "description": "eco selected nets with ignoring routes",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer_range",
      "description": "for -fix_drc within lowerLayer:upperLayer",
      "required": false,
      "type": "string"
    },
    {
      "name": "-modifyOnlyLayers",
      "description": "modify only on frozen metal layers within lowerLayer:upperLayer",
      "required": false,
      "type": "string"
    },
    {
      "name": "-passive_fill",
      "description": "do passive fill after filler fixing",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-prototype",
      "description": "Do prototype eco routing",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-target",
      "description": "target",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-trim_layer_patch",
      "description": "fix trim only",
      "required": false,
      "type": "flag"
    }
  ]
}