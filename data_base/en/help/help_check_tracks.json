{
  "command": "check_tracks",
  "is_cmd": true,
  "summary": "Checks tracks.",
  "description": "Checks tracks.",
  "usage": "check_tracks [-help] [-direction <string>] [-grid <string>] [-layer <string>] [-mask <string>] [-offset <string>] [-origin <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-direction",
      "description": "track direction: horiz | vert | H | V",
      "required": false,
      "type": "string"
    },
    {
      "name": "-grid",
      "description": "track spacing",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer",
      "description": "track layer",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mask",
      "description": "mask name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-offset",
      "description": "track offset from starting point",
      "required": false,
      "type": "string"
    },
    {
      "name": "-origin",
      "description": "track starting point: design | core | D | C",
      "required": false,
      "type": "string"
    }
  ]
}