{
  "command": "prepareForEcoRoute",
  "is_cmd": true,
  "summary": "Prepares for eco route.",
  "description": "Prepares for eco route.",
  "usage": "prepareForEcoRoute [-help] [-exclude <net>*] [-ignore_wire_status] [-nets <net>*]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-exclude",
      "description": "Specifies the nets not to convert. ((net)*, optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ignore_wire_status",
      "description": "convert all special wires",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-nets",
      "description": "Specifies the nets to convert. ((net)*, optional)",
      "required": false,
      "type": "string"
    }
  ]
}