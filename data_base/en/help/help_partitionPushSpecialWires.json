      "type": "flag"
    },
    {
      "name": "-nets",
      "description": "To specify list of nets to consider",
      "required": false,
      "type": "string"
    },
    {
      "name": "-overlappingPartitions",
      "description": "for special nets overlapping the partition",
      "required": false,
      "type": "string"
    }
  ]
}