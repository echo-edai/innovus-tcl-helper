  "usage": "deleteInstPad [-help] [-suppress] { <instName> | -all  }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<instName>",
      "description": "delete padding for given inst",
      "required": true,
      "type": "string"
    },
    {
      "name": "-all",
      "description": "delete padding for all insts",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-suppress",
      "description": "Suppress verbose messages",
      "required": false,
      "type": "flag"
    }
  ]
}