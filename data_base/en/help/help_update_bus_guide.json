{
  "command": "update_bus_guide",
  "is_cmd": true,
  "summary": "Updates bus guide.",
  "description": "Updates bus guide.",
  "usage": "update_bus_guide [-help] [-avoidObstacles] [-layer_horizontal {id | id1:id2}] [-layer_vertical {id | id1:id2}] [-no_snap] [-resize_direction {low high}] [-type {soft hard}] [-width <value> | -net_group <name> | {{-rule <rulename> | {-wire_width <value> -wire_spacing <value>}} [-with_shield ]}]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-avoidObstacles",
      "description": "Specifies whether to avoid pre-routes and blockages",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-layer_horizontal",
      "description": "Horizontal layer id or a layer range",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer_vertical",
      "description": "Verticle layer id or a layer range",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net_group",
      "description": "Specifies net group name. ((netGroup), optional)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-no_snap",
      "description": "Specifies whether not to snap the busguide",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-resize_direction",
      "description": "The resize direction",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-rule",
      "description": "Specifies rule name or default",
      "required": false,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "Specifies the new constraint type of bus guide.",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-width",
      "description": "Specifies bus guide width",
      "required": false,
      "type": "float"
    },
    {
      "name": "-wire_spacing",
      "description": "Specifies wire spacing",
      "required": false,
      "type": "float"
    },
    {
      "name": "-wire_width",
      "description": "Specifies wire width",
      "required": false,
      "type": "float"
    },
    {
      "name": "-with_shield",
      "description": "Specifies whether to add shield wire",
      "required": false,
      "type": "flag"
    }
  ]
}