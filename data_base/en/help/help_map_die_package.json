{
  "command": "map_die_package",
  "is_cmd": true,
  "summary": "Maps die package.",
  "description": "Maps die package.",
  "usage": "map_die_package [-help] [-output <string>] -package_model_file <string> {-die_mcp_header <string> | -net_pad_file_pair <string>}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-die_mcp_header",
      "description": "<MCP header containing die abstract>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net_pad_file_pair",
      "description": "{{<net1> <pad file1>} {<net2> <pad file2>}...}",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output",
      "description": "<output directory of mapping results>",
      "required": false,
      "type": "string"
    },
    {
      "name": "-package_model_file",
      "description": "<package model file>",
      "required": true,
      "type": "string"
    }
  ]
}