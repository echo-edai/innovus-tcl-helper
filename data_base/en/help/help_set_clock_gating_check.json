{
  "command": "set_clock_gating_check",
  "is_cmd": true,
  "summary": "Sets clock gating check.",
  "description": "Sets clock gating check.",
  "usage": "set_clock_gating_check [-help] [<object_list>] [-fall] [-hold <hold_value>] [-rise] [-setup <setup_value>] [-high  | -low ]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<object_list>",
      "description": "List of clocks, intances or pins",
      "required": false,
      "type": "string"
    },
    {
      "name": "-fall",
      "description": "Applies the value to the falling signals",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-high",
      "description": "Sets non-controlling value of clock as high",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hold",
      "description": "Hold value",
      "required": false,
      "type": "float"
    },
    {
      "name": "-low",
      "description": "Sets non-controlling value of clock as low",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-rise",
      "description": "Applies the value to the rising signals",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-setup",
      "description": "Setup value",
      "required": false,
      "type": "float"
    }
  ]
}