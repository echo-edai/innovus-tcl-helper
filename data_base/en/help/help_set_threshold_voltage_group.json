{
  "command": "set_threshold_voltage_group",
  "is_cmd": true,
  "summary": "Sets threshold voltage group.",
  "description": "Sets threshold voltage group.",
  "usage": "set_threshold_voltage_group [-help] [-hinst <string>] -name <group_name> [-override] {-libraries <library list> | -lib_cells <lib cell list>}",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hinst",
      "description": "Specify the hinst",
      "required": false,
      "type": "string"
    },
    {
      "name": "-lib_cells",
      "description": "lib_cells to be defined in the VT group",
      "required": false,
      "type": "string"
    },
    {
      "name": "-libraries",
      "description": "libraries to be defined in the VT group",
      "required": false,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "Name of the VT group",
      "required": true,
      "type": "string"
    },
    {
      "name": "-override",
      "description": "override liberty defined VT groups",
      "required": false,
      "type": "flag"
    }
  ]
}