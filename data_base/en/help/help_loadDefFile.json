      "required": false,
      "type": "flag"
    },
    {
      "name": "-reflib",
      "description": "OA reference library",
      "required": false,
      "type": "string"
    },
    {
      "name": "-stub",
      "description": "Stub file",
      "required": false,
      "type": "string"
    }
  ]
}