{
  "command": "report_voltage_swing",
  "is_cmd": true,
  "summary": "Reports voltage swing.",
  "description": "Reports voltage swing.",
  "usage": "report_voltage_swing [-help] -high_threshold <float> -low_threshold <float> [-output_file <string>] [-required_width {all clock}] [-view <string>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-high_threshold",
      "description": "high threshold for voltage swing",
      "required": true,
      "type": "float"
    },
    {
      "name": "-low_threshold",
      "description": "low threshold for voltage swing",
      "required": true,
      "type": "float"
    },
    {
      "name": "-output_file",
      "description": "output file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-required_width",
      "description": "type of report for voltage swing, default=all",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-view",
      "description": "list of view names",
      "required": false,
      "type": "string"
    }
  ]
}