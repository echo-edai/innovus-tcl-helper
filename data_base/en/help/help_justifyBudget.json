{
  "command": "justifyBudget",
  "is_cmd": true,
  "summary": "Justifies budget.",
  "description": "Justifies budget.",
  "usage": "justifyBudget [-help] <ptn_or_instname> [-outfile <string>] [-summary] [-view <string>] {-pins <string> }",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<ptn_or_instname>",
      "description": "instance or partition name",
      "required": true,
      "type": "string"
    },
    {
      "name": "-outfile",
      "description": "output file name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pins",
      "description": "pins to be analaysed, use * for all pins",
      "required": true,
      "type": "string"
    },
    {
      "name": "-summary",
      "description": "reportBudget style summary report",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view",
      "description": "report only for specified view",
      "required": false,
      "type": "string"
    }
  ]
}