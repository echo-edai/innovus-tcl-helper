{
  "command": "addHaloToBlock",
  "is_cmd": true,
  "summary": "Adds halo to block.",
  "description": "Adds halo to block.",
  "usage": "addHaloToBlock [-help] <left_bottom_right_top> [-fromInstBox] [-ori <orientation>] [-snapToSite] [<inst_name> | -allMacro  | -allBlackBox  | -allCommitPtn  | -allBlock  | -allIOPad  | -cell <name>]",
  "options": [
    {
      "name": "-help",
      "description": "Prints out the command usage",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<left_bottom_right_top>",
      "description": "halo of 4 side: left bottom right top",
      "required": true,
      "type": "point"
    },
    {
      "name": "<inst_name>",
      "description": "for instance",
      "required": false,
      "type": "string"
    },
    {
      "name": "-allBlackBox",
      "description": "for all blackBoxs",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allBlock",
      "description": "for all blocks",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allCommitPtn",
      "description": "for all partitions",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allIOPad",
      "description": "for all Io Pads",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allMacro",
      "description": "for all Macros",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "by cell name",
      "required": false,
      "type": "string"
    },
    {
      "name": "-fromInstBox",
      "description": "for all blocks",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ori",
      "description": "base on orientation",
      "required": false,
      "type": "string"
    },
    {
      "name": "-snapToSite",
      "description": "halo box will snap to site",
      "required": false,
      "type": "flag"
    }
  ]
}