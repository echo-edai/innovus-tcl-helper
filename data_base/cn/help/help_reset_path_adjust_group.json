{
  "command": "reset_path_adjust_group",
  "is_cmd": true,
  "summary": "重置路径调整组",
  "description": "该命令用于移除指定的或全部的路径调整组。使用 -name 参数可以移除特定名称的路径调整组；使用 -all 参数则可以移除所有路径调整组。",
  "usage": "reset_path_adjust_group [-help] [-name <group_name> | -all ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "移除所有路径调整组",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "移除指定名称的路径调整组",
      "required": false,
      "type": "string"
    }
  ]
}