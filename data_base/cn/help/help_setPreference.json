  "usage": "setPreference [-help] <preference_name> <value>",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<preference_name>",
      "description": "偏好参数的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<value>",
      "description": "偏好参数的值",
      "required": true,
      "type": "string"
    }
  ]
}