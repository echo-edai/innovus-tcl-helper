{
  "command": "set_thermal_analysis_mode",
  "is_cmd": true,
  "summary": "设置热分析模式",
  "description": "该命令用于配置热分析模式，允许用户指定边界条件文件、功耗分布图文件、温度分布图文件、热分析输出目录以及外部热分析工具路径等参数，以进行精确的热仿真。",
  "usage": "set_thermal_analysis_mode [-help] [-boundary_condition_file <string>] [-power_map_file <string>] [-temperature_map_file <string>] [-thermal_output_dir <string>] [-tool_path <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-boundary_condition_file",
      "description": "指定芯片边界条件文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-power_map_file",
      "description": "指定功耗分布图文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-temperature_map_file",
      "description": "指定温度分布图文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-thermal_output_dir",
      "description": "指定热分析输出目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tool_path",
      "description": "指定外部热分析工具的可执行文件目录",
      "required": false,
      "type": "string"
    }
  ]
}