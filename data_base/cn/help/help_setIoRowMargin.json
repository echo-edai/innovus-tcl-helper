{
  "command": "setIoRowMargin",
  "is_cmd": true,
  "summary": "设置I/O行边距",
  "description": "该命令用于设置I/O行与设计边缘之间的距离，适用于多I/O行设计。",
  "usage": "setIoRowMargin [-help] [<side> <row> <margin>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<side>",
      "description": "指定边方向，可选值：n（北）、w（西）、s（南）、e（东）",
      "required": false,
      "type": "string"
    },
    {
      "name": "<row>",
      "description": "在多I/O行设计中的行号，取值范围为0到1000",
      "required": false,
      "type": "int"
    },
    {
      "name": "<margin>",
      "description": "与设计边缘的距离",
      "required": false,
      "type": "float"
    }
  ]
}