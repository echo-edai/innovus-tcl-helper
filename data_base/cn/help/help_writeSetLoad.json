{
  "command": "writeSetLoad",
  "is_cmd": true,
  "summary": "将设置的负载信息写入指定文件",
  "description": "该命令用于将设计中设置的负载（Set Load）信息写入到一个指定的文件中。用户可以选择是否包含引脚电容、是否排除零电容网络、是否直接引用端口以及指定特定的视图（View）等选项来控制输出的内容。",
  "usage": "writeSetLoad [-help] [-direct] [-excludeZeroCap] -file <string> [-includePinCap] [-view <string>] [-wire_load]",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-direct",
      "description": "直接引用端口",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-excludeZeroCap",
      "description": "排除电容值为零的网络",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "输出文件的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-includePinCap",
      "description": "包含引脚电容",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view",
      "description": "输出文件所对应的视图名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-wire_load",
      "description": "为端口标记-wire_load选项",
      "required": false,
      "type": "flag"
    }
  ]
}