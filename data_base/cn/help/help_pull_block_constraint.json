{
  "command": "pull_block_constraint",
  "is_cmd": true,
  "summary": "提取模块约束",
  "description": "该命令用于将指定模块、实例或单元视图的约束提取到顶层。用户可以选择将约束详情输出到报告文件中，并可选择覆盖顶层现有的约束。",
  "usage": "pull_block_constraint [-help] [-file <report_file_name>] [-override] {-all_blocks  | -block <list_of_blocks> | -inst <list_of_instances> | -cellview {list of <libName cellName viewName>}}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all_blocks",
      "description": "提取所有模块的约束",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-block",
      "description": "指定一个或多个需要提取约束的模块",
      "required": true,
      "type": "string"
    },
    {
      "name": "-cellview",
      "description": "指定需要提取约束的库、单元和视图列表",
      "required": true,
      "type": "string"
    },
    {
      "name": "-file",
      "description": "包含所有约束详情的报告文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-inst",
      "description": "指定一个或多个需要提取约束的实例",
      "required": true,
      "type": "string"
    },
    {
      "name": "-override",
      "description": "覆盖顶层模块的约束",
      "required": false,
      "type": "flag"
    }
  ]
}