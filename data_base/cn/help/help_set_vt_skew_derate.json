{
  "command": "set_vt_skew_derate",
  "is_cmd": true,
  "summary": "设置电压阈值偏差的降额因子",
  "description": "此命令用于为特定的电压阈值组或延迟角设置降额因子，以调整时序分析中的快慢路径延迟。可以分别设置用于建立时间和保持时间分析的降额值，并可选择应用于均值或标准差分量。",
  "usage": "set_vt_skew_derate [-help] [-delay_corner <string>] [-fast <float>] [-hold] [-mean] [-resetViewListVTSkew] [-setup] [-sigma] [-slow <float>] [-threshold_voltage_group <group name>] [-viewListVTSkew <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-delay_corner",
      "description": "延迟角列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-fast",
      "description": "快速降额因子",
      "required": false,
      "type": "float"
    },
    {
      "name": "-hold",
      "description": "应用于保持时间分析的降额",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-mean",
      "description": "应用于均值分量的降额",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-resetViewListVTSkew",
      "description": "重置VT偏差视图列表",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-setup",
      "description": "应用于建立时间分析的降额",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-sigma",
      "description": "应用于标准差分量的降额",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-slow",
      "description": "慢速降额因子",
      "required": false,
      "type": "float"
    },
    {
      "name": "-threshold_voltage_group",
      "description": "要应用降额的电压阈值组",
      "required": false,
      "type": "string"
    },
    {
      "name": "-viewListVTSkew",
      "description": "VT偏差视图列表",
      "required": false,
      "type": "string"
    }
  ]
}