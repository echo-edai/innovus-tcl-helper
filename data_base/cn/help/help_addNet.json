{
  "command": "addNet",
  "is_cmd": true,
  "summary": "在设计中添加一个网络",
  "description": "该命令用于在当前设计或指定模块中添加一个新的网络。可以创建普通信号网络、总线网络、电源网络或地网络。",
  "usage": "addNet [-help] [-bus <msb:lsb>] { <netName> } [ -moduleBased <moduleName> ] [-power | -ground ]",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bus",
      "description": "为总线网络指定位范围，格式为<最高有效位:最低有效位>",
      "required": false,
      "type": "string"
    },
    {
      "name": "<netName>",
      "description": "要创建的网络的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-moduleBased",
      "description": "指定Verilog模块的名称，网络将添加到此模块中",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ground",
      "description": "创建一个地网络",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-power",
      "description": "创建一个电源网络",
      "required": false,
      "type": "flag"
    }
  ]
}