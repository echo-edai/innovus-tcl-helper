{
  "command": "ccopt_design",
  "is_cmd": true,
  "summary": "执行时钟树综合与优化设计",
  "description": "该命令用于执行时钟树综合（CTS）和时钟树优化（CCOpt）流程。它提供了多种选项来控制流程的执行，例如仅检查先决条件、指定输出目录、生成时序调试报告等。",
  "usage": "ccopt_design [-help] [-check_prerequisites] [-ckSpec] [-cts] [-expandedViews] [-num_paths <string>] [-outDir <string>] [-prefix <string>] [-timing_debug_report]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-check_prerequisites",
      "description": "仅检查先决条件，不对设计进行任何更改",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ckSpec",
      "description": "使用EDI CTS规范运行设计",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cts",
      "description": "使用ICTS运行设计",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-expandedViews",
      "description": "启用扩展视图选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-num_paths",
      "description": "指定时序报告中生成的路径数量",
      "required": false,
      "type": "string"
    },
    {
      "name": "-outDir",
      "description": "指定输出目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "文件名前缀选项（仅限原生模式）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-timing_debug_report",
      "description": "生成时序调试报告",
      "required": false,
      "type": "flag"
    }
  ]
}