{
  "command": "setWhatIfClockPort",
  "is_cmd": true,
  "summary": "设置黑盒或黑团单元的时钟端口",
  "description": "该命令用于指定黑盒（blackbox）或黑团（blackblob）单元的时钟端口名称。",
  "usage": "setWhatIfClockPort [-help] <blackBoxCellName> -port <portName>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<blackBoxCellName>",
      "description": "黑盒或黑团单元的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-port",
      "description": "指定时钟端口的名称",
      "required": true,
      "type": "string"
    }
  ]
}