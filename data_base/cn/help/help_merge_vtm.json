{
  "command": "merge_vtm",
  "is_cmd": true,
  "summary": "合并VTM（电压温度模型）的命令",
  "description": "该命令用于合并电压温度模型（VTM）文件。用户可以通过指定配置文件来定义合并过程，并可选择设置输出格式、合并后的文件名以及运行目录。",
  "usage": "merge_vtm [-help] -config <string> [-format <string>] [-merged_file <string>] [-rundir <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-config",
      "description": "配置文件的名称（必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-format",
      "description": "输出映射文件的格式（可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-merged_file",
      "description": "输出文件的名称（可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rundir",
      "description": "运行目录（可选）",
      "required": false,
      "type": "string"
    }
  ]
}