{
  "command": "reset_path_group",
  "is_cmd": true,
  "summary": "重置路径组",
  "description": "该命令用于移除指定的路径组或所有路径组。",
  "usage": "reset_path_group [-help] [-name <group_name> | -all ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "移除所有路径组",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "移除指定名称的路径组",
      "required": false,
      "type": "string"
    }
  ]
}