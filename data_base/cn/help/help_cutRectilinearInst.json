{
  "command": "cutRectilinearInst",
  "is_cmd": true,
  "summary": "切割不规则形状实例的命令",
  "description": "此命令用于切割一个不规则形状的层级实例。它提供了多种方式来指定切割区域：可以通过参考另一个实例并设置间距来定义，可以通过指定一个角点和偏移量来定义，或者直接指定一个矩形切割框。",
  "usage": "cutRectilinearInst [-help] -inst <inst|hInst|group>+ [-pushOut <string>] {{-refInst <inst|hInst|group>+ [-spacingX <float>] [-spacingY <float>]} | {-corner <string> [-x <float> -y <float>]} | {-cutBox {x1 y1 x2 y2}}}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-inst",
      "description": "要切割的层级实例的名称",
      "required": true,
      "type": "inst|hInst|group+"
    },
    {
      "name": "-pushOut",
      "description": "指定一个边或侧面的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-refInst",
      "description": "作为参考的实例名称",
      "required": false,
      "type": "inst|hInst|group+"
    },
    {
      "name": "-spacingX",
      "description": "X方向的间距值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-spacingY",
      "description": "Y方向的间距值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-corner",
      "description": "指定一个角点的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-x",
      "description": "x方向的偏移值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-y",
      "description": "y方向的偏移值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-cutBox",
      "description": "指定要切割的不规则矩形框",
      "required": false,
      "type": "box"
    }
  ]
}