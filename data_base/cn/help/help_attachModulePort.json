{
  "command": "attachModulePort",
  "is_cmd": true,
  "summary": "将模块端口连接到指定网络",
  "description": "该命令用于将一个模块的指定端口连接到给定的网络上。可以控制是否允许在连接时创建新的端口。",
  "usage": "attachModulePort [-help] <moduleName> <portName> <netName> [-noNewPort]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<moduleName>",
      "description": "模块名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<portName>",
      "description": "端口名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<netName>",
      "description": "网络名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-noNewPort",
      "description": "无论给定的模块端口和网络是否在同一层次结构中，都不允许创建新端口",
      "required": false,
      "type": "flag"
    }
  ]
}