{
  "command": "reset_clock_latency",
  "is_cmd": true,
  "summary": "重置时钟延迟断言",
  "description": "该命令用于移除指定引脚、端口或时钟对象上的时钟延迟断言。可以指定特定的时钟列表来移除其关联的延迟，或使用-source选项移除源延迟。",
  "usage": "reset_clock_latency [-help] <pin_or_clock_list> [-clock <clock_list>] [-source]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pin_or_clock_list>",
      "description": "需要移除延迟断言的引脚、端口或时钟对象列表（必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-clock",
      "description": "移除与指定时钟列表关联的延迟",
      "required": false,
      "type": "string"
    },
    {
      "name": "-source",
      "description": "移除源延迟",
      "required": false,
      "type": "flag"
    }
  ]
}