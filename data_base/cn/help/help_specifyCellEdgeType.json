{
  "command": "specifyCellEdgeType",
  "is_cmd": true,
  "summary": "为指定单元或单元行设置边缘类型约束",
  "description": "此命令用于为布局中的特定单元或单元行定义其边缘（左、右、上、下）的类型。它可以设置或重置约束，并支持为水平边缘类型指定行号，以及为垂直边缘类型指定范围。",
  "usage": "specifyCellEdgeType [-help] [-cellRow <integer>] {-left <string> | -right <string> | -top <string> | -bottom <string> | -reset } [{-left <string> | -right <string>} [-half {top | bottom}]] [{-top <string> | -bottom <string>} [-range {x y}]] [{-cell <string>} [-reset ]]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bottom",
      "description": "指定底部边缘的类型",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "指定要添加边缘约束的单元",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cellRow",
      "description": "为水平边缘类型指定行号",
      "required": false,
      "type": "int"
    },
    {
      "name": "-half",
      "description": "指定单元行的半行（上半部分或下半部分）",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-left",
      "description": "指定左侧边缘的类型",
      "required": false,
      "type": "string"
    },
    {
      "name": "-range",
      "description": "为垂直边缘类型指定范围（坐标点）",
      "required": false,
      "type": "point"
    },
    {
      "name": "-reset",
      "description": "将指定单元的约束重置为默认状态",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-right",
      "description": "指定右侧边缘的类型",
      "required": false,
      "type": "string"
    },
    {
      "name": "-top",
      "description": "指定顶部边缘的类型",
      "required": false,
      "type": "string"
    }
  ]
}