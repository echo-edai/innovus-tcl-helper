{
  "command": "analyze_paths_by_view",
  "is_cmd": true,
  "summary": "按视图分析时序路径",
  "description": "该命令用于分析时序路径，并可按指定的主类别对路径进行分类，同时可为类别名称添加前缀。",
  "usage": "analyze_paths_by_view [-help] [-master <string>] [-prefix <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-master",
      "description": "指定时序路径应仅针对该主类别进行分类。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "为类别名称添加前缀。",
      "required": false,
      "type": "string"
    }
  ]
}