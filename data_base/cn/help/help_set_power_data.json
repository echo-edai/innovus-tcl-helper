{
  "command": "set_power_data",
  "is_cmd": true,
  "summary": "设置功耗数据",
  "description": "该命令用于为设计中的实例或整个设计设置功耗数据。它支持从文件读取功耗信息，或直接通过参数指定功耗值、格式、缩放比例等。可以指定特定的实例、偏移量、重复窗口以及偏置电压等参数，以精细控制功耗数据的应用。使用 -reset 选项可以重置所有已设置的功耗数据。",
  "usage": "set_power_data [-help] -reset | {-format {current ascii area ascii_current} [-instance <string>] [-strip_hier_instance <string>] [-offset <string>] [-power <float>] [-scale <float>] [-repeat <float>] [-repeat_window <string>] [-bias_voltage <float>] [-die_instance_name <string>] [<filename> | -power_output_directory <string>]}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "重置所有功耗数据",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-format",
      "description": "指定功耗数据的格式，可选值包括 current、ascii、area、ascii_current",
      "required": true,
      "type": "enum"
    },
    {
      "name": "-instance",
      "description": "指定要应用功耗数据的实例名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-strip_hier_instance",
      "description": "指定要剥离层次结构的实例名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-offset",
      "description": "指定周期偏移量",
      "required": false,
      "type": "string"
    },
    {
      "name": "-power",
      "description": "直接指定功耗值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-scale",
      "description": "指定缩放系数",
      "required": false,
      "type": "float"
    },
    {
      "name": "-repeat",
      "description": "指定重复次数",
      "required": false,
      "type": "float"
    },
    {
      "name": "-repeat_window",
      "description": "指定重复窗口，格式为 {开始时间 结束时间} (单位：纳秒)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-bias_voltage",
      "description": "指定偏置电压值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-die_instance_name",
      "description": "指定芯片实例名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-power_output_directory",
      "description": "指定功耗文件输出目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "<filename>",
      "description": "指定包含功耗数据的文件名",
      "required": false,
      "type": "string"
    }
  ]
}