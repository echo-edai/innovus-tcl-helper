{
  "command": "createSdpGroup",
  "is_cmd": true,
  "summary": "创建一个SDP（标准设计规划）组，用于对实例进行行、列或空间排列分组。",
  "description": "该命令用于创建一个标准设计规划（SDP）组，允许用户根据指定的参数（如排列方向、组名、类型、间距等）对一组设计实例进行组织。用户可以通过通配符指定实例，或使用当前选中的实例。命令支持多种间距定义方式（如基于行数、微米或技术站点宽度），并可配置组的行数和列数，以实现灵活的布局规划。",
  "usage": "createSdpGroup [-help] [-justifyBy <SW|SE|NW|NE|N|W|S|E|MID>] -name <sdpGroupName> [-type <row|col|space>] {{-skip_space <val> } | -skip_space_by_site_width <val> <siteName> | -skip_space_by_micron <val>} | {{{-inst <WCardName...> [-keepOrder ]} | -selected } [[-spread_group <val> ] | [-spread_group_by_site_width <val> <siteName>] | [-spread_group_by_micron <val>] | [[-numRow <val>] [-numCol <val>] ]]}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-justifyBy",
      "description": "指定排列方向，可选值为SW、SE、NW、NE、N、W、S、E或MID",
      "required": false,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "要创建的SDP组的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "记录类型，可选值为row、col或space",
      "required": false,
      "type": "string"
    },
    {
      "name": "-skip_space",
      "description": "行/列之间的间距值",
      "required": false,
      "type": "string"
    },
    {
      "name": "-skip_space_by_site_width",
      "description": "基于技术站点宽度的行/列间距，需提供间距值和站点名称",
      "required": false,
      "type": "list"
    },
    {
      "name": "-skip_space_by_micron",
      "description": "以微米为单位的行/列间距值",
      "required": false,
      "type": "string"
    },
    {
      "name": "-inst",
      "description": "通配符实例名称，用于指定要包含在组中的实例",
      "required": false,
      "type": "string"
    },
    {
      "name": "-keepOrder",
      "description": "保持输入SDP实例列表中的顺序",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-selected",
      "description": "使用当前选中的实例",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-spread_group",
      "description": "使用间距值展开组",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spread_group_by_site_width",
      "description": "基于技术站点宽度展开组，需提供间距值和站点名称",
      "required": false,
      "type": "list"
    },
    {
      "name": "-spread_group_by_micron",
      "description": "以微米为单位展开组",
      "required": false,
      "type": "string"
    },
    {
      "name": "-numRow",
      "description": "要创建的行数",
      "required": false,
      "type": "int"
    },
    {
      "name": "-numCol",
      "description": "要创建的列数",
      "required": false,
      "type": "int"
    }
  ]
}