{
  "command": "update_bus_guide",
  "is_cmd": true,
  "summary": "更新总线引导线",
  "description": "该命令用于更新总线引导线（bus guide）的属性，例如指定其宽度、层、类型，以及是否避免障碍物等。用户可以通过多种方式定义宽度，包括直接指定数值、引用网络组或应用特定的布线规则。",
  "usage": "update_bus_guide [-help] [-avoidObstacles] [-layer_horizontal {id | id1:id2}] [-layer_vertical {id | id1:id2}] [-no_snap] [-resize_direction {low high}] [-type {soft hard}] [-width <value> | -net_group <name> | {{-rule <rulename> | {-wire_width <value> -wire_spacing <value>}} [-with_shield ]}]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-avoidObstacles",
      "description": "指定是否避开预布线路径和障碍物",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-layer_horizontal",
      "description": "指定水平层ID或层范围",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer_vertical",
      "description": "指定垂直层ID或层范围",
      "required": false,
      "type": "string"
    },
    {
      "name": "-no_snap",
      "description": "指定是否不对总线引导线进行对齐吸附",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-resize_direction",
      "description": "指定调整大小的方向",
      "required": false,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "指定总线引导线的新约束类型",
      "required": false,
      "type": "string"
    },
    {
      "name": "-width",
      "description": "指定总线引导线的宽度",
      "required": false,
      "type": "float"
    },
    {
      "name": "-net_group",
      "description": "指定网络组名称",
      "required": false,
      "type": "netGroup"
    },
    {
      "name": "-rule",
      "description": "指定规则名称或默认规则",
      "required": false,
      "type": "string"
    },
    {
      "name": "-wire_width",
      "description": "指定导线宽度",
      "required": false,
      "type": "float"
    },
    {
      "name": "-wire_spacing",
      "description": "指定导线间距",
      "required": false,
      "type": "float"
    },
    {
      "name": "-with_shield",
      "description": "指定是否添加屏蔽线",
      "required": false,
      "type": "flag"
    }
  ]
}