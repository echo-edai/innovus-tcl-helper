{
  "command": "update_partition",
  "is_cmd": true,
  "summary": "更新分区",
  "description": "该命令用于更新分区，支持多种操作，如更新引脚位置、执行ECO（工程变更单）等。它允许用户指定不同的目录来处理FlexILM数据、ECO作业以及完整的网表结果。",
  "usage": "update_partition [-help] [-pinLocation] [-postECOSuffix <string>] {-flexIlmECO } { -goldenBlockDir <string>} -flexIlmDir <string> [-ecoDir <string>] [-fullNetlistWithECODir <string> -flexILMECODir <string> ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pinLocation",
      "description": "更新原始数据库中的引脚位置",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-postECOSuffix",
      "description": "用户指定的ECO后数据库后缀",
      "required": false,
      "type": "string"
    },
    {
      "name": "-flexIlmECO",
      "description": "在FlexILM模块上执行ECO",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-goldenBlockDir",
      "description": "原始模块目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-flexIlmDir",
      "description": "后优化FlexILM数据目录",
      "required": true,
      "type": "string"
    },
    {
      "name": "-ecoDir",
      "description": "运行ECO作业的目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-fullNetlistWithECODir",
      "description": "存储完整网表ECO结果的目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-flexILMECODir",
      "description": "存储ECO作业的目录",
      "required": false,
      "type": "string"
    }
  ]
}