{
  "command": "deselectSecondaryPGNet",
  "is_cmd": true,
  "summary": "取消选择指定实例的次级电源地网络",
  "description": "该命令用于取消选择指定实例（inst）上连接的次级电源地网络（net）。用户需要提供实例列表和网络名称作为必要参数。",
  "usage": "deselectSecondaryPGNet [-help] -insts <inst>+ -net <net>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-insts",
      "description": "指定具有次级电源地引脚的实例列表",
      "required": true,
      "type": "inst+"
    },
    {
      "name": "-net",
      "description": "指定网络名称",
      "required": true,
      "type": "net"
    }
  ]
}