{
  "command": "deleteNet",
  "is_cmd": true,
  "summary": "删除指定的网络",
  "description": "此命令用于从设计中删除指定的网络。可以删除单个网络，也可以指定总线位范围进行删除，或者基于特定的Verilog模块来删除网络。",
  "usage": "deleteNet [-help] <netName> [-bus <startId:endId>] [-moduleBased <moduleName>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<netName>",
      "description": "网络名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-bus",
      "description": "总线位起始ID:结束ID",
      "required": false,
      "type": "string"
    },
    {
      "name": "-moduleBased",
      "description": "Verilog模块名称",
      "required": false,
      "type": "string"
    }
  ]
}