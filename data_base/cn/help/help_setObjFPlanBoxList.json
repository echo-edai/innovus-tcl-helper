{
  "command": "setObjFPlanBoxList",
  "is_cmd": true,
  "summary": "设置对象的平面规划框列表",
  "description": "该命令用于为指定对象（如单元、组、实例、层形状或模块）设置一个矩形框列表，以定义其在平面规划中的形状。可选择是否对齐到网格。",
  "usage": "setObjFPlanBoxList [-help] {Cell Group Instance Layershape Module} <objectName> <boxList> [-no_snap_to_grid]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "{Cell Group Instance Layershape Module}",
      "description": "对象类型（枚举，必需）",
      "required": true,
      "type": "enum"
    },
    {
      "name": "<objectName>",
      "description": "对象名称（字符串，必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "<boxList>",
      "description": "对象的矩形形状（列表，必需）",
      "required": true,
      "type": "list"
    },
    {
      "name": "-no_snap_to_grid",
      "description": "指定不遵循对齐网格规则（布尔，可选）",
      "required": false,
      "type": "flag"
    }
  ]
}