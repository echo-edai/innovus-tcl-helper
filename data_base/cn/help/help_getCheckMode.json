{
  "command": "getCheckMode",
  "is_cmd": true,
  "summary": "获取当前设计检查模式的设置",
  "description": "该命令用于查询当前设计中各种检查模式的启用状态。用户可以通过指定不同的选项来查询特定检查项（如布局、布线、网表等）是否被激活。命令支持显示所有检查项、仅显示非默认设置或仅以简洁的Tcl列表格式输出结果。",
  "usage": "getCheckMode [-help] [-all] [-checkIlm] [-extraction] [-floorplan] [-globalNet] [-integrity] [-io] [-library] [-mgrid] [-netlist] [-placement] [-route] [-sroute] [-tapeOut] [-timingGraph] [-vcellnetlist] [-quiet] [-nonDefault]",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "执行所有检查",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-checkIlm",
      "description": "检查ILM模型",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-extraction",
      "description": "检查提取所需的所有数据是否正确",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-floorplan",
      "description": "检查布局规划",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-globalNet",
      "description": "在init_design或restoreDesign后，执行与checkDesign -powerGround相同的检查",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-integrity",
      "description": "检查完整性",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-io",
      "description": "检查输入输出",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-library",
      "description": "在init_design或restoreDesign后，执行与checkDesign -physicalLibrary -timingLibrary相同的检查",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-mgrid",
      "description": "检查几何图形是否在制造网格上",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-netlist",
      "description": "读入网表后，执行与checkDesign -netlist相同的检查",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-placement",
      "description": "检查布局",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-route",
      "description": "在电源布线前，检查电源和地引脚是否连接到电源和地网络",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-sroute",
      "description": "检查特殊布线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-tapeOut",
      "description": "读取网表时，如果存在未定义的实例或端口，将报错（而不是创建黑盒或空模块）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-timingGraph",
      "description": "检查库单元的时序信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-vcellnetlist",
      "description": "读取Verilog网表时，检查高电平和低电平输出引脚",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-quiet",
      "description": "仅以Tcl列表格式显示当前设置",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-nonDefault",
      "description": "仅显示当前非默认的设置",
      "required": false,
      "type": "flag"
    }
  ]
}