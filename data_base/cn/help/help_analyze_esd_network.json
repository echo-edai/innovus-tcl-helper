{
  "command": "analyze_esd_network",
  "is_cmd": true,
  "summary": "分析ESD网络",
  "description": "该命令用于分析静电放电（ESD）网络。它允许用户指定一个域或网络名称，并通过配置文件来执行分析。用户可以选择是否使用电源焊盘文件、是否仅保留最低层的钳位抽头进行有效电阻分析、移除指定层以下的所有层进行分析，以及指定输出结果目录。此外，还支持通过任务助手（task assistant）使用Cadence帮助API来辅助操作。",
  "usage": "analyze_esd_network [-help] -ta  | -task_assistant  | { <name> -type {domain net} -config_file <string> [-output <string>] [-use_power_pad {true false}] [-clamp_lowest_layer_taps {true false}] [-remove_layers_below <string>]  [-clamp_pin_short_file <string>] }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<name>",
      "description": "域或网络名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-clamp_lowest_layer_taps",
      "description": "仅保留最低层的钳位抽头进行有效电阻分析",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-clamp_pin_short_file",
      "description": "指定用于有效电阻分析的钳位单元/实例层短路文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-config_file",
      "description": "运行的配置文件",
      "required": true,
      "type": "string"
    },
    {
      "name": "-output",
      "description": "结果输出目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-remove_layers_below",
      "description": "移除指定层以下的所有层，不参与分析",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ta",
      "description": "使用Cadence帮助API的任务助手",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-task_assistant",
      "description": "使用Cadence帮助API的任务助手",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-type",
      "description": "类型：域或网络",
      "required": true,
      "type": "enum"
    },
    {
      "name": "-use_power_pad",
      "description": "指定是否使用电源焊盘文件",
      "required": false,
      "type": "enum"
    }
  ]
}