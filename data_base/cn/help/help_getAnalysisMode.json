{
  "command": "getAnalysisMode",
  "is_cmd": true,
  "summary": "获取当前时序分析模式的设置",
  "description": "该命令用于查询或报告当前EDA工具中配置的时序分析模式。它提供了众多选项，允许用户指定或查看特定的分析类型（如单点、BCWC、OCV）、变化分析（如AOCV、SOCV）、时钟处理方式（如时钟门控检查、时钟传播）、路径悲观度消除（如CPPR）、以及各种其他时序分析引擎和检查的详细设置。通过使用不同的参数，用户可以定制或获取关于静态时序分析（STA）或统计时序分析（SSTA）环境的具体配置信息。",
  "usage": "getAnalysisMode [-help] [-aging] [-analysisType] [-aocv] [-asyncChecks] [-caseAnalysis] [-checkType] [-clkNetsMarking] [-clkSrcPath] [-clockGatingCheck] [-clockPropagation] [-cppr] [-honorActiveLogicView] [-honorClockDomains] [-log] [-multi_input_switching_mode] [-propSlew] [-sequentialConstProp] [-skew] [-slackBalancing] [-socv] [-timeBorrowing] [-timing_robustness] [-timingEngine] [-timingSelfLoopsNoSkew] [-usefulSkew] [-useOutputPinCap] [-warn] [-quiet] [-nonDefault]",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-aging",
      "description": "老化分析",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-analysisType",
      "description": "时序分析类型：单点、BCWC或片上变异(OCV)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-aocv",
      "description": "AOCV（高级片上变异）分析",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-asyncChecks",
      "description": "异步检查设置",
      "required": false,
      "type": "string"
    },
    {
      "name": "-caseAnalysis",
      "description": "案例分析",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-checkType",
      "description": "报告建立时间或保持时间的违规",
      "required": false,
      "type": "string"
    },
    {
      "name": "-clkNetsMarking",
      "description": "时钟网络标记时机",
      "required": false,
      "type": "string"
    },
    {
      "name": "-clkSrcPath",
      "description": "时钟源路径",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clockGatingCheck",
      "description": "时钟门控检查",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clockPropagation",
      "description": "时序弧属性对时序分析的影响",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cppr",
      "description": "消除时钟路径中公共部分的悲观度",
      "required": false,
      "type": "string"
    },
    {
      "name": "-honorActiveLogicView",
      "description": "遵循活动逻辑视图",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-honorClockDomains",
      "description": "遵循时钟域",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-log",
      "description": "日志记录",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-multi_input_switching_mode",
      "description": "指定多输入切换(MIS)模式",
      "required": false,
      "type": "int"
    },
    {
      "name": "-propSlew",
      "description": "控制早期路径的互连线转换时间衰减",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-sequentialConstProp",
      "description": "时序常量传播",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skew",
      "description": "时钟偏斜",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-slackBalancing",
      "description": "裕量平衡",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-socv",
      "description": "SOCV（片上变化符号）分析",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-timeBorrowing",
      "description": "时间借用",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-timing_robustness",
      "description": "时序鲁棒性分析",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-timingEngine",
      "description": "时序引擎类型：统计、静态或Rql",
      "required": false,
      "type": "string"
    },
    {
      "name": "-timingSelfLoopsNoSkew",
      "description": "消除因时钟不确定性导致的、起始和结束于同一寄存器的路径上的时钟偏斜",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-usefulSkew",
      "description": "有益偏斜",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-useOutputPinCap",
      "description": "使用输出引脚电容",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-warn",
      "description": "警告信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-quiet",
      "description": "仅以Tcl列表格式显示当前设置",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-nonDefault",
      "description": "仅显示非默认的当前设置",
      "required": false,
      "type": "flag"
    }
  ]
}