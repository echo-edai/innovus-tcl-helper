{
  "command": "editChangeRule",
  "is_cmd": true,
  "summary": "编辑变更规则",
  "description": "该命令用于修改现有的变更规则，允许用户将旧的规则替换为新的规则。",
  "usage": "editChangeRule [-help] [-from <string>] -to <string>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-from",
      "description": "旧的规则（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-to",
      "description": "新的规则（字符串，必需）",
      "required": true,
      "type": "string"
    }
  ]
}