  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<hinstName>",
      "description": "层次化实例的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<portName>",
      "description": "端口的名称",
      "required": true,
      "type": "string"
    }
  ]
}