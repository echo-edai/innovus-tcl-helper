{
  "command": "setHInstColorId",
  "is_cmd": true,
  "summary": "设置层次化实例的颜色ID",
  "description": "该命令用于为指定的层次化实例分配一个颜色ID，颜色ID的范围为0到29。可选地，可以将此颜色ID同时应用于该实例的所有子实例或后代实例。",
  "usage": "setHInstColorId [-help] <hInstName> <colorID> [-descendant]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<hInstName>",
      "description": "层次化实例的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<colorID>",
      "description": "颜色ID，取值范围为0到29",
      "required": true,
      "type": "int"
    },
    {
      "name": "-descendant",
      "description": "指定颜色ID也应应用于子实例或后代实例",
      "required": false,
      "type": "flag"
    }
  ]
}