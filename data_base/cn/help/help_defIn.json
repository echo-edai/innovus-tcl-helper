{
  "command": "defIn",
  "is_cmd": true,
  "summary": "读取DEF文件到设计数据库",
  "description": "该命令用于将DEF（Design Exchange Format）文件的内容读入当前的设计数据库。它支持读取组件、网络、特殊网络等部分，并可配置多种选项以处理特殊情况，如忽略DRC填充、忽略电源地连接性、删除特定布线、覆盖特殊布线类型以及进行增量布线读取等。",
  "usage": "defIn [-help] <fileName> [-add_blockage] [-add_power_switch] [-allWarning] [-components] [-deleteBump] [-deleteSpecialRoute] [-ignore_drcfill] [-ignore_pg_connectivity] [-nets] [-override_special_routing {pg signal logical physical all}] [-preserveShape] [-removeHalfWireExtensionOnPin] [-specialRouteUserClass <string>] [-specialnets] [-verilog_from_def_netlist_flow] [-incremental_routing]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<fileName>",
      "description": "DEF文件名（必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-add_blockage",
      "description": "指示为简化网表，未定义实例将转换为阻挡物",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-add_power_switch",
      "description": "为缺失的DEF组件添加电源开关",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allWarning",
      "description": "列出所有警告信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-components",
      "description": "读取COMPONENTS部分",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-deleteBump",
      "description": "删除凸块",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-deleteSpecialRoute",
      "description": "删除特殊布线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ignore_drcfill",
      "description": "忽略具有DRCFILL形状属性的特殊布线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ignore_pg_connectivity",
      "description": "忽略SPECIALNETS和NETS部分中的电源地连接性",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-incremental_routing",
      "description": "增量读取网络",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-nets",
      "description": "读取NETS部分",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-override_special_routing",
      "description": "根据DEF文件中的网络类型，删除数据库中指定的特殊布线（可选值：pg, signal, logical, physical, all）",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-preserveShape",
      "description": "保留形状",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-removeHalfWireExtensionOnPin",
      "description": "截断引脚上的半宽延伸",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-specialRouteUserClass",
      "description": "特殊布线的用户类别",
      "required": false,
      "type": "string"
    },
    {
      "name": "-specialnets",
      "description": "读取SPECIALNETS部分",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-verilog_from_def_netlist_flow",
      "description": "协调DEF和Verilog中的名称",
      "required": false,
      "type": "flag"
    }
  ]
}