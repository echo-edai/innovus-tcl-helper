{
  "command": "setLimitedAccessFeature",
  "is_cmd": true,
  "summary": "设置受限访问功能",
  "description": "此命令用于启用或禁用指定的受限访问功能。通过提供功能名称和开关值（1或0），可以控制该功能的状态。",
  "usage": "setLimitedAccessFeature [-help] <featureName> <1 | 0>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<featureName>",
      "description": "指定受限访问功能的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<1 | 0>",
      "description": "指定值1以启用功能，指定值0以禁用功能",
      "required": true,
      "type": "bool"
    }
  ]
}