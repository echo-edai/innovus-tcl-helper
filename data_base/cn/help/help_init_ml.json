{
  "command": "init_ml",
  "is_cmd": true,
  "summary": "初始化机器学习相关流程或设置",
  "description": "该命令用于初始化与机器学习（ML）相关的流程或设置。它允许用户指定输出文件的前缀、设计名称、流程阶段、场景以及可选的注释信息。",
  "usage": "init_ml [-help] [-comment <string>] [-flow_phase <string>] [-name <string>] -prefix <string> [-scenario <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法帮助信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-comment",
      "description": "注释信息",
      "required": false,
      "type": "string"
    },
    {
      "name": "-flow_phase",
      "description": "流程阶段",
      "required": false,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "设计名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "输出文件的前缀",
      "required": true,
      "type": "string"
    },
    {
      "name": "-scenario",
      "description": "场景",
      "required": false,
      "type": "string"
    }
  ]
}