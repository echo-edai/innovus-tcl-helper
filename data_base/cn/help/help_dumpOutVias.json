{
  "command": "dumpOutVias",
  "is_cmd": true,
  "summary": "输出通孔信息到文件",
  "description": "该命令用于将设计中的通孔（via）信息导出到指定的文件中。用户可以选择导出所有通孔、特定类型（如信号通孔）的通孔、或基于特定布线规则（如默认规则、非默认规则）的通孔。",
  "usage": "dumpOutVias [-help] [-autogen] [-file <filename>] [-all_via  | -signal  | -all_rule  | -default  | -ndr ]",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-autogen",
      "description": "输出自动生成的通孔",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "指定输出文件的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-all_via",
      "description": "输出所有通孔",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-signal",
      "description": "输出信号通孔",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all_rule",
      "description": "输出所有布线规则下的通孔",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-default",
      "description": "输出默认布线规则下的通孔（此为默认行为）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ndr",
      "description": "输出非默认布线规则下的通孔",
      "required": false,
      "type": "flag"
    }
  ]
}