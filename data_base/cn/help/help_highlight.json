{
  "command": "highlight",
  "is_cmd": true,
  "summary": "高亮显示指定对象",
  "description": "该命令用于在EDA工具中高亮显示指定的对象。用户可以通过提供对象指针列表，并可选地指定颜色、索引或图案来自定义高亮效果。支持自动分配颜色、使用原始颜色或自定义颜色值。索引值有特定范围限制（1到256）。",
  "usage": "highlight [-help] [<object>+] [-index <integer>] [ -color <string> | -auto_color  | -original  ] [ -pattern <string> | -original  ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<object>+",
      "description": "指定对象指针列表",
      "required": false,
      "type": "any_object+"
    },
    {
      "name": "-auto_color",
      "description": "自动指定对象颜色",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-color <string>",
      "description": "为指定对象指定颜色值",
      "required": false,
      "type": "string"
    },
    {
      "name": "-index <integer>",
      "description": "为指定对象指定索引值",
      "required": false,
      "type": "int"
    },
    {
      "name": "-original",
      "description": "使用原始颜色高亮对象",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pattern <string>",
      "description": "为指定对象指定图案值",
      "required": false,
      "type": "string"
    }
  ]
}