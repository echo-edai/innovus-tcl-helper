{
  "command": "set_aocv_interface_path_offset",
  "is_cmd": true,
  "summary": "设置AOCV接口路径偏移量",
  "description": "此命令用于设置高级片上变化（AOCV）接口的路径偏移量（降额偏移值）。用户可以为特定的库单元、单元、网络对象、延迟角落、电源域和视图指定偏移值，以应用于时序分析中的降额计算。",
  "usage": "set_aocv_interface_path_offset [-help] <derateOffsetVal> [<lib_cells>] [-cell] [-delay_corner <dc_corner_name>] [-net] -power_domain <power_domain_name_list> [-view <view_name>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<derateOffsetVal>",
      "description": "降额偏移值（浮点数）",
      "required": true,
      "type": "float"
    },
    {
      "name": "<lib_cells>",
      "description": "指定库单元列表，用于特定接口降额（字符串）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "指定单元列表（布尔值）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-delay_corner",
      "description": "指定延迟角落列表（字符串）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "仅将降额偏移应用于网络对象。默认：降额偏移值将同时应用于单元和网络类型的对象（布尔值）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-power_domain",
      "description": "指定电源域列表（字符串）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "指定视图列表（字符串）",
      "required": false,
      "type": "string"
    }
  ]
}