{
  "command": "reportCapViolation",
  "is_cmd": true,
  "summary": "报告电容违规情况",
  "description": "该命令用于生成电容违规的报告。用户可以通过指定各种选项来控制报告的范围和内容，例如排除特定网络、选择报告最大或最小约束违规、指定输出文件、选择要优化的网络列表、设置输出数值的有效位数，以及决定是否使用DRC裕度进行计算。",
  "usage": "reportCapViolation [-help] [-excNetFile <fileName>] [-max] [-min] [-outfile <fileName>] [-selNetFile <fileName>] [-significant_digits <integer>] [-useDrcMargin] [-all  | -noGlobalNets ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "报告所有选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-excNetFile",
      "description": "指定不进行优化的网络列表文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-max",
      "description": "报告最大约束违规",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-min",
      "description": "报告最小约束违规",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noGlobalNets",
      "description": "不报告全局网络",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-outfile",
      "description": "指定输出报告的文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selNetFile",
      "description": "指定要进行优化的网络列表文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-significant_digits",
      "description": "设置输出数值的有效位数",
      "required": false,
      "type": "int"
    },
    {
      "name": "-useDrcMargin",
      "description": "使用DRC裕度进行计算",
      "required": false,
      "type": "flag"
    }
  ]
}