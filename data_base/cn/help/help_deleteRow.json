{
  "command": "deleteRow",
  "is_cmd": true,
  "summary": "删除布局中的行",
  "description": "该命令用于从布局中删除指定的行。用户可以选择删除所有行、删除选中的行、根据站点名称删除行，或者直接指定要删除的行ID或名称。",
  "usage": "deleteRow [-help] {-all  | -selected  | -site <string> | <row> }",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<row>",
      "description": "要删除的行的ID或名称列表",
      "required": true,
      "type": "list"
    },
    {
      "name": "-all",
      "description": "删除所有行",
      "required": true,
      "type": "bool"
    },
    {
      "name": "-selected",
      "description": "删除当前选中的行",
      "required": true,
      "type": "bool"
    },
    {
      "name": "-site",
      "description": "根据站点名称删除行",
      "required": true,
      "type": "string"
    }
  ]
}