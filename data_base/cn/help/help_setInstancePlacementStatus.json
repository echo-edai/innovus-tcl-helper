{
  "command": "setInstancePlacementStatus",
  "is_cmd": true,
  "summary": "设置实例的布局状态",
  "description": "此命令用于设置指定实例（如硬宏、分区、黑盒单元或具体命名实例）的布局状态，可将其状态设置为未放置、固定、已放置、覆盖或软固定。",
  "usage": "setInstancePlacementStatus [-help] -status {unplaced fixed placed cover softFixed} {-allHardMacros | -allPtnBlks | -allBlackBoxes | -name <instName(s)>}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-status",
      "description": "要设置的布局状态，可选值为 unplaced、fixed、placed、cover 或 softFixed",
      "required": true,
      "type": "enum"
    },
    {
      "name": "-allHardMacros",
      "description": "设置所有硬宏",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allPtnBlks",
      "description": "设置所有分区",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allBlackBoxes",
      "description": "设置所有黑盒单元",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "指定实例名称",
      "required": false,
      "type": "string"
    }
  ]
}