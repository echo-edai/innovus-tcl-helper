{
  "command": "setLayerPreference",
  "is_cmd": true,
  "summary": "设置图层显示与交互偏好",
  "description": "此命令用于配置指定图层或对象类型的视觉显示属性（如颜色、线宽、填充图案）以及交互属性（如是否可选择、是否可见）。",
  "usage": "setLayerPreference [-help] <layer_name> [-color <string>] [-isSelectable {1 0}] [-isVisible {1 0}] [-lineWidth <integer>] [-stipple <string>] [-stippleData <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<layer_name>",
      "description": "图层或对象类型的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-color",
      "description": "颜色名称或RGB数值",
      "required": false,
      "type": "string"
    },
    {
      "name": "-isSelectable",
      "description": "设置对象是否可选择",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-isVisible",
      "description": "设置对象是否可见",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-lineWidth",
      "description": "指定对象边框的像素宽度",
      "required": false,
      "type": "int"
    },
    {
      "name": "-stipple",
      "description": "设置对象的填充图案信息",
      "required": false,
      "type": "string"
    },
    {
      "name": "-stippleData",
      "description": "设置对象的填充图案详细信息",
      "required": false,
      "type": "string"
    }
  ]
}