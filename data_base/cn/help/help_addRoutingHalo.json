{
  "command": "addRoutingHalo",
  "is_cmd": true,
  "summary": "添加布线光晕",
  "description": "该命令用于为指定的模块、单元或实例添加布线光晕（Routing Halo）。光晕是在对象周围创建的一个区域，用于在布线过程中保持间距，可以指定光晕的层、空间大小和方向等参数。此外，还支持添加基于LEF LITHOMACROHALO定义的光刻光晕（lithoHalo）。",
  "usage": "addRoutingHalo [-help] [-orientation <string>] { {-bottom <auto|name> -space <left bottom right top> -top <auto|name>} | -lithoHalo } {-allBlocks  | -block <name> | -cell <name> | -inst <name> | -designHalo  }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-orientation",
      "description": "基于方向设置光晕",
      "required": false,
      "type": "string"
    },
    {
      "name": "-bottom",
      "description": "底部层名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-space",
      "description": "四个方向（左、下、右、上）的空间大小",
      "required": true,
      "type": "list"
    },
    {
      "name": "-top",
      "description": "顶部层名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-lithoHalo",
      "description": "为每个布线层上的实例添加光刻光晕（基于LEF LITHOMACROHALO定义）",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-allBlocks",
      "description": "应用于所有模块",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-block",
      "description": "模块名称",
      "required": true,
      "type": "list"
    },
    {
      "name": "-cell",
      "description": "单元名称",
      "required": true,
      "type": "list"
    },
    {
      "name": "-inst",
      "description": "实例名称",
      "required": true,
      "type": "list"
    },
    {
      "name": "-designHalo",
      "description": "应用于所有分区",
      "required": true,
      "type": "flag"
    }
  ]
}