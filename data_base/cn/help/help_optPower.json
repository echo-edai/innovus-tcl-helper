{
  "command": "optPower",
  "is_cmd": true,
  "summary": "功耗优化命令",
  "description": "该命令用于执行功耗优化。它提供多种模式（如布局前、时钟树综合前/后、布线后）和选项来控制优化力度、是否允许单元尺寸调整以及是否强制进行漏电优化等。",
  "usage": "optPower [-help] [-allowResizing] [-effortLevel {high}] [-force] [-postCts] [-postRoute] [-preCts] [-prePlace] [-seqOnly]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allowResizing",
      "description": "仅允许进行同尺寸、缩小或放大单元的调整",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-effortLevel",
      "description": "优化力度级别选项",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-force",
      "description": "强制进行漏电优化",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-postCts",
      "description": "设置为时钟树综合后模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-postRoute",
      "description": "设置为布线后模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-preCts",
      "description": "设置为时钟树综合前模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-prePlace",
      "description": "设置为布局前模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-seqOnly",
      "description": "以触发器为重点进行功耗恢复",
      "required": false,
      "type": "flag"
    }
  ]
}