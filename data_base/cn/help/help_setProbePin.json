{
  "command": "setProbePin",
  "is_cmd": true,
  "summary": "设置探针引脚",
  "description": "该命令用于将特定的I/O实例引脚或凸块（bump）指定为探针引脚。探针引脚是用于在物理验证或测试过程中进行探测的物理连接点。用户可以通过指定I/O实例名和引脚名，或者直接指定凸块名来定义探针位置。",
  "usage": "setProbePin [-help] {{-instName <instName> -pinName <pinName>} | -bump <bumpName>}",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bump",
      "description": "指定凸块的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-instName",
      "description": "指定I/O实例的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-pinName",
      "description": "指定I/O实例上引脚的名称",
      "required": true,
      "type": "string"
    }
  ]
}