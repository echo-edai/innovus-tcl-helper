{
  "command": "createRuler",
  "is_cmd": true,
  "summary": "创建标尺",
  "description": "该命令用于在布局中创建标尺。可以通过指定中心点和半径来创建圆形标尺，或者通过指定一系列坐标点来创建由线段组成的标尺。",
  "usage": "createRuler [-help] {{-center {x y} -radius <float>} | -coordinates {x1 y1 x2 y2 ...}}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-center",
      "description": "中心点位置（点，可选）",
      "required": false,
      "type": "point"
    },
    {
      "name": "-coordinates",
      "description": "标尺线段起始和结束的坐标序列（单位为微米）（点列表，可选）",
      "required": false,
      "type": "point_list"
    },
    {
      "name": "-radius",
      "description": "圆的半径（浮点数，可选）",
      "required": false,
      "type": "float"
    }
  ]
}