      "required": false,
      "type": "flag"
    },
    {
      "name": "<blackBoxCellName>",
      "description": "黑盒或黑团单元的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-outfile",
      "description": "输出文件的名称",
      "required": false,
      "type": "string"
    }
  ]
}