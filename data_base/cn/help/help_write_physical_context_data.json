{
  "command": "write_physical_context_data",
  "is_cmd": true,
  "summary": "写入物理上下文数据",
  "description": "该命令用于将物理上下文数据写入指定的输出文件。用户可以选择指定输出文件的名称、层宽映射的指定名称以及技术类型。",
  "usage": "write_physical_context_data [-help] <file> [-designation <name>] [-type <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<file>",
      "description": "输出文件的名称（字符串，必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-designation",
      "description": "从微米到枚举的接收层宽度映射 - 格式为 um:nsw{:um:nsw}...（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "技术名称（字符串，可选）",
      "required": false,
      "type": "string"
    }
  ]
}