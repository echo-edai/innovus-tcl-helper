{
  "command": "set_die_model",
  "is_cmd": true,
  "summary": "设置芯片模型，用于定义芯片实例、SPICE模型、映射文件或重置相关设置",
  "description": "该命令用于配置芯片模型，可指定芯片实例名称、关联的SPICE模型文件、映射文件，或重置所有先前的set_die_model设置。它支持静态电流分析选项，允许使用初始或平均电流进行静态分析。",
  "usage": "set_die_model [-help] [-static_current <string>] [-subckt <string>] {-reset  | [[-die_instance_name <string> [-spice <string> [-mapping <string>]]] ]}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-static_current",
      "description": "指定用于静态分析的电流类型，如初始或平均电流（来自PWL电流源）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-subckt",
      "description": "指定顶层子电路名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "重置所有先前set_die_model命令的设置",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-die_instance_name",
      "description": "指定芯片实例名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spice",
      "description": "指定SPICE芯片模型文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mapping",
      "description": "指定映射文件",
      "required": false,
      "type": "string"
    }
  ]
}