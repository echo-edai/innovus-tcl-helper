{
  "command": "check_tcic",
  "is_cmd": true,
  "summary": "检查TCIC文件并生成报告",
  "description": "该命令用于检查指定的TCIC文件，验证设计规则，并可选择性地生成包含违规、对象面积和未放置宏数量等信息的摘要报告。",
  "usage": "check_tcic [-help] [<files>] [-pre_opt] [-report_area] [-report_file <string>] [-report_unplaced_block] [ -include_all_rules ] [-selected_rules <string> ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<files>",
      "description": "指定要检查的TCIC文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-include_all_rules",
      "description": "报告所有规则，即使该规则没有违规",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pre_opt",
      "description": "启用预优化检查",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-report_area",
      "description": "启用工具在摘要文件中报告对象面积数据",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-report_file",
      "description": "指定摘要文件的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-report_unplaced_block",
      "description": "启用工具在摘要中显示未放置宏的数量",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-selected_rules",
      "description": "指定要检查的规则名称",
      "required": false,
      "type": "string"
    }
  ]
}