{
  "command": "report_voltage_swing",
  "is_cmd": true,
  "summary": "报告电压摆幅",
  "description": "该命令用于报告设计中信号的电压摆幅。用户可以通过指定高阈值和低阈值来筛选需要报告的电压摆幅情况，并可选择输出到文件、指定报告类型（如所有信号或仅时钟信号）以及视图。",
  "usage": "report_voltage_swing [-help] -high_threshold <float> -low_threshold <float> [-output_file <string>] [-required_width {all clock}] [-view <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-high_threshold",
      "description": "电压摆幅的高阈值",
      "required": true,
      "type": "float"
    },
    {
      "name": "-low_threshold",
      "description": "电压摆幅的低阈值",
      "required": true,
      "type": "float"
    },
    {
      "name": "-output_file",
      "description": "输出文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-required_width",
      "description": "电压摆幅报告的类型，默认为'all'",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-view",
      "description": "视图名称列表",
      "required": false,
      "type": "string"
    }
  ]
}