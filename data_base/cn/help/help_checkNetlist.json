{
  "command": "checkNetlist",
  "is_cmd": true,
  "summary": "检查网表命令",
  "description": "此命令用于检查当前设计的网表。它提供了验证端口定义和生成输出报告的选项。",
  "usage": "checkNetlist [-help] [-includeSubModule] [-outfile <string> ]",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-includeSubModule",
      "description": "检查任何子模块的端口定义",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-outfile",
      "description": "指定输出文件的名称",
      "required": false,
      "type": "string"
    }
  ]
}