{
  "command": "delete_pg_keepout",
  "is_cmd": true,
  "summary": "删除电源地（PG）布线禁区",
  "description": "此命令用于从版图中移除指定的电源地（PG）布线禁区。用户可以通过指定单元、实例、层或层ID来定位要删除的禁区，也可以选择移除所有禁区。",
  "usage": "delete_pg_keepout [-help] {-cell <string> | -inst <string> | -all } [-layer <string> | -layerId <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "移除所有的PG布线禁区",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "指定要移除PG禁区的单元名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-inst",
      "description": "指定要移除PG禁区的实例名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer",
      "description": "指定要移除PG禁区的层名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layerId",
      "description": "指定要移除PG禁区的层ID",
      "required": false,
      "type": "string"
    }
  ]
}