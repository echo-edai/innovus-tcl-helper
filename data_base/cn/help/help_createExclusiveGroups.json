{
  "command": "createExclusiveGroups",
  "is_cmd": true,
  "summary": "创建互斥组",
  "description": "该命令用于创建互斥组。可以指定组名、间隙值、最小间隙值，以及需要被排除的组或相互之间需要排除的组。",
  "usage": "createExclusiveGroups [-help] [<groupName>] [-gap <float>] [-min_gap <float>] [-exclusiveGroups <string> | -mutuallyExclusiveGroups <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<groupName>",
      "description": "指定一个组名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-exclusiveGroups",
      "description": "指定需要被排除的组",
      "required": false,
      "type": "string"
    },
    {
      "name": "-gap",
      "description": "指定间隙值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-min_gap",
      "description": "指定最小间隙值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-mutuallyExclusiveGroups",
      "description": "指定相互之间需要排除的组。此选项可独立使用。",
      "required": false,
      "type": "string"
    }
  ]
}