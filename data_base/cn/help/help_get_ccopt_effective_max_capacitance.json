{
  "command": "get_ccopt_effective_max_capacitance",
  "is_cmd": true,
  "summary": "查询指定引脚的有效最大电容值",
  "description": "该命令用于获取指定实例引脚或端口的有效最大电容值。用户可以通过指定延迟角落、延迟类型等参数来查询特定条件下的电容值，并可以选择报告该值的来源或具体数值。",
  "usage": "get_ccopt_effective_max_capacitance [-help] <instTerm|term> [-delay_corner <delay_corner>] [-source] [-value] [-delay_type <type>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<instTerm|term>",
      "description": "需要查询有效最大电容的引脚",
      "required": true,
      "type": "string"
    },
    {
      "name": "-delay_corner",
      "description": "指定查询的延迟角落",
      "required": false,
      "type": "string"
    },
    {
      "name": "-delay_type",
      "description": "指定延迟类型，可选值为 early 或 late",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-source",
      "description": "报告目标值的来源",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-value",
      "description": "报告目标值的具体数值",
      "required": false,
      "type": "flag"
    }
  ]
}