{
  "command": "reportPowerDomain",
  "is_cmd": true,
  "summary": "报告电源域信息",
  "description": "该命令用于生成关于设计中电源域的详细报告。它可以报告库绑定、隔离实例、电源门控网络、层次化引脚、电源域覆盖范围、电压信息等。用户可以通过指定模块、实例、网络、引脚或特定的电源域来过滤报告内容，并可将结果输出到文件。",
  "usage": "reportPowerDomain [-help] [-bindLib] [-file <string>] [-isoInst] [-module <inst|hinst>+] [-partitionHports <pin|port|hpin>+] [-pgNet] [-pin <pin|port|hpin>+] [-powerDomainBoundaryPort <string>] [-powerDomainCoverage <pd1 pd2>] [-shifter] [-supplyCrossing <supp1 supp2>] [-verbose] [-voltage] [-powerDomain <pd> [-checkPgScope ] ] [-net <net>+} ] [-inst <inst>+ ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bindLib",
      "description": "报告库绑定",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-checkPgScope",
      "description": "电源门控网络应仅连接到作用域网络",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "输出文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-inst",
      "description": "实例列表",
      "required": false,
      "type": "inst+"
    },
    {
      "name": "-isoInst",
      "description": "报告隔离实例",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-module",
      "description": "模块列表",
      "required": false,
      "type": "inst|hinst+"
    },
    {
      "name": "-net",
      "description": "网络列表",
      "required": false,
      "type": "net+"
    },
    {
      "name": "-partitionHports",
      "description": "层次化引脚列表",
      "required": false,
      "type": "pin|port|hpin+"
    },
    {
      "name": "-pgNet",
      "description": "报告电源门控网络",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pin",
      "description": "引脚列表",
      "required": false,
      "type": "pin|port|hpin+"
    },
    {
      "name": "-powerDomain",
      "description": "电源域名称",
      "required": false,
      "type": "pd"
    },
    {
      "name": "-powerDomainBoundaryPort",
      "description": "端口名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-powerDomainCoverage",
      "description": "电源域覆盖范围",
      "required": false,
      "type": "string"
    },
    {
      "name": "-shifter",
      "description": "报告电平转换器",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-supplyCrossing",
      "description": "电源交叉",
      "required": false,
      "type": "string"
    },
    {
      "name": "-verbose",
      "description": "打印详细信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-voltage",
      "description": "报告域电压",
      "required": false,
      "type": "flag"
    }
  ]
}