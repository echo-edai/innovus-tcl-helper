{
  "command": "deleteRoutingHalo",
  "is_cmd": true,
  "summary": "删除布线光晕",
  "description": "该命令用于删除指定对象（如模块、单元、实例等）上的布线光晕（Routing Halo）。用户可以通过指定不同的参数来选择删除特定对象或所有对象上的光晕。",
  "usage": "deleteRoutingHalo [-help] [-lithoHalo] {-allBlocks  | -block <name> | -cell <name> | -inst <name> | -designHalo }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-lithoHalo",
      "description": "针对光刻光晕（Litho Halo）进行操作",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allBlocks",
      "description": "对所有模块（blocks）进行操作",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-block",
      "description": "指定要操作的模块名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "指定要操作的单元名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-inst",
      "description": "指定要操作的实例名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-designHalo",
      "description": "对所有分区（partitions）进行操作",
      "required": false,
      "type": "flag"
    }
  ]
