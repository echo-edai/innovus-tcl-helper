{
  "command": "scale_what_if_current",
  "is_cmd": true,
  "summary": "缩放或设置特定对象的电流值",
  "description": "该命令用于对设计中的特定对象（如网络、实例、层次结构或区域）进行电流值的缩放或直接设置。它支持全局操作或针对特定范围的操作，并可选择是否重置缩放选项或对时钟网络进行缩放。",
  "usage": "scale_what_if_current [-help] [-net <string>] [-reset] [-scale_clock_network] [-scale <string> | -current <string>] [-global | -region <string> | -hierarchy <string> | -inst_list <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-net",
      "description": "网络名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "重置缩放电流选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-scale_clock_network",
      "description": "是否缩放时钟网络",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-scale",
      "description": "缩放值",
      "required": false,
      "type": "string"
    },
    {
      "name": "-current",
      "description": "电流值，单位为毫安(mA)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-global",
      "description": "全局操作",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-region",
      "description": "区域名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-hierarchy",
      "description": "层次结构名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-inst_list",
      "description": "实例列表",
      "required": false,
      "type": "string"
    }
  ]
}