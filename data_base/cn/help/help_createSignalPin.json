{
  "command": "createSignalPin",
  "is_cmd": true,
  "summary": "创建信号引脚",
  "description": "该命令用于在设计中创建信号引脚。它允许用户通过指定实例列表（-inst）或引脚列表（-pins）来定义引脚位置。可以选择忽略悬空引脚（-ignore_floating_pins）。",
  "usage": "createSignalPin [-help] [-ignore_floating_pins] {-inst <instList> | -pins <pinLinst>}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ignore_floating_pins",
      "description": "忽略悬空引脚",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-inst",
      "description": "实例名称列表",
      "required": true,
      "type": "string list"
    },
    {
      "name": "-pins",
      "description": "引脚名称列表",
      "required": false,
      "type": "(instTerm)+"
    }
  ]
}