{
  "command": "index_collection",
  "is_cmd": true,
  "summary": "索引集合命令",
  "description": "该命令用于根据指定的索引号从基础集合中获取元素。",
  "usage": "index_collection [-help] <base_collection> <index>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<base_collection>",
      "description": "基础集合（字符串类型，必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "<index>",
      "description": "索引号（字符串类型，必需）",
      "required": true,
      "type": "string"
    }
  ]
}