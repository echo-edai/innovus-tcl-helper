{
  "command": "savePartition",
  "is_cmd": true,
  "summary": "保存分区数据",
  "description": "该命令用于保存当前设计中的分区信息。它可以将分区数据以多种格式（如DEF、Verilog、增量布局规划文件等）输出到指定目录，并支持多种选项来控制输出内容，例如是否包含标准单元、是否保存布局、是否生成网表文件等。用户可以选择保存为OpenAccess数据库格式或传统的文件格式。",
  "usage": "savePartition [-help] [<partitionName {list}>] [-fplan] [-verilog] [ [-dir <dirName>] [-module_model_tag <model tag >] [ {[-noFPlan | { [-noNetlist ] [-savePlacement ] }] [-def_netlist_for_eco | {[-def [-savePlacement ]]}] [ -defNoCutRow ] [-ptnSite ] [-topLevelNoPtnModule ] } | { { [-ptnLib <ptnLibName>] [-ptnView <ptnViewName>] [-topView <topViewName>] } } ] ] [ -def_no_std_cells ] [ -def_no_trial_route ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<partitionName {list}>",
      "description": "指定分区名称列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-def",
      "description": "输出DEF文件",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-defNoCutRow",
      "description": "不对抗布局障碍、模块光晕或电源域栅栏切割行",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-def_netlist_for_eco",
      "description": "输出包含未布局网表的DEF文件，供create_pushdown_eco命令使用",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-def_no_std_cells",
      "description": "不在DEF文件中写入标准单元",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-def_no_trial_route",
      "description": "不在DEF文件中写入试验性布线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-dir",
      "description": "指定分区文件的输出目录名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-fplan",
      "description": "输出增量布局规划文件",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-module_model_tag",
      "description": "指定要使用的模块模型标签",
      "required": false,
      "type": "string"
    },
    {
      "name": "-noFPlan",
      "description": "不生成布局规划文件",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noNetlist",
      "description": "不生成网表文件",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ptnLib",
      "description": "指定OpenAccess数据库库目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ptnSite",
      "description": "在LEF文件中输出分区的站点信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ptnView",
      "description": "指定视图名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-savePlacement",
      "description": "保存布局",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-topLevelNoPtnModule",
      "description": "在顶层分区网表中抑制分区的存根Verilog模块",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-topView",
      "description": "指定顶层设计的视图名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-verilog",
      "description": "将设计保存为非二进制Verilog文件",
      "required": false,
      "type": "flag"
    }
  ]
}