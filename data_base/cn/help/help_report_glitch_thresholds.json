{
  "command": "report_glitch_thresholds",
  "is_cmd": true,
  "summary": "报告毛刺阈值",
  "description": "此命令用于报告设计中的毛刺阈值信息。可以指定故障点、毛刺类型、实例引脚、库引脚等参数来筛选报告内容，并支持列出未标注的引脚。",
  "usage": "report_glitch_thresholds [-help] [-failure_point {input output}] [-glitch_type <string>] [-instance_pins <string>] [-library_pins <string>] [-list_unannotated_instance_pins] [-list_unannotated_library_pins] [-view <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-failure_point",
      "description": "指定阈值故障点是输入还是输出。默认值为input。",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-glitch_type",
      "description": "指定要报告的空格分隔的毛刺类型。选项包括：vl, vh, vlu, vho, all。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance_pins",
      "description": "指定实例引脚名称列表。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-library_pins",
      "description": "指定库引脚名称列表。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-list_unannotated_instance_pins",
      "description": "列出未标注的实例引脚。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-list_unannotated_library_pins",
      "description": "列出未标注的库引脚。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view",
      "description": "视图名称。",
      "required": false,
      "type": "string"
    }
  ]
}