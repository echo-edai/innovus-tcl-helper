{
  "command": "setExportMode",
  "is_cmd": true,
  "summary": "设置导出模式",
  "description": "该命令用于配置设计导出时的模式选项，包括是否输出所有引脚以及是否进行隐式端口映射等。",
  "usage": "setExportMode [-help] [-reset] [-fullPinout {true|false}] [-implicitPortMapping {true|false}]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "将所有或指定选项重置为默认值",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-fullPinout",
      "description": "输出所有引脚。",
      "required": false,
      "type": "bool"
    },
    {
      "name": "-implicitPortMapping",
      "description": "进行隐式端口映射。",
      "required": false,
      "type": "bool"
    }
  ]
}