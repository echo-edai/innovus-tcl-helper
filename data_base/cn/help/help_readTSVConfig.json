{
  "command": "readTSVConfig",
  "is_cmd": true,
  "summary": "读取TSV（硅通孔）配置文件",
  "description": "该命令用于读取与硅通孔（TSV）相关的配置文件，以支持3D-IC设计流程。它可以指定芯片名称、电源连接文件、堆叠芯片文件以及顶层网表文件。",
  "usage": "readTSVConfig [-help] [-chipName <string>] {[-stackedDieFile <string>][-powerFile <string>][-topNetlist <string>]}",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-chipName",
      "description": "当前芯片被实例化时使用的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-stackedDieFile",
      "description": "堆叠芯片文件的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-powerFile",
      "description": "电源连接文件的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-topNetlist",
      "description": "顶层网表Verilog文件的名称",
      "required": false,
      "type": "string"
    }
  ]
}