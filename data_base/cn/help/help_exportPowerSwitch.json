{
  "command": "exportPowerSwitch",
  "is_cmd": true,
  "summary": "导出电源开关信息",
  "description": "该命令用于将电源开关信息导出到指定文件。用户可以通过指定文件名和电源域来筛选导出的内容。",
  "usage": "exportPowerSwitch [-help] [-file <string>] [-powerDomain <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "指定导出信息的目标文件路径和名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-powerDomain",
      "description": "指定要导出信息的电源域",
      "required": false,
      "type": "string"
    }
  ]
}