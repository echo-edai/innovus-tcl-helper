{
  "command": "remove_gui_marker",
  "is_cmd": true,
  "summary": "移除图形界面标记",
  "description": "该命令用于移除图形用户界面（GUI）中的标记。用户可以通过指定标记的名称来移除特定标记，或者使用选项移除所有标记。",
  "usage": "remove_gui_marker [-help] {-name <string> | -all}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "移除所有标记",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "指定要移除的标记的名称",
      "required": false,
      "type": "string"
    }
  ]
}