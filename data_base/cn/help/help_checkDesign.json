{
  "command": "checkDesign",
  "is_cmd": true,
  "summary": "执行设计检查的命令",
  "description": "该命令用于检查设计的各个方面，包括网表、物理库、时序库、电源地连接、高低电平连接、布局规划、布局、SPEF文件以及赋值语句等。用户可以选择进行全面检查或指定特定模块进行检查，并支持多种输出格式和选项。",
  "usage": "checkDesign [-help] {[-all [-danglingNet [highlight]]] | [[-io ] [-netlist [-danglingNet [highlight]]] [-physicalLibrary ] [-timingLibrary ] [-powerGround ] [-tieHiLo ] [-floorplan ] [-place ] [-spef ] [-assigns ]]} [[[-noText ] [-outdir <string>] [-browser ]] | [-noHtml [-outfile <string>]]]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "检查所有项目",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-assigns",
      "description": "报告网表中的所有赋值语句，包括对1'b0/1'b1的赋值",
      "required": false,
      "type": "flag"
    },
    {
