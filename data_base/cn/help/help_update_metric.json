{
  "command": "update_metric",
  "is_cmd": true,
  "summary": "更新度量表，添加度量项或表头",
  "description": "该命令用于更新度量表，可以向表中添加新的度量项或表头。它支持多种输出格式（如HTML、Excel、文本），并可配置图表类型（如树状图、折线图或无图）、分组标题、链接行为等选项，以定制化度量报告的展示方式。",
  "usage": "update_metric [-help] [-format {html excel text}] [-graph_type {treemap line none}] [-group <string>] [-header <string>] [-link_file_metric <string>] [-link_table <string>] [-metric <string>] [-no_shared_max] [-renderer <string>] [-show_graph] -table <string> [-title <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-format",
      "description": "配置指定report_metric的输出格式",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-graph_type",
      "description": "指定在表中使用的图表类型",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-group",
      "description": "在HTML表中使用的分组标题",
      "required": false,
      "type": "string"
    },
    {
      "name": "-header",
      "description": "要添加的表头名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-link_file_metric",
      "description": "包含文件名的度量项名称，点击度量值时打开该文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-link_table",
      "description": "点击度量值时要滚动到的表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-metric",
      "description": "要添加的度量项名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-no_shared_max",
      "description": "每行单独计算Y轴最大值",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-renderer",
      "description": "强制为度量项（如直方图）使用特定的HTML格式渲染器，默认基于度量类型",
      "required": false,
      "type": "string"
    },
    {
      "name": "-show_graph",
      "description": "是否在比较图中显示此度量项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-table",
      "description": "要添加度量项的表ID",
      "required": true,
      "type": "string"
    },
    {
      "name": "-title",
      "description": "在HTML表中使用的标题",
      "required": false,
      "type": "string"
    }
  ]
}