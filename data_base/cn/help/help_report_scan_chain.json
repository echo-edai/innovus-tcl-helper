{
  "command": "report_scan_chain",
  "is_cmd": true,
  "summary": "报告扫描链信息",
  "description": "该命令用于生成并报告设计中扫描链的详细信息。用户可以通过指定扫描链名称、输出文件以及详细程度来控制报告的内容和输出位置。",
  "usage": "report_scan_chain [-help] [-chain <chain_name>] [-out_file <file_name>] [-verbose {true|false}]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-chain",
      "description": "扫描链的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-out_file",
      "description": "扫描链输出文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-verbose",
      "description": "打印更多信息",
      "required": false,
      "type": "bool"
    }
  ]
}