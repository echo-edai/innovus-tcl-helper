{
  "command": "clock_opt_design",
  "is_cmd": true,
  "summary": "时钟树优化设计命令",
  "description": "该命令用于执行时钟树优化设计。它提供了多种选项，包括检查时钟树综合（CTS）配置、仅构建时钟树、生成扩展视图、指定时序报告中的路径数量、设置输出目录和文件前缀，以及生成时序调试报告。",
  "usage": "clock_opt_design [-help] [-check_cts_config] [-cts] [-expandedViews] [-num_paths <string>] [-out_dir <string>] [-prefix <string>] [-timing_debug_report]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-check_cts_config",
      "description": "仅检查时钟树综合的先决条件，不对设计进行任何更改",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cts",
      "description": "仅构建时钟树",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-expandedViews",
      "description": "扩展视图选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-num_paths",
      "description": "指定时序报告中生成的路径数量",
      "required": false,
      "type": "string"
    },
    {
      "name": "-out_dir",
      "description": "输出目录选项",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "文件名前缀选项",
      "required": false,
      "type": "string"
    },
    {
      "name": "-timing_debug_report",
      "description": "生成时序调试报告",
      "required": false,
      "type": "flag"
    }
  ]
}