{
  "command": "unfixBondPad",
  "is_cmd": true,
  "summary": "解除绑定焊盘的固定状态",
  "description": "该命令用于解除I/O实例上指定引脚或当前选中绑定焊盘的固定状态。用户可以通过指定I/O实例名称和引脚名称，或者直接使用-selected选项来操作当前选中的焊盘。",
  "usage": "unfixBondPad [-help] {{-ioInstName <instName> [-pinName <pinName>]} | -selected }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ioInstName",
      "description": "指定I/O实例的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-pinName",
      "description": "指定引脚的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selected",
      "description": "解除当前选中绑定焊盘的固定状态",
      "required": true,
      "type": "flag"
    }
  ]
}