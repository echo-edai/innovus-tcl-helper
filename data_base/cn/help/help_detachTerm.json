{
  "command": "detachTerm",
  "is_cmd": true,
  "summary": "从指定实例的端口上分离连接",
  "description": "该命令用于将指定的端口（Term）从其当前连接的网络上分离。可以指定一个可选的网络名称（netName）进行精确操作，或者使用-moduleBased选项基于特定的Verilog模块名称进行操作。",
  "usage": "detachTerm [-help] <instName> <termName> [<netName>]\n[-moduleBased <moduleName>]",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<instName>",
      "description": "实例的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<termName>",
      "description": "端口（Term）的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<netName>",
      "description": "网络的名称（可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-moduleBased",
      "description": "指定Verilog模块的名称（可选）",
      "required": false,
      "type": "string"
    }
  ]
}