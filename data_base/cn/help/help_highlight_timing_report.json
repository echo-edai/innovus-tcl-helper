{
  "command": "highlight_timing_report",
  "is_cmd": true,
  "summary": "高亮时序报告中的路径",
  "description": "该命令用于在时序报告中高亮显示指定的路径。用户可以选择高亮特定路径或所有路径，并可自定义颜色、是否追加高亮、是否显示箭头以及将高亮结果输出到文件。",
  "usage": "highlight_timing_report [-help] [-append] [-color_index <integer>] [-file <string>] [-noarrow] {-path <string> | -all }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "高亮所有路径",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-append",
      "description": "追加到当前的高亮显示中",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-color_index",
      "description": "指定路径的颜色索引，范围为1到8",
      "required": false,
      "type": "int"
    },
    {
      "name": "-file",
      "description": "指定输出文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-noarrow",
      "description": "移除高亮的箭头",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-path",
      "description": "指定要高亮的路径编号",
      "required": true,
      "type": "string"
    }
  ]
}