{
  "command": "setModuleView",
  "is_cmd": true,
  "summary": "设置模块视图",
  "description": "该命令用于设置指定层次实例或分区的视图类型，例如将其标记为只读、接口或全部视图。",
  "usage": "setModuleView [-help] [[-topReadOnly {true false}] ] [{-hinst <string> | -partition <string>} -type {readOnly interface all} ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hinst",
      "description": "分区层次实例列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-partition",
      "description": "分区列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-topReadOnly",
      "description": "将顶层标记为只读",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-type",
      "description": "分区视图类型",
      "required": false,
      "type": "enum"
    }
  ]
}