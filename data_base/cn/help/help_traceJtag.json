{
  "command": "traceJtag",
  "is_cmd": true,
  "summary": "追踪JTAG逻辑的命令",
  "description": "该命令用于追踪JTAG逻辑。它需要一个输入文件，该文件列出了JTAG逻辑的端点，并生成一个输出文件，其中包含所有JTAG逻辑的追踪结果。",
  "usage": "traceJtag [-help] -infile <string> -outfile <string>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-infile",
      "description": "列出JTAG逻辑端点的文件",
      "required": true,
      "type": "string"
    },
    {
      "name": "-outfile",
      "description": "所有JTAG逻辑追踪的输出文件",
      "required": true,
      "type": "string"
    }
  ]
}