{
  "command": "reset_aocv_stage_weight",
  "is_cmd": true,
  "summary": "重置AOCV阶段权重",
  "description": "该命令用于重置指定端口列表的AOCV（先进片上变化）阶段权重。用户可以选择性地重置早期路径、晚期路径或两者的权重。",
  "usage": "reset_aocv_stage_weight [-help] <port_list> [-early] [-late]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<port_list>",
      "description": "输入、输出或双向端口的列表或集合",
      "required": true,
      "type": "string"
    },
    {
      "name": "-early",
      "description": "重置早期路径的权重",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-late",
      "description": "重置晚期路径的权重",
      "required": false,
      "type": "flag"
    }
  ]
}