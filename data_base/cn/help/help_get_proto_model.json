{
  "command": "get_proto_model",
  "is_cmd": true,
  "summary": "获取原型模型信息",
  "description": "该命令用于报告原型模型的属性信息。用户可以通过指定模型名称、类型匹配或来源匹配等参数来筛选和获取特定模型的详细数据，如面积、门数等，并支持以表格或TCL列表形式输出结果。",
  "usage": "get_proto_model [-help] [-committed] [-create_optimize_effort] [-exclude <string>] [-file <string>] [-flip_table] [-include_default] [-tcl] {-all | -model <string> | {[-type_match {flex_module flex_instgroup}] [-source_match {user auto}] }} [-name | [-type ] | [-create_total_area ] | [-create_gate_area ] | [-create_gate_count ] | [-create_area_per_gate ] | [-create_extra_macro ] | [-planDesign_target_util ] | [-flexfiller_route_blockage ] ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "显示所有指定模型的数据",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-committed",
      "description": "仅报告已提交模型的属性",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-create_area_per_gate",
      "description": "报告指定的每门面积值",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-create_extra_macro",
      "description": "报告指定的额外宏单元",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-create_gate_area",
      "description": "报告指定的门面积值",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-create_gate_count",
      "description": "报告指定的门数量值",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-create_optimize_effort",
      "description": "启用或禁用不同努力程度的优化",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-create_total_area",
      "description": "报告总面积值",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-exclude",
      "description": "排除指定的选项",
      "required": false,
      "type": "string"
    },
    {
      "name": "-file",
      "description": "指定输出文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-flexfiller_route_blockage",
      "description": "报告flexFiller布线阻塞的百分比",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-flip_table",
      "description": "翻转表格输出（行转列）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-include_default",
      "description": "输出默认值（在括号中）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-model",
      "description": "报告指定模型的属性",
      "required": false,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "仅报告模型名称",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-planDesign_target_util",
      "description": "报告将被planDesign使用的目标利用率值",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-source_match",
      "description": "指定报告的数据来源类型，默认为 {user auto}",
      "required": false,
      "type": "enum_list"
    },
    {
      "name": "-tcl",
      "description": "以TCL列表形式报告模型，默认为表格打印",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-type",
      "description": "报告模型类型",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-type_match",
      "description": "指定报告时的类型匹配，默认为 {flex_module}",
      "required": false,
      "type": "enum_list"
    }
  ]
}