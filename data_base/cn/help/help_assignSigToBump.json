{
  "command": "assignSigToBump",
  "is_cmd": true,
  "summary": "将信号分配至凸块",
  "description": "此命令用于将指定的网络或顶层引脚连接到特定的凸块（bump）上。用户可以通过指定网络名称或顶层引脚，以及目标凸块列表或当前选中的凸块，来完成信号到凸块的物理连接分配。",
  "usage": "assignSigToBump [-help] { {{-net <net_name> | {-top_pin <port> }} {-bumps <bump_name_list> | -selected }} }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bumps",
      "description": "指定要分配信号的凸块名称列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "指定要分配的网络名称",
      "required": false,
      "type": "net"
    },
    {
      "name": "-selected",
      "description": "将当前选中的凸块分配给指定的网络",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-top_pin",
      "description": "指定顶层引脚名称",
      "required": false,
      "type": "string"
    }
  ]
}