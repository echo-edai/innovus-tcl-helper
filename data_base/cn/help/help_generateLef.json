{
  "command": "generateLef",
  "is_cmd": true,
  "summary": "生成LEF文件",
  "description": "该命令用于生成库交换格式（LEF）文件。LEF文件包含工艺技术和单元库的物理信息，用于物理设计流程。用户可以通过指定输出文件名，并可选地提供CLF文件、输入LEF文件、LEF文件列表、技术文件等参数来控制生成过程。使用`-noWE`选项可以为无布线延伸（no wire extension）的路由生成默认通孔。",
  "usage": "generateLef [-help] <outputLefFile> [-clfFile <clffile>] [-lefFile <lefFile>] [-lefFileList <fileList>] [-noWE] [-techFile <techFile>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<outputLefFile>",
      "description": "输出的LEF文件名（必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-clfFile",
      "description": "CLF文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-lefFile",
      "description": "LEF文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-lefFileList",
      "description": "LEF文件列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-noWE",
      "description": "为无布线延伸的路由生成默认通孔",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-techFile",
      "description": "技术文件名",
      "required": false,
      "type": "string"
    }
  ]
}