{
  "command": "report_oa_lib",
  "is_cmd": true,
  "summary": "报告指定库的OA（OpenAccess）信息",
  "description": "该命令用于报告指定库的OpenAccess（OA）信息。用户可以通过指定库名称来获取相关信息，并可选地使用过滤器来筛选特定类型的数据（如cdsinfo、压缩信息、约束组、属性或技术图），也可以选择是否显示报告头信息。",
  "usage": "report_oa_lib [-help] <lib_name> [-header ] [-filter {cdsinfo | compression | constraint_groups | property | tech_graph}]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<lib_name>",
      "description": "指定要报告的库名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-header",
      "description": "显示报告头信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-filter",
      "description": "过滤报告内容，可选值包括：cdsinfo、compression、constraint_groups、property、tech_graph",
      "required": false,
      "type": "enum_list"
    }
  ]
}