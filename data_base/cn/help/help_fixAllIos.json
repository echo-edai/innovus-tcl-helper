{
  "command": "fixAllIos",
  "is_cmd": true,
  "summary": "修复所有输入/输出端口",
  "description": "该命令用于修复设计中的所有输入/输出（I/O）端口。它提供了选项来指定是仅修复单元（cell）、仅修复引脚（pin），或是包含区域I/O（areaIo）。",
  "usage": "fixAllIos [-help] [-incAreaIo] [-pinOnly | -cellOnly]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cellOnly",
      "description": "仅修复单元",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-incAreaIo",
      "description": "修复时包含区域I/O",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pinOnly",
      "description": "仅修复引脚",
      "required": false,
      "type": "flag"
    }
  ]
}