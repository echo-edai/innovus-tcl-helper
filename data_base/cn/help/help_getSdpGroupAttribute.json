{
  "command": "getSdpGroupAttribute",
  "is_cmd": true,
  "summary": "获取SDP（特殊设计规划）组的属性信息",
  "description": "该命令用于查询指定SDP（特殊设计规划）对象的各种属性，例如翻转状态、对齐方式、方向、原点位置、填充、空间模式以及类型等。用户可以通过指定SDP对象的名称来获取其相关属性信息。",
  "usage": "getSdpGroupAttribute [-help] [-flip] [-justifyBy] -name <string> [-orient] [-origin] [-padding] [-skipSpace] [-type]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-flip",
      "description": "获取SDP对象的翻转信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-justifyBy",
      "description": "获取SDP对象的对齐方式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "指定要查询的SDP对象的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-orient",
      "description": "获取SDP对象的方向信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-origin",
      "description": "获取SDP对象的位置（原点）信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-padding",
      "description": "获取顶层SDP对象的填充信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skipSpace",
      "description": "获取SDP对象中的空间模式信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-type",
      "description": "获取SDP对象的类型信息",
      "required": false,
      "type": "flag"
    }
  ]
}