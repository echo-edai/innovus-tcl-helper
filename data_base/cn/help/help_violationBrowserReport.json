{
  "command": "violationBrowserReport",
  "is_cmd": true,
  "summary": "生成并报告设计中的违规信息",
  "description": "该命令用于生成并报告设计中的各类违规信息，例如几何、连接性、密度、重叠、短路和天线效应等违规。用户可以通过多种选项来过滤和定制报告的内容、范围及输出格式。",
  "usage": "violationBrowserReport [-help] [-aclimit] [-all] [-area {x1 y1 x2 y2}] [-connectivity] [-density] [-filter <filterString>] [-filter_mode {AND|OR|NOT}] [-geometry] [-max_error_per_type <integer>] [-no_display_false] [-overlap] [-process_antenna] [-report <filename>] [-search_desc] [-short]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-aclimit",
      "description": "报告交流电（AC）限制违规",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "报告所有类型的违规",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-area",
      "description": "指定报告违规的矩形区域坐标（x1 y1 x2 y2）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-connectivity",
      "description": "报告连接性违规",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-density",
      "description": "报告金属密度违规",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-filter",
      "description": "指定一个文本字符串用于在违规信息中搜索。违规浏览器将搜索每个违规的信息，并仅显示信息匹配搜索条件的违规",
      "required": false,
      "type": "string"
    },
    {
      "name": "-filter_mode",
      "description": "指定在违规浏览器中搜索多个字符串的条件。由于AND、OR和NOT参数是互斥的，因此无法过滤复杂的表达式",
      "required": false,
      "type": "string"
    },
    {
      "name": "-geometry",
      "description": "报告几何违规",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-max_error_per_type",
      "description": "指定每种类型错误标记的数量限制",
      "required": false,
      "type": "int"
    },
    {
      "name": "-no_display_false",
      "description": "禁止EDI系统软件显示错误的违规",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-overlap",
      "description": "报告重叠违规",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-process_antenna",
      "description": "报告工艺天线效应违规",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-report",
      "description": "指定用于存储违规信息的报告文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-search_desc",
      "description": "除了表格条目外，还搜索每个标记的描述字段",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-short",
      "description": "报告短路违规",
      "required": false,
      "type": "flag"
    }
  ]
}