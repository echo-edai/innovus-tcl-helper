{
  "command": "analyze_joule_heat",
  "is_cmd": true,
  "summary": "分析焦耳热效应",
  "description": "该命令用于分析电路中的焦耳热效应。它可以根据指定的参数（如网表、域、输出目录等）计算并生成与热效应相关的详细报告和温度变化文件。用户可以通过选项控制报告的详细程度、输出文件的位置以及温度缩放限制等。",
  "usage": "analyze_joule_heat [-help] [-detail_delta_temperature_file <string>] [-detail_delta_temperature_region <string>] [-domain <string>] [-net <string>] [-output_directory <string>] [-report_conn_pin_wire <string>] [-scale_rms_limit <float>] [-tile_delta_temperature_file <string>] [-tiles <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-detail_delta_temperature_file",
      "description": "详细的温度变化文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-detail_delta_temperature_region",
      "description": "详细的温度变化区域",
      "required": false,
      "type": "string"
    },
    {
      "name": "-domain",
      "description": "域名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "网络名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output_directory",
      "description": "焦耳热输出目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-report_conn_pin_wire",
      "description": "报告连接到单元引脚的导线上的结果",
      "required": false,
      "type": "string"
    },
    {
      "name": "-scale_rms_limit",
      "description": "RMS电迁移限制缩放因子",
      "required": false,
      "type": "float"
    },
    {
      "name": "-tile_delta_temperature_file",
      "description": "图块温度变化文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tiles",
      "description": "地图图块数量 <num_x num_y>",
      "required": false,
      "type": "string"
    }
  ]
}