{
  "command": "write_ldb",
  "is_cmd": true,
  "summary": "将库转换为LDB格式",
  "description": "该命令用于将指定的库文件转换为LDB（Library Database）格式，并输出到指定的文件中。",
  "usage": "write_ldb [-help] -library <string> -outfile <string>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-library",
      "description": "要转换为LDB格式的库文件",
      "required": true,
      "type": "string"
    },
    {
      "name": "-outfile",
      "description": "输出的LDB文件",
      "required": true,
      "type": "string"
    }
  ]
}