{
  "command": "set_voltage_regulator_module",
  "is_cmd": true,
  "summary": "设置电压调节器模块",
  "description": "此命令用于配置电压调节器模块（VRM）。用户可以通过指定名称、网表文件、电源引脚映射、地引脚映射以及组件列表等参数来定义VRM。该命令还支持重置所有VRM选项。",
  "usage": "set_voltage_regulator_module [-help] {-reset  | {-name <string> -netlist <string> -input_pwr_pin_mapping <string> -output_pwr_pin_mapping <string> -ground_pin_mapping <string> -component_list <string> [-subckt_name <string>]}}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "重置所有VRM选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "VRM的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-netlist",
      "description": "VRM的SPICE网表文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-input_pwr_pin_mapping",
      "description": "输入电源引脚映射，格式为{spice_pin_name [DEF_net_name]}+",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output_pwr_pin_mapping",
      "description": "输出电源引脚映射，格式为{spice_pin_name [DEF_net_name]}+",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ground_pin_mapping",
      "description": "地引脚映射，格式为{spice_pin_name [DEF_net_name]}+",
      "required": false,
      "type": "string"
    },
    {
      "name": "-component_list",
      "description": "VRM组件列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-subckt_name",
      "description": "VRM子电路名称",
      "required": false,
      "type": "string"
    }
  ]
}