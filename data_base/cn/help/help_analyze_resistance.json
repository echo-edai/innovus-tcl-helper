{
  "command": "analyze_resistance",
  "is_cmd": true,
  "summary": "分析电阻",
  "description": "该命令用于分析电路中的电阻特性。它允许用户指定特定的单元、实例、网络、节点或区域进行分析，并可以设置各种阈值和过滤条件。用户可以选择性地强制重新提取数据，并控制输出报告的格式和内容。",
  "usage": "analyze_resistance [-help] [-cell <string>] [-die_mode {3dic}] [-domain <string>] [-domain_threshold <float>] [-exclude_list_file <string>] [-force_reextraction {true false}] [-instance_list {string1 string2 ...}] [-instance_list_file <string>] [-instance_pair_list {string1 string2 ...}] [-instance_pair_list_file <string>] [-net <string>] [-net_threshold {string1 string2 ...}] [-node_list {string1 string2 ...}] [-node_list_file <string>] [-node_pair_list {string1 string2 ...}] [-node_pair_list_file <string>] [-output <string>] [-output_dir <string>] [-print_cell_name] [-region <string>] [-report_limit <integer>] [-threshold <float>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "主单元名称或名称列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-die_mode",
      "description": "芯片模型",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-domain",
      "description": "域名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-domain_threshold",
      "description": "域阈值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-exclude_list_file",
      "description": "排除单元/实例的文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-force_reextraction",
      "description": "强制重新提取",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-instance_list",
      "description": "实例列表",
      "required": false,
      "type": "list"
    },
    {
      "name": "-instance_list_file",
      "description": "实例列表文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance_pair_list",
      "description": "实例对列表",
      "required": false,
      "type": "list"
    },
    {
      "name": "-instance_pair_list_file",
      "description": "实例对列表文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "网络名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net_threshold",
      "description": "网络阈值",
      "required": false,
      "type": "list"
    },
    {
      "name": "-node_list",
      "description": "节点列表",
      "required": false,
      "type": "list"
    },
    {
      "name": "-node_list_file",
      "description": "节点列表文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-node_pair_list",
      "description": "节点对列表",
      "required": false,
      "type": "list"
    },
    {
      "name": "-node_pair_list_file",
      "description": "节点列表文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output",
      "description": "输出文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output_dir",
      "description": "输出目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-print_cell_name",
      "description": "在有效电阻报告中打印单元名称",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-region",
      "description": "分析区域",
      "required": false,
      "type": "string"
    },
    {
      "name": "-report_limit",
      "description": "限制报告的有效电阻数量",
      "required": false,
      "type": "int"
    },
    {
      "name": "-threshold",
      "description": "阈值",
      "required": false,
      "type": "float"
    }
  ]
}