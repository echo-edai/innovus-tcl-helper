{
  "command": "summaryReport",
  "is_cmd": true,
  "summary": "生成设计总结报告",
  "description": "该命令用于生成设计的总结报告，支持以文本和/或HTML格式输出。用户可以通过指定输出目录、文件名以及排除特定单元或实例前缀来控制报告的内容和格式。",
  "usage": "summaryReport [-help] [-outdir <string>] [-noText  | -noHtml ] [-outfile <string> | -noText ] [-noHtml  | -browser ] [-exclude_base_cell_for_density <libCell/ptnCell>+ | -exclude_inst_prefix <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-browser",
      "description": "在浏览器中显示结果",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-exclude_base_cell_for_density",
      "description": "指定要从密度报告中排除的单元列表",
      "required": false,
      "type": "libCell/ptnCell+"
    },
    {
      "name": "-exclude_inst_prefix",
      "description": "指定要从密度报告中排除的实例名称前缀列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-noHtml",
      "description": "不生成HTML格式报告",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noText",
      "description": "不生成文本格式报告",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-outdir",
      "description": "输出目录名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-outfile",
      "description": "输出文件名称",
      "required": false,
      "type": "string"
    }
  ]
}