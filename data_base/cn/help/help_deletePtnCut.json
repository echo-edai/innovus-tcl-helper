{
  "command": "deletePtnCut",
  "is_cmd": true,
  "summary": "删除分区切割",
  "description": "该命令用于删除指定的分区切割。可以通过指定单个分区名称、分区名称列表或使用-all选项来删除所有分区切割。",
  "usage": "deletePtnCut [-help] { -ptn {ptnName | ptnNameList} | -all  }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "指定删除所有分区",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ptn",
      "description": "指定要删除的分区名称或分区名称列表",
      "required": false,
      "type": "string"
    }
  ]
}