{
  "command": "reportSpecialRoute",
  "is_cmd": true,
  "summary": "报告特殊布线信息",
  "description": "该命令用于生成关于特殊布线的报告，包括线长、过孔、线段的详细信息，并支持针对中介层（interposer）的布线、非默认规则（NDR）检查以及屏蔽比等特定分析。用户可以通过多种选项筛选和定制报告内容。",
  "usage": "reportSpecialRoute [-help] [<reportName>] [-center_line] [-net <netName>] [-interposer_shielding_ratio [-exclude_nets <netName>]] [-interposer_ndr_check [-exclude_nets <netName>]] [-interposer_route [-exclude_nets <netName>]] [-interposer_route [[-interposer_route_constraint_file <ircFileName>] [-interposer_layers <layerName>]]] [[ [-summary ] [-wirelength ] [-wire_segment ] [-selected ] [-highlight45layer <layerName>] [-lengththreshold <value>] [-resfile <resFileName>] [-by_layer ]] | [-interposer_route ] | [-interposer_ndr_check ] | [-interposer_shielding_ratio ]]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<reportName>",
      "description": "指定报告文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-by_layer",
      "description": "按层报告",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-center_line",
      "description": "按中心线计算布线长度",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-exclude_nets",
      "description": "指定要排除的网络名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-highlight45layer",
      "description": "指定用于高亮显示45度布线的层",
      "required": false,
      "type": "string"
    },
    {
      "name": "-interposer_layers",
      "description": "指定中介层",
      "required": false,
      "type": "string"
    },
    {
      "name": "-interposer_ndr_check",
      "description": "进行中介层布线的非默认规则和缺失屏蔽检查",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-interposer_route",
      "description": "报告中介层布线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-interposer_route_constraint_file",
      "description": "指定中介层布线约束文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-interposer_shielding_ratio",
      "description": "报告中介层屏蔽比",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-lengththreshold",
      "description": "指定长度阈值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-net",
      "description": "指定网络名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-resfile",
      "description": "指定电阻文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selected",
      "description": "报告SPECIALNET中选中线段的长度",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-summary",
      "description": "汇总特殊网络的线长和过孔信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-wire_segment",
      "description": "报告每个SPECIALNET的线段信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-wirelength",
      "description": "报告线长",
      "required": false,
      "type": "flag"
    }
  ]
}