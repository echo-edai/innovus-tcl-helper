{
  "command": "set_annotated_glitch",
  "is_cmd": true,
  "summary": "设置标注的毛刺",
  "description": "此命令用于在指定的端口上应用VH、VHO、VL、VLU等类型的毛刺波形点。用户可以通过指定端口名、视图名以及各类毛刺波形点列表来配置毛刺标注。",
  "usage": "set_annotated_glitch [-help] [-port <string>] [-vh_glitch <string>] [-vho_glitch <string>] [-view <string>] [-vl_glitch <string>] [-vlu_glitch <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-port",
      "description": "需要应用毛刺的端口名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-vh_glitch",
      "description": "VH毛刺波形点列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-vho_glitch",
      "description": "VHO毛刺波形点列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "视图名称列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-vl_glitch",
      "description": "VL毛刺波形点列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-vlu_glitch",
      "description": "VLU毛刺波形点列表",
      "required": false,
      "type": "string"
    }
  ]
}