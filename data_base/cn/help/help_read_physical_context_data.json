{
  "command": "read_physical_context_data",
  "is_cmd": true,
  "summary": "读取物理上下文数据",
  "description": "该命令用于从指定的输入文件中读取物理上下文数据。用户可以选择在读取前清除现有的物理上下文数据，并可指定技术名称。",
  "usage": "read_physical_context_data [-help] <files> [-clear] [-type <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<files>",
      "description": "输入文件的名称（必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-clear",
      "description": "在读取前清除物理上下文数据",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-type",
      "description": "技术名称",
      "required": false,
      "type": "string"
    }
  ]
}