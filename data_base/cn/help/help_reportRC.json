{
  "command": "reportRC",
  "is_cmd": true,
  "summary": "报告RC（电阻电容）信息",
  "description": "该命令用于生成电阻电容（RC）信息的报告。用户可以指定输出文件名、目标实例、相关层以及计算二阶RC的最大距离等参数。",
  "usage": "reportRC [-help] <<fileName>> [-inst <string>] -layer <string> [-max_second_rc <float>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<<fileName>>",
      "description": "指定报告文件的名称（必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-inst",
      "description": "指定要报告的实例",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer",
      "description": "指定用于计算障碍物（obs）的层",
      "required": true,
      "type": "string"
    },
    {
      "name": "-max_second_rc",
      "description": "指定计算二阶RC的最大距离，默认值为2",
      "required": false,
      "type": "float"
    }
  ]
}