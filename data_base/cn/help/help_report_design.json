{
  "command": "report_design",
  "is_cmd": true,
  "summary": "报告设计信息，包括操作条件等",
  "description": "该命令用于报告当前设计的信息，特别是与操作条件相关的细节。用户可以选择报告最小（-early）或最大（-late）操作条件，指定特定的视图（-view），将输出重定向到文件（> 或 >>），或以Tcl列表格式（-tcl_list）输出结果。",
  "usage": "report_design [-help] [-view <view_name>] [-early  | -late ] [ [ > | >> ] | [ -tcl_list  ] ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-early",
      "description": "报告最小操作条件（在'bcwc'或'onChipVariation'分析模式下）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-late",
      "description": "报告最大操作条件",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-tcl_list",
      "description": "以Tcl列表格式输出结果",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view",
      "description": "报告指定视图的操作条件",
      "required": false,
      "type": "string"
    },
    {
      "name": ">",
      "description": "将输出重定向到文件（覆盖模式）",
      "required": false,
      "type": "redirect_operator"
    },
    {
      "name": ">>",
      "description": "将输出重定向到文件（追加模式）",
      "required": false,
      "type": "redirect_operator"
    }
  ]
}