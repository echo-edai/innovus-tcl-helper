{
  "command": "saveColorPreference",
  "is_cmd": true,
  "summary": "保存颜色偏好设置",
  "description": "该命令用于将当前的颜色偏好设置保存到指定文件中，以便后续加载或共享。可以指定保存目录、是否包含自定义选项卡设置以及输出文件名。",
  "usage": "saveColorPreference [-help] [-dir <string>] [-include_customized] -name <string>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-dir",
      "description": "指定保存目录路径，默认为当前文件夹",
      "required": false,
      "type": "string"
    },
    {
      "name": "-include_customized",
      "description": "包含自定义选项卡的设置",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "指定保存的文件名",
      "required": true,
      "type": "string"
    }
  ]
}