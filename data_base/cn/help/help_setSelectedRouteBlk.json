{
  "command": "setSelectedRouteBlk",
  "is_cmd": true,
  "summary": "设置选定的布线阻塞区域",
  "description": "该命令用于在指定的边界框内创建一个布线阻塞区域。用户可以定义区域的坐标、名称、影响的层或通孔，并可选择性地设置阻塞属性和间距规则。",
  "usage": "setSelectedRouteBlk [-help] <llx> <lly> <urx> <ury> <name> <layers> [<attr>] [<spacing>]",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<llx>",
      "description": "边界框左下角的x坐标",
      "required": true,
      "type": "float"
    },
    {
      "name": "<lly>",
      "description": "边界框左下角的y坐标",
      "required": true,
      "type": "float"
    },
    {
      "name": "<urx>",
      "description": "边界框右上角的x坐标",
      "required": true,
      "type": "float"
    },
    {
      "name": "<ury>",
      "description": "边界框右上角的y坐标",
      "required": true,
      "type": "float"
    },
    {
      "name": "<name>",
      "description": "布线阻塞区域的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<layers>",
      "description": "受影响的布线层和/或通孔",
      "required": true,
      "type": "string"
    },
    {
      "name": "<attr>",
      "description": "布线阻塞的属性，可选值包括：Undefined, Fills, Slots, Partial Pushdown, EXCEPTPGNET, PGNETONLY, ALLNET",
      "required": false,
      "type": "string"
    },
    {
      "name": "<spacing>",
      "description": "布线阻塞区域内层间的最小间距或有效宽度，格式为 -spacing 或 -designRuleWidth",
      "required": false,
      "type": "string"
    }
  ]
}