{
  "command": "reportFanoutViolation",
  "is_cmd": true,
  "summary": "报告扇出违规",
  "description": "该命令用于生成设计中违反扇出约束的报告。扇出是指一个驱动单元（如逻辑门）所驱动的负载单元数量。违反扇出约束可能影响时序和信号完整性。命令提供多种选项，允许用户指定报告的范围（如最大或最小约束）、排除或选择特定网络、设置输出文件以及控制报告的精度等。",
  "usage": "reportFanoutViolation [-help] [-excNetFile <fileName>] [-max] [-min] [-outfile <fileName>] [-selNetFile <fileName>] [-significant_digits <integer>] [-useDrcMargin] [-all  | -noGlobalNets ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "报告所有选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-excNetFile",
      "description": "不报告的网络列表文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-max",
      "description": "最大约束选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-min",
      "description": "最小约束选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noGlobalNets",
      "description": "不报告全局网络选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-outfile",
      "description": "输出文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selNetFile",
      "description": "要报告的网络列表文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-significant_digits",
      "description": "有效数字位数选项",
      "required": false,
      "type": "int"
    },
    {
      "name": "-useDrcMargin",
      "description": "使用DRC裕度选项",
      "required": false,
      "type": "flag"
    }
  ]
}