{
  "command": "unlockOaDesign",
  "is_cmd": true,
  "summary": "解锁指定的OA设计数据库文件",
  "description": "该命令用于解锁一个指定的OpenAccess（OA）设计数据库文件。在团队协作或某些异常锁定情况下，设计文件可能被锁定以防止并发写入。使用此命令可以解除对特定库（lib）、单元（cell）和视图（view）组合的锁定状态，使其可被编辑。",
  "usage": "unlockOaDesign [-help] <lib> <cell> <view>",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<lib>",
      "description": "库名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<cell>",
      "description": "单元名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<view>",
      "description": "视图名称",
      "required": true,
      "type": "string"
    }
  ]
}