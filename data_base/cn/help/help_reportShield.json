{
  "command": "reportShield",
  "is_cmd": true,
  "summary": "报告屏蔽信息",
  "description": "该命令用于生成关于屏蔽（shield）的报告，可以指定输出文件、包含的层、是否仅针对选定的网络、是否包含crosstie和tap_cells等详细信息，并提供详细输出模式。",
  "usage": "reportShield [-help] [-crosstie] [-include_layer] [-out_file <filename>] [-selected] [-tap_cells] [-verbose]",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-crosstie",
      "description": "包含crosstie信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-include_layer",
      "description": "包含层信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-out_file",
      "description": "指定输出报告的文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selected",
      "description": "仅报告选定网络（nets）的屏蔽信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-tap_cells",
      "description": "包含tap_cells信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-verbose",
      "description": "启用详细输出模式",
      "required": false,
      "type": "flag"
    }
  ]
}