{
  "command": "route_opt_design",
  "is_cmd": true,
  "summary": "布线后优化设计命令",
  "description": "该命令用于执行布线后的设计优化，可以针对时序（建立时间、保持时间）、设计规则违例（DRV）进行修复，也可以仅执行布线或优化操作。用户可以通过参数控制优化的类型、生成报告的数量和存放位置等。",
  "usage": "route_opt_design [-help] [-drv] [-hold] [-ideal_clock] [-incremental] [-num_paths <string>] [-opt] [-out_dir <string>] [-prefix <string>] [-route] [-setup] [-timing_debug_report]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-drv",
      "description": "仅修复设计规则违例",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hold",
      "description": "修复保持时间违例",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ideal_clock",
      "description": "理想时钟选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-incremental",
      "description": "进行布线后增量优化",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-num_paths",
      "description": "指定时序报告中生成的时序路径数量",
      "required": false,
      "type": "string"
    },
    {
      "name": "-opt",
      "description": "仅执行布线后优化",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-out_dir",
      "description": "指定报告的输出目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "指定报告文件名的前缀",
      "required": false,
      "type": "string"
    },
    {
      "name": "-route",
      "description": "仅执行布线操作",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-setup",
      "description": "修复建立时间违例和设计规则违例",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-timing_debug_report",
      "description": "生成机器可读的时序报告",
      "required": false,
      "type": "flag"
    }
  ]
}