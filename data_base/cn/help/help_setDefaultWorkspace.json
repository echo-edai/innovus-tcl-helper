{
  "command": "setDefaultWorkspace",
  "is_cmd": true,
  "summary": "设置默认工作空间",
  "description": "该命令用于设置默认的工作空间，可以指定工作空间的名称和可选的目录路径。",
  "usage": "setDefaultWorkspace [-help] [-dir <string>] -name <string>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-dir",
      "description": "指定目录路径（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "指定工作空间名称（字符串，必需）",
      "required": true,
      "type": "string"
    }
  ]
}