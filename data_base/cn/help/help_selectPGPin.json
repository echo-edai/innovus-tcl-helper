{
  "command": "selectPGPin",
  "is_cmd": true,
  "summary": "选择电源地引脚",
  "description": "该命令用于在指定区域、层或网络上选择电源地（PG）引脚。用户可以通过坐标区域、层名称或网络名称来筛选需要选择的引脚。",
  "usage": "selectPGPin [-help] [-all] [-area {x1 y1 x2 y2}] [-layer <layer> | {list_of_layer}] [-net <name>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "指定是否选择所有PG引脚",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-area",
      "description": "指定区域的坐标",
      "required": false,
      "type": "box"
    },
    {
      "name": "-layer",
      "description": "指定层",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "指定网络名称",
      "required": false,
      "type": "net+"
    }
  ]
}