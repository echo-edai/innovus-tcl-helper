  "usage": "get_via_pillars [-help] [-required] { -term <term|term> | -instterm <instTerm|pgInstTerm> }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-instterm",
      "description": "实例终端名称或指针",
      "required": true,
      "type": "instTerm|pgInstTerm"
    },
    {
      "name": "-required",
      "description": "返回所需标志（布尔值，可选）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-term",
      "description": "终端（单元名称/终端基础名称）名称或指针",
      "required": true,
      "type": "term|term"
    }
  ]
}