{
  "command": "addSpareInstance",
  "is_cmd": true,
  "summary": "添加备用单元实例",
  "description": "此命令用于在指定模块或电源域中添加备用单元实例。可以通过文件指定单元名称和数量，并支持配置时钟、异步信号、前缀、绑定网络等参数。可以选择是否固定已放置的实例位置以寻找新备用实例的放置位置。",
  "usage": "addSpareInstance [-help] [-async <netName>] [-clock <netName>] -file <fname> [-fix_placed_insts {TRUE|FALSE}] [-prefix <prefix>] [-tie <0|1>] [-hier <module> | -powerDomain <domain> [-submodule <name>]]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-async",
      "description": "异步网络信息",
      "required": false,
      "type": "string"
    },
    {
      "name": "-clock",
      "description": "时钟网络名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-file",
      "description": "包含单元名称和数量的文件",
      "required": true,
      "type": "string"
    },
    {
      "name": "-fix_placed_insts",
      "description": "不移动现有已放置的实例来为新备用实例寻找位置",
      "required": false,
      "type": "bool"
    },
    {
      "name": "-prefix",
      "description": "备用实例的前缀",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tie",
      "description": "备用实例的绑定网络",
      "required": false,
      "type": "int"
    },
    {
      "name": "-hier",
      "description": "要添加备用实例的模块",
      "required": false,
      "type": "string"
    },
    {
      "name": "-powerDomain",
      "description": "要添加备用实例的电源域",
      "required": false,
      "type": "string"
    },
    {
      "name": "-submodule",
      "description": "为备用实例创建的模块",
      "required": false,
      "type": "string"
    }
  ]
}