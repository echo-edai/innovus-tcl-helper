{
  "command": "trace_obj_connectivity",
  "is_cmd": true,
  "summary": "追踪对象连接性",
  "description": "该命令用于追踪设计中对象（如宏单元、IO端口）的连接性。它可以根据指定的模式（基于网表或基于时序）和追踪级别，分析并输出连接关系。用户可以选择追踪特定的实例、端口或已选中的对象，并可以将追踪结果保存到文件或从文件加载先前的结果。",
  "usage": "trace_obj_connectivity [-help] [-clear_trace] [-level <integer>] [-mode {netlist_based timing_based}] [-out_file <string>] [-insts <string>] | [-ports <string>] | [-selected ] | [-in_files <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clear_trace",
      "description": "清除现有的追踪结果",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-in_files",
      "description": "加载已保存的追踪结果文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-insts",
      "description": "指定要追踪的宏单元",
      "required": false,
      "type": "string"
    },
    {
      "name": "-level",
      "description": "指定追踪级别，默认值为1",
      "required": false,
      "type": "int"
    },
    {
      "name": "-mode",
      "description": "指定追踪模式：基于网表或基于时序",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-out_file",
      "description": "将追踪结果保存到指定文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ports",
      "description": "指定要追踪的IO端口",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selected",
      "description": "追踪已选中的宏单元或IO端口",
      "required": false,
      "type": "flag"
    }
  ]
}