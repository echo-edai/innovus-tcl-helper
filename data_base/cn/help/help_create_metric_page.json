{
  "command": "create_metric_page",
  "is_cmd": true,
  "summary": "创建一个新的指标页面",
  "description": "该命令用于创建一个新的指标页面，可用于配置报告指标的格式，并指定页面在序列中的插入位置。",
  "usage": "create_metric_page [-help] [-after <string>] [-before <string>] [-format {html excel text}] -name <string>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-after",
      "description": "在此名称的页面之后插入新页面",
      "required": false,
      "type": "string"
    },
    {
      "name": "-before",
      "description": "在此名称的页面之前插入新页面",
      "required": false,
      "type": "string"
    },
    {
      "name": "-format",
      "description": "为指定的报告指标配置输出格式",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-name",
      "description": "页面的名称",
      "required": true,
      "type": "string"
    }
  ]
}