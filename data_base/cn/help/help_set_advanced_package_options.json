{
  "command": "set_advanced_package_options",
  "is_cmd": true,
  "summary": "设置高级封装选项",
  "description": "该命令用于配置高级封装相关的选项，包括指定封装分析工具的路径和网络映射文件，或重置所有设置。",
  "usage": "set_advanced_package_options [-help] -reset | {[-tool_path <string>] [{-net_mapping_file <string> }] }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-net_mapping_file",
      "description": "指定网络映射文件，格式为两列（def_name pkg_name）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "清除所有设置",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-tool_path",
      "description": "指定封装分析工具的二进制文件夹路径",
      "required": false,
      "type": "string"
    }
  ]
}