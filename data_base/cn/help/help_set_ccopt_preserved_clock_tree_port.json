{
  "command": "set_ccopt_preserved_clock_tree_port",
  "is_cmd": true,
  "summary": "设置CCopt保留的时钟树端口",
  "description": "该命令用于指定在时钟树综合（CCopt）过程中需要保留的时钟树端口。可以指定端口名称及其物理位置，以确保这些端口在优化过程中不被修改或移除。",
  "usage": "set_ccopt_preserved_clock_tree_port [-help] {[<portname> [-location {x y}]]}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<portname>",
      "description": "端口名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-location",
      "description": "端口的物理位置坐标",
      "required": false,
      "type": "point"
    }
  ]
}