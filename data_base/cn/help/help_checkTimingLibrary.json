{
  "command": "checkTimingLibrary",
  "is_cmd": true,
  "summary": "检查时序库的命令",
  "description": "该命令用于检查指定的时序库，可以验证库中的单元定义，特别是电源相关构造（如内部功耗、泄漏功耗）的完整性。",
  "usage": "checkTimingLibrary [-help] [-cellname <string>] [-checkpower] [-library <string>] [-outfile <string>] [-reportMissingPowerOnly]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cellname",
      "description": "指定要检查的单元名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-checkpower",
      "description": "检查单元是否定义了电源构造，如内部功耗、泄漏功耗或ECSM功耗",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-library",
      "description": "指定要检查的库名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-outfile",
      "description": "指定输出文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reportMissingPowerOnly",
      "description": "仅报告未定义内部功耗（引脚级）或泄漏功耗的单元",
      "required": false,
      "type": "flag"
    }
  ]
}