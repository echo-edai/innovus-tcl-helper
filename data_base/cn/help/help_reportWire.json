{
  "command": "reportWire",
  "is_cmd": true,
  "summary": "报告布线信息",
  "description": "该命令用于生成布线报告，可以指定输出文件、阈值、详细程度、最大扇出、最小线长、排序方式以及是否仅生成摘要报告。",
  "usage": "reportWire [-help] [<<fileName>] [<<threshold>>] [-detail] [-maxFanout <integer>] [-minWireLength <float>] [-sort {ratio wire_length half_perimeter}] [-summary]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<<fileName>",
      "description": "报告文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "<<threshold>>",
      "description": "阈值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-detail",
      "description": "包含详细信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-maxFanout",
      "description": "指定网络的最大扇出数",
      "required": false,
      "type": "int"
    },
    {
      "name": "-minWireLength",
      "description": "指定网络的最小线长",
      "required": false,
      "type": "float"
    },
    {
      "name": "-sort",
      "description": "指定报告中网络的排序方式",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-summary",
      "description": "仅包含摘要报告",
      "required": false,
      "type": "flag"
    }
  ]
}