{
  "command": "uiSet",
  "is_cmd": true,
  "summary": "设置用户界面组件的属性",
  "description": "该命令用于创建或修改图形用户界面(GUI)中的小部件(widget)属性，例如窗口、按钮、菜单项等。可以指定其名称、标签、命令、状态、可见性、几何布局等多种参数，以定制界面元素的行为和外观。",
  "usage": "uiSet [-help] <name> [-before <name>] [-checked <true|false>] [-command <string>] [-disabled <true|false>] [-enablevar <string>] [-foreground <string>] [-icon <file>] [-in <name>] [-label <string>] [-menuseparate <true|false>] [-message <string>] [-movable <true|false>] [-newline <true|false>] [-shortcut <string>] [-statusbar <string>] [-title <string>] [-tooltip <string>] [-underline <integer>] [-value <string>] [-variable <string>] [-visible <true|false>] [-visiblevar <string>] [-geometry <string> | -fullscreen <true|false>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<name>",
      "description": "小部件名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-before",
      "description": "下一个同级小部件名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-checked",
      "description": "复选框和单选按钮的开关状态",
      "required": false,
      "type": "bool"
    },
    {
      "name": "-command",
      "description": "Tcl命令",
      "required": false,
      "type": "string"
    },
    {
      "name": "-disabled",
      "description": "小部件状态（是否禁用）",
      "required": false,
      "type": "bool"
    },
    {
      "name": "-enablevar",
      "description": "用于控制启用状态的Tcl全局变量",
      "required": false,
      "type": "string"
    },
    {
      "name": "-foreground",
      "description": "图标前景颜色",
      "required": false,
      "type": "string"
    },
    {
      "name": "-fullscreen",
      "description": "全屏模式",
      "required": false,
      "type": "bool"
    },
    {
      "name": "-geometry",
      "description": "窗口几何布局",
      "required": false,
      "type": "string"
    },
    {
      "name": "-icon",
      "description": "图标文件名",
      "required": false,
      "type": "file"
    },
    {
      "name": "-in",
      "description": "父小部件名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-label",
      "description": "小部件标签",
      "required": false,
      "type": "string"
    },
    {
      "name": "-menuseparate",
      "description": "菜单分离状态",
      "required": false,
      "type": "bool"
    },
    {
      "name": "-message",
      "description": "状态栏上显示的消息",
      "required": false,
      "type": "string"
    },
    {
      "name": "-movable",
      "description": "是否可移动",
      "required": false,
      "type": "bool"
    },
    {
      "name": "-newline",
      "description": "是否从新行开始",
      "required": false,
      "type": "bool"
    },
    {
      "name": "-shortcut",
      "description": "快捷键",
      "required": false,
      "type": "string"
    },
    {
      "name": "-statusbar",
      "description": "窗口中的状态栏",
      "required": false,
      "type": "string"
    },
    {
      "name": "-title",
      "description": "窗口标题",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tooltip",
      "description": "工具提示",
      "required": false,
      "type": "string"
    },
    {
      "name": "-underline",
      "description": "用于下划线的字符索引",
      "required": false,
      "type": "int"
    },
    {
      "name": "-value",
      "description": "小部件的值",
      "required": false,
      "type": "string"
    },
    {
      "name": "-variable",
      "description": "Tcl全局变量",
      "required": false,
      "type": "string"
    },
    {
      "name": "-visible",
      "description": "可见状态",
      "required": false,
      "type": "bool"
    },
    {
      "name": "-visiblevar",
      "description": "用于控制可见状态的Tcl全局变量",
      "required": false,
      "type": "string"
    }
  ]
}