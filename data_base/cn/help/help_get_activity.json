{
  "command": "get_activity",
  "is_cmd": true,
  "summary": "获取设计中的活动信息",
  "description": "该命令用于获取设计中实例、网络、引脚或端口的活动信息，例如开关活动性。它可以基于驱动或活动信息来源生成网络列表，并支持生成平均开关活动报告、单元组活动摘要报告等多种输出格式。",
  "usage": "get_activity [-help] [-instance <string>] [-list_of_nets_based_on_driver <string>] [-list_of_nets_based_on_source_of_activity_info <string>] [-net <string>] [-outfile <string>] [-pin <string>] [-port <string>] [-report_average_switching_activity] [-report_cell_group_activity_summary_report] [-summary] [-tcl_list]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-instance",
      "description": "实例名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-list_of_nets_based_on_driver",
      "description": "基于驱动生成的网络列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-list_of_nets_based_on_source_of_activity_info",
      "description": "基于活动信息来源生成的网络列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "用于获取活动来源的网络列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-outfile",
      "description": "输出文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pin",
      "description": "用于获取活动来源的引脚列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-port",
      "description": "用于获取活动来源的端口列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-report_average_switching_activity",
      "description": "报告平均开关活动",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-report_cell_group_activity_summary_report",
      "description": "生成单元组活动的摘要报告",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-summary",
      "description": "开启类型摘要",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-tcl_list",
      "description": "返回Tcl列表",
      "required": false,
      "type": "flag"
    }
  ]
}