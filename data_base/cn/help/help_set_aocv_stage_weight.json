{
  "command": "set_aocv_stage_weight",
  "is_cmd": true,
  "summary": "设置AOCV（高级片上变化）阶段权重",
  "description": "此命令用于为指定的端口列表设置AOCV阶段权重值。阶段权重是一个浮点数，用于在时序分析中调整特定路径的延迟计算，以更精确地建模工艺变化的影响。用户可以为早期路径、晚期路径以及输入或输出端口分别指定权重。",
  "usage": "set_aocv_stage_weight [-help] <stage_weight> <port_list> [-early] [-input] [-late] [-output]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<stage_weight>",
      "description": "阶段权重的值（浮点数）",
      "required": true,
      "type": "float"
    },
    {
      "name": "<port_list>",
      "description": "输入、输出或双向端口的列表或集合",
      "required": true,
      "type": "string"
    },
    {
      "name": "-early",
      "description": "为早期路径指定权重",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-input",
      "description": "为输入端口指定权重",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-late",
      "description": "为晚期路径指定权重",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-output",
      "description": "为输出端口指定权重",
      "required": false,
      "type": "flag"
    }
  ]
}