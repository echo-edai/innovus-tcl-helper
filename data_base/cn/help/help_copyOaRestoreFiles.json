{
  "command": "copyOaRestoreFiles",
  "is_cmd": true,
  "summary": "复制OA恢复文件",
  "description": "该命令用于将指定的源库、单元和视图中的OA恢复文件复制到目标库、单元和视图中。",
  "usage": "copyOaRestoreFiles [-help] <fromLib> <fromCell> <fromView> <toLib> <toCell> <toView>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<fromLib>",
      "description": "指定源库名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<fromCell>",
      "description": "指定源单元名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<fromView>",
      "description": "指定源视图名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<toLib>",
      "description": "指定目标库名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<toCell>",
      "description": "指定目标单元名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<toView>",
      "description": "指定目标视图名称",
      "required": true,
      "type": "string"
    }
  ]
}