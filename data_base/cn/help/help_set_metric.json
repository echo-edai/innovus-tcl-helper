{
  "command": "set_metric",
  "is_cmd": true,
  "summary": "设置已定义度量的值",
  "description": "此命令用于将任何已定义的度量（metric）设置为指定的值。用户需要提供度量的名称和要设置的具体数值。",
  "usage": "set_metric -name <metric_name> -value <metric_value>",
  "options": [
    {
      "name": "-name",
      "description": "指定度量的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-help",
      "description": "输出包含每个参数类型和默认信息的简要描述。如需命令及其所有参数的详细描述，请使用 man 命令：man set_metric",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-value",
      "description": "指定度量的值",
      "required": true,
      "type": "string"
    }
  ]
}