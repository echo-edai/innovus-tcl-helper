      "required": false,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "指定表头的名称。",
      "required": true,
      "type": "string"
    },
    {
      "name": "-value",
      "description": "指定表头的值。",
      "required": true,
      "type": "string"
    },
    {
      "name": "-help",
      "description": "输出包含每个参数类型和默认信息的简要描述。",
      "required": false,
      "type": "flag"
    }
  ]
}