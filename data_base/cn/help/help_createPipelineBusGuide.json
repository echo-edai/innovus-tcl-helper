{
  "command": "createPipelineBusGuide",
  "is_cmd": true,
  "summary": "创建流水线总线引导线",
  "description": "该命令用于为指定的网络组创建流水线总线引导线。用户可以通过指定层、网络组名称、宽度因子、间距等参数来定制引导线的生成，并可选择生成分析报告。",
  "usage": "createPipelineBusGuide [-help] [-layer <id1:id2>] [-netGroup <netGroupNames>] [-widthFactor <val>] [-spacing <val> [-report <fileName>]]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-layer",
      "description": "引导线所在的层，格式为 id1:id2",
      "required": false,
      "type": "string"
    },
    {
      "name": "-netGroup",
      "description": "网络组的名称（一个或多个）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-widthFactor",
      "description": "引导线的宽度因子",
      "required": false,
      "type": "float"
    },
    {
      "name": "-spacing",
      "description": "触发器之间的最大间距",
      "required": false,
      "type": "float"
    },
    {
      "name": "-report",
      "description": "分析报告的文件名",
      "required": false,
      "type": "string"
    }
  ]
}