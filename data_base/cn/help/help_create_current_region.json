{
  "command": "create_current_region",
  "is_cmd": true,
  "summary": "创建一个电流区域",
  "description": "该命令用于在指定的区域或实例上创建一个电流区域，可以定义静态或动态电流、串联电阻、电容等参数。它允许用户为电源完整性分析（如IR Drop和电迁移分析）建模电流源或电流负载。",
  "usage": "create_current_region [-help] [-die_instance_name <string>] [-file <string>] [-label <string>] [-series_resistance <string>] [-current <string> | -current_pwl_file <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "单元名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-current",
      "description": "静态电流值（单位mA）或动态电流波形描述（格式如 {{#ns #mA }...}）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-current_pwl_file",
      "description": "动态电流波形文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-die_instance_name",
      "description": "要应用电流区域的die实例名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-file",
      "description": "要合并参数的文件名（可包含die名称）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-gndnet",
      "description": "地网络名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance",
      "description": "实例名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-intrinsic_cap",
      "description": "本征电容（单位pF）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-label",
      "description": "电流区域的标签",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer",
      "description": "层名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-loading_cap",
      "description": "负载电容（单位pF）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "网络名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-polygon",
      "description": "多边形区域坐标（单位um，格式为 <x1 y1 x2 y2 x3 y3 .....>）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pwrnet",
      "description": "电源网络名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-region",
      "description": "矩形区域坐标（单位um，格式为 <x1 y1 x2 y2>）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "重置所有选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-series_resistance",
      "description": "串联电阻（单位ohm）",
      "required": false,
      "type": "string"
    }
  ]
}