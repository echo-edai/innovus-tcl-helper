{
  "command": "restore_module_model",
  "is_cmd": true,
  "summary": "恢复模块模型",
  "description": "该命令用于恢复指定模块的模型。用户可以通过提供模块名称（cellName）或使用 -cell 选项指定单元名称来调用。命令支持多种可选参数，用于配置恢复过程中的动态视图、时序视图（建立和保持）、泄漏视图、LEF文件、MMMC配置文件等。此外，可以控制是否恢复时序信息（-noTiming）和时序图（-noTimingGraph），并通过 -tag 选项添加流程标签。 -add_ons 选项允许指定额外的恢复功能，如与特定类型（如1801、MMMC、SPEF、ECO、延迟等）相关的扫描信息、时序上下文、提取上下文或引脚分配。",
  "usage": "restore_module_model [-help] [-dynamic_view <string>] [-hold_views <string>] [-leakage_view <string>] [-lef_files <string>] [-mmmcFile <string>] [-noTiming] [-noTimingGraph] [-setup_views <string>] [-tag <string>] {<cellName> | -cell <string>} [<options>] [-add_ons <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<cellName>",
      "description": "模块名称（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "<options>",
      "description": "恢复选项（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-add_ons",
      "description": "与 -type 相关的附加功能，如1801、mmmc、spef、eco、延迟、scan_info、timing_context、extraction_context、pin_assign（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "单元名称（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-dynamic_view",
      "description": "动态视图（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-hold_views",
      "description": "活动保持视图（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-leakage_view",
      "description": "泄漏视图（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-lef_files",
      "description": "LEF文件列表（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mmmcFile",
      "description": "MMMC配置文件（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-noTiming",
      "description": "不恢复时序信息（布尔值，可选）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noTimingGraph",
      "description": "不恢复时序图（布尔值，可选）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-setup_views",
      "description": "活动建立视图（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tag",
      "description": "流程标签（字符串，可选）",
      "required": false,
      "type": "string"
    }
  ]
}