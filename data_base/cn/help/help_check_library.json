{
  "command": "check_library",
  "is_cmd": true,
  "summary": "执行库检查的命令",
  "description": "该命令用于执行库检查，特别是针对布局（placement）阶段。它允许用户检查指定的库单元（lib cells）或所有库单元，验证其合法性（如多高度单元的合法频率），并可将检查结果输出到指定文件。",
  "usage": "check_library [-help] [-place [-cell <cells> | -all_lib_cell ] [-legal_frequency ] [-file <name>] ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-place",
      "description": "执行针对布局的库检查",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "指定要检查的单元",
      "required": false,
      "type": "libCell/ptnCell+"
    },
    {
      "name": "-all_lib_cell",
      "description": "检查所有库单元",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-legal_frequency",
      "description": "检查多高度单元的合法频率",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "指定输出文件名",
      "required": false,
      "type": "string"
    }
  ]
}