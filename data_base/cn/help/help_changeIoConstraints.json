{
  "command": "changeIoConstraints",
  "is_cmd": true,
  "summary": "修改I/O约束",
  "description": "此命令用于修改I/O单元的布局约束，包括间距、顺序和边界空间等。",
  "usage": "changeIoConstraints [-help] [-forceIt] [-removeAll] [-firstCellSpacing <float> | -removeFirstCellSpacing] [-row <string> | -ioOrder <string>] [-endspace <float> | -removeEndSpace] [-spacing <float> | -removeSpacing]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-forceIt",
      "description": "强制在非I/O行流程上运行",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-removeAll",
      "description": "移除所有约束",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-firstCellSpacing",
      "description": "从行边缘到第一个单元的间距",
      "required": false,
      "type": "float"
    },
    {
      "name": "-removeFirstCellSpacing",
      "description": "移除从第一个单元开始的间距约束",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-row",
      "description": "I/O行名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ioOrder",
      "description": "更改I/O放置顺序",
      "required": false,
      "type": "string"
    },
    {
      "name": "-endspace",
      "description": "边界空间约束",
      "required": false,
      "type": "float"
    },
    {
      "name": "-removeEndSpace",
      "description": "移除边界空间约束",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-spacing",
      "description": "所有单元的间距约束",
      "required": false,
      "type": "float"
    },
    {
      "name": "-removeSpacing",
      "description": "移除间距约束",
      "required": false,
      "type": "flag"
    }
  ]
}