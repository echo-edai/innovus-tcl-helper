{
  "command": "get_lib_clock_tree_path_delay",
  "is_cmd": true,
  "summary": "获取库时钟树路径延迟",
  "description": "该命令用于获取指定库时钟树路径的延迟信息。用户可以通过指定基础引脚、延迟类型、信号边沿、分析模式、电源域、输入转换时间和分析视图等参数来精确查询所需的延迟数据。",
  "usage": "get_lib_clock_tree_path_delay [-help] -base_pin <term> [-delay_type {max min}] [-edge {rise fall}] [-mode <string>] [-power_domain <pd>] -transition <float> -view <analysis_view>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-base_pin",
      "description": "基础引脚名称（必需）",
      "required": true,
      "type": "term"
    },
    {
      "name": "-delay_type",
      "description": "延迟类型（默认值：max）",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-edge",
      "description": "信号方向（默认值：rise）",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-mode",
      "description": "分析模式名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-power_domain",
      "description": "电源域名称",
      "required": false,
      "type": "pd"
    },
    {
      "name": "-transition",
      "description": "输入转换时间（必需，范围：0-99）",
      "required": true,
      "type": "float"
    },
    {
      "name": "-view",
      "description": "分析视图名称（必需）",
      "required": true,
      "type": "analysis_view"
    }
  ]
}