{
  "command": "setAnalysisMode",
  "is_cmd": true,
  "summary": "设置时序分析模式",
  "description": "该命令用于配置 Innovus 工具进行时序分析时的各种模式和参数。它可以控制分析类型（如单角、最差情况、片上偏差）、检查类型（建立时间、保持时间）、时钟传播方式、公共路径悲观消除（CPPR）设置、老化分析、统计时序分析引擎选择等众多选项，是进行精确时序收敛的关键命令。",
  "usage": "setAnalysisMode [-help] [-reset] [-aging {true|false}] [-analysisType {single|bcwc|onChipVariation}] [-asyncChecks {async|noAsync|asyncOnly|auto}] [-caseAnalysis {true|false}] [-checkType {setup|hold}] [-clkNetsMarking {beforeConstProp|afterConstProp}] [-clkSrcPath {true|false}] [-clockGatingCheck {true|false}] [-clockPropagation {sdcControl|forcedIdeal|autoDetectClockTree}] [-cppr {both|none|setup|hold}] [-honorActiveLogicView {true|false}] [-honorClockDomains {true|false}] [-log {true|false}] [-multi_input_switching_mode <value>] [-propSlew {true|false}] [-sequentialConstProp {true|false}] [-skew {true|false}] [-slackBalancing {true|false}] [-timeBorrowing {true|false}] [-timing_robustness {true|false}] [-timingEngine {statistical|static|rql}] [-timingSelfLoopsNoSkew {true|false}] [-usefulSkew {true|false}] [-useOutputPinCap {true|false}] [-warn {true|false}] [-socv {true|false} | -aocv {true|false}]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "将所有或指定选项重置为默认值",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-aging",
      "description": "老化分析",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-analysisType",
      "description": "时序分析类型：单角、最差情况或片上偏差",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-asyncChecks",
      "description": "异步检查模式",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-caseAnalysis",
      "description": "案例分析",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-checkType",
      "description": "报告违规类型：建立时间或保持时间",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-clkNetsMarking",
      "description": "时钟网络标记时机",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-clkSrcPath",
      "description": "时钟源路径",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-clockGatingCheck",
      "description": "时钟门控检查",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-clockPropagation",
      "description": "时序弧属性对时序分析的影响方式",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-cppr",
      "description": "消除时钟路径上公共部分的悲观度",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-honorActiveLogicView",
      "description": "遵循活动逻辑视图",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-honorClockDomains",
      "description": "遵循时钟域",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-log",
      "description": "日志记录",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-multi_input_switching_mode",
      "description": "指定多输入切换模式：0-不考虑同时输入切换；1-考虑单元中多个输入相连的情况；2-考虑输入独立切换和相连的情况；3-基于降额的MIS分析",
      "required": false,
      "type": "int"
    },
    {
      "name": "-propSlew",
      "description": "控制早期路径的互连线转换时间衰减",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-sequentialConstProp",
      "description": "时序常量传播",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-skew",
      "description": "时钟偏斜",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-slackBalancing",
      "description": "裕量平衡",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-socv",
      "description": "片上变化统计时序分析",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-aocv",
      "description": "先进片上变化分析",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-timeBorrowing",
      "description": "时间借用",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-timing_robustness",
      "description": "时序鲁棒性分析",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-timingEngine",
      "description": "时序分析引擎：统计、静态或RQL",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-timingSelfLoopsNoSkew",
      "description": "消除起始和结束于同一寄存器的路径中由于时钟不确定性造成的时钟偏斜",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-usefulSkew",
      "description": "有益偏斜",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-useOutputPinCap",
      "description": "使用输出引脚电容",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-warn",
      "description": "警告信息",
      "required": false,
      "type": "enum"
    }
  ]
}