{
  "command": "modifyBudget",
  "is_cmd": true,
  "summary": "修改时序预算",
  "description": "该命令用于根据输入文件中的手动预算信息，修改指定实例或分区的建立时间或保持时间预算。",
  "usage": "modifyBudget [-help] -file <string> -view <string> {-ptn <string> | -inst <string>} [-setup | -hold]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "包含手动预算信息的输入文件",
      "required": true,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "仅修改特定视图的预算",
      "required": true,
      "type": "string"
    },
    {
      "name": "-ptn",
      "description": "将应用手动预算的分区",
      "required": false,
      "type": "string"
    },
    {
      "name": "-inst",
      "description": "将应用手动预算的层次化实例",
      "required": false,
      "type": "string"
    },
    {
      "name": "-setup",
      "description": "修改建立时间信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hold",
      "description": "修改保持时间信息",
      "required": false,
      "type": "flag"
    }
  ]
}