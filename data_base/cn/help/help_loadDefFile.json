{
  "command": "loadDefFile",
  "is_cmd": true,
  "summary": "加载DEF文件",
  "description": "该命令用于加载一个DEF（Design Exchange Format）文件。它支持加载平面或层次化的DEF设计。对于层次化DEF文件，可以使用-stub或-reflib选项来指定存根文件或OA参考库。",
  "usage": "loadDefFile [-help] <defFile> [-hier  [-stub <string> | -reflib <string>]]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<defFile>",
      "description": "要加载的DEF文件（字符串，必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-hier",
      "description": "加载层次化DEF文件（布尔值，可选）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reflib",
      "description": "OA参考库（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-stub",
      "description": "存根文件（字符串，可选）",
      "required": false,
      "type": "string"
    }
  ]
}