{
  "command": "clonePlace",
  "is_cmd": true,
  "summary": "克隆放置命令",
  "description": "该命令用于在布局中克隆指定实例的放置位置。通过指定主实例和克隆实例列表，可以快速复制其物理位置和方向。",
  "usage": "clonePlace [-help] [-clone_list {string1 string2 ...}] [-master_inst <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clone_list",
      "description": "克隆实例规格列表，格式为 {<cloneInst1> <orientation1> ...}，可选",
      "required": false,
      "type": "list"
    },
    {
      "name": "-master_inst",
      "description": "主实例名称，可选",
      "required": false,
      "type": "string"
    }
  ]
}