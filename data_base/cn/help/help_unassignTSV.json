{
  "command": "unassignTSV",
  "is_cmd": true,
  "summary": "取消分配TSV（硅通孔）的命令",
  "description": "此命令用于取消分配一个或多个TSV（硅通孔）与特定网络的关联。用户可以通过指定网络名称、选择所有TSV、或按类型（信号、电源、地）来取消分配。",
  "usage": "unassignTSV [-help] {-netName <string> | -all | -signal | -power | -ground | -selected}",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "取消分配所有TSV",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-ground",
      "description": "取消分配地网络TSV",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-netName",
      "description": "取消分配指定网络名称的TSV",
      "required": true,
      "type": "string"
    },
    {
      "name": "-power",
      "description": "取消分配电源网络TSV",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-selected",
      "description": "取消分配当前选中的TSV",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-signal",
      "description": "取消分配信号网络TSV",
      "required": true,
      "type": "flag"
    }
  ]
}