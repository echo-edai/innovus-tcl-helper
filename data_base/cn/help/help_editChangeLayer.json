{
  "command": "editChangeLayer",
  "is_cmd": true,
  "summary": "编辑并更改布线层",
  "description": "该命令用于编辑并更改布线层，允许用户指定水平或垂直方向的布线层，或设置在这些方向上的层移动量。",
  "usage": "editChangeLayer [-help] [-layer_horizontal <string> | -layer_horizontal_movement <integer>] [-layer_horizontal <string> | -layer_vertical_movement <integer>] [-layer_vertical <string> | -layer_horizontal_movement <integer>] [-layer_vertical <string> | -layer_vertical_movement <integer>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-layer_horizontal",
      "description": "指定水平布线层",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer_horizontal_movement",
      "description": "指定水平层移动量",
      "required": false,
      "type": "int"
    },
    {
      "name": "-layer_vertical",
      "description": "指定垂直布线层",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer_vertical_movement",
      "description": "指定垂直层移动量",
      "required": false,
      "type": "int"
    }
  ]
}