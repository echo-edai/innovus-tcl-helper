{
  "command": "deletePinGuide",
  "is_cmd": true,
  "summary": "删除引脚引导线",
  "description": "该命令用于删除设计中指定的引脚引导线（Pin Guide）。用户可以通过指定引脚、引脚组、网络、网络组、对象名称或使用-all选项来删除所有引导线，从而管理布局布线中的引脚引导信息。",
  "usage": "deletePinGuide [-help] { -pin <string> | -pinGroup <string> | -net <string> | -netGroup <string> | -name <string> | -all  } [-cell <string> | -net <string> | -netGroup <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "指定删除所有引脚引导线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "指定模块的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "指定分区引脚引导线对象的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "对于网络，指定网络名称；对于总线，指定总线名称或总线基数",
      "required": false,
      "type": "string"
    },
    {
      "name": "-netGroup",
      "description": "指定网络组的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pin",
      "description": "指定引脚的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pinGroup",
      "description": "指定引脚组的名称",
      "required": false,
      "type": "string"
    }
  ]
}