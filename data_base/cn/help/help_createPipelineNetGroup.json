{
  "command": "createPipelineNetGroup",
  "is_cmd": true,
  "summary": "创建流水线网络组",
  "description": "该命令用于创建一个流水线网络组。用户需要指定网络组的名称，并可选地配置起始和终止端的预留距离、起始和终止端术语列表、以及关联的实例和网络列表。",
  "usage": "createPipelineNetGroup [-help] <netGroupName> [-endReserve <val>] [-endTerm <list>] [-inst <list>] [-net <list>] [-startReserve <val>] [-startTerm <list>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<netGroupName>",
      "description": "网络组的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-endReserve",
      "description": "在末端预留的距离",
      "required": false,
      "type": "float"
    },
    {
      "name": "-endTerm",
      "description": "终止端术语列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-inst",
      "description": "实例名称或模式列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "网络名称或模式列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-startReserve",
      "description": "在起始端预留的距离",
      "required": false,
      "type": "float"
    },
    {
      "name": "-startTerm",
      "description": "起始端术语列表",
      "required": false,
      "type": "string"
    }
  ]
}