{
  "command": "gui_deselect",
  "is_cmd": true,
  "summary": "图形界面取消选择对象",
  "description": "该命令用于在图形界面中取消选择对象。可以通过指定矩形区域、点、线或使用-all选项来取消选择所有对象。",
  "usage": "gui_deselect [-help] {-all  | -rect {x1 y1 x2 y2} | -point {x y} | -line {x1 y1 x2 y2}}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "取消选择所有对象",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-line",
      "description": "通过线（框）取消选择",
      "required": false,
      "type": "string"
    },
    {
      "name": "-point",
      "description": "通过点取消选择",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rect",
      "description": "通过矩形框取消选择",
      "required": false,
      "type": "string"
    }
  ]
}