{
  "command": "setPathGroupOptions",
  "is_cmd": true,
  "summary": "设置路径组选项",
  "description": "该命令用于配置指定路径组的时序优化选项，包括工作模式、优化力度、松弛调整、目标松弛值以及权重等参数，以指导工具进行更精细的时序收敛。",
  "usage": "setPathGroupOptions [-help] <pathgroupName> [-early] [-effortLevel {low high}] [-late] [-skewingSlackConstraint <float>] [-slackAdjustment <float>] [-slackAdjustmentPriority <integer>] [-targetSlack <float>] [-view <string>] [-weight <integer>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pathgroupName>",
      "description": "路径组名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-early",
      "description": "仅针对早期时序模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-effortLevel",
      "description": "优化力度等级",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-late",
      "description": "仅针对晚期时序模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skewingSlackConstraint",
      "description": "进行时钟偏斜调整时的松弛约束值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-slackAdjustment",
      "description": "松弛调整值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-slackAdjustmentPriority",
      "description": "松弛调整的优先级",
      "required": false,
      "type": "int"
    },
    {
      "name": "-targetSlack",
      "description": "目标松弛值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-view",
      "description": "视图名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-weight",
      "description": "优化优先级权重",
      "required": false,
      "type": "int"
    }
  ]
}