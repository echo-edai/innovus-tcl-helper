{
  "command": "extract_package",
  "is_cmd": true,
  "summary": "提取封装模型",
  "description": "该命令用于提取封装模型，可以指定输出目录、SPD文件、工作空间、参考网络、封装管芯名称和BGA电路名称等参数。",
  "usage": "extract_package [-help] [-output <string>] [-spd_file <string>] { [<domain> [-workspace <string>] [-reference_net <string>] [-pkg_die_name <string>] [-pkg_bga_name <string>] ]}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<domain>",
      "description": "电源分析域名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-output",
      "description": "封装模型的输出目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spd_file",
      "description": "封装提取的SPD文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-workspace",
      "description": "封装提取的工作空间 .ximx 文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reference_net",
      "description": "定义网络名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pkg_die_name",
      "description": "指定管芯电路",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pkg_bga_name",
      "description": "指定BGA电路",
      "required": false,
      "type": "string"
    }
  ]
}