{
  "command": "setObjFPlanPolygon",
  "is_cmd": true,
  "summary": "设置对象的物理规划多边形形状",
  "description": "该命令用于为指定的对象（如单元、组、实例、层形状或模块）定义一个多边形形状，通常用于物理规划（Floorplanning）阶段。用户可以提供坐标列表来指定一个直角多边形形状，并可选择是否遵循网格对齐规则。",
  "usage": "setObjFPlanPolygon [-help] {Cell Group Instance Layershape Module} <objectName> <coordList> [-no_snap_to_grid]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "{Cell Group Instance Layershape Module}",
      "description": "对象类型（枚举值，必需）",
      "required": true,
      "type": "enum"
    },
    {
      "name": "<objectName>",
      "description": "对象名称（字符串，必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "<coordList>",
      "description": "对象的直角多边形形状坐标列表（列表，必需）",
      "required": true,
      "type": "list"
    },
    {
      "name": "-no_snap_to_grid",
      "description": "指定不遵循网格对齐规则（布尔值，可选）",
      "required": false,
      "type": "flag"
    }
  ]
}