{
  "command": "setSdpTopGroup",
  "is_cmd": true,
  "summary": "设置SDP顶层组",
  "description": "该命令用于设置一个数据路径（SDP）的顶层组。可以指定组的名称，并通过指定层次路径或物理坐标位置来定义该组。使用-force选项可以强制在核心区域外设置位置。",
  "usage": "setSdpTopGroup [-help] [-force] -group <sdpGroupName> {-location <llx> <lly> | -hierPath <hierPath>}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-force",
      "description": "即使指定位置在核心区域外，也强制设置该组",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-group",
      "description": "数据路径组的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-hierPath",
      "description": "SDP模块的层次路径",
      "required": false,
      "type": "string"
    },
    {
      "name": "-location",
      "description": "设置组的物理位置坐标点",
      "required": false,
      "type": "point"
    }
  ]
}