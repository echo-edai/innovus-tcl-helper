{
  "command": "report_property",
  "is_cmd": true,
  "summary": "报告对象属性",
  "description": "该命令用于报告指定集合（collection）或集合列表中对象的属性。用户可以通过 -property_list 参数指定要报告的特定属性列表，也可以将输出重定向到文件。",
  "usage": "report_property [-help] [-property_list <list of properties>] [> <file_name>] [>> <file_name>] {<collection> | <list_of_collections>}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-property_list",
      "description": "指定要报告的有效属性名称列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "<collection>",
      "description": "指定一个集合",
      "required": false,
      "type": "string"
    },
    {
      "name": "<list_of_collections>",
      "description": "指定一个集合列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "> <file_name>",
      "description": "将输出重定向到指定文件（覆盖模式）",
      "required": false,
      "type": "redirect_operator"
    },
    {
      "name": ">> <file_name>",
      "description": "将输出重定向到指定文件（追加模式）",
      "required": false,
      "type": "redirect_operator"
    }
  ]
}