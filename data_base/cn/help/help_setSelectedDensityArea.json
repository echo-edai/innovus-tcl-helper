{
  "command": "setSelectedDensityArea",
  "is_cmd": true,
  "summary": "设置选定区域的密度屏幕",
  "description": "该命令用于定义一个密度屏幕区域，指定其边界坐标、标准单元放置密度百分比、名称、硬度属性以及与设计的关联关系。",
  "usage": "setSelectedDensityArea [-help] <x1> <y1> <x2> <y2> <density> <name> [{Partial Soft Hard}] [{Instance Pushdown Undefined}]",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<x1>",
      "description": "区域左下角X坐标",
      "required": true,
      "type": "float"
    },
    {
      "name": "<y1>",
      "description": "区域左下角Y坐标",
      "required": true,
      "type": "float"
    },
    {
      "name": "<x2>",
      "description": "区域右上角X坐标",
      "required": true,
      "type": "float"
    },
    {
      "name": "<y2>",
      "description": "区域右上角Y坐标",
      "required": true,
      "type": "float"
    },
    {
      "name": "<density>",
      "description": "标准单元放置密度百分比（0到100之间的浮点数）",
      "required": true,
      "type": "float"
    },
    {
      "name": "<name>",
      "description": "密度屏幕区域的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "{Partial Soft Hard}",
      "description": "密度屏幕区域的硬度属性（枚举值：Partial, Soft, Hard）",
      "required": false,
      "type": "enum"
    },
    {
      "name": "{Instance Pushdown Undefined}",
      "description": "密度屏幕区域与设计的关联关系（枚举值：Instance, Pushdown, Undefined）",
      "required": false,
      "type": "enum"
    }
  ]
}