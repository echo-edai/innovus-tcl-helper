{
  "command": "select_row",
  "is_cmd": true,
  "summary": "选择布局中的行",
  "description": "此命令用于在布局中选择特定的行。用户可以通过指定行名称、站点名称或使用-all标志来选择所有行来筛选目标行。",
  "usage": "select_row [-help] [-all  | -name <string> | -site <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "选择所有行",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "根据行名称选择行",
      "required": false,
      "type": "string"
    },
    {
      "name": "-site",
      "description": "根据站点名称选择行",
      "required": false,
      "type": "string"
    }
  ]
}