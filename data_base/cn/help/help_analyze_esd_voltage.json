{
  "command": "analyze_esd_voltage",
  "is_cmd": true,
  "summary": "分析ESD电压",
  "description": "该命令用于分析指定网络上的静电放电（ESD）电压分布。它需要输入电流分布层、总ESD电流、驱动/接收器文件、ESD引脚位置文件以及目标网络名称等关键信息，并可选择性地生成详细报告、设置报告过滤阈值以及限制报告的最大违规数量。",
  "usage": "analyze_esd_voltage [-help] -current_distribution_layer <string> [-detailed_report <string>] -driver_receiver_file <string> -esd_pin_location_file <string> [-maximum_violations <integer>] -net <string> [-report <string>] [-threshold <float>] -total_current <string>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-current_distribution_layer",
      "description": "电流分布层",
      "required": true,
      "type": "string"
    },
    {
      "name": "-detailed_report",
      "description": "输出详细报告的文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-driver_receiver_file",
      "description": "网络的驱动/接收器文件",
      "required": true,
      "type": "string"
    },
    {
      "name": "-esd_pin_location_file",
      "description": "ESD引脚位置文件",
      "required": true,
      "type": "string"
    },
    {
      "name": "-maximum_violations",
      "description": "要报告的最大最差违规数量",
      "required": false,
      "type": "int"
    },
    {
      "name": "-net",
      "description": "要分析的网络名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-report",
      "description": "输出报告的文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-threshold",
      "description": "用于报告过滤的驱动/接收器电压最小阈值（单位：伏特）",
      "required": false,
      "type": "float"
    },
    {
      "name": "-total_current",
      "description": "待分配的总ESD电流",
      "required": true,
      "type": "string"
    }
  ]
}