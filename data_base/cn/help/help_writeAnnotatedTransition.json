{
  "command": "writeAnnotatedTransition",
  "is_cmd": true,
  "summary": "将时序转换（transition）信息写入带注释的输出文件",
  "description": "该命令用于生成一个包含时序转换（transition）信息的带注释的输出文件。用户可以指定输出文件名，并选择性地包含最大或最小转换值、是否跳过主端口的转换值、指定视图名称，以及是否同时写入输出引脚和双向引脚的转换信息。",
  "usage": "writeAnnotatedTransition [-help] [-direct] -file <string> [-max] [-min] [-noPort] [-view <string>] [-writeOutput]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-direct",
      "description": "直接引用端口",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "输出文件名",
      "required": true,
      "type": "string"
    },
    {
      "name": "-max",
      "description": "指定是否写入最大转换值",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-min",
      "description": "指定是否写入最小转换值",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noPort",
      "description": "跳过为主端口写入转换值",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view",
      "description": "输出文件的视图名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-writeOutput",
      "description": "同时为输出引脚和双向引脚的输出转换写入转换值",
      "required": false,
      "type": "flag"
    }
  ]
}