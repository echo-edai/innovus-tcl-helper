{
  "command": "modifyPipelineNetGroup",
  "is_cmd": true,
  "summary": "修改流水线网络组的命令",
  "description": "该命令用于修改指定的流水线网络组（netGroupName），允许用户调整其起始和结束端的预留距离、终端列表，以及关联的实例和网络列表。",
  "usage": "modifyPipelineNetGroup [-help] <netGroupName> [-endReserve <val>] [-endTerm <list>] [-inst <list>] [-net <list>] [-startReserve <val>] [-startTerm <list>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<netGroupName>",
      "description": "网络组的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-endReserve",
      "description": "结束端的预留距离",
      "required": false,
      "type": "float"
    },
    {
      "name": "-endTerm",
      "description": "结束端终端列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-inst",
      "description": "实例名称或模式列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "网络名称或模式列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-startReserve",
      "description": "起始端的预留距离",
      "required": false,
      "type": "float"
    },
    {
      "name": "-startTerm",
      "description": "起始端终端列表",
      "required": false,
      "type": "string"
    }
  ]
}