{
  "command": "report_cell_stack_area",
  "is_cmd": true,
  "summary": "报告单元堆叠面积",
  "description": "该命令用于生成指定单元或组的堆叠面积报告。用户可以通过指定单元、组或输出文件来控制报告的内容和输出位置。",
  "usage": "report_cell_stack_area [-help] [-cell <string>] [-file <string>] [-group <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "指定需要报告的单元",
      "required": false,
      "type": "string"
    },
    {
      "name": "-file",
      "description": "将报告信息输出到指定的文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-group",
      "description": "指定需要报告的组",
      "required": false,
      "type": "string"
    }
  ]
}