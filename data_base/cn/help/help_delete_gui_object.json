      "required": false,
      "type": "flag"
    },
    {
      "name": "-marker",
      "description": "删除GUI标记",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-selected",
      "description": "删除选中的GUI对象",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-shape",
