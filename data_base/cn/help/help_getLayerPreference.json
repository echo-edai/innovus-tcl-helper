{
  "command": "getLayerPreference",
  "is_cmd": true,
  "summary": "获取图层显示偏好设置",
  "description": "该命令用于查询指定图层或对象类型的显示属性，例如可见性、可选性、颜色、线宽、点画线图案及其数据。",
  "usage": "getLayerPreference [-help] <layer_name> {-isVisible | -isSelectable | -color | -lineWidth | -stipple | -stippleData }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<layer_name>",
      "description": "图层或对象类型的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-color",
      "description": "颜色名称或数字RGB值",
      "required": false,
      "type": "bool"
    },
    {
      "name": "-isSelectable",
      "description": "对象是否可选",
      "required": false,
      "type": "bool"
    },
    {
      "name": "-isVisible",
      "description": "对象是否可见",
      "required": false,
      "type": "bool"
    },
    {
      "name": "-lineWidth",
      "description": "指定对象边框的像素宽度",
      "required": false,
      "type": "bool"
    },
    {
      "name": "-stipple",
      "description": "对象的点画线图案信息",
      "required": false,
      "type": "bool"
    },
    {
      "name": "-stippleData",
      "description": "对象的点画线信息",
      "required": false,
      "type": "bool"
    }
  ]
}