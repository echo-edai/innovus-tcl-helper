{
  "command": "update_module_model",
  "is_cmd": true,
  "summary": "更新模块模型",
  "description": "此命令用于更新模块模型。它提供了多种选项来控制更新过程，例如指定CPU数量、分布式运行、生成ECO报告、设置日志目录、指定返回模型的类型和标签，以及通过交互模式或Tcl插件脚本进行操作。",
  "usage": "update_module_model [-help] [-cpu <integer>] [-distribute_job] [-eco_report] [-log_dir <string>] [-return_tag <string>] [-return_type {lef flexIlm ilm pnr}] [-tag <string>] { [-cell <string>] [-distribute_run ] [ -interactive | -plugin_tcl <string> | -gen_eco_only ]}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "单元名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cpu",
      "description": "CPU数量",
      "required": false,
      "type": "int"
    },
    {
      "name": "-distribute_job",
      "description": "为分布式运行设置update_module_model作业",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-distribute_run",
      "description": "在分布式模式下运行update_module_model",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-eco_report",
      "description": "报告模块模型变更",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-gen_eco_only",
      "description": "仅生成ECO文件",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-interactive",
      "description": "交互模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-log_dir",
      "description": "日志文件目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-plugin_tcl",
      "description": "Tcl命令",
      "required": false,
      "type": "string"
    },
    {
      "name": "-return_tag",
      "description": "返回的模块模型标签",
      "required": false,
      "type": "string"
    },
    {
      "name": "-return_type",
      "description": "返回的模块模型类型",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-tag",
      "description": "模块标签",
      "required": false,
      "type": "string"
    }
  ]
