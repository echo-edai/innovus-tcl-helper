{
  "command": "display_timing_map",
  "is_cmd": true,
  "summary": "显示时序映射",
  "description": "该命令用于显示时序映射，可以指定检查类型（如建立时间或保持时间）、设置步长和松弛阈值，或者清除当前的时序映射。",
  "usage": "display_timing_map [-help] [-step <float>] [-threshold <float>] { -check_type {setup hold} | -clear }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-check_type",
      "description": "指定检查类型（如建立时间或保持时间）",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-clear",
      "description": "清除时序映射",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-step",
      "description": "指定步长",
      "required": false,
      "type": "float"
    },
    {
      "name": "-threshold",
      "description": "指定松弛阈值",
      "required": false,
      "type": "float"
    }
  ]
}