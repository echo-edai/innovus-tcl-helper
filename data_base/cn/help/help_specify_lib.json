{
  "command": "specify_lib",
  "is_cmd": true,
  "summary": "指定库文件",
  "description": "该命令用于读取指定的库文件，并可选择重置库列表。",
  "usage": "specify_lib [-help] [<in_file <file1[file2] ...>>] [-reset]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<in_file <file1[file2] ...>>",
      "description": "读取库文件（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "重置库列表（布尔值，可选）",
      "required": false,
      "type": "flag"
    }
  ]
}