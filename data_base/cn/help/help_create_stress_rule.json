{
  "command": "create_stress_rule",
  "is_cmd": true,
  "summary": "创建应力规则",
  "description": "该命令用于创建应力规则，可以指定层名和间距表来定义应力规则，也可以重置所有应力规则。",
  "usage": "create_stress_rule [-help] { {-layer <layerName> -spacing_table <spacing_table> [-chip_name <chipName>]} | [-reset ] }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-chip_name",
      "description": "芯片名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer",
      "description": "应力层名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "重置所有应力规则",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-spacing_table",
      "description": "间距表定义，格式为 {{x1 y1} {x2 y2} ...}",
      "required": false,
      "type": "string"
    }
  ]
}