{
  "command": "read_parasitics",
  "is_cmd": true,
  "summary": "读取寄生参数文件",
  "description": "该命令用于从RCDB或SPEF文件中读取寄生参数信息。它支持多种选项，如强制读取、启用索引流、指定SPEF文件类型、指定RC角以及读取SPEF文件中的*N语句等。",
  "usage": "read_parasitics [-help] [-force] [-idx] [-idx_spef_type <string>] [-starN] [-via_variation_file <string>] { [{{ [-rc_corner <string>] }} ] }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-force",
      "description": "允许块级缺少某个角的RCDB或SPEF文件时仍继续读取",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-idx",
      "description": "启用索引流",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-idx_spef_type",
      "description": "指定SPEF文件的类型，如idx、vidx等",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rc_corner",
      "description": "指定角名称，后跟该角特定的RCDB或SPEF文件列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-starN",
      "description": "指定是否读取SPEF文件中的*N语句",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-via_variation_file",
      "description": "指定VIA变异文件",
      "required": false,
      "type": "string"
    }
  ]
}