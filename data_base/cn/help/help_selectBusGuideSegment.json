{
  "command": "selectBusGuideSegment",
  "is_cmd": true,
  "summary": "选择总线引导线段",
  "description": "此命令用于在指定边界框和图层范围内，选择一个与给定网络组（NetGroup）相关的总线引导线段。",
  "usage": "selectBusGuideSegment [-help] -box {x1 y1 x2 y2} -layer {id | id1:id2} -netGroup <netGroup>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-box",
      "description": "总线引导线段的边界框坐标，格式为 x1 y1 x2 y2",
      "required": true,
      "type": "string"
    },
    {
      "name": "-layer",
      "description": "图层标识符或图层范围，可以是单个ID或ID1:ID2格式的范围",
      "required": true,
      "type": "string"
    },
    {
      "name": "-netGroup",
      "description": "网络组的名称",
      "required": true,
      "type": "string"
    }
  ]
}