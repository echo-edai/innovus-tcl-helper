{
  "command": "scale_what_if_capacitance",
  "is_cmd": true,
  "summary": "缩放或添加假设性电容的命令",
  "description": "此命令用于缩放或添加假设性电容，以进行时序或信号完整性分析。它允许用户全局、按区域、按单元、按实例或通过文件指定电容调整。可以缩放固有电容、负载电容和栅极电容，或直接添加绝对电容值。使用 `-reset` 选项可以重置所有缩放设置。",
  "usage": "scale_what_if_capacitance [-help] [-add] [-layer <string>] [-net <string>] -reset  | {{-global  | -region <string> | -cell <string> | -instance <string> | -file <string>} [-intrinsic_cap <string>] [-loading_cap <string>] [-grid_cap <string>]}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-add",
      "description": "添加电容而非缩放电容；所有缩放值均假定为以法拉(F)为单位的绝对值",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-layer",
      "description": "用于添加电容的LEF层名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "网络名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "重置所有电容缩放选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-global",
      "description": "应用全局缩放",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-region",
      "description": "指定区域 <x1 y1 x2 y2> (单位：微米)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "单元名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance",
      "description": "实例名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-file",
      "description": "包含缩放或添加电容信息的文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-intrinsic_cap",
      "description": "固有电容缩放因子",
      "required": false,
      "type": "string"
    },
    {
      "name": "-loading_cap",
      "description": "负载电容缩放因子",
      "required": false,
      "type": "string"
    },
    {
      "name": "-grid_cap",
      "description": "栅极电容缩放因子",
      "required": false,
      "type": "string"
    }
  ]
}