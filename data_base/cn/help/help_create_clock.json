{
  "command": "create_clock",
  "is_cmd": true,
  "summary": "创建时钟定义",
  "description": "该命令用于在设计中定义一个时钟。可以指定时钟源（如引脚或端口）、时钟周期、波形边沿等属性。通过 -add 选项可以在同一源上定义多个时钟。",
  "usage": "create_clock [-help] [<sources>] [-add] [-comment <string>] [-name <clock_name>] -period <period_value> [-waveform <edge_list>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<sources>",
      "description": "与时钟关联的引脚或端口列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-add",
      "description": "在同一源上定义多个时钟",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-comment",
      "description": "不受支持的选项",
      "required": false,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "时钟的名称字符串",
      "required": false,
      "type": "string"
    },
    {
      "name": "-period",
      "description": "以库时间单位表示的时钟周期",
      "required": true,
      "type": "float"
    },
    {
      "name": "-waveform",
      "description": "时钟的上升沿和下降沿时间",
      "required": false,
      "type": "string"
    }
  ]
}