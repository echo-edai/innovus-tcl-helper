{
  "command": "report_noise_propagation",
  "is_cmd": true,
  "summary": "报告噪声传播路径",
  "description": "该命令用于分析和报告电路中噪声（毛刺）的传播路径。用户可以指定各种参数来过滤和定制报告内容，例如根据毛刺电平、路径数量、最大松弛度、特定网络或引脚、视图等条件进行筛选，并可将输出重定向到文件。",
  "usage": "report_noise_propagation [-help] [-level {VL VH worst all}] [-max_paths <integer>] [-max_slack <float>] [-nets <string>] [-nworst <integer>] [-pins <string>] [-source_depth <integer>] [-views <string>] [ [ > | >> ] <filename>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-level",
      "description": "报告指定毛刺电平的路径。允许值为：VL, VH, worst, 或 all。",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-max_paths",
      "description": "报告指定数量的路径",
      "required": false,
      "type": "int"
    },
    {
      "name": "-max_slack",
      "description": "报告毛刺松弛度等于或小于指定值的路径",
      "required": false,
      "type": "float"
    },
    {
      "name": "-nets",
      "description": "报告以连接到该网络的所有输入引脚为终点的路径",
      "required": false,
      "type": "string"
    },
    {
      "name": "-nworst",
      "description": "每个端点需要报告的最大源数量",
      "required": false,
      "type": "int"
    },
    {
      "name": "-pins",
      "description": "报告指定端点引脚的路径",
      "required": false,
      "type": "string"
    },
    {
      "name": "-source_depth",
      "description": "在违规扇入锥中任何给定分支上要追踪的最大源数量",
      "required": false,
      "type": "int"
    },
    {
      "name": "-views",
      "description": "报告指定视图的路径",
      "required": false,
      "type": "string"
    },
    {
      "name": ">",
      "description": "将输出重定向到文件",
      "required": false,
      "type": "redirect_operator"
    },
    {
      "name": ">>",
      "description": "将输出追加到文件",
      "required": false,
      "type": "redirect_operator"
    }
  ]
}