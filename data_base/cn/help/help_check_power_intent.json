{
  "command": "check_power_intent",
  "is_cmd": true,
  "summary": "检查电源意图",
  "description": "该命令用于检查设计的电源意图。它支持IEEE 1801标准，可以进行层次化检查，并可选择将结果输出到指定文件或显示详细信息。",
  "usage": "check_power_intent [-help] -1801 -hierarchical [-outfile <string>] [-verbose]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-1801",
      "description": "指定电源意图遵循IEEE 1801标准",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-hierarchical",
      "description": "指定输入电源意图的样式为层次化",
      "required": true,
      "type": "flag"
    },
    {
      "name": "-outfile",
      "description": "指定输出文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-verbose",
      "description": "打印更多信息",
      "required": false,
      "type": "flag"
    }
  ]
}