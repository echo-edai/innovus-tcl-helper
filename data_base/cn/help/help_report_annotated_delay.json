{
  "command": "report_annotated_delay",
  "is_cmd": true,
  "summary": "报告指定引脚或端口的标注延迟信息。",
  "description": "此命令用于报告设计中指定引脚或端口的标注延迟。它可以列出已标注或未标注的时序弧，并提供多种选项来控制输出格式和内容，例如忽略电源/地网络的时序弧、设置输出行数上限、指定视图以及将输出重定向到文件。",
  "usage": "report_annotated_delay [-help] [<pin_port_list>] [-ignore_tied_low_high_net_arcs] [-list_annotated] [-list_non_annotated] [-max_line <number>] [-tcl_list] [-view <viewName>] [> <file_name[.gz]>] [>> <file_name[.gz]>]",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pin_port_list>",
      "description": "指定需要报告标注延迟的引脚或端口列表。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ignore_tied_low_high_net_arcs",
      "description": "忽略连接到电源和地网络的时序弧。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-list_annotated",
      "description": "报告已标注的时序弧。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-list_non_annotated",
      "description": "报告未标注的时序弧。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-max_line",
      "description": "设置每种延迟弧类型报告的最大行数上限。",
      "required": false,
      "type": "int"
    },
    {
      "name": "-tcl_list",
      "description": "指定输出格式为Tcl列表。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view",
      "description": "指定要报告延迟的视图。默认为所有视图中最差的情况。",
      "required": false,
      "type": "string"
    },
    {
      "name": ">",
      "description": "将输出重定向到文件（覆盖模式）。",
      "required": false,
      "type": "redirect_operator"
    },
    {
      "name": ">>",
      "description": "将输出重定向到文件（追加模式）。",
      "required": false,
      "type": "redirect_operator"
    }
  ]
}