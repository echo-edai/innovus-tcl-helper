{
  "command": "set_package",
  "is_cmd": true,
  "summary": "设置封装模型参数",
  "description": "该命令用于配置芯片封装模型。它允许用户指定SPICE封装模型文件、映射关系、子电路名称，并可以对封装实例进行偏移、旋转、翻转和缩放等几何变换。使用 `-reset` 选项可以清除所有先前通过此命令进行的设置。",
  "usage": "set_package [-help] [-mapping_type <string>] {-reset  | [[-spice <string> [-mapping <string>] [-subckt <string>]] [-offset {x y}] [-rotate <float>] [-flip {true false}] [-scale <float>] ]} [-die_instance_name <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-mapping_type",
      "description": "映射类型：分布式（distributed）或集总式（lumped）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "重置所有先前通过 set_package 命令进行的设置",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-spice",
      "description": "SPICE封装模型文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mapping",
      "description": "映射文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-subckt",
      "description": "顶层子电路名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-offset",
      "description": "偏移量，单位为微米（x y）",
      "required": false,
      "type": "point"
    },
    {
      "name": "-rotate",
      "description": "旋转角度，单位为度",
      "required": false,
      "type": "float"
    },
    {
      "name": "-flip",
      "description": "翻转：true 或 false",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-scale",
      "description": "缩放因子",
      "required": false,
      "type": "float"
    },
    {
      "name": "-die_instance_name",
      "description": "芯片实例名称",
      "required": false,
      "type": "string"
    }
  ]
}