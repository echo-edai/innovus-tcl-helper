      "description": "ESD单元边界框文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-esd_marker_layer_file",
      "description": "ESD标记层文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extract_signal_net_logic_info_only",
      "description": "仅在NET部分输出信号网络的逻辑连接信息，不包含布线形状",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-gds_file",
      "description": "输入GDS文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-gds_layermap",
      "description": "层映射文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ignore_gds_inst_name",
      "description": "忽略从GDS文件中读取的实例名称",
