{
  "command": "placeSpareModule",
  "is_cmd": true,
  "summary": "放置备用模块",
  "description": "该命令用于在芯片布局中放置指定数量的备用模块。用户可以通过参数定义模块名称、数量、放置区域、偏移量、步长、尺寸约束（如最大宽度、最小长度和宽度）、利用率，并可指定电源域和名称前缀。`-channel` 选项可用于通道放置模式。",
  "usage": "placeSpareModule [-help] [-area <box>] [-channel] [-maxWidth <float>] [-minLen <float>] [-minWidth <float>] -moduleName <moduleName> [-numModules <integer>] [-offsetx <float>] [-offsety <float>] [-powerDomain <string>] [-prefix <prefixName>] [-stepx <float>] [-stepy <float>] [-util <float>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-area",
      "description": "指定放置区域的边界框（box）",
      "required": false,
      "type": "box"
    },
    {
      "name": "-channel",
      "description": "启用通道放置模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-maxWidth",
      "description": "模块的最大宽度约束",
      "required": false,
      "type": "float"
    },
    {
      "name": "-minLen",
      "description": "模块的最小长度约束",
      "required": false,
      "type": "float"
    },
    {
      "name": "-minWidth",
      "description": "模块的最小宽度约束",
      "required": false,
      "type": "float"
    },
    {
      "name": "-moduleName",
      "description": "要放置的备用模块的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-numModules",
      "description": "要放置的模块数量",
      "required": false,
      "type": "int"
    },
    {
      "name": "-offsetx",
      "description": "在X轴方向的起始偏移量",
      "required": false,
      "type": "float"
    },
    {
      "name": "-offsety",
      "description": "在Y轴方向的起始偏移量",
      "required": false,
      "type": "float"
    },
    {
      "name": "-powerDomain",
      "description": "模块所属的电源域名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "为放置的模块实例名称添加的前缀",
      "required": false,
      "type": "string"
    },
    {
      "name": "-stepx",
      "description": "在X轴方向放置模块的步长",
      "required": false,
      "type": "float"
    },
    {
      "name": "-stepy",
      "description": "在Y轴方向放置模块的步长",
      "required": false,
      "type": "float"
    },
    {
      "name": "-util",
      "description": "目标区域利用率",
      "required": false,
      "type": "float"
    }
  ]
}