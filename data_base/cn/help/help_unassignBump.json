{
  "command": "unassignBump",
  "is_cmd": true,
  "summary": "取消指定凸块（Bump）的分配",
  "description": "该命令用于移除凸块（Bump）的分配。可以通过指定凸块名称、凸块位置站点、选择所有凸块或仅取消选中凸块的分配来执行操作。",
  "usage": "unassignBump [-help] {-allBumps  | -byBumpName {list} | -byBumpSite {list} | -selected }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allBumps",
      "description": "取消分配所有凸块",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-byBumpName",
      "description": "指定要取消分配的凸块名称列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-byBumpSite",
      "description": "指定站点名称列表，这些站点的凸块将被取消分配",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selected",
      "description": "取消分配选中的凸块",
      "required": false,
      "type": "flag"
    }
  ]
}