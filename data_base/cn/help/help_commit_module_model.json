{
  "command": "commit_module_model",
  "is_cmd": true,
  "summary": "提交模块模型",
  "description": "该命令用于提交模块模型，支持通过指定多模式多角（MMMC）配置文件、IEEE 1801文件或CPF文件来设置或合并时序约束。它提供了复制MMMC延迟、传播时钟等选项，用于在层次化设计流程中管理模块级的时序模型和约束。",
  "usage": "commit_module_model [-help] [-copy_mmmc_latencies] [-merged_mmmc_map_file <string>] [-merged_mmmc_sdc_files <string>] [-mmmc_file <string>] [-mmmc_module_model_tag <string>] [-propagate_clocks] [-cpf_file <string> | -1801 <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-1801",
      "description": "指定IEEE 1801文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-copy_mmmc_latencies",
      "description": "保留MMMC延迟",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cpf_file",
      "description": "指定要使用的全芯片CPF文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-merged_mmmc_map_file",
      "description": "指定合并的层次化MMMC映射文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-merged_mmmc_sdc_files",
      "description": "指定合并的SDC文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mmmc_file",
      "description": "指定全芯片MMMC视图文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mmmc_module_model_tag",
      "description": "指定MMMC模块模型标签",
      "required": false,
      "type": "string"
    },
    {
      "name": "-propagate_clocks",
      "description": "传播时钟",
      "required": false,
      "type": "flag"
    }
  ]
}