{
  "command": "map_dies",
  "is_cmd": true,
  "summary": "用于映射管芯的命令",
  "description": "该命令用于执行管芯映射操作，支持多种模式，包括读取3DIC设计堆叠文件、组件配置文件、JSON配置文件，以及指定输出目录和映射搜索距离等参数。它主要用于处理多芯片设计中的管芯间连接和映射关系。",
  "usage": "map_dies [-help] [-3dic_design_stack_file <string>] [-component_config_file <string>] [-config <string>] [-die_pad_file_pair <string>] [-map_search_distance <string>] [-mode <string>] [-output <string>] [-stacked_die_mapping <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-3dic_design_stack_file",
      "description": "用于3DIC设计布局的XML文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-component_config_file",
      "description": "用于完整性检查的配置文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-config",
      "description": "用于create_xml模式的JSON配置文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-die_pad_file_pair",
      "description": "管芯焊盘文件对",
      "required": false,
      "type": "string"
    },
    {
      "name": "-map_search_distance",
      "description": "用于完整性检查的合法映射距离范围",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mode",
      "description": "操作模式",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output",
      "description": "映射结果的输出目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-stacked_die_mapping",
      "description": "用于检查的堆叠管芯映射结果",
      "required": false,
      "type": "string"
    }
  ]
}