{
  "command": "mark_physical_power_domains",
  "is_cmd": true,
  "summary": "标记物理电源域",
  "description": "该命令用于标记物理电源域，可以指定域名称、检查电源/地网栅栏共享、重置共享设置或仅进行检查。它允许将物理电源域与逻辑电源域进行分组关联。",
  "usage": "mark_physical_power_domains [-help] {-domains <string> | -reset | -checkOnly } [-domains <string> [-groupPhyLogicalDomains {{phyPd lpd1 lpd2 ...} ...}] ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-checkOnly",
      "description": "仅针对电源/地网检查栅栏共享",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-domains",
      "description": "带有栅栏的域名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-groupPhyLogicalDomains",
      "description": "域列表，用于将物理电源域与逻辑电源域分组",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "重置共享设置",
      "required": false,
      "type": "flag"
    }
  ]
}