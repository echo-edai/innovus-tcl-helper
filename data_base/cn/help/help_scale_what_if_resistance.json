{
  "command": "scale_what_if_resistance",
  "is_cmd": true,
  "summary": "缩放指定网络的电阻值以进行假设分析",
  "description": "该命令用于对特定网络（net）的电阻值进行缩放，以执行假设（what-if）分析。用户可以通过指定全局范围、特定区域、单元、实例或文件来定义缩放范围。命令支持自动缩放相邻通孔层，并可通过比例因子或特定的电源门导通电阻比例因子来调整电阻值。使用 `-reset` 选项可以重置所有缩放设置。",
  "usage": "scale_what_if_resistance [-help] -reset | {-net <string> {-global | -region <string> | -cell <string> | -instance <string> | -file <string>} [-auto_scale_adjacent_via_layers {true false}] {{ {-scale <string> } {-layer <string> }} | -scale_ron <string>} }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "重置所有电阻缩放选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-net",
      "description": "网络名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-global",
      "description": "应用于全局范围",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-region",
      "description": "指定区域 <x1 y1 x2 y2> (单位：微米)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "单元名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance",
      "description": "实例名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-file",
      "description": "文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-auto_scale_adjacent_via_layers",
      "description": "自动缩放相邻通孔层",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-scale",
      "description": "缩放因子",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layer",
      "description": "层名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-scale_ron",
      "description": "电源门导通电阻缩放因子",
      "required": false,
      "type": "string"
    }
  ]
}