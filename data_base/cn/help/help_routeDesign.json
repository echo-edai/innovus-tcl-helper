{
  "command": "routeDesign",
  "is_cmd": true,
  "summary": "执行布线设计",
  "description": "该命令用于执行物理设计的布线过程。它提供多种选项来控制布线行为，例如仅布线特定区域、进行时钟网络优化、执行时序优化、进行通孔优化或仅布线选定的网络等。用户可以通过不同的参数组合来定制布线流程，以满足特定的设计需求，如高频设计、背面布线或凸点布线。",
  "usage": "routeDesign [-help] [-backside] [-bump] [-fill_area {x1 y1 x2 y2}] [-highFrequency] [-selected] [-viaPillarOpt] [[[-clockEco ] [-globalDetail ] [-placementCheck | -noPlacementCheck ] [[ -trackOpt ] [-idealClock ]] [-viaOpt ] [-wireOpt ]] | [-passiveFill ]]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-backside",
      "description": "仅布线背面层",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bump",
      "description": "执行凸点布线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-fill_area",
      "description": "为指定区域执行无源填充",
      "required": false,
      "type": "box"
    },
    {
      "name": "-highFrequency",
      "description": "执行高频布线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-selected",
      "description": "仅布线选定的网络",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-viaPillarOpt",
      "description": "执行机会性通孔柱优化",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clockEco",
      "description": "执行时钟工程变更布线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-globalDetail",
      "description": "执行全局详细布线",
