{
  "command": "flipOrRotateObject",
  "is_cmd": true,
  "summary": "翻转或旋转对象",
  "description": "该命令用于翻转或旋转指定的对象。用户可以选择沿X轴或Y轴进行翻转，或者按90度、180度、270度进行旋转。支持以组为单位操作选中的实例，并可选择保持相对位置关系。",
  "usage": "flipOrRotateObject [-help] [-group] [-keepRelative] {-flip <MX|MY> | -rotate <R90|R180|R270>} [-name <string> ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-flip",
      "description": "翻转轴（MX或MY）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-group",
      "description": "将所有选中的实例作为一个组进行旋转",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-keepRelative",
      "description": "调用相对布局命令",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "要翻转或旋转的对象名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rotate",
      "description": "旋转角度（R90、R180或R270）",
      "required": false,
      "type": "string"
    }
  ]
}