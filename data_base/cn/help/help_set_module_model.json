{
  "command": "set_module_model",
  "is_cmd": true,
  "summary": "设置模块模型",
  "description": "该命令用于配置和管理模块模型，例如设置模型的数据目录、类型、视图以及各种默认选项。它支持为特定单元或顶层模块设置模型，并允许强制更新模型。",
  "usage": "set_module_model [-help] [-allow_port_mismatch] [-dir <string>] [-hold_views <string>] [-phys_hier] [-setup_views <string>] [-tag <string>] [-type <string>] [-update] {[[[[-cell <string>] [-default_set_options <string>]] | [-top <string> [-logical_only ]]] [-add_ons <string>]] | -default_dir <string> | -default_create_options <string> | -default_commit_options <string> | -active_rc_corners <string> }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allow_port_mismatch",
      "description": "允许顶层I/O端口与原始数据库不匹配",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-dir",
      "description": "模型数据目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-hold_views",
      "description": "保持视图",
      "required": false,
      "type": "string"
    },
    {
      "name": "-phys_hier",
      "description": "建立物理层次结构",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-setup_views",
      "description": "设置视图",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tag",
      "description": "流程标签",
      "required": false,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "模块模型的类型，可选值包括：lef, flexIlm, ilm, pnr, pnr_shell",
      "required": false,
      "type": "string"
    },
    {
      "name": "-update",
      "description": "强制更新模型",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-active_rc_corners",
      "description": "活动的RC角点",
      "required": false,
      "type": "string"
    },
    {
      "name": "-add_ons",
      "description": "与 -type 参数关联的附加功能，例如：1801, boundary_model, etm, latency, pnr_view, scan_info, spef, timing_context, extraction_context",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "模块名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-default_commit_options",
      "description": "默认提交选项",
      "required": false,
      "type": "string"
    },
    {
      "name": "-default_create_options",
      "description": "默认创建选项",
      "required": false,
      "type": "string"
    },
    {
      "name": "-default_dir",
      "description": "默认模型数据目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-default_set_options",
      "description": "设置默认选项",
      "required": false,
      "type": "string"
    },
    {
      "name": "-logical_only",
      "description": "仅读入逻辑数据",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-top",
      "description": "顶层模块名称",
      "required": false,
      "type": "string"
    }
  ]
}