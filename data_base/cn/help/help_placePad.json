{
  "command": "placePad",
  "is_cmd": true,
  "summary": "放置焊盘命令",
  "description": "该命令用于在指定位置放置一个I/O单元（焊盘），并可选择性地指定其方向。",
  "usage": "placePad [-help] <pad_name> <location> [<orientation>]",
  "options": [
    {
      "name": "-help",
      "description": "打印出命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pad_name>",
      "description": "I/O单元的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<location>",
      "description": "新原点的坐标",
      "required": true,
      "type": "point"
    },
    {
      "name": "<orientation>",
      "description": "新的方向",
      "required": false,
      "type": "string"
    }
  ]
}