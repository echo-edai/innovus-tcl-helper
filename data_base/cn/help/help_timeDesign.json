{
  "command": "timeDesign",
  "is_cmd": true,
  "summary": "时序设计分析命令",
  "description": "timeDesign 命令用于执行时序分析，生成时序报告。它支持多种选项来控制报告的类型、范围、输出格式以及分析的阶段（如布局前、时钟树综合前/后、布线后等）。用户可以通过指定参数来生成违反路径报告、保持时间报告、设计规则违反报告等，并可以设置输出目录和文件前缀。",
  "usage": "timeDesign [-help] [-drvReports] [-expandReg2Reg] [-expandedViews] [-hold] [-idealClock] [-numPaths <integer>] [-outDir <string>] [-pathreports] [-prefix <string>] [-proto] [-reportOnly] [-slackReports] [-timingDebugReport] [-useTransitionFiles] [ -prePlace | -preCTS | -postCTS | -postRoute ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-drvReports",
      "description": "生成设计规则违反报告选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-expandReg2Reg",
      "description": "扩展寄存器到寄存器路径组选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-expandedViews",
      "description": "扩展视图选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hold",
      "description": "保持时间报告选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-idealClock",
      "description": "理想时钟选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-numPaths",
      "description": "路径数量选项",
      "required": false,
      "type": "int"
    },
    {
      "name": "-outDir",
      "description": "输出目录选项",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pathreports",
      "description": "生成路径报告选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-prefix",
      "description": "文件名前缀选项",
      "required": false,
      "type": "string"
    },
    {
      "name": "-proto",
      "description": "支持灵活模型",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reportOnly",
      "description": "仅生成报告选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-slackReports",
      "description": "生成裕量报告选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-timingDebugReport",
      "description": "时序调试报告选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-useTransitionFiles",
      "description": "使用转换文件选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-prePlace",
      "description": "布局前选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-preCTS",
      "description": "时钟树综合前选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-postCTS",
      "description": "时钟树综合后选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-postRoute",
      "description": "布线后选项",
      "required": false,
      "type": "flag"
    }
  ]
}