      "type": "flag"
    },
    {
      "name": "<dir>",
      "description": "输出目录路径",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "重置所有选项",
      "required": false,
      "type": "flag"
    }
  ]
}