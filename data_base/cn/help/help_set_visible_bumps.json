{
  "command": "set_visible_bumps",
  "is_cmd": true,
  "summary": "设置可见凸块",
  "description": "该命令用于控制设计中凸块（bump）的可见性。用户可以选择显示所有凸块，或仅显示基于指定凸块单元名称的凸块。",
  "usage": "set_visible_bumps [-help] { -bump_cells <string> | -all  }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "显示所有凸块",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bump_cells",
      "description": "仅显示基于指定凸块单元名称的凸块",
      "required": false,
      "type": "string"
    }
  ]
}