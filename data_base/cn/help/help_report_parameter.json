{
  "command": "report_parameter",
  "is_cmd": true,
  "summary": "报告参数信息",
  "description": "该命令用于报告指定的参数信息，可以指定参数名称、作用范围以及视图名称。",
  "usage": "report_parameter [-help] [-correlation] [-name <string>] -scope {vtskew wire_variation beol lle layout_effect} -view <string>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-correlation",
      "description": "报告相关性（布尔值，可选）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "参数名称（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-scope",
      "description": "参数作用范围（枚举，必需），可选值包括：vtskew, wire_variation, beol, lle, layout_effect",
      "required": true,
      "type": "enum"
    },
    {
      "name": "-view",
      "description": "视图名称（字符串，必需）",
      "required": true,
      "type": "string"
    }
  ]
}