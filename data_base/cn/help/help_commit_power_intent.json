{
  "command": "commit_power_intent",
  "is_cmd": true,
  "summary": "提交电源意图",
  "description": "该命令用于提交电源意图，支持提交隔离单元、电平转换器、电源域、电源开关和状态保持单元等电源管理相关对象。用户可以通过指定选项来控制提交的具体内容和详细程度，并可选择生成CLP日志文件或指定ECO（工程变更单）CPF文件。",
  "usage": "commit_power_intent [-help] [-clpLog <string>] [-eco <string>] [-isolation] [-keepRows] [-level_shifter] [-power_domain] [-power_switch] [-state_retention] [-verbose]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clpLog",
      "description": "CLP日志文件（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-eco",
      "description": "ECO CPF文件（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-isolation",
      "description": "提交隔离单元（布尔值，可选）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-keepRows",
      "description": "保留行（布尔值，可选）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-level_shifter",
      "description": "提交电平转换器（布尔值，可选）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-power_domain",
      "description": "提交电源域（布尔值，可选）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-power_switch",
      "description": "提交电源开关（布尔值，可选）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-state_retention",
      "description": "提交状态保持单元（布尔值，可选）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-verbose",
      "description": "详细模式（布尔值，可选）",
      "required": false,
      "type": "flag"
    }
  ]
}