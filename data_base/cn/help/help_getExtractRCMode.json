{
  "command": "getExtractRCMode",
  "is_cmd": true,
  "summary": "获取或设置RC提取模式",
  "description": "该命令用于获取或设置RC（电阻电容）提取的模式。它提供了丰富的选项来控制提取引擎、精度、阈值、文件路径以及各种高级功能，如是否考虑耦合电容、金属填充、使用增量模式等。用户可以通过指定不同的参数来配置提取过程，以满足从预布线到签核等不同设计阶段的需求。",
  "usage": "getExtractRCMode [-help] [-assumeMetFill] [-capFilterMode] [-cerebrus_license_only] [-compressOptMemRCDB] [-coupled] [-coupling_c_th] [-defViaCap] [-effortLevel] [-engine] [-extraCmdFile] [-extract_rc_quantus_executable] [-extract_rc_signoff_stream_layer_map_ccl] [-extractionFillStreamMapFile] [-hardBlockObs] [-incremental] [-iquantus_cap_high_accuracy_mode] [-layerIndependent] [-lefTechFileMap] [-localCpu] [-pvs_fill] [-qrcCmdFile] [-qrcCmdType] [-qrcOutputMode] [-qrcRunMode] [-relative_c_th] [-signoff_stream_layer_map] [-total_c_th] [-tQuantusModelFile] [-tsvSubcktFile] [-turboReduce] [-useQrcOAInterface] [-useShieldingInDetailMode] [-viaCap] [-writeDefOptionsForSignoffExtract] [-quiet] [-nonDefault]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-assumeMetFill",
      "description": "假设金属填充",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-capFilterMode",
      "description": "耦合电容过滤模式",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cerebrus_license_only",
      "description": "当Cerebrus不可用时，回退到常规QTS许可证",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-compressOptMemRCDB",
      "description": "创建压缩的RCDB",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-coupled",
      "description": "提取耦合电容",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-coupling_c_th",
      "description": "耦合电容阈值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-defViaCap",
      "description": "考虑通孔电容用于提取",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-effortLevel",
      "description": "指定后布线提取引擎的努力级别",
      "required": false,
      "type": "string"
    },
    {
      "name": "-engine",
      "description": "提取引擎",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extraCmdFile",
      "description": "Quantus QRC的额外命令文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extract_rc_quantus_executable",
      "description": "QRC可执行文件路径",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extract_rc_signoff_stream_layer_map_ccl",
      "description": "CCL格式的QRC流图文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extractionFillStreamMapFile",
      "description": "Quantus流/oasis文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-hardBlockObs",
      "description": "仅对硬模块，使障碍物和电源/地引脚形状对提取器可见",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-incremental",
      "description": "使用增量签核模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-iquantus_cap_high_accuracy_mode",
      "description": "用于iquantus电容高精度模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-layerIndependent",
      "description": "启用层独立提取",
      "required": false,
      "type": "int"
    },
    {
      "name": "-lefTechFileMap",
      "description": "LEF-QRCTechfile层映射文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-localCpu",
      "description": "本地CPU数量",
      "required": false,
      "type": "int"
    },
    {
