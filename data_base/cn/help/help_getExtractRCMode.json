      "description": "Quantus QRC用户命令文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-qrcCmdType",
      "description": "Quantus QRC命令输入类型",
      "required": false,
      "type": "string"
    },
    {
      "name": "-qrcOutputMode",
      "description": "Quantus QRC输出模式",
      "required": false,
      "type": "string"
    },
    {
      "name": "-qrcRunMode",
      "description": "Quantus QRC MMMC运行模式",
      "required": false,
      "type": "string"
    },
    {
      "name": "-relative_c_th",
      "description": "相对电容阈值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-signoff_stream_layer_map",
      "description": "QRC流图文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-total_c_th",
      "description": "总电容阈值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-tQuantusModelFile",
      "description": "TQuantus模型文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tsvSubcktFile",
      "description": "TSV子电路文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-turboReduce",
      "description": "减少XCap（IQuantus）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-useQrcOAInterface",
      "description": "使用OA接口调用Quantus QRC提取",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-useShieldingInDetailMode",
      "description": "考虑线段的屏蔽效应",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-viaCap",
      "description": "考虑通孔电容用于提取",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-writeDefOptionsForSignoffExtract",
      "description": "write_def选项",
      "required": false,
      "type": "string"
    },
    {
      "name": "-quiet",
      "description": "仅以Tcl列表格式显示当前设置",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-nonDefault",
      "description": "显示当前非默认设置",
      "required": false,
      "type": "flag"
    }
  ]
}