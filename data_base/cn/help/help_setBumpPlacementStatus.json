{
  "command": "setBumpPlacementStatus",
  "is_cmd": true,
  "summary": "设置凸点（Bump）的布局状态",
  "description": "此命令用于设置凸点（Bump）的布局状态，可以将其状态设置为已放置（PLACED）、固定（FIXED）或覆盖（COVER）。用户可以通过指定凸点名称或选择凸点来应用此状态。",
  "usage": "setBumpPlacementStatus [-help] {PLACED FIXED COVER} {-bumpName <string> | -selected}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "{PLACED FIXED COVER}",
      "description": "凸点布局状态（枚举值，必需）",
      "required": true,
      "type": "enum"
    },
    {
      "name": "-bumpName",
      "description": "凸点名称（字符串，必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-selected",
      "description": "对选中的凸点设置布局状态（布尔值，必需）",
      "required": true,
      "type": "bool"
    }
  ]
}