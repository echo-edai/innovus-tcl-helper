{
  "command": "placeInstance",
  "is_cmd": true,
  "summary": "放置一个实例到指定位置",
  "description": "该命令用于将一个实例（inst）放置到指定的坐标位置（location）。可以指定实例的新方向（orientation），并可选地将其标记为固定（fixed）、已放置（placed）或软固定（softFixed）状态。",
  "usage": "placeInstance [-help] <inst> <location> [{R0 R90 R180 R270 MX MX90 MY MY90}] [{ -fixed  | -placed  | -softFixed  }]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<inst>",
      "description": "实例名称",
      "required": true,
      "type": "inst"
    },
    {
      "name": "<location>",
      "description": "新原点的坐标点",
      "required": true,
      "type": "point"
    },
    {
      "name": "{R0 R90 R180 R270 MX MX90 MY MY90}",
      "description": "新的方向",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-fixed",
      "description": "将实例标记为固定",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-placed",
      "description": "将实例标记为已放置",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-softFixed",
      "description": "将实例标记为软固定",
      "required": false,
      "type": "flag"
    }
  ]
}