{
  "command": "route_pg",
  "is_cmd": true,
  "summary": "执行电源地网络布线",
  "description": "该命令用于根据PSDL（Power Switch Description Language）文件或默认设置，对电源和地网络进行布线。它提供了多种选项来控制布线行为，例如检查PSDL文件、连接悬空网络、删除悬空线、启用快速模式、跳过特定连接（如模块引脚或通孔）以及在出错时停止等。",
  "usage": "route_pg [-help] [-check_psdl_only] [-connect_floating_net <string>] [-delete_floating] [-fast] [-post_cut_color] [-psdl_file <file_name>] [-skip_block_pin] [-skip_partial_overlap_via] [-skip_physical_pin] [-skip_via] [-stop_on_error] [-use_full_pattern] [-use_namespace] [-write_psdl <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-check_psdl_only",
      "description": "仅对PSDL输入文件执行完整性检查",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-connect_floating_net",
      "description": "连接指定网络名的悬空线",
      "required": false,
      "type": "string"
    },
    {
      "name": "-delete_floating",
      "description": "移除悬空线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-fast",
      "description": "以快速模式生成电源地网络",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-post_cut_color",
      "description": "启用后切割颜色",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-psdl_file",
      "description": "PSDL输入文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-skip_block_pin",
      "description": "跳过与模块引脚的连接",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skip_partial_overlap_via",
      "description": "跳过在部分重叠交叉点上构建通孔",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skip_physical_pin",
      "description": "跳过在设计边界上创建物理引脚",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skip_via",
      "description": "跳过构建通孔对象",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-stop_on_error",
      "description": "如果PSDL文件中存在任何错误，则停止电源地布线过程",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-use_full_pattern",
      "description": "仅允许完整的PATTERN",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-use_namespace",
      "description": "为METAL ID使用命名空间",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-write_psdl",
      "description": "写入一个用于检查的PSDL文件",
      "required": false,
      "type": "string"
    }
  ]
}