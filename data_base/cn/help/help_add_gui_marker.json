{
  "command": "add_gui_marker",
  "is_cmd": true,
  "summary": "在图形用户界面中添加一个标记",
  "description": "该命令用于在EDA工具的图形用户界面（GUI）中创建一个可视化的标记。用户可以指定标记的颜色、名称、位置和形状类型，以在版图或设计视图中高亮显示特定点或区域。",
  "usage": "add_gui_marker [-help] -color <string> -name <string> -pt {x y} -type {X TICK STAR}",
  "options": [
    {
      "name": "-help",
      "description": "打印出此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-color",
      "description": "标记的颜色",
      "required": true,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "标记的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-pt",
      "description": "标记的位置坐标点",
      "required": true,
      "type": "point"
    },
    {
      "name": "-type",
      "description": "标记的形状类型，可选值为X、TICK或STAR",
      "required": true,
      "type": "enum"
    }
  ]
}