{
  "command": "resetPathGroupOptions",
  "is_cmd": true,
  "summary": "重置路径组选项",
  "description": "此命令用于重置指定路径组的配置选项，例如时序模式、松弛约束、优化等级等。通过指定路径组名称和相应的参数，可以清除或恢复该路径组的特定设置到默认状态。",
  "usage": "resetPathGroupOptions [-help] [<pathgroupName>] [-early] [-effortLevel] [-late] [-skewingSlackConstraint] [-slackAdjustment] [-slackAdjustmentPriority] [-targetSlack] [-view]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pathgroupName>",
      "description": "路径组名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-early",
      "description": "仅针对早期时序模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-effortLevel",
      "description": "优化等级选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-late",
      "description": "仅针对晚期时序模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skewingSlackConstraint",
      "description": "偏斜时的松弛约束",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-slackAdjustment",
      "description": "松弛调整选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-slackAdjustmentPriority",
      "description": "松弛调整优先级选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-targetSlack",
      "description": "目标松弛选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view",
      "description": "视图设置",
      "required": false,
      "type": "flag"
    }
  ]
}