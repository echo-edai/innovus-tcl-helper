{
  "command": "validate_pg_library",
  "is_cmd": true,
  "summary": "验证电源地（PG）库文件",
  "description": "该命令用于验证电源地（PG）库文件的有效性和正确性。它支持多种分析模式，包括静态和动态分析，可以检查IR压降、设置电源切换模式、指定分析频率和持续时间等。用户需要提供必需的单元名称和电源地库路径，其他参数如活动因子、时钟、温度、电压等可根据需要进行配置。",
  "usage": "validate_pg_library [-help] [-activity <string>] -cell <string> [-clock <string>] [-disable_rail_analysis {true false}] [-dynamic_analysis_duration <string>] [-enable_xp {true false}] [-extraction_include_file <string>] [-extraction_tech_file <string>] [-frequency <string>] [-input_pin_set_case_analysis_high <string>] [-input_pin_set_case_analysis_low <string>] [-liberty <string>] [-max_ir_drop <float>] [-net_capacitance <string>] [-output <string>] [-pgv_mode_dynamic_switch_pattern <string>] [-pin_capacitance <string>] -power_grid_library_path <string> [-power_grid_library_view <string>] [-power_include_file <string>] [-power_pad_size <float>] [-rail_analysis_type <string>] [-rail_include_file_begin <string>] [-rail_include_file_end <string>] [-rail_trigger_switching_pattern <string>] [-sdc_file <string>] [-set_power_switching_pattern <string>] [-set_total_power <string>] [-step_size <string>] [-supply_voltage <float>] [-tech_lef_file <string>] [-temperature <string>] [-transition_time <string>] [-twf_path <string>] [-user_defined_ploc_file <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-activity",
      "description": "活动因子，默认值为0.2",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "单元名称，必需参数",
      "required": true,
      "type": "string"
    },
    {
      "name": "-clock",
      "description": "时钟引脚列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-disable_rail_analysis",
      "description": "禁用轨道分析，默认值为false",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-dynamic_analysis_duration",
      "description": "动态分析持续时间，默认值为10ns",
      "required": false,
      "type": "string"
    },
    {
      "name": "-enable_xp",
      "description": "启用XP模式，默认值为false",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-extraction_include_file",
      "description": "提取包含文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extraction_tech_file",
      "description": "提取技术文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-frequency",
      "description": "频率，默认值为200MHz",
      "required": false,
      "type": "string"
    },
    {
      "name": "-input_pin_set_case_analysis_high",
      "description": "设置输入引脚为高电平的案例分析引脚列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-input_pin_set_case_analysis_low",
      "description": "设置输入引脚为低电平的案例分析引脚列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-liberty",
      "description": "库名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-max_ir_drop",
      "description": "最大IR压降，默认值为5（单位：%）",
      "required": false,
      "type": "float"
    },
    {
      "name": "-net_capacitance",
      "description": "网络电容，默认值为1pf",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output",
      "description": "输出目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pgv_mode_dynamic_switch_pattern",
      "description": "PGV模式动态切换模式",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pin_capacitance",
      "description": "引脚电容，默认值为1pf",
      "required": false,
      "type": "string"
    },
    {
      "name": "-power_grid_library_path",
      "description": "电源地库路径，必需参数",
      "required": true,
      "type": "string"
    },
    {
      "name": "-power_grid_library_view",
      "description": "视图名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-power_include_file",
      "description": "电源包含文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-power_pad_size",
      "description": "电源焊盘尺寸，默认值为50",
      "required": false,
      "type": "float"
    },
    {
      "name": "-rail_analysis_type",
      "description": "轨道分析类型，可选静态或动态",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rail_include_file_begin",
      "description": "轨道分析开始包含文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rail_include_file_end",
      "description": "轨道分析结束包含文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rail_trigger_switching_pattern",
      "description": "轨道触发切换模式",
      "required": false,
      "type": "string"
    },
    {
      "name": "-sdc_file",
      "description": "SDC文件路径",
      "required": false,
      "type": "string"
    },
    {
      "name": "-set_power_switching_pattern",
      "description": "设置电源动态切换模式",
      "required": false,
      "type": "string"
    },
    {
      "name": "-set_total_power",
      "description": "设置总功耗，默认值为0.001",
      "required": false,
      "type": "string"
    },
    {
      "name": "-step_size",
      "description": "步长，默认值为20ps",
      "required": false,
      "type": "string"
    },
    {
      "name": "-supply_voltage",
      "description": "供电电压，默认值为1（单位：V）",
      "required": false,
      "type": "float"
    },
    {
      "name": "-tech_lef_file",
      "description": "技术LEF文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-temperature",
      "description": "温度，默认值为125",
      "required": false,
      "type": "string"
    },
    {
      "name": "-transition_time",
      "description": "转换时间，默认值为1（100ps）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-twf_path",
      "description": "TWF文件位置",
      "required": false,
      "type": "string"
    },
    {
      "name": "-user_defined_ploc_file",
      "description": "用户定义的PLOC文件",
      "required": false,
      "type": "string"
    }
  ]
}