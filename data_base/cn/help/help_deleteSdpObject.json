{
  "command": "deleteSdpObject",
  "is_cmd": true,
  "summary": "删除SDP（特殊设计规划）对象",
  "description": "该命令用于删除指定的SDP对象、SDP组阻挡或清空指定实例前后的行。删除SDP对象时可以选择保留单元布局。",
  "usage": "deleteSdpObject [-help] {[-object {objName(s)} [-keepCellPlacement ]] | -obstruct {sdpGroupName(s)} | [-emptyRow <instName> [-numRow <val>]]}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-object",
      "description": "要删除的SDP对象的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-keepCellPlacement",
      "description": "删除SDP对象时保留单元布局",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-obstruct",
      "description": "要删除的SDP组阻挡的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-emptyRow",
      "description": "指定一个实例名称，将根据组对齐约束删除该实例前后空行",
      "required": false,
      "type": "string"
    },
    {
      "name": "-numRow",
      "description": "要删除的行数",
      "required": false,
      "type": "int"
    }
  ]
}