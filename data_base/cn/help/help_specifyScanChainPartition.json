{
  "command": "specifyScanChainPartition",
  "is_cmd": true,
  "summary": "指定扫描链分区",
  "description": "此命令用于为扫描链指定分区。通过指定分区名称，可以将特定的扫描链或所有扫描链分配到该分区中，以便于在物理实现和测试生成中进行组织和管理。",
  "usage": "specifyScanChainPartition [-help] -partition <partition_name> {-all  | {<chainName>}}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-partition",
      "description": "要指定的扫描分区名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-all",
      "description": "指定所有扫描链",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<chainName>",
      "description": "指定扫描链的名称",
      "required": false,
      "type": "string"
    }
  ]
}