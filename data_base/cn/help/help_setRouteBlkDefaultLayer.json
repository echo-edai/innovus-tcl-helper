{
  "command": "setRouteBlkDefaultLayer",
  "is_cmd": true,
  "summary": "设置布线阻塞的默认层属性",
  "description": "该命令用于设置布线阻塞（Route Blockage）的默认层属性。它可以指定金属层、切割层、修剪金属层或DRC区域层，或者通过一个选项为所有金属层和切割层设置'填充'（fill）属性。",
  "usage": "setRouteBlkDefaultLayer [-help] {{[-layer <layerZ|{layerZ list}|all>] [-cutLayer <layerZ|{layerZ list}|all>] [-trimMetalLayer <layerZ|{layerZ list}|all>] [-drcRegionLayer <layerZ|{layerZ list}|all>]} | {-allMetalCut }}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allMetalCut",
      "description": "为所有金属层和切割层设置'填充'（fill）属性",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cutLayer",
      "description": "指定切割层",
      "required": false,
      "type": "list"
    },
    {
      "name": "-drcRegionLayer",
      "description": "指定DRC区域层",
      "required": false,
      "type": "list"
    },
    {
      "name": "-layer",
      "description": "指定金属层",
      "required": false,
      "type": "list"
    },
    {
      "name": "-trimMetalLayer",
      "description": "指定修剪金属层",
      "required": false,
      "type": "list"
    }
  ]
}