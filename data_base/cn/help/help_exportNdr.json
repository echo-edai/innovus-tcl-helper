{
  "command": "exportNdr",
  "is_cmd": true,
  "summary": "导出非默认布线规则",
  "description": "该命令用于将指定的非默认布线（NDR）规则导出到DEF或LEF文件中。用户必须提供NDR规则的名称，并选择通过`-def`或`-lef`参数指定一个输出文件。",
  "usage": "exportNdr [-help] <ndrRuleName> {-def <file_name> | -lef <file_name>}",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<ndrRuleName>",
      "description": "要导出的NDR规则的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-def",
      "description": "指定输出DEF文件的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-lef",
      "description": "指定输出LEF文件的名称",
      "required": false,
      "type": "string"
    }
  ]
}