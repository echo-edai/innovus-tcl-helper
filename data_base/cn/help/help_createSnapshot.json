{
  "command": "createSnapshot",
  "is_cmd": true,
  "summary": "创建一个设计快照",
  "description": "该命令用于创建一个设计快照，将当前设计状态保存到指定目录。",
  "usage": "createSnapshot [-help] -dir <string> -name <string> [-overwrite]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-dir",
      "description": "保存快照的目录（字符串，必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "快照名称（字符串，必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-overwrite",
      "description": "将快照保存到已存在的目录（布尔值，可选）",
      "required": false,
      "type": "flag"
    }
  ]
}