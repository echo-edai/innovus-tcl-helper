{
  "command": "reportLengthViolation",
  "is_cmd": true,
  "summary": "报告长度违规",
  "description": "该命令用于报告设计中的长度违规情况。用户可以通过指定排除或选择的网络文件来过滤报告内容，并可选择输出到文件、生成直方图或设置有效数字位数。",
  "usage": "reportLengthViolation [-help] [-excNetFile <fileName>] [-histogram] [-outfile <fileName>] [-selNetFile <fileName>] [-significant_digits <integer>] [-all  | -noGlobalNets ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "报告所有选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-excNetFile",
      "description": "不报告的网络列表文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-histogram",
      "description": "打印直方图",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noGlobalNets",
      "description": "不包含全局网络选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-outfile",
      "description": "输出文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selNetFile",
      "description": "要报告的网络列表文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-significant_digits",
      "description": "有效数字位数选项",
      "required": false,
      "type": "int"
    }
  ]
}