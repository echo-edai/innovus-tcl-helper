  "usage": "reset_noise_lib_pin [-help] [-all] [-to <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "重置所有用户指定的噪声映射",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-to",
      "description": "重置用户指定的目标引脚的噪声映射",
      "required": false,
      "type": "string"
    }
  ]
}