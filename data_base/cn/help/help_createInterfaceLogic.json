{
  "command": "createInterfaceLogic",
  "is_cmd": true,
  "summary": "创建接口逻辑模型",
  "description": "该命令用于生成接口逻辑模型，支持多种选项以控制模型类型、输出目录、端口处理、优化阶段等行为。用户可以通过指定参数来定制模型生成过程，例如忽略特定端口、选择时序或SI模型类型、设置在时钟树综合前或后进行优化，以及控制是否覆盖现有文件等。",
  "usage": "createInterfaceLogic [-help] [-allowIlmEco] [-ignorePorts <string>] [-keepAll] [-keepSelected] [-modelType {timing si all}] [-noInterClockPath] [-optStage {preCTS postCTS}] [-overwrite] [-removePowerGround] [-dir <string> | -cellview <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allowIlmEco",
      "description": "允许ILM ECO（工程变更顺序）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cellview",
      "description": "指定库单元视图名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-dir",
      "description": "指定输出目录名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ignorePorts",
      "description": "忽略指定的端口名称列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-keepAll",
      "description": "保留所有内容",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-keepSelected",
      "description": "仅保留选中的内容",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-modelType",
      "description": "指定模型类型：时序（timing）、信号完整性（si）或全部（all）",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-noInterClockPath",
      "description": "禁用时钟间路径",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-optStage",
      "description": "指定优化阶段：时钟树综合前（preCTS）或时钟树综合后（postCTS）",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-overwrite",
      "description": "覆盖现有文件",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-removePowerGround",
      "description": "移除电源和地线",
      "required": false,
      "type": "flag"
    }
  ]
}