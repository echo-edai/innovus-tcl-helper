{
  "command": "saveWhatIfConstraints",
  "is_cmd": true,
  "summary": "保存假设情景约束",
  "description": "该命令用于将假设情景（What-If）分析中生成的约束保存到文件中。用户可以选择保存为特定格式（如PT或DC），并指定输出目录和文件前缀。",
  "usage": "saveWhatIfConstraints [-help] [<blackBoxCellName>] [-dir <dirName>] [-filePrefix <prefix>] [-pt | -dc]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<blackBoxCellName>",
      "description": "黑盒或黑块单元的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-dc",
      "description": "指定约束格式为DC",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-dir",
      "description": "指定输出目录名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-filePrefix",
      "description": "指定约束文件名的前缀",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pt",
      "description": "指定约束格式为PT",
      "required": false,
      "type": "flag"
    }
  ]
}