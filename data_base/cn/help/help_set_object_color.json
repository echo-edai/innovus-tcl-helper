{
  "command": "set_object_color",
  "is_cmd": true,
  "summary": "设置指定对象在图形界面中的显示颜色",
  "description": "该命令用于为设计中的特定对象（如实例、层次化实例、电源域、实例组等）或特定类型的对象设置颜色。可以通过指定颜色ID、使用多色模式或重置颜色来操作。还可以选择是否同时为层次化实例的子实例着色。",
  "usage": "set_object_color [-help] {[-object_name <InstOrHInstName> | -object_type <typeList>] [-multicolor  | -color_id <colorID>] [-include_children {off color multicolor}] [-reset ]}",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-color_id",
      "description": "指定颜色ID",
      "required": false,
      "type": "int"
    },
    {
      "name": "-include_children",
      "description": "决定是否同时为层次化实例的子实例着色。off：子实例不着色。color：子实例使用与其父实例相同的颜色。multicolor：对子实例使用多种颜色。",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-multicolor",
      "description": "对对象使用多种颜色",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-object_name",
      "description": "指定实例、层次化实例、电源域或实例组的名称，支持对象列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-object_type",
      "description": "指定对象类型列表，例如SDP、BusGuide、Module、PowerDomain、InstGroup等",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "重置对象的颜色",
      "required": false,
      "type": "flag"
    }
  ]
}