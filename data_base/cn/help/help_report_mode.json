{
  "command": "report_mode",
  "is_cmd": true,
  "summary": "报告指定实例的模式信息",
  "description": "此命令用于报告指定实例列表的模式信息。用户可以选择指定分析视图，并可将输出重定向到文件。",
  "usage": "report_mode [-help] <instance_list> [-view <view_name>] [> <filename[.gz]>] [>> <filename[.gz]>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<instance_list>",
      "description": "实例列表",
      "required": true,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "指定分析视图",
      "required": false,
      "type": "string"
    },
    {
      "name": ">",
      "description": "将输出重定向到指定文件",
      "required": false,
      "type": "redirect_operator"
    },
    {
      "name": ">>",
      "description": "将输出重定向到指定文件",
      "required": false,
      "type": "redirect_operator"
    }
  ]
}