{
  "command": "findLefEquivalentCells",
  "is_cmd": true,
  "summary": "查找LEF等效单元",
  "description": "该命令用于根据给定的单元名称，查找并报告其对应的LEF（库交换格式）等效单元。用户可以通过指定输出文件将结果保存。",
  "usage": "findLefEquivalentCells [-help] -cells <string> [-outFile <fileName>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cells",
      "description": "单元名称（字符串，必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-outFile",
      "description": "用于报告LEF等效单元的输出文件名（字符串，可选）",
      "required": false,
      "type": "string"
    }
  ]
}