{
  "command": "placePIO",
  "is_cmd": true,
  "summary": "放置焊盘输入输出单元（PIO）的命令",
  "description": "该命令用于在芯片布局中放置焊盘输入输出（PIO）单元。它提供了多种选项来指定要放置的IO单元或实例、应用额外的配置文件、优化初始放置以减少布线拥塞、指定电源域、设置IO行最大高度以及控制是否进行随机初始放置等。",
  "usage": "placePIO [-help] [-assignBump] [-cellList <{cellNamePattern}>] [-extraConfig <fileName>] [-instList <{instNamePattern}>] [-ioFile <fileName>] [-maxIOHeight] [-noRandomPlacement] [-optIOs] [-overflowMap] [-powerDomain <powerDomainName>] [-rdlConstraintFile <fileName>]",
  "options": [
    {
      "name": "-help",
      "description": "打印出命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-assignBump",
      "description": "允许重新分配信号凸点以改善布线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cellList",
      "description": "指定要放置的区域IO单元",
      "required": false,
      "type": "string"
    },
    {
      "name": "-extraConfig",
      "description": "指定额外的配置文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instList",
      "description": "指定要放置的区域IO实例",
      "required": false,
      "type": "string"
    },
    {
      "name": "-ioFile",
      "description": "指定IO文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-maxIOHeight",
      "description": "指定IO行的最大高度",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noRandomPlacement",
      "description": "不进行随机的初始IO放置",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-optIOs",
      "description": "优化初始放置以改善布线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-overflowMap",
      "description": "显示拥塞图",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-powerDomain",
      "description": "在指定电源域的行中放置IO",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rdlConstraintFile",
      "description": "指定rdl约束文件",
      "required": false,
      "type": "string"
    }
  ]
}