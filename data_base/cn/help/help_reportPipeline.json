{
  "command": "reportPipeline",
  "is_cmd": true,
  "summary": "报告流水线分析结果",
  "description": "该命令用于生成流水线（pipeline）的分析报告。用户可以通过指定参数来控制报告的内容和输出方式，例如指定网络组、设置最大间距、基于时序或PSPM模型自动查找间距，以及将报告输出到指定文件。",
  "usage": "reportPipeline [-help] [-netGroup <netGroupNames>] [{-spacing <val> | -timingBased  | -psPMBased } [-file <fileName>]]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "分析报告的文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-netGroup",
      "description": "网络组的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-psPMBased",
      "description": "使用PSPM模型自动查找最大间距",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-spacing",
      "description": "触发器之间的最大间距",
      "required": false,
      "type": "float"
    },
    {
      "name": "-timingBased",
      "description": "自动查找最大间距",
      "required": false,
      "type": "flag"
    }
  ]
}