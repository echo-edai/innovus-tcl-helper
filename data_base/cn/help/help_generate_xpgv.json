{
  "command": "generate_xpgv",
  "is_cmd": true,
  "summary": "生成XPGV文件",
  "description": "该命令用于生成XPGV（X-Propagation Guard Vector）文件。用户必须通过指定单元名称，并选择提供状态目录或MVMF配置文件来执行。命令还支持可选参数，如指定实例列表、库生成包含文件、输出目录、电源轨包含文件以及重用块状态目录。",
  "usage": "generate_xpgv [-help] -cell <string> [-inst_list <string>] [-libgen_include <string>] [-output_dir <string>] [-rail_include <string>] [-reuse_block_state_directory <string>] {-state_directory <string> | -mvmf_config <string>}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "指定目标单元名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-inst_list",
      "description": "指定实例列表文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-libgen_include",
      "description": "指定库生成包含文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-mvmf_config",
      "description": "指定MVMF配置文件（与-state_directory互斥，必须二选一）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output_dir",
      "description": "指定输出目录，默认为当前目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-rail_include",
      "description": "指定电源轨包含文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reuse_block_state_directory",
      "description": "指定重用块状态目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-state_directory",
      "description": "指定状态目录（与-mvmf_config互斥，必须二选一）",
      "required": false,
      "type": "string"
    }
  ]
}