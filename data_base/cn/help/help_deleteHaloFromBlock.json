{
  "command": "deleteHaloFromBlock",
  "is_cmd": true,
  "summary": "从指定模块实例中删除光环（Halo）约束",
  "description": "该命令用于从一个或多个模块实例（如宏单元、黑盒、分区、模块、IO焊盘等）中移除其周围定义的光环（Halo）约束。光环是一种物理约束，用于在布局时在模块周围预留一定的禁止布线或放置区域。用户可以通过指定具体的实例名称、单元名称，或使用选项（如-allMacro、-allBlock等）来批量选择目标。",
  "usage": "deleteHaloFromBlock [-help] [<inst_name> | -allMacro  | -allBlackBox  | -allCommitPtn  | -allBlock  | -allIOPad  | -cell <name>]",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<inst_name>",
      "description": "目标模块的实例名称（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-allBlackBox",
      "description": "针对所有黑盒（blackBox）模块",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allBlock",
      "description": "针对所有模块（block）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allCommitPtn",
      "description": "针对所有分区（partition）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allIOPad",
      "description": "针对所有IO焊盘",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allMacro",
      "description": "针对所有宏单元（Macro）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "根据单元名称（cell name）选择目标",
      "required": false,
      "type": "string"
    }
  ]
}