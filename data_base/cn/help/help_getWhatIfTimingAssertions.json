{
  "command": "getWhatIfTimingAssertions",
  "is_cmd": true,
  "summary": "获取假设性时序约束",
  "description": "该命令用于获取与指定端口或黑盒/黑团单元相关的假设性时序约束。用户可以通过指定端口名称或黑盒单元名称来查询相应的时序断言信息，并可以选择以Tcl列表的格式输出结果。",
  "usage": "getWhatIfTimingAssertions [-help] -port <portName> [-tclList] { <blackBoxCellName>}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<blackBoxCellName>",
      "description": "黑盒或黑团单元的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-port",
      "description": "指定一个或多个端口的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-tclList",
      "description": "将规范生成为Tcl列表",
      "required": false,
      "type": "flag"
    }
  ]
}