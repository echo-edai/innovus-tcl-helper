{
  "command": "verifyPowerDomain",
  "is_cmd": true,
  "summary": "验证电源域",
  "description": "该命令用于验证设计中的电源域。它可以检查实例是否在指定域内、验证天线二极管、隔离、电源开关、保持单元等结构，进行库绑定和电压检查，以及执行放置规则检查。支持生成DRC违规标记文件。",
  "usage": "verifyPowerDomain [-help] [-allInstInPD] [-antennaDiode {fileName ...}] [-aoBufferType] [-bind] [-cell_bind {cell ...}] [-drcFile <string>] [-isoNetPD {fileName ...}] [-libBindingVoltage] [-noFTermIsoC] [-noFTermShifter] [-powerSwitch {fileName ...}] [-pwrWithinMinGap] [-retention {fileName ...}] [-xNetPD {fileName ...}] [-place  [-place_rpt <string>]] [-gconn {module ...} [-aobBiasConn ]]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allInstInPD",
      "description": "检查所有实例是否在域内",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-antennaDiode",
      "description": "验证天线二极管",
      "required": false,
      "type": "string"
    },
    {
      "name": "-aoBufferType",
      "description": "检查域内的AOB类型",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bind",
      "description": "验证库绑定",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell_bind",
      "description": "单元格列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-drcFile",
      "description": "创建设计规则检查(DRC)违规标记并保存到指定文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-isoNetPD",
      "description": "验证隔离",
      "required": false,
      "type": "string"
    },
    {
      "name": "-libBindingVoltage",
      "description": "根据绑定库检查电压",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noFTermIsoC",
      "description": "忽略隔离的fterm",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noFTermShifter",
      "description": "忽略移位器的fterm",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-place",
      "description": "检查布局",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-place_rpt",
      "description": "布局输出文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-powerSwitch",
      "description": "验证电源开关",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pwrWithinMinGap",
      "description": "检查环形结构是否在最小间隙内",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-retention",
      "description": "验证保持单元",
      "required": false,
      "type": "string"
    },
    {
      "name": "-xNetPD",
      "description": "验证移位器",
      "required": false,
      "type": "string"
    },
    {
      "name": "-gconn",
      "description": "模块列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-aobBiasConn",
      "description": "检查AOB偏置网络连接",
      "required": false,
      "type": "flag"
    }
  ]
}