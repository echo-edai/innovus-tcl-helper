{
  "command": "createRegion",
  "is_cmd": true,
  "summary": "创建一个区域",
  "description": "该命令用于创建一个模块或组的约束区域。可以指定区域名称、边界框，并可选地创建浮动围栏或区域。",
  "usage": "createRegion [-help] <obj_name> <box> [-floating]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<obj_name>",
      "description": "模块或组的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<box>",
      "description": "约束框，格式为 <左下角x> <左下角y> <右上角x> <右上角y>",
      "required": true,
      "type": "box"
    },
    {
      "name": "-floating",
      "description": "创建浮动围栏/区域",
      "required": false,
      "type": "bool"
    }
  ]
}