{
  "command": "saveIoFile",
  "is_cmd": true,
  "summary": "保存I/O约束文件",
  "description": "该命令用于将当前的I/O约束信息保存到指定的文件中。用户可以选择包含IO实例的单元名称、仅保存选中的凸块、保存相对于底边的方向、使用版本2语法、保存模板文件、指定IO顺序或保存位置等选项。",
  "usage": "saveIoFile [-help] <fileName> [-includeCellName] [-only_selected_bump] [-relativeOrient] [-v2] [-temp  [-ioOrder <string>]] [-locations  | -byOrder ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<fileName>",
      "description": "I/O约束文件的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-includeCellName",
      "description": "若指定此选项，IO文件将包含IO实例的单元名称",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-only_selected_bump",
      "description": "仅将选中的凸块保存到文件",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-relativeOrient",
      "description": "保存相对于底边的方向",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-v2",
      "description": "使用版本2语法保存",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-temp",
      "description": "保存模板文件",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ioOrder",
      "description": "模板文件中的顺序：默认(default)、顺时针(clockwise)、逆时针(counterclockwise)",
      "required": false,
      "type": "string"
    },
    {
      "name": "-locations",
      "description": "保存位置",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-byOrder",
      "description": "按顺序保存",
      "required": false,
      "type": "flag"
    }
  ]
}