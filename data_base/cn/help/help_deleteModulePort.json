{
  "command": "deleteModulePort",
  "is_cmd": true,
  "summary": "删除模块端口",
  "description": "该命令用于从指定模块中删除一个端口。可以指定模块名称和端口名称，对于总线端口，还可以通过可选的 -bus 参数指定其位范围。",
  "usage": "deleteModulePort [-help] <moduleName> <portName> [-bus <startId:endId>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<moduleName>",
      "description": "模块名称，使用 '-' 表示根模块",
      "required": true,
      "type": "string"
    },
    {
      "name": "<portName>",
      "description": "要删除的端口名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-bus",
      "description": "指定总线端口的起始位和结束位，格式为 startId:endId",
      "required": false,
      "type": "string"
    }
  ]
}