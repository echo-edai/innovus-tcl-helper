{
  "command": "analyze_package",
  "is_cmd": true,
  "summary": "执行封装分析，用于直流或瞬态分析",
  "description": "该命令用于对芯片封装进行电气分析，支持直流（dc）和瞬态（transient）两种分析类型。用户可以指定封装提取的SPD文件、输出目录、结果名称、计算机资源、工作空间以及相关的电路名称和引脚电流文件。对于多芯片情况，可以指定多个电路和文件。",
  "usage": "analyze_package [-help] [-computer_resources <string>] [-output <string>] [-result_name <string>] [-spd_file <string>] -type {dc transient} { [<domain> [-workspace <string>] [-pkg_die_name <string>] [-pkg_bga_name <string>] [-pkg_pin_current_file <string>] ]}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<domain>",
      "description": "电源完整性分析域名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-computer_resources",
      "description": "设置计算机资源",
      "required": false,
      "type": "string"
    },
    {
      "name": "-output",
      "description": "封装模型输出目录",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pkg_bga_name",
      "description": "指定BGA电路",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pkg_die_name",
      "description": "指定芯片电路",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pkg_pin_current_file",
      "description": "指定来自电源完整性分析的引脚电流文件，或多芯片情况下的电路与文件对列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-result_name",
      "description": "工具将生成 output/result_name.xml 文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-spd_file",
      "description": "封装提取的SPD文件",
      "required": false,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "指定分析类型：直流（dc）或瞬态（transient）",
      "required": true,
      "type": "enum"
    },
    {
      "name": "-workspace",
      "description": "封装分析工作空间",
      "required": false,
      "type": "string"
    }
  ]
}