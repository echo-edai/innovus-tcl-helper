    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-layer",
      "description": "当前活动层（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "重置温度图显示（布尔值，可选）",
      "required": false,
      "type": "flag"
    }
  ]
}