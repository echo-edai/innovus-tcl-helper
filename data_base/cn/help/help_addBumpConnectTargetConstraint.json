{
  "command": "addBumpConnectTargetConstraint",
  "is_cmd": true,
  "summary": "添加凸块连接目标约束",
  "description": "该命令用于为指定的凸块（bump）或选中的凸块添加连接目标约束。约束可以指定连接到特定的实例（inst）、引脚（pin）、网络（net）或电源地（PG）连接类型（如环、条带等）。",
  "usage": "addBumpConnectTargetConstraint [-help] {-bump <string> | -selected } {{-instName <string> [{-pinName <string> | -netName <string>} [-portNum <integer>]]} | -PGConnectType {ioring corering stripe iopin}}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-PGConnectType",
      "description": "电源地连接类型（枚举值：ioring, corering, stripe, iopin）",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-bump",
      "description": "在指定的凸块上添加连接目标约束",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instName",
      "description": "连接目标实例名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-netName",
      "description": "连接目标网络名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pinName",
      "description": "连接目标引脚名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-portNum",
      "description": "连接目标端口号",
      "required": false,
      "type": "int"
    },
    {
      "name": "-selected",
      "description": "在选中的凸块上添加连接目标约束",
      "required": false,
      "type": "flag"
    }
  ]
}