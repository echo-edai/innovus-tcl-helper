{
  "command": "createPinGuide",
  "is_cmd": true,
  "summary": "创建引脚引导",
  "description": "该命令用于创建引脚引导（Pin Guide）。引脚引导用于定义引脚在版图边界上的放置区域和规则。可以通过指定区域坐标或版图边缘、金属层、以及关联的引脚、引脚组、网络或网络组等参数来配置。",
  "usage": "createPinGuide [-help] {[ -area {x1 y1 x2 y2} | [-edge <integer> [[-offset_start <float>] [-offset_end <float>]]] ] [ -layer {layeridList} [-layerPriority ]]} [-pin <string> | -pinGroup <string> | -net <string> | -netGroup <string> | -name <string> ] [-edge <integer> | -net <string> | -netGroup <string>] [-cell <string> | -net <string> | -netGroup <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-area",
      "description": "指定引脚引导区域的坐标（x1 y1 x2 y2）。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "指定单元的名称。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-edge",
      "description": "指定边缘编号的整数值，编号从分区的左下角开始顺时针计算。",
      "required": false,
      "type": "int"
    },
    {
      "name": "-layer",
      "description": "指定引脚引导的金属层。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-layerPriority",
      "description": "指定引脚应根据层顺序进行分配。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "指定分区引脚引导对象的名称。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-net",
      "description": "对于网络，指定网络名称；对于总线，指定总线名称或总线基数。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-netGroup",
      "description": "指定网络组的名称。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-offset_end",
      "description": "指定距离边缘结束角的距离（微米）。",
      "required": false,
      "type": "float"
    },
    {
      "name": "-offset_start",
      "description": "指定距离边缘起始角的距离（微米）。",
      "required": false,
      "type": "float"
    },
    {
      "name": "-pin",
      "description": "指定引脚的名称。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-pinGroup",
      "description": "指定引脚组的名称。",
      "required": false,
      "type": "string"
    }
  ]
}