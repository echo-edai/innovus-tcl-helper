{
  "command": "ecoDefIn",
  "is_cmd": true,
  "summary": "导入ECO（工程变更单）DEF文件",
  "description": "该命令用于导入一个包含工程变更单（ECO）信息的DEF（设计交换格式）文件。它允许用户指定各种选项来控制导入过程，例如是否清理前端数据、是否保留实例位置、为浮动布线指定电源地网络、应用掩模后处理、生成报告文件、添加后缀以及使用特定类型的单元。",
  "usage": "ecoDefIn [-help] <fileName> [-cleanFEData] [-ecoDef <fileName>] [-keepInstLoc] [-mergeFloatingRouteToPGNet <netName>] [-postMask] [-reportFile <fileName>] [-suffix <suffixVal>] [-useGACells <val>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<fileName>",
      "description": "要导入的DEF文件名",
      "required": true,
      "type": "string"
    },
    {
      "name": "-cleanFEData",
      "description": "清理前端数据",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ecoDef",
      "description": "指定ECO DEF文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-keepInstLoc",
      "description": "保留实例位置",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-mergeFloatingRouteToPGNet",
      "description": "将浮动布线合并到指定的电源地网络",
      "required": false,
      "type": "string"
    },
    {
      "name": "-postMask",
      "description": "启用掩模后处理后缀",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reportFile",
      "description": "指定报告文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-suffix",
      "description": "指定后缀字符串",
      "required": false,
      "type": "string"
    },
    {
      "name": "-useGACells",
      "description": "使用GA（门阵列）单元",
      "required": false,
      "type": "string"
    }
  ]
}