{
  "command": "hilite_proto_model",
  "is_cmd": true,
  "summary": "高亮原型模型对象",
  "description": "该命令用于在EDA工具中高亮显示原型模型对象，例如Flex模块、Flex实例组、分区或电源域。它允许用户指定高亮的层级范围或重置现有高亮。",
  "usage": "hilite_proto_model [-help] [-keep_existing_hilite] [-type {flex_module flex_instgroup partition power_domain}] -reset  | -level <integer> | {[-min_level <integer>] [-max_level <integer>]}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-keep_existing_hilite",
      "description": "在现有高亮对象的基础上添加高亮",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-level",
      "description": "要高亮的层级",
      "required": false,
      "type": "int"
    },
    {
      "name": "-max_level",
      "description": "要高亮的最高层级",
      "required": false,
      "type": "int"
    },
    {
      "name": "-min_level",
      "description": "要高亮的最低层级",
      "required": false,
      "type": "int"
    },
    {
      "name": "-reset",
      "description": "取消高亮已高亮的对象",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-type",
      "description": "设置要高亮的类型，默认值为flex_module和flex_instgroup",
      "required": false,
      "type": "enum_list"
    }
  ]
}