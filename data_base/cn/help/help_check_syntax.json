{
  "command": "check_syntax",
  "is_cmd": true,
  "summary": "检查TCL脚本语法",
  "description": "该命令用于检查一个或多个TCL脚本文件的语法。它基于nagelfar.tcl工具，可以列出所有合法的nagelfar选项，并将输出重定向到指定文件。",
  "usage": "check_syntax [-help] [file1.tcl file2.tcl ...] [<nagelfar.tcl options>] [-options] [-out_file <file>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<file1.tcl file2.tcl ...>",
      "description": "需要检查的文件（可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "<nagelfar.tcl options>",
      "description": "nagelfar.tcl工具的选项（可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-options",
      "description": "列出所有合法的nagelfar选项（可选）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-out_file",
      "description": "将输出发送到指定文件，而不是默认的标准输出（可选）",
      "required": false,
      "type": "string"
    }
  ]
}