{
  "command": "ecoOaDesign",
  "is_cmd": true,
  "summary": "导入或处理OpenAccess设计以进行工程变更命令",
  "description": "该命令用于导入或处理一个OpenAccess设计，以便进行工程变更（ECO）操作。它需要指定OpenAccess库、单元和视图，并接受一个Verilog网表文件作为输入。命令支持生成报告文件、指定后缀名以及使用特定单元等可选功能。",
  "usage": "ecoOaDesign [-help] <lib> <cell> <view> -ecoVerilogFile <input_fileName> [-reportFile <output_fileName>] [-useGACells <string>] [-postMask  [-suffix <suffix_name>]]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<lib>",
      "description": "指定OpenAccess库名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<cell>",
      "description": "指定要导入的顶层单元的OpenAccess单元名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "<view>",
      "description": "指定要导入的OpenAccess视图名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-ecoVerilogFile",
      "description": "指定一个Verilog网表文件",
      "required": true,
      "type": "string"
    },
    {
      "name": "-postMask",
      "description": "指定后掩模选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reportFile",
      "description": "指定一个报告文件。默认值为：eco.log",
      "required": false,
      "type": "string"
    },
    {
      "name": "-suffix",
      "description": "为备用单元指定后缀名。默认值为：_SPARE",
      "required": false,
      "type": "string"
    },
    {
      "name": "-useGACells",
      "description": "指定GA核心站点",
      "required": false,
      "type": "string"
    }
  ]
}