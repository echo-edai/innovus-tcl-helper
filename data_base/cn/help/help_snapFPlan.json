{
  "command": "snapFPlan",
  "is_cmd": true,
  "summary": "将布局规划对象（如单元、引脚、阻挡等）的几何形状捕捉到设计网格或指定位置。",
  "description": "该命令用于将布局规划中的各种对象（例如标准单元、I/O单元、引脚、布线阻挡、放置阻挡等）的几何形状对齐到设计网格或特定的捕捉位置。用户可以通过参数选择要处理的对象类型。",
  "usage": "snapFPlan [-help] { {-all } | {-selected } | {[-guide ][-block ][-stdCell ][-ioPad ][-areaIo ][-ptnCore ][-pinGuide ][-routeBlk ][-placeBlk ][-macroPin ][-pin ][-pinBlk ]}}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "捕捉所有支持的对象。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-selected",
      "description": "捕捉当前选中的对象。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-guide",
      "description": "捕捉引导约束。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-block",
      "description": "捕捉模块单元。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-stdCell",
      "description": "捕捉标准单元。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ioPad",
      "description": "捕捉I/O单元。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-areaIo",
      "description": "捕捉I/O单元。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ptnCore",
      "description": "捕捉分区。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pinGuide",
      "description": "捕捉引脚引导。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-routeBlk",
      "description": "捕捉布线阻挡。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-placeBlk",
      "description": "捕捉放置阻挡。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-macroPin",
      "description": "根据引脚位置与DPT轨道的关系捕捉宏单元。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pin",
      "description": "捕捉I/O引脚。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pinBlk",
      "description": "捕捉引脚阻挡。",
      "required": false,
      "type": "flag"
    }
  ]
}