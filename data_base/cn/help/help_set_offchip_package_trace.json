{
  "command": "set_offchip_package_trace",
  "is_cmd": true,
  "summary": "设置芯片外封装走线模型",
  "description": "该命令用于定义芯片外部的封装走线模型。它允许用户通过指定名称、引脚位置文件列表、SPICE模型和映射文件来创建一个走线模型。可以选择性地指定顶层子电路名称，或者使用-reset选项清除所有先前设置的模型。",
  "usage": "set_offchip_package_trace [-help] -reset  | {-name <string> -ploc_file_list <string> -spice <string> -mapping <string> [-subckt <string>] }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "重置所有先前通过set_offchip_package_trace命令设置的模型",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "走线模型的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-ploc_file_list",
      "description": "凸点位置文件的列表",
      "required": true,
      "type": "string"
    },
    {
      "name": "-spice",
      "description": "SPICE模型文件",
      "required": true,
      "type": "string"
    },
    {
      "name": "-mapping",
      "description": "映射文件",
      "required": true,
      "type": "string"
    },
    {
      "name": "-subckt",
      "description": "顶层子电路名称",
      "required": false,
      "type": "string"
    }
  ]
}