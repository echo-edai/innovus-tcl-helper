{
  "command": "set_cdb_binding",
  "is_cmd": true,
  "summary": "设置CDB绑定关系",
  "description": "该命令用于将一个CDB文件中的单元绑定到指定的库文件。",
  "usage": "set_cdb_binding [-help] -from <string> -to <string>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-from",
      "description": "CDB文件名和单元名（字符串，必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-to",
      "description": "库文件名（字符串，必需）",
      "required": true,
      "type": "string"
    }
  ]
}