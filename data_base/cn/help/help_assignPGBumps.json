{
  "command": "assignPGBumps",
  "is_cmd": true,
  "summary": "分配电源地凸块",
  "description": "该命令用于将指定的电源或地网络分配到芯片上的凸块（bump）。用户可以通过多种模式（如水平、垂直、棋盘格）和连接类型（如环状、条状）来控制分配方式，并可以指定特定的凸块或网络进行分配。",
  "usage": "assignPGBumps [-help] [-connectType {ioring corering stripe iopin}] -nets <net+> [-V  | -H  | -checkerboard ] [-selected  | -floating  | -bumps <bump+>] [-checkerboard  [-square <width height>]]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-connectType",
      "description": "指定凸块的连接类型",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-nets",
      "description": "指定要分配的网络名称",
      "required": true,
      "type": "net+"
    },
    {
      "name": "-V",
      "description": "指定凸块分配样式为垂直",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-H",
      "description": "指定凸块分配样式为水平",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-checkerboard",
      "description": "指定凸块分配样式为棋盘格",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-selected",
      "description": "分配到选定的凸块",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-floating",
      "description": "分配到浮动的凸块",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-bumps",
      "description": "指定要分配的凸块",
      "required": false,
      "type": "bump+"
    },
    {
      "name": "-square",
      "description": "指定棋盘格方块的宽度和高度",
      "required": false,
      "type": "point"
    }
  ]
}