{
  "command": "write_module_model_context",
  "is_cmd": true,
  "summary": "写入模块模型上下文",
  "description": "该命令用于将指定单元的模块模型上下文信息写入输出文件。用户需要指定单元名称和上下文类型（提取上下文或时序上下文），并可选择性地提供主/克隆实例名称、输出标签名以及类型特定的选项。",
  "usage": "write_module_model_context [-help] -cell <name> [-master_clone_inst <name>] [-tag <name>] -type {extraction_context timing_context} [-type_specific_options <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "指定实例的单元名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-master_clone_inst",
      "description": "指定主/克隆的实例名称。如果实例有克隆，请使用此选项",
      "required": false,
      "type": "string"
    },
    {
      "name": "-tag",
      "description": "指定输出标签名称。默认值为 latest",
      "required": false,
      "type": "string"
    },
    {
      "name": "-type",
      "description": "指定要写入的模块模型类型，可选值为 extraction_context 或 timing_context",
      "required": true,
      "type": "enum"
    },
    {
      "name": "-type_specific_options",
      "description": "指定类型特定的选项",
      "required": false,
      "type": "string"
    }
  ]
}