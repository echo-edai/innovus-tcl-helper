{
  "command": "set_cell_binding",
  "is_cmd": true,
  "summary": "设置单元绑定",
  "description": "该命令用于将一个或多个指定的单元模式绑定到特定的库和视图上。通过指定库和视图，可以将单元抽象与具体的实现关联起来。",
  "usage": "set_cell_binding [-help] [-abstract ] [-lib <list_of_libs>] { -cell <list_of_cell_patterns> -view <list_of_views> }",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-abstract",
      "description": "抽象（布尔值，可选）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-lib",
      "description": "指定用于查找单元抽象的OpenAccess库（字符串，必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "指定一个或多个要替换的单元名称模式（字符串，必需）",
      "required": true,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "指定单元视图（字符串，必需）",
      "required": true,
      "type": "string"
    }
  ]
}