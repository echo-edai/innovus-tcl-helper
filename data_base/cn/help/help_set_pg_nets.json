{
  "command": "set_pg_nets",
  "is_cmd": true,
  "summary": "设置电源/地网络的电压属性",
  "description": "此命令用于为指定的电源或地网络（PG nets）设置电压值及其他相关属性，如阈值、容差和库绑定电压。它可用于定义芯片或封装级别的电源网络连接和电压规格。",
  "usage": "set_pg_nets [-help] [-die_instance_name <string>] [-force] [-pkg_net_name <string>] [-vu_limit <float>] -reset  | {-net <string> -voltage <float> [-lib_binding_voltage <float>] [-threshold <float>] [-tolerance <float>] }",
  "options": [
    {
      "name": "-help",
      "description": "打印此命令的使用说明",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-die_instance_name",
      "description": "指定芯片实例的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-force",
      "description": "跳过有效性检查",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-lib_binding_voltage",
      "description": "用于库绑定的电压值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-net",
      "description": "要设置的网络名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-pkg_net_name",
      "description": "指定封装侧的对应网络名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "重置所有电源/地网络数据",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-threshold",
      "description": "网络的电压阈值",
      "required": false,
      "type": "float"
    },
    {
      "name": "-tolerance",
      "description": "网络的电压容差",
      "required": false,
      "type": "float"
    },
    {
      "name": "-voltage",
      "description": "网络的电压值",
      "required": true,
      "type": "float"
    },
    {
      "name": "-vu_limit",
      "description": "电压单位限制值",
      "required": false,
      "type": "float"
    }
  ]
}