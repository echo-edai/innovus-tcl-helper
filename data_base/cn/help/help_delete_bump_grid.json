{
  "command": "delete_bump_grid",
  "is_cmd": true,
  "summary": "删除凸点网格",
  "description": "该命令用于删除指定的凸点网格。用户可以通过指定网格名称来删除特定的网格，或者使用选项删除所有凸点网格。",
  "usage": "delete_bump_grid [-help] [-grid_names <string> | -all ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "删除所有凸点网格",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-grid_names",
      "description": "指定要删除的凸点网格名称",
      "required": false,
      "type": "string"
    }
  ]
}