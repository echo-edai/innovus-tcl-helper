{
  "command": "setCycleBudgetRatio",
  "is_cmd": true,
  "summary": "设置时钟周期预算比例",
  "description": "该命令用于为特定的时钟路径设置周期预算比例。它可以指定路径的起点和终点（可以是顶层或特定分区），并应用相应的比例值。支持重置所有先前声明的比例预算。",
  "usage": "setCycleBudgetRatio [-help] {[[[{-fromTop | -fromPtn {hinst ratio}} {-toTop | -toPtn {hinst ratio}}] ] [-clock <string>]] | [-reset ]}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clock",
      "description": "应用比例预算的时钟名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-fromPtn",
      "description": "指定路径起始的分区及其比例",
      "required": false,
      "type": "string"
    },
    {
      "name": "-fromTop",
      "description": "指定路径起始于顶层",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "重置所有先前声明的比例预算",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-toPtn",
      "description": "指定路径结束的分区及其比例",
      "required": false,
      "type": "string"
    },
    {
      "name": "-toTop",
      "description": "指定路径结束于顶层",
      "required": false,
      "type": "flag"
    }
  ]
}