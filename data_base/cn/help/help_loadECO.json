{
  "command": "loadECO",
  "is_cmd": true,
  "summary": "加载工程变更命令",
  "description": "用于加载工程变更命令，从指定的增量文件中读取变更信息，并支持使用备用单元或特定核心单元等选项来应用这些变更。",
  "usage": "loadECO [-help] <fileName....> [-suffix <suffix>] [-verbose] [-postMask  | -useGACells <GACoreSiteName>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<fileName....>",
      "description": "增量文件名",
      "required": true,
      "type": "string"
    },
    {
      "name": "-postMask",
      "description": "使用备用单元",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-suffix",
      "description": "后缀名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-useGACells",
      "description": "核心单元站点名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-verbose",
      "description": "详细模式",
      "required": false,
      "type": "flag"
    }
  ]
}