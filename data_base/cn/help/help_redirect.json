{
  "command": "redirect",
  "is_cmd": true,
  "summary": "重定向命令输出到文件或变量",
  "description": "该命令用于将命令的标准输出、标准错误或标准输入重定向到指定的文件或Tcl变量。支持追加模式、同时输出到屏幕和文件/变量等多种操作模式。",
  "usage": "redirect [-help] [<file_or_var_name>] [<command>] [-tee] [-stdin | -append ] [-stdin | -variable ] [ -variable ] [-stderr | -stdin ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<file_or_var_name>",
      "description": "输出目标文件名或变量名",
      "required": false,
      "type": "string"
    },
    {
      "name": "<command>",
      "description": "要执行的命令",
      "required": false,
      "type": "string"
    },
    {
      "name": "-append",
      "description": "将标准输出/标准错误追加到文件",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-stderr",
      "description": "同时重定向标准错误",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-stdin",
      "description": "重定向标准输入",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-tee",
      "description": "将输出同时发送到屏幕和文件或变量",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-variable",
      "description": "重定向到Tcl变量",
      "required": false,
      "type": "flag"
    }
  ]
}