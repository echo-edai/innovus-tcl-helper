{
  "command": "reset_clock",
  "is_cmd": true,
  "summary": "重置时钟命令",
  "description": "该命令用于移除设计中指定的时钟或所有时钟。",
  "usage": "reset_clock [-help] {-all  | <clock_list>}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<clock_list>",
      "description": "时钟列表（字符串，可选）",
      "required": false,
      "type": "string"
    },
    {
      "name": "-all",
      "description": "移除设计中的所有时钟（布尔值，可选）",
      "required": false,
      "type": "flag"
    }
  ]
}