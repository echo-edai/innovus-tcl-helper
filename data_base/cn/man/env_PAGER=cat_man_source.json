{
  "command": "source",
  "is_cmd": true,
  "summary": "读取并执行文件中的命令（脚本）",
  "description": "该命令用于读取一个文件并执行其中的命令（脚本）。可以读取由 encrypt 命令创建的加密文件。要被 source 的文件，其文件名必须添加后缀 \"p\"，例如，test.tcl 被加密为 test.tclp。",
  "usage": "source [-help] filename [-quiet | -verbose | -echo]",
  "options": [
    {
      "name": "-help",
      "description": "描述命令的用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<filename>",
      "description": "指定要读取并执行的文件名",
      "required": true,
      "type": "string"
    },
    {
      "name": "-quiet",
      "description": "禁用详细输出模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-verbose",
      "description": "启用详细输出模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-echo",
      "description": "启用详细输出模式",
      "required": false,
      "type": "flag"
    }
  ]
}