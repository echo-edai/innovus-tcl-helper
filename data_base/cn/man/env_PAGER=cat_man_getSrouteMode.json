{
  "command": "getSrouteMode",
  "is_cmd": true,
  "summary": "获取特殊布线（Sroute）模式的当前配置",
  "description": "该命令用于查询当前特殊布线（Sroute）操作的所有配置参数。Sroute通常用于电源/地网络布线、Pad连接等特殊布线场景。此命令会列出所有可配置的选项及其当前状态，但不接受参数来修改这些设置。如需修改配置，请使用 `setSrouteMode` 命令。",
  "usage": "getSrouteMode [-help] [-allowWrongWayRoute] [-avoidOverCoreRowLayer] [-blockPinConnectRingPinCorners] [-blockPinRouteWithPinWidth] [-connectBrokenCorePin] [-corePinIgnoreObs] [-corePinJoinLimit] [-corePinLength] [-corePinLengthAsInstance] [-corePinMaxViaScale] [-corePinReferToFollowPin] [-corePinReferenceMacro] [-corePinSiteRailWidth] [-corePinSnapTo] [-corePinStopRoute] [-extendNearestTarget] [-jogThresholdRatio] [-layerNormalCost] [-layerWrongWayCost] [-nonDefault] [-padPinMinViaSize] [-padPinSplit] [-padRingLefConvention] [-secondaryPinMaxGap] [-secondaryPinRailWidth] [-signalPinAsPG] [-splitLongVia] [-srpgAonCellPin] [-targetNumber] [-targetSearchDistance] [-timeLimit] [-treatEndcapAsCore] [-treatWelltapAsEndcap] [-viaConnectToShape] [-viaThruToClosestRing] [-quiet]",
  "options": [
    {
      "name": "-help",
      "description": "显示此命令的帮助信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-allowWrongWayRoute",
      "description": "允许错误方向的布线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-avoidOverCoreRowLayer",
      "description": "避免在核心单元行层上方布线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-blockPinConnectRingPinCorners",
      "description": "连接模块引脚与环形引脚拐角",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-blockPinRouteWithPinWidth",
      "description": "使用引脚宽度进行模块引脚布线",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-connectBrokenCorePin",
      "description": "连接断开的核芯引脚",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-corePinIgnoreObs",
      "description": "核芯引脚布线时忽略障碍物",
