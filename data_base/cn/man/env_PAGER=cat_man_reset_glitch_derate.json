{
  "command": "reset_glitch_derate",
  "is_cmd": true,
  "summary": "移除先前使用set_glitch_derate命令设置的毛刺波形降额因子",
  "description": "该命令用于移除先前通过set_glitch_derate命令设置的毛刺波形降额因子。可以通过指定参数来重置特定的降额属性，如高度、宽度、偏移量，或针对特定的引脚、实例引脚、视图和毛刺类型进行操作。",
  "usage": "reset_glitch_derate [-help] [-derate_height] [-derate_width] [-glitch_type <string>] [-instance_pin <string>] [-offset] [-pin <string>] [-view <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-derate_height",
      "description": "重置降额高度因子",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-derate_width",
      "description": "重置降额宽度因子",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-glitch_type",
      "description": "指定毛刺类型：vl、vh或both",
      "required": false,
      "type": "string"
    },
    {
      "name": "-instance_pin",
      "description": "指定需要重置降额因子的实例引脚名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-offset",
      "description": "重置降额偏移因子",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-pin",
      "description": "指定需要重置降额因子的库引脚名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "指定视图名称",
      "required": false,
      "type": "string"
    }
  ]
}