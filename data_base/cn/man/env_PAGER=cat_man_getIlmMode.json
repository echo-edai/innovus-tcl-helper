{
  "command": "getIlmMode",
  "is_cmd": true,
  "summary": "显示指定 setIlmMode 参数的配置信息",
  "description": "该命令用于在 Innovus 日志文件和 Innovus 控制台中显示指定 setIlmMode 参数的详细信息。显示内容包括参数名称、当前值、参数类型（如布尔型、字符串型等）以及当前值是否由用户设置。如果未指定任何参数，软件将显示所有 setIlmMode 参数的信息。",
  "usage": "getIlmMode [-filterInternalPath] [-ilm] [-ilm <ilmName>] [-keepAsync {true|false}] [-keepFlatten {true|false}] [-keepHighFanoutPorts {true|false}] [-keepInstInSdc {true|false}] [-keepLoopBack {true|false}] [-map {view|corner}] [-maxNumInsts] [-maxNumRegisters] [-resetMap {view|corner}] [-slackDriven] [-top <topViewName>] [-quiet]",
  "options": [
    {
      "name": "-filterInternalPath",
      "description": "过滤内部路径信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ilm",
      "description": "指定 ILM（Interface Logic Model）",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ilm <ilmName>",
      "description": "指定具体的 ILM 名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-keepAsync {true|false}",
      "description": "设置是否保持异步路径",
      "required": false,
      "type": "string"
    },
    {
      "name": "-keepFlatten {true|false}",
      "description": "设置是否保持扁平化",
      "required": false,
      "type": "string"
    },
    {
      "name": "-keepHighFanoutPorts {true|false}",
      "description": "设置是否保持高扇出端口",
      "required": false,
      "type": "string"
    },
    {
      "name": "-keepInstInSdc {true|false}",
      "description": "设置是否在 SDC 中保持实例",
      "required": false,
      "type": "string"
    },
    {
      "name": "-keepLoopBack {true|false}",
      "description": "设置是否保持回环路径",
      "required": false,
      "type": "string"
    },
    {
      "name": "-map {view|corner}",
      "description": "映射视图或分析角",
      "required": false,
      "type": "string"
    },
    {
      "name": "-maxNumInsts",
      "description": "设置最大实例数",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-maxNumRegisters",
      "description": "设置最大寄存器数",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-resetMap {view|corner}",
      "description": "重置视图或分析角的映射",
      "required": false,
      "type": "string"
    },
    {
      "name": "-slackDriven",
      "description": "启用时序裕量驱动模式",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-top <topViewName>",
      "description": "指定顶层视图名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-quiet",
      "description": "仅以 Tcl 列表格式显示当前设置",
      "required": false,
      "type": "flag"
    }
  ]
}