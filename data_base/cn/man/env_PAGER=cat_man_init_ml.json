{
  "command": "init_ml",
  "is_cmd": true,
  "summary": "初始化环境以开始为JedAI写入数据",
  "description": "此命令用于初始化环境，以便开始为JedAI（大数据分析平台）写入数据。在使用write_ml_design、write_ml_library、write_ml_timing_graph、write_ml_timing_path等命令之前，必须先运行此命令，以确保内容被正确标记，便于大数据摄取和注册。",
  "usage": "init_ml [-help] [-comment <string>] [-flow_phase <string>] [-name <string>] -prefix <string> [-scenario <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印包含每个参数类型和默认信息的简要描述。如需详细说明，请使用 man init_ml 命令。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-comment",
      "description": "指定注释信息。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-flow_phase",
      "description": "指定流程阶段（例如：cts）。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "指定设计名称。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "指定输出文件的前缀。",
      "required": true,
      "type": "string"
    },
    {
      "name": "-scenario",
      "description": "指定场景（例如：default）。",
      "required": false,
      "type": "string"
    }
  ]
}