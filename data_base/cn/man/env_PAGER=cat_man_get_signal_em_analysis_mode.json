      "required": false,
      "type": "string"
    },
    {
      "name": "-quiet",
      "description": "仅以 Tcl 列表格式显示指定参数的当前设置。如果未指定任何参数，则显示所有 set_signal_em_analysis_mode 参数的当前设置。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<parameter_names>",
