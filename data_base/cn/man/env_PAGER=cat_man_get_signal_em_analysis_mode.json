{
  "command": "get_signal_em_analysis_mode",
  "is_cmd": true,
  "summary": "获取信号电迁移分析模式的参数信息",
  "description": "该命令用于在系统日志文件和系统控制台中显示一个或多个 set_signal_em_analysis_mode 参数的详细信息，包括参数名称、当前值、类型（如布尔型、字符串型等）以及当前值是否由用户设置。如果未指定任何参数，软件将显示所有 set_signal_em_analysis_mode 参数的信息。",
  "usage": "get_signal_em_analysis_mode [-help] [-Ipeak_Td_method] [-avgRecovery] [-default_freq_for_unconstrained_nets] [-delta_T] [-effort_level] [-em_temperature] [-em_res_width] [-error] [-forceHoldView] [-lifetime] [-method] [-minPeakDutyRatio] [-minPeakFreq] [-net_file] [-toggle] [-useQrcTech] [-use_db_freq] [-view] [-net | -selected] [-report [-detailed]] [-report_db] [-set_current_file] [-skip_net] [-skip_net_file] [-ict_em_models] [-current_scale_factor] [-em_limit_scale_factor] [-em_threshold] [-current_scale_table] [-em_limit_scale_table] [-top_scope_ignore_block_internal_nets_on_boundary_path] [-extraction_tech_file] [-handle_pin_obs_via] [-quiet] [<parameter_names>]",
  "options": [
    {
      "name": "-help",
      "description": "输出每个 get_signal_em_analysis_mode 参数的简要描述，包括类型和默认信息。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-Ipeak_Td_method",
      "description": "指定峰值电流与延迟时间的方法参数。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-avgRecovery",
      "description": "平均恢复参数。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-default_freq_for_unconstrained_nets",
      "description": "为无约束网络设置的默认频率参数。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-delta_T",
      "description": "温度变化参数。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-effort_level",
      "description": "分析努力级别参数。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-em_temperature",
      "description": "电迁移分析温度参数。",
      "required": false,
      "type": "string"
