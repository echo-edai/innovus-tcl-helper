      "type": "string"
    },
    {
      "name": "-lifetime",
      "description": "寿命参数。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-method",
      "description": "分析方法参数。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-minPeakDutyRatio",
      "description": "最小峰值占空比参数。",
