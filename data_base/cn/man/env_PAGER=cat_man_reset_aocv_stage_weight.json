{
  "command": "reset_aocv_stage_weight",
  "is_cmd": true,
  "summary": "重置指定端口的现有阶段权重值",
  "description": "此命令用于重置为指定端口设置的现有阶段权重值。可以指定端口列表，并可选择性地仅重置早期路径或晚期路径的权重。",
  "usage": "reset_aocv_stage_weight <port_list> [-early] [-late]",
  "options": [
    {
      "name": "<port_list>",
      "description": "指定一个输入、输出或双向端口的列表或集合，用于重置其阶段权重值。",
      "required": true,
      "type": "net+"
    },
    {
      "name": "-early",
      "description": "重置早期路径的权重。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-late",
      "description": "重置晚期路径的权重。",
      "required": false,
      "type": "flag"
    }
  ]
}