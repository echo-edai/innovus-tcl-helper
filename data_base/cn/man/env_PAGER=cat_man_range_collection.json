{
  "command": "range_collection",
  "is_cmd": true,
  "summary": "返回基础集合的子集合",
  "description": "该命令用于返回基础集合中指定索引范围内的子集合。子集合的范围由`from`和`to`索引号指定，包含这两个端点。索引号可以是整数或表达式（例如“end”或“end-integer”，表达式内部不能有空格）。如果指定的`from`或`to`值小于0，软件会将其改为0；如果大于“集合大小-1”，则改为“集合大小-1”。",
  "usage": "range_collection [-help] <base_collection> <from> <to>",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<base_collection>",
      "description": "指定基础集合。",
      "required": true,
      "type": "collection"
    },
    {
      "name": "<from>",
      "description": "指定起始索引号。",
      "required": true,
      "type": "int_or_expr"
    },
    {
      "name": "<to>",
      "description": "指定结束索引号。",
      "required": true,
      "type": "int_or_expr"
    }
  ]
}