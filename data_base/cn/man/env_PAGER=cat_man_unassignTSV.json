{
  "command": "unassignTSV",
  "is_cmd": true,
  "summary": "取消指定TSV的分配",
  "description": "此命令用于取消指定TSV（硅通孔）的分配。它常用于手动操作TSV或在TSV分配与实例布局之间进行迭代。",
  "usage": "unassignTSV {-netName <netname>| -all |-signal | -power | -ground | -selected}",
  "options": [
    {
      "name": "-netName",
      "description": "取消指定网络从TSV的分配",
      "required": false,
      "type": "string"
    },
    {
      "name": "-all",
      "description": "取消所有TSV的分配",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-signal",
      "description": "取消信号网络从TSV的分配",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-power",
      "description": "取消电源网络从TSV的分配",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ground",
      "description": "取消地网络从TSV的分配",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-selected",
      "description": "取消所选TSV的分配",
      "required": false,
      "type": "flag"
    }
  ]
}