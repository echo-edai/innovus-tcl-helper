  "usage": "set_metric_header [-id <db_id>] -name <header_name> -help -value <header> <_value>",
  "options": [
    {
      "name": "-id",
      "description": "指定数据库ID",
      "required": false,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "指定指标头的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-help",
      "description": "输出包含每个参数类型和默认信息的简要描述",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-value",
      "description": "指定指标头的值",
      "required": true,
      "type": "string"
    }
  ]
}