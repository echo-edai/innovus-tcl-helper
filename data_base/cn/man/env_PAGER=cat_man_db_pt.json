{
  "command": "db_pt",
  "is_cmd": true,
  "summary": "返回任意点的X或Y坐标",
  "description": "该命令用于返回任意点的X或Y坐标。当需要查找形状的坐标以便移动形状或更改形状的某个坐标时，此命令可帮助您找到坐标。",
  "usage": "db_pt {-x | -y} <pt> [-help]",
  "options": [
    {
      "name": "-x",
      "description": "返回点的X坐标",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-y",
      "description": "返回点的Y坐标",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<pt>",
      "description": "指定要从中获取坐标值的点。这是一个必需参数。",
      "required": true,
      "type": "point"
    },
    {
      "name": "-help",
      "description": "输出包含每个db_pt参数类型和默认信息的简要描述。",
      "required": false,
      "type": "flag"
    }
  ]
}