{
  "command": "set_aocv_interface_path_offset",
  "is_cmd": true,
  "summary": "为跨多电源域的路径设置AOCV降额偏移值，以执行基于路径的跨电源域时序分析。",
  "description": "此命令允许您为跨越多个电源域的路径段指定降额偏移值。该功能仅支持基于路径的分析模式。软件会将此偏移值加到AOCV降额值上，如果组合后的降额数导致基于路径分析的时序裕量值过于悲观。",
  "usage": "set_aocv_interface_path_offset <derateOffsetVal> [<lib_cells>] [-view <view_name>] [-delay_corner <dc_corner_name>] [-cell] [-net] -power_domain <power_domain_name_list>",
  "options": [
    {
      "name": "<derateOffsetVal>",
      "description": "指定降额偏移值。",
      "required": true,
      "type": "float"
    },
    {
      "name": "<lib_cells>",
      "description": "为特定接口指定一个库单元列表。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "指定一个视图列表。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-delay_corner",
      "description": "指定一个延迟角列表。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "布尔选项。指定此选项时，意图是仅对单元对象应用“降额偏移”。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-net",
      "description": "布尔选项。指定此选项时，意图是仅对线网对象应用“降额偏移”。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-power_domain",
      "description": "指定一个电源域列表。",
      "required": true,
      "type": "string"
    }
  ]
}