{
  "command": "reset_path_adjust_group",
  "is_cmd": true,
  "summary": "移除所有通过 set_path_adjust 命令设置的路径调整组",
  "description": "该命令用于移除所有通过 set_path_adjust 命令设置的路径调整组，这些组用于设定路径松弛调整值。它提供选项来移除所有组或仅移除指定名称的组。",
  "usage": "reset_path_adjust_group [-help] [-name <group_name> | -all]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "移除所有路径调整组",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "移除指定名称的路径调整组",
      "required": false,
      "type": "string"
    }
  ]
}