{
  "command": "read_twf",
  "is_cmd": true,
  "summary": "读取外部时序窗口文件（TWF），用于噪声（信号完整性）和功耗计算（通用功耗引擎 - CPE）",
  "description": "读取用于噪声（信号完整性）和功耗计算（通用功耗引擎 - CPE）的外部时序窗口文件（TWF）。该文件用于获取时钟、常量、外部负载、转换时间、时序窗口和裕量信息。外部TWF规范是可选的。如果没有TWF，在读取时序约束的情况下，此信息将使用通用时序引擎（CTE）自动推导。注意：如果TWF文件头中缺少VOLTAGE_THRESHOLD构造，则会自动分配值10和90作为最小和最大阈值。",
  "usage": "read_twf [-help] [<filenames>] [-cell <string>] [-prefix <string>] [-quiet] [-reset] [-scope <string>] [-skipconst] [-skiptw] [-strip_prefix <string>] [-verbose] [-view <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<filenames>",
      "description": "指定时序窗口文件的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-cell",
      "description": "指定时序窗口文件的主单元",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "为网络或引脚名称添加前缀",
      "required": false,
      "type": "string"
    },
    {
      "name": "-quiet",
      "description": "跳过信息和警告消息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reset",
      "description": "清除先前读取的TWF文件",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-scope",
      "description": "为给定的层次化时序窗口文件指定作用域",
      "required": false,
      "type": "string"
    },
    {
      "name": "-skipconst",
      "description": "跳过常量处理",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-skiptw",
      "description": "跳过程序窗口处理",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-strip_prefix",
      "description": "移除层次化路径名称",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-verbose",
      "description": "打印命令进度详情",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-view",
      "description": "指定时序窗口文件的视图",
      "required": false,
      "type": "string"
    }
  ]
}