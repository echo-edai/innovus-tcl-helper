{
  "command": "dumpOutVias",
  "is_cmd": true,
  "summary": "用于调试和测试，输出通孔信息",
  "description": "该命令用于调试和测试，帮助输出通孔信息。所有布尔选项默认为 false。如果未设置任何选项，通孔将以 LEF 格式输出。",
  "usage": "dumpOutVias [-help] [-autogen] [-file <filename>] [-all_via | -signal | -all_rule | -default | -ndr ]",
  "options": [
    {
      "name": "-help",
      "description": "输出包含每个参数类型和默认值的简要描述。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-autogen",
      "description": "输出自动生成的通孔。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "指定输出文件名。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-all_via",
      "description": "输出所有通孔。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-signal",
      "description": "输出信号通孔。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all_rule",
      "description": "输出所有布线规则中的通孔。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-default",
      "description": "输出默认布线规则中的通孔。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ndr",
      "description": "输出非默认布线规则中的通孔。",
      "required": false,
      "type": "flag"
    }
  ]
}