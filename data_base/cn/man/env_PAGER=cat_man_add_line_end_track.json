{
  "command": "add_line_end_track",
  "is_cmd": true,
  "summary": "创建线端轨道",
  "description": "该命令用于创建一个线端轨道。可以指定轨道宽度、间距、所在层、偏移量、轨道间距和轨道间距等参数。",
  "usage": "add_line_end_track [-help] [-eol_width <float>] [-except_eol_spacing <float> [-within <float>]] -layer <string> -offset <float> [-track_distance <float>] [-track_pitch <float>]",
  "options": [
    {
      "name": "-help",
      "description": "输出包含每个参数类型和默认信息的简要描述。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-eol_width",
      "description": "指定线端轨道的宽度。",
      "required": false,
      "type": "float"
    },
    {
      "name": "-except_eol_spacing",
      "description": "指定线端轨道的间距。",
      "required": false,
      "type": "float"
    },
    {
      "name": "-within",
      "description": "指定在正交方向上查找相邻导线的延伸距离。",
      "required": false,
      "type": "float"
    },
    {
      "name": "-layer",
      "description": "指定要创建轨道的层。",
      "required": true,
      "type": "string"
    },
    {
      "name": "-offset",
      "description": "指定到核心边界的偏移量。",
      "required": true,
      "type": "float"
    },
    {
      "name": "-track_distance",
      "description": "指定两组轨道之间的距离。",
      "required": false,
      "type": "float"
    },
    {
      "name": "-track_pitch",
      "description": "指定轨道间距。",
      "required": false,
      "type": "float"
    }
  ]
}