{
  "command": "hilite_proto_model",
  "is_cmd": true,
  "summary": "高亮显示对象，例如FlexModels、分区和/或电源域",
  "description": "高亮显示对象，例如FlexModels、分区和/或电源域。此命令会自动重置每个分区已使用的颜色列表，以便相同的颜色可以在不同的分区中重复使用。",
  "usage": "hilite_proto_model [-help] [-keep_existing_hilite] [-type {flex_module flex_instgroup partition power_domain}] [-reset] [-level <integer>] | {[-min_level <integer>][-max_level <integer>]}",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-keep_existing_hilite",
      "description": "在现有高亮对象的基础上高亮新对象",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-type",
      "description": "允许指定要高亮的模型类型",
      "required": false,
      "type": "enum_list"
    },
    {
      "name": "-reset",
      "description": "重置所有先前高亮的模型",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-level",
      "description": "指定要高亮的层级",
      "required": false,
      "type": "int"
    },
    {
      "name": "-max_level",
      "description": "高亮从层级0到指定层级的对象",
      "required": false,
      "type": "int"
    },
    {
      "name": "-min_level",
      "description": "要高亮的最小层级",
      "required": false,
      "type": "int"
    }
  ]
}