{
  "command": "define_proc_arguments",
  "is_cmd": true,
  "summary": "定义Tcl过程的参数和属性",
  "description": "该命令用于定义Tcl过程的参数和属性。定义的参数和属性会在查看该过程相关帮助时显示。与parse_proc_arguments命令结合使用时，可以验证命令的用法，并为无效命令显示相应的错误信息。",
  "usage": "define_proc_arguments [-help] <command_name> [-info <string>] [-define_args <string>] [-hide]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<proc_name>",
      "description": "指定现有Tcl过程的名称。",
      "required": true,
      "type": "string"
    },
    {
      "name": "-info",
      "description": "为过程提供帮助信息。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-define_args",
      "description": "定义Tcl过程所有可能的参数。也可用于定义单个参数的帮助文本和约束，并为命令选项生成帮助。其值是一个列表的列表，每个列表元素定义一个参数，格式为：\"arg_name\" \"option_help\" \"value_help\" \"data_type\" \"attributes\"。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-hide",
      "description": "隐藏过程及其主体。",
      "required": false,
      "type": "bool"
    }
  ]
}