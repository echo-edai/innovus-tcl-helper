{
  "command": "create_path_category",
  "is_cmd": true,
  "summary": "根据时序分析结果，使用条件创建路径类别以对路径进行分组",
  "description": "该命令用于创建路径类别，通过设定各种条件（如起点、终点、路径上的元件、时序参数等）对分析得到的时序路径进行分组。它适用于加载了机器可读时序报告的任何场景。创建路径类别有助于用户更有效地分析和调试时序结果，例如，可以基于SDC约束创建类别来集中分析受特定约束影响的路径。",
  "usage": "create_path_category [-help] [-capture_latency <string>] [-check_type <string>] [-clock <string>] [-comment <string>] [-critical_false_path <string>] [-delay_of_any_inst <string>] [-delay_of_any_inst_not_of_celltype <string>] [-delay_of_any_inst_not_of_name <string>] [-delay_of_any_inst_of_celltype <string>] [-delay_of_any_inst_of_name <string>] [-delay_of_any_net <string>] [-delay_of_any_net_not_of_name <string>] [-delay_of_any_net_of_name <string>] [-delay_of_every_inst <string>] [-delay_of_every_inst_not_of_celltype <string>] [-delay_of_every_inst_not_of_name <string>] [-delay_of_every_inst_of_celltype <string>] [-delay_of_every_inst_of_name <string>] [-delay_of_every_net <string>] [-delay_of_every_net_not_of_name <string>] [-delay_of_every_net_of_name <string>] [-file string] [-from_cell <string>] [-from_clock <string>] [-from_clock_edge <string>] [-from_inst <string>] [-from_inst_pointer <string>] [-from_pd <string>] [-from_pin <string>] [-from_port <string>] [-from_port_pointer <string>] [-incr_delay_of_any_net <string>] [-incr_delay_of_every_net <string>] [-launch_latency <string>] [-master <string>] [-name <string>] [-not_from_cell <string>] [-not_from_clock <string>] [-not_from_clock_edge <string>] [-not_from_inst <string>] [-not_from_pd <string>] [-not_from_pin <string>] [-not_from_port <string>] [-not_through_cell <string>] [-not_through_inst <string>] [-not_through_net <string>] [-not_through_pd <string>] [-not_through_pin <string>] [-not_through_port <string>] [-not_to_cell <string>] [-not_to_clock <string>] [-not_to_clock_edge <string>] [-not_to_inst <string>] [-not_to_pd <string>] [-not_to_pin <string>] [-not_to_port <string>] [-number_of_insts <string>] [-number_of_insts_not_of_celltype <string>] [-number_of_insts_not_of_name <string>] [-number_of_insts_of_celltype <string>] [-number_of_insts_of_name <string>] [-overwrite] [-sdc <string>] [-skew <string>] [-slack <string>] [-through_cell <string>] [-through_inst <string>] [-through_net <string>] [-through_pd <string>] [-through_pin <string>] [-through_port <string>] [-to_cell <string>] [-to_clock <string>] [-to_clock_edge <string>] [-to_inst <string>] [-to_inst_pointer <string>] [-to_pd <string>] [-to_pin <string>] [-to_port <string>] [-to_port_pointer <string>] [-total_delay_of_insts <string>] [-total_delay_of_insts_not_of_celltype <string>] [-total_delay_of_insts_not_of_name <string>] [-total_delay_of_insts_of_celltype <string>] [-total_delay_of_insts_of_name <string>] [-total_delay_of_level_of_chain_of_insttype <string>] [-total_delay_of_nets <string>] [-total_delay_of_nets_not_of_name <string>] [-total_delay_of_nets_of_name <string>] [-total_delay_of_path <string>] [-total_incr_delay_of_path <string>] [-uncertainty <string>] [-view <string>]",
  "options": [
    {
      "name": "-help",
      "description": "输出包含每个参数类型和默认信息的简要描述。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-clock",
      "description": "指定在时钟树而非数据路径上搜索。可选值：both, launch, capture。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-comment",
      "description": "指定与此类别关联的注释文本。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-master",
      "description": "指定新类别应作为指定主类别的嵌套类别创建。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-name",
      "description": "指定要创建的类别的名称。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-overwrite",
      "description": "覆盖类别列表中同名的任何预定义类别。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-sdc",
      "description": "基于指定的SDC文件名和行号对应的SDC约束创建类别。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-check_type",
      "description": "指定检查类型，如Setup Check、Hold Check等。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-critical_false_path",
      "description": "指定关键虚假路径。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-file",
      "description": "指定文件名。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-from_inst",
      "description": "指定路径必须来自给定的实例模式。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-from_clock_edge",
      "description": "指定路径必须来自给定的时钟边沿。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-incr_delay_of_any_net",
      "description": "指定至少一个网络的增量延迟匹配给定的浮点值。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-incr_delay_of_every_net",
      "description": "指定每个网络的增量延迟匹配给定的浮点值。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-not_from_clock_edge",
      "description": "指定路径不能来自给定的时钟边沿。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-not_to_clock_edge",
      "description": "指定路径不能到达给定的时钟边沿。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-slack",
      "description": "指定路径的裕量必须匹配给定的浮点值。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-skew",
      "description": "指定路径的偏移必须匹配给定的浮点值。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-launch_latency",
      "description": "指定路径的发射延迟必须匹配给定的浮点值。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-capture_latency",
      "description": "指定路径的捕获延迟必须匹配给定的浮点值。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-uncertainty",
      "description": "指定路径的不确定性必须匹配给定的浮点值。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-number_of_insts",
      "description": "指定数据段中的实例数量必须匹配给定的整数值。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-to_clock_edge",
      "description": "指定路径必须到达给定的时钟边沿。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-total_delay_of_level_of_chain_of_insttype",
      "description": "指定实例类型链中层级的总延迟。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "指定视图。",
      "required": false,
      "type": "string"
    }
  ]
}