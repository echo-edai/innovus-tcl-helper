{
  "command": "change_IB_cell_site_name",
  "is_cmd": true,
  "summary": "更改IB单元站点名称，使其与Innovus使用的站点定义匹配",
  "description": "此命令用于更改那些站点定义与Innovus使用的站点定义不匹配的单元的站点。这仅适用于特定的节点。",
  "usage": "change_IB_cell_site_name [-help] [-NF <site_name>] [-NNF <site_name>] [-PF <site_name>] [-PPF <site_name>] [-new <site_name>] [-original <site_name>] [-vertical]",
  "options": [
    {
      "name": "-help",
      "description": "输出包含每个参数类型和默认信息的简要描述。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-NF",
      "description": "指定N-filler单元的站点名称。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-NNF",
      "description": "指定NN-filler单元的站点名称。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-PF",
      "description": "指定P-filler单元的站点名称。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-PPF",
      "description": "指定PP-filler单元的站点名称。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-new",
      "description": "指定IB单元的新站点名称。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-original",
      "description": "指定IB单元的原始站点名称。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-vertical",
      "description": "指定是否为IB变换。",
      "required": false,
      "type": "flag"
    }
  ]
}