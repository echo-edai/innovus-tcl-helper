{
  "command": "set_aocv_stage_weight",
  "is_cmd": true,
  "summary": "设置AOCV（高级片上变异）分析中端口的级数权重",
  "description": "在对独立模块进行高级片上变异（AOCV）分析时，此命令允许指定当该模块被建模为顶层设计的一部分时，在其端口上所见的级数权重。应用的级数权重会影响模块内部针对输入输出路径的权重计数。级数权重仅能应用于端口。可以在report_timing输出的'Stage Weighting'列中查看级数权重。set_aocv_stage_weight命令可用于多模式多端角模式，并可作为SDC文件的一部分使用。",
  "usage": "set_aocv_stage_weight <stage_weight> <port_list> [-early] [-late] [-input] [-output]",
  "options": [
    {
      "name": "-early",
      "description": "为早期路径指定权重",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-late",
      "description": "为晚期路径指定权重",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-input",
      "description": "为端口指定输入权重",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-output",
      "description": "为端口指定输出权重",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<port_list>",
      "description": "指定输入、输出和双向端口的列表或集合",
      "required": true,
      "type": "net+"
    },
    {
      "name": "<stage_weight>",
      "description": "指定级数权重的值",
      "required": true,
      "type": "float"
    }
  ]
}