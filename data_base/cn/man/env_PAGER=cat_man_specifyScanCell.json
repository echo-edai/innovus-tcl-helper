{
  "command": "specifyScanCell",
  "is_cmd": true,
  "summary": "指定时序库中未列出的扫描单元",
  "description": "此命令用于指定那些未在时序库中列出的扫描单元，以便工具在扫描链插入和优化时能够识别和处理这些特殊单元。",
  "usage": "specifyScanCell [-help] <[cellName]> [-in <ftname>] [-out <ftname>] [-scanClock <ftname>] [-scanEnable <ftname>]",
  "options": [
    {
      "name": "-help",
      "description": "显示此命令的帮助信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<cellName>",
      "description": "指定扫描单元的名称",
      "required": true,
      "type": "string"
    },
    {
      "name": "-in",
      "description": "指定扫描输入的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-out",
      "description": "指定扫描输出的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-scanClock",
      "description": "指定扫描时钟的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-scanEnable",
      "description": "指定扫描使能端（f-term或引脚）的名称",
      "required": false,
      "type": "string"
    }
  ]
}