{
  "command": "specifyClockToDataSpacing",
  "is_cmd": true,
  "summary": "指定时钟单元与数据单元之间的间距规则",
  "description": "该命令用于指定时钟单元与数据单元之间的间距。布局工具将遵循此间距规则进行检查和合法化，以确保设计满足物理约束。",
  "usage": "specifyClockToDataSpacing [-help] {{-cell <clockCell> {[-x <leftRightSpacing> ] [-y <topBottomSpacing> ] | -reset }",
  "options": [
    {
      "name": "-help",
      "description": "输出命令参数的简要描述，包括类型和默认值信息。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-cell",
      "description": "指定时钟单元。",
      "required": true,
      "type": "string"
    },
    {
      "name": "-reset",
      "description": "清除所有时钟到数据的间距规则。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-x",
      "description": "指定左右两侧的间距。",
      "required": false,
      "type": "int"
    },
    {
      "name": "-y",
      "description": "指定上下两侧的间距。",
      "required": false,
      "type": "int"
    }
  ]
}