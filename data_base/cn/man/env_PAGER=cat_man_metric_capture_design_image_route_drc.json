  "usage": "metric_capture_design_image_route_drc {true | false}",
  "options": [
    {
      "name": "true",
      "description": "启用捕获布线DRC标记",
      "required": true,
      "type": "flag"
    },
    {
      "name": "false",
      "description": "禁用捕获布线DRC标记",
      "required": true,
      "type": "flag"
    }
  ]
}