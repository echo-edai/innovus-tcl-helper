{
  "command": "metric_enable",
  "is_cmd": true,
  "summary": "启用度量快照捕获功能",
  "description": "该命令用于启用或禁用度量快照捕获功能。当设置为 true 时，系统将捕获度量快照；默认值为 false，即禁用此功能。",
  "usage": "metric_enable {true | false}",
  "options": [
    {
      "name": "true",
      "description": "启用度量快照捕获",
      "required": false,
      "type": "flag"
    },
    {
      "name": "false",
      "description": "禁用度量快照捕获",
      "required": false,
      "type": "flag"
    }
  ]
}