{
  "command": "current_design",
  "is_cmd": true,
  "summary": "更改设计层次结构中的当前目录到指定设计并返回该设计的路径",
  "description": "该命令用于在设计层次结构中切换当前工作目录至指定的设计，并返回该设计的路径。如果未指定设计名称，则命令返回顶层设计。",
  "usage": "current_design [-help] [<design_name>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "<design_name>",
      "description": "指定顶层设计的名称",
      "required": false,
      "type": "string"
    }
  ]
}