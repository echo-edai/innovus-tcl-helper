{
  "command": "report_parameter",
  "is_cmd": true,
  "summary": "生成显示 define_parameter 命令设置的报告",
  "description": "该命令用于生成一份报告，展示通过 define_parameter 命令设置的参数信息，包括参数名称、范围、分布类型等。",
  "usage": "report_parameter [-help] [-correlation] [-name <string>] [-scope {vtskew | wire_variation | beol | lle layout_effect}] [-view <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法信息",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-correlation",
      "description": "报告参数相关性",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-name",
      "description": "报告指定名称的参数",
      "required": false,
      "type": "string"
    },
    {
      "name": "-scope",
      "description": "报告指定作用域的参数。允许的选项有：vtskew, wire_variation, beol, lle layout_effect",
      "required": false,
      "type": "string"
    },
    {
      "name": "-view",
      "description": "显示指定视图名称的信息",
      "required": false,
      "type": "string"
    }
  ]
}