{
  "command": "readSdpFile",
  "is_cmd": true,
  "summary": "读取SDP文件。",
  "description": "读取SDP文件。",
  "usage": "readSdpFile [-help] -file <sdpFileName> [-leftoverGroup] [-origin <llx> <lly>] [-skipPlacement] [-hierPath <path> ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-file",
      "description": "SDP文件名。",
      "required": true,
      "type": "string"
    },
    {
      "name": "-hierPath",
      "description": "层次化路径名。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-leftoverGroup",
      "description": "将剩余实例存储到一个组中",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-origin",
      "description": "SDP块原点",
      "required": false,
      "type": "int"
    },
    {
      "name": "-skipPlacement",
      "description": "不放置SDP组，仅读取组定义",
      "required": false,
      "type": "flag"
    }
  ]
}