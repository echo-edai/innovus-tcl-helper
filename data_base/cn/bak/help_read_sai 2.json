{
  "command": "read_sai",
  "is_cmd": true,
  "summary": "读取SAI文件。",
  "description": "读取SAI文件。",
  "usage": "read_sai [-help] [<name>] [-partial] [-reduce_by_flexfiller] [-rule_only]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法。<name> 指定SAI文件名。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-partial",
      "description": "设计已通过restoreDesign加载。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-reduce_by_flexfiller",
      "description": "指定是否使用flexfiller。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-rule_only",
      "description": "仅导入SAI文件中的规则。",
      "required": false,
      "type": "flag"
    }
  ]
}