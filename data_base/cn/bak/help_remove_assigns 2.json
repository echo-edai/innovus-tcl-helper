{
  "command": "remove_assigns",
  "is_cmd": true,
  "summary": "移除assign赋值",
  "description": "移除assign赋值语句。",
  "usage": "remove_assigns [-help] [-buffer <bufName>] [-ignorePortConstraints] [-includeClockPath] [-prefix <bufNamePreFix>] [-report] [ -net <netName> [-netBuffer <netBufName>] ] [ -buffering [-buffer_tie_assigns ] [-includeIdealNets ] ] [ -honorDontTouch ] [ -net <netName> ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-buffer",
      "description": "为所有assign网指定的缓冲器名称，禁用自动缓冲器选择",
      "required": false,
      "type": "string"
    },
    {
      "name": "-buffer_tie_assigns",
      "description": "允许对tie assign进行缓冲。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-buffering",
      "description": "启用assign网缓冲。除非用户指定缓冲器，否则自动选择缓冲器。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-honorDontTouch",
      "description": "尊重dont_touch属性",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ignorePortConstraints",
      "description": "允许在移除assign时忽略所有端口约束",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-includeClockPath",
      "description": "移除时钟路径上的assign",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-includeIdealNets",
      "description": "移除理想网上的assign",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-net",
      "description": "网名。单个或名称列表，标量或总线名，支持通配符*",
      "required": false,
      "type": "string"
    },
    {
      "name": "-netBuffer",
      "description": "为通过-net选项指定的特定网指定的缓冲器名称。如果指定，该选项应跟在-net选项之后。",
      "required": false,
      "type": "string"
    },
    {
      "name": "-prefix",
      "description": "用户指定的缓冲器名称前缀",
      "required": false,
      "type": "string"
    },
    {
      "name": "-report",
      "description": "报告所有被缓冲器替换的缓冲器和assign网列表。",
      "required": false,
      "type": "flag"
    }
  ]
}