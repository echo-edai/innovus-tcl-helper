{
  "command": "reportDensityMap",
  "is_cmd": true,
  "summary": "报告密度图。",
  "description": "报告密度图。",
  "usage": "reportDensityMap [-help] [-gridInMicron <micron>] [-gridInRow <nrRow>] [-ignoreBlock {true|false}] [-ignoreFiller {true|false}] [-threshold <density>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令使用方法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-gridInMicron",
      "description": "指定用于密度计算的方形网格边长值（单位：微米）",
      "required": false,
      "type": "float"
    },
    {
      "name": "-gridInRow",
      "description": "指定用于密度计算的方形网格边长值（以行高度为单位）",
      "required": false,
      "type": "int"
    },
    {
      "name": "-ignoreBlock",
      "description": "",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-ignoreFiller",
      "description": "",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-threshold",
      "description": "密度超过此阈值时才报告",
      "required": false,
      "type": "float"
    }
  ]
}