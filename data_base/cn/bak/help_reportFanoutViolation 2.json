{
  "command": "reportFanoutViolation",
  "is_cmd": true,
  "summary": "报告扇出违规",
  "description": "报告扇出违规。",
  "usage": "reportFanoutViolation [-help] [-excNetFile <fileName>] [-max] [-min] [-outfile <fileName>] [-selNetFile <fileName>] [-significant_digits <integer>] [-useDrcMargin] [-all  | -noGlobalNets ]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-all",
      "description": "报告所有选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-excNetFile",
      "description": "不报告的网络列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-max",
      "description": "最大约束选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-min",
      "description": "最小约束选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-noGlobalNets",
      "description": "不包含全局网络选项",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-outfile",
      "description": "输出文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-selNetFile",
      "description": "要报告的网络列表",
      "required": false,
      "type": "string"
    },
    {
      "name": "-significant_digits",
      "description": "有效数字位数选项",
      "required": false,
      "type": "int"
    },
    {
      "name": "-useDrcMargin",
      "description": "使用DRC裕量选项",
      "required": false,
      "type": "flag"
    }
  ]
}