{
  "command": "read_parallel_edit_files",
  "is_cmd": true,
  "summary": "读取并行编辑文件。",
  "description": "读取并行编辑文件。",
  "usage": "read_parallel_edit_files [-help] [-check] [-conflict_mode {only_one stop_all}] -files <string> [-ignore_error] [-report_file <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-check",
      "description": "仅检查文件的语法和冲突",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-conflict_mode",
      "description": "指定冲突模式",
      "required": false,
      "type": "enum"
    },
    {
      "name": "-files",
      "description": "指定要读取的文件列表",
      "required": true,
      "type": "string"
    },
    {
      "name": "-ignore_error",
      "description": "指定是否忽略文件中的错误",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-report_file",
      "description": "指定冲突报告文件名",
      "required": false,
      "type": "string"
    }
  ]
}