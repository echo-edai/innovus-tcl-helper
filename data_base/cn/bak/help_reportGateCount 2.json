{
  "command": "reportGateCount",
  "is_cmd": true,
  "summary": "报告门级数量。",
  "description": "报告门级数量。",
  "usage": "reportGateCount [-help] [-hinst <hinst>] [-level <level>] [-limit <gateCount>] [-outfile <fileName>] [-stdCellOnly]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-hinst",
      "description": "层次化实例名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-level",
      "description": "层次级别",
      "required": false,
      "type": "int"
    },
    {
      "name": "-limit",
      "description": "最小门级数量",
      "required": false,
      "type": "int"
    },
    {
      "name": "-outfile",
      "description": "输出文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-stdCellOnly",
      "description": "仅标准单元",
      "required": false,
      "type": "flag"
    }
  ]
}