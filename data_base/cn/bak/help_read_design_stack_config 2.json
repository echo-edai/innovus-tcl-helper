{
  "command": "read_design_stack_config",
  "is_cmd": true,
  "summary": "读取设计堆叠配置",
  "description": "读取设计堆叠配置。",
  "usage": "read_design_stack_config [-help] [-avoid_floorplan_change] [-chipName <string>] [-manufacturing_grid <float>] [-power_config_file <string>] [-topNetlist <string>] [ -xml <string>]",
  "options": [
    {
      "name": "-help",
      "description": "打印命令用法",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-avoid_floorplan_change",
      "description": "read_design_stack_config 在 restoreDesign 内部调用，此命令不会创建版图和裸片实例。",
      "required": false,
      "type": "flag"
    },
    {
      "name": "-chipName",
      "description": "当前裸片实例化时使用的名称",
      "required": false,
      "type": "string"
    },
    {
      "name": "-manufacturing_grid",
      "description": "指定制造网格",
      "required": false,
      "type": "float"
    },
    {
      "name": "-power_config_file",
      "description": "电源连接文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-topNetlist",
      "description": "顶层网表 Verilog 文件名",
      "required": false,
      "type": "string"
    },
    {
      "name": "-xml",
      "description": "堆叠裸片文件名",
      "required": false,
      "type": "string"
    }
  ]
}