{
    "name": "innovus-tcl-helper",
    "displayName": "Innovus TCL Helper",
    "description": "TCL 语言支持，集成 Cadence Innovus EDA 工具命令的智能提示、悬停文档和静态检查",
    "version": "0.2.1",
    "publisher": "fd-echoro",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/echo-edai/innovus-tcl-helper"
    },
    "engines": {
        "vscode": "^1.67.0"
    },
    "activationEvents": [
        "onLanguage:tcl"
    ],
    "categories": [
        "Programming Languages",
        "Linters"
    ],
    "keywords": [
        "tcl",
        "innovus",
        "cadence",
        "eda",
        "semiconductor"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "innovus-tcl.reloadDB",
                "title": "Innovus TCL: 重新加载命令数据库"
            },
            {
                "command": "innovus-tcl.showHelp",
                "title": "Innovus TCL: 显示插件信息"
            },
            {
                "command": "innovus-tcl.switchLanguage",
                "title": "Innovus TCL: 切换中/英文"
            },
            {
                "command": "innovus-tcl.toggleHelpStyle",
                "title": "Innovus TCL: 切换帮助显示风格 (Webview/纯文本)"
            }
        ],
        "configuration": {
            "title": "Innovus TCL Helper",
            "properties": {
                "innovus-tcl.language": {
                    "type": "string",
                    "default": "auto",
                    "enum": [
                        "auto",
                        "zh",
                        "en"
                    ],
                    "enumDescriptions": [
                        "跟随 VS Code 界面语言自动选择",
                        "中文 (DeepSeek 结构化翻译)",
                        "English (原生 help 输出解析)"
                    ],
                    "description": "命令文档的显示语言。设为 auto 则自动跟随 VS Code 显示语言"
                },
                "innovus-tcl.dataRoot": {
                    "type": "string",
                    "default": "",
                    "description": "data_base 目录的绝对路径。留空则自动使用插件同级目录下的 data_base/"
                },
                "innovus-tcl.dataPath": {
                    "type": "string",
                    "default": "",
                    "description": "[已废弃] 请使用 dataRoot。Innovus 命令 JSON 数据目录路径"
                },
                "innovus-tcl.version": {
                    "type": "string",
                    "default": "",
                    "description": "Innovus 版本号（如 25.1）。留空使用默认版本。数据目录需对应存在: data_base/help/v{version}/deepseek-chat/"
                },
                "innovus-tcl.enableDiagnostics": {
                    "type": "boolean",
                    "default": true,
                    "description": "启用 TCL 语法静态检查"
                },
                "innovus-tcl.enableHover": {
                    "type": "boolean",
                    "default": true,
                    "description": "启用命令悬停提示"
                },
                "innovus-tcl.enableCompletion": {
                    "type": "boolean",
                    "default": true,
                    "description": "启用命令自动补全"
                },
                "innovus-tcl.helpStyle": {
                    "type": "string",
                    "default": "webview",
                    "enum": [
                        "webview",
                        "plain"
                    ],
                    "enumDescriptions": [
                        "Webview 富文本面板（教育化排版、参数分析、示例提示）",
                        "纯文本编辑器标签（类 man page 风格）"
                    ],
                    "description": "F12/Ctrl+Click 帮助文档的显示风格"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "node scripts/prepublish.mjs && npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "prepublish": "node scripts/prepublish.mjs",
        "package": "node scripts/prepublish.mjs && npm run compile && mkdir -p publish && vsce package --allow-missing-repository --out publish/",
        "publish": "node scripts/prepublish.mjs && npm run compile && vsce publish --allow-missing-repository",
        "publish:check": "echo 'VSCE_PAT 状态:' && [ -n \"$VSCE_PAT\" ] && echo '✅ 已设置' || echo '❌ 未设置 - 需要: export VSCE_PAT=<your-pat>'",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/vscode": "^1.67.0",
        "@vscode/vsce": "^3.9.2",
        "typescript": "^5.3.3"
    }
}
