.vscode/**
*.tar.gz
*.tgz
tcl9.0.0/**
tcl9.0.0/
.vscode-test/**
.gitignore
node_modules/**
src/**
tsconfig.json
**/*.tsbuildinfo
dev/**
test/**
scripts/**
!scripts/mcp-server.mjs
*.vsix
**/.DS_Store
# 排除原始 data_base（打包时由 prepublish 脚本复制精简版到 data/）
!data/**
# data/ 内只保留 JSON，不要 .DS_Store 和 log
data/**/.DS_Store
data/**/*.log
# 仿真数据：发布时只用单文件 DB，排除数千个小 .tcl 文件
data/simulations/cn/*.tcl
data/simulations/en/*.tcl
!data/simulations/cn.db.tcl
!data/simulations/en.db.tcl
